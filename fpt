local function openRednet()
    if not rednet then return false end

    if peripheral.getType(REDNET_SIDE) == "modem" then
        if not rednet.isOpen(REDNET_SIDE) then rednet.open(REDNET_SIDE) end
        return rednet.isOpen(REDNET_SIDE)
    end

    for _, n in ipairs(peripheral.getNames()) do
        if peripheral.getType(n) == "modem" then
            if not rednet.isOpen(n) then rednet.open(n) end
            if rednet.isOpen(n) then REDNET_SIDE = n return true end
        end
    end

    return false
end

local rednetReady = openRednet()
local function sendParticleTurtle(msg)
    if not rednetReady then rednetReady = openRednet() end
    if rednetReady then
        msg.controllerId = FLOOR_COMPUTER_ID
        pcall(rednet.send, PARTICLE_TURTLE_ID, msg, PROTOCOL)
    end
end

local function sendParticleRegistry()
    local reg = {}
    for id, p in pairs(pieces or {}) do
        reg[id] = {
            pieceId = id,
            side = p.side,
            kind = p.kind,
            start = p.start,
            label = PIECE_LABELS and PIECE_LABELS[id] or nil,
            computerId = PIECE_COMPUTER_IDS and PIECE_COMPUTER_IDS[id] or nil,
        }
    end
    sendParticleTurtle({ type = "particle_registry", pieces = reg })
end

local function sendParticlePieceUpdate(pieceId, square, active)
    if not pieceId then return end
    local p = pieces and pieces[pieceId]
    sendParticleTurtle({
        type = "particle_piece_update",
        pieceId = pieceId,
        label = PIECE_LABELS and PIECE_LABELS[pieceId] or nil,
        computerId = PIECE_COMPUTER_IDS and PIECE_COMPUTER_IDS[pieceId] or nil,
        side = p and p.side or nil,
        kind = p and p.kind or nil,
        square = square or (loc and loc[pieceId]) or (p and p.start) or nil,
        active = active ~= false,
    })
end

local function sendParticleStartGame()
    sendParticleRegistry()
    sendParticleTurtle({ type = "particle_start_game" })
    for id, sq in pairs(loc or {}) do
        if sq then sendParticlePieceUpdate(id, sq, true) end
    end
end

local function sendParticleStopPiece(pieceId)
    sendParticleTurtle({
        type = "particle_piece_captured",
        pieceId = pieceId,
        label = PIECE_LABELS and PIECE_LABELS[pieceId] or nil,
    })
end


