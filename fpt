local function drawDashboard()
    if not msgMon then
        msgMon = peripheral.wrap(MESSAGE_MONITOR_NAME)
    end
    if not msgMon then return false end

    pcall(function()
        msgMon.setTextScale(0.5)
        msgMon.setBackgroundColor(colors.black)
        msgMon.setTextColor(colors.white)
        msgMon.clear()

        local w, h = msgMon.getSize()
        local whiteCount, blackCount = countActivePieces()

        -- Header
        msgMon.setBackgroundColor(colors.black)
        msgMon.setTextColor(colors.yellow)
        local title = "=== LIVING WIZARD CHESS ==="
        msgMon.setCursorPos(math.max(1, math.floor((w - #title) / 2) + 1), 1)
        msgMon.write(title)

        msgMon.setTextColor(colors.lightGray)
        local subtitle = "Mob-board referee / recovery / status"
        msgMon.setCursorPos(math.max(1, math.floor((w - #subtitle) / 2) + 1), 2)
        msgMon.write(subtitle)

        local leftW = math.floor(w / 2) - 2
        local rightW = w - leftW - 3
        local x1 = 1
        local x2 = leftW + 3

        writeBox(msgMon, x1, 4, leftW, 5, "TURN",
            "Turn: " .. currentTurnName() .. "\nState: " .. tostring(dashboard.state or "READY") ..
            "\nWhite: " .. whiteCount .. "   Black: " .. blackCount,
            colors.lime, colors.white)

        writeBox(msgMon, x2, 4, rightW, 5, "SELECTED",
            selectedText(),
            colors.yellow, colors.white)

        writeBox(msgMon, x1, 10, leftW, 6, "LAST MOVE",
            tostring(lastMove or "None"),
            colors.cyan, colors.white)

        writeBox(msgMon, x2, 10, rightW, 6, "RECOVERY",
            tostring(dashboard.recovery or "OK"),
            colors.orange, colors.white)

        writeBox(msgMon, x1, 17, w, math.max(5, h - 18), "MESSAGE",
            tostring(lastMessage or dashboard.message or "Ready."),
            colors.purple, colors.white)

        -- Footer
        if h >= 3 then
            msgMon.setTextColor(colors.gray)
            msgMon.setCursorPos(2, h)
            msgMon.write("Floor ID " .. tostring(FLOOR_COMPUTER_ID) .. " | Rednet " .. (rednetReady and "OK" or "OFF") .. " | Deposit " .. tostring(DEPOSIT_CHEST))
        end
    end)

    return true
end

local function messageMonitor(text, scale, fg, bg)
    -- Big emergency/splash message mode, then normal dashboard can redraw later.
    text = tostring(text or "")
    if not msgMon then
        msgMon = peripheral.wrap(MESSAGE_MONITOR_NAME)
    end
    if not msgMon then return false end

    pcall(function()
        msgMon.setTextScale(scale or 1)
        msgMon.setBackgroundColor(bg or colors.black)
        msgMon.setTextColor(fg or colors.white)
        msgMon.clear()

        local w, h = msgMon.getSize()
        local lines = {}
        for line in (text .. "\n"):gmatch("(.-)\n") do
            lines[#lines + 1] = line
        end

        local startY = math.max(1, math.floor((h - #lines) / 2) + 1)
        for i, line in ipairs(lines) do
            if startY + i - 1 <= h then
                local x = math.max(1, math.floor((w - #line) / 2) + 1)
                msgMon.setCursorPos(x, startY + i - 1)
                msgMon.write(line:sub(1, w))
            end
        end
    end)
    return true
end

