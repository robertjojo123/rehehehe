local function wrapText(text, width)
    text = tostring(text or "")
    local lines = {}

    for raw in (text .. "\n"):gmatch("(.-)\n") do
        local line = raw
        while #line > width do
            local cut = width
            for i = math.min(width, #line), 1, -1 do
                if line:sub(i, i) == " " then
                    cut = i
                    break
                end
            end
            lines[#lines + 1] = line:sub(1, cut):gsub("%s+$", "")
            line = line:sub(cut + 1):gsub("^%s+", "")
        end
        lines[#lines + 1] = line
    end

    return lines
end

local function writeBox(mon, x, y, w, h, title, body, titleColor, bodyColor, bgColor)
    bgColor = bgColor or colors.black
    titleColor = titleColor or colors.yellow
    bodyColor = bodyColor or colors.white

    mon.setBackgroundColor(bgColor)
    mon.setTextColor(colors.gray)

    -- top/bottom
    mon.setCursorPos(x, y)
    mon.write("+" .. string.rep("-", math.max(0, w - 2)) .. "+")
    for yy = y + 1, y + h - 2 do
        mon.setCursorPos(x, yy)
        mon.write("|" .. string.rep(" ", math.max(0, w - 2)) .. "|")
    end
    mon.setCursorPos(x, y + h - 1)
    mon.write("+" .. string.rep("-", math.max(0, w - 2)) .. "+")

    if title and #title > 0 then
        mon.setTextColor(titleColor)
        mon.setCursorPos(x + 2, y)
        mon.write(" " .. tostring(title):sub(1, math.max(0, w - 5)) .. " ")
    end

    mon.setTextColor(bodyColor)
    local lines = wrapText(body or "", math.max(1, w - 4))
    for i = 1, math.min(#lines, h - 2) do
        mon.setCursorPos(x + 2, y + i)
        mon.write(lines[i]:sub(1, w - 4))
    end
end

local function countActivePieces()
    local white, black = 0, 0
    for id, sq in pairs(loc or {}) do
        if sq then
            local s = sideOf(id)
            if s == "w" then white = white + 1 end
            if s == "b" then black = black + 1 end
        end
    end
    return white, black
end

