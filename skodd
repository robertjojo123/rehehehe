-- =========================================================
-- === MONITOR / FRAME RENDERER
-- =========================================================

local function getMonitor()
    if MONITOR_NAME and peripheral.isPresent(MONITOR_NAME) then
        return peripheral.wrap(MONITOR_NAME), MONITOR_NAME
    end

    local name = peripheral.find("monitor")
    if not name then
        error("No monitor found")
    end

    if type(name) == "string" then
        return peripheral.wrap(name), name
    end

    return name, peripheral.getName(name)
end

local mon, monName = getMonitor()
