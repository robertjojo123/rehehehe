    [colors.black] = "f"
}

local function colorToBlit(color)
    return BLIT_BY_COLOR[color or colors.white] or "0"
end

local function sixelChar(mask)
    if mask > 31 then
        return string.char(0x80 + (63 - mask)), true
    end
    return string.char(0x80 + mask), false
end

local function splitLines(text)
    local lines = {}
    text = tostring(text or ""):gsub("\r\n", "\n"):gsub("\r", "\n")
    for line in (text .. "\n"):gmatch("(.-)\n") do
        table.insert(lines, line)
    end
    while #lines > 0 and lines[#lines] == "" do
        table.remove(lines)
    end
    return lines
end

local function loadSubpixelFrame(path)
    local file = fs.open(path, "r")
    if not file then
        error("Could not open " .. path)
    end

    local raw = file.readAll()
    file.close()

    local lines = splitLines(raw)
    local width, height = lines[1]:match("^(%d+)%s+(%d+)$")
    width = tonumber(width)
    height = tonumber(height)

    if not width or not height then
        error("First line of " .. path .. " must be width height, example: 114 114")
    end

    local grid = {}
    for y = 1, height do
        local row = lines[y + 1] or ""
        if #row < width then
            row = row .. string.rep("e", width - #row)
        end

        grid[y] = {}
        for x = 1, width do
            local ch = row:sub(x, x)
            grid[y][x] = FRAME_COLOR[ch] or colors.green
        end
    end

    return {
        width = width,
        height = height,
        grid = grid
    }
end

local frame = loadSubpixelFrame(FRAME_FILE)

local function drawPackedFrame()
    local grid = frame.grid
    local charW = math.floor(frame.width / 2)
    local charH = math.floor(frame.height / 3)
    local bitValues = {1, 2, 4, 8, 16, 32}

    for cy = 1, charH do
        local chars = {}
        local fgs = {}
        local bgs = {}

        for cx = 1, charW do
            local pts = {
                grid[(cy - 1) * 3 + 1][(cx - 1) * 2 + 1],
                grid[(cy - 1) * 3 + 1][(cx - 1) * 2 + 2],
                grid[(cy - 1) * 3 + 2][(cx - 1) * 2 + 1],
                grid[(cy - 1) * 3 + 2][(cx - 1) * 2 + 2],
                grid[(cy - 1) * 3 + 3][(cx - 1) * 2 + 1],
                grid[(cy - 1) * 3 + 3][(cx - 1) * 2 + 2],
            }

            local counts = {}
            local ordered = {}

            for i = 1, 6 do
                local color = pts[i]
                local key = tostring(color)
                if not counts[key] then
                    counts[key] = {color = color, count = 0, first = i}
                    table.insert(ordered, counts[key])
                end
                counts[key].count = counts[key].count + 1
            end

            table.sort(ordered, function(a, b)
                if a.count == b.count then return a.first < b.first end
                return a.count > b.count
            end)

            local bg = ordered[1].color
            local fg = ordered[2] and ordered[2].color or bg

            local mask = 0
            if fg ~= bg then
                for i = 1, 6 do
                    if pts[i] == fg then
                        mask = mask + bitValues[i]
                    end
                end
            end

            if mask == 0 then
                table.insert(chars, " ")
                table.insert(fgs, colorToBlit(bg))
                table.insert(bgs, colorToBlit(bg))
            else
                local ch, inverted = sixelChar(mask)
                table.insert(chars, ch)
                if inverted then
                    table.insert(fgs, colorToBlit(bg))
                    table.insert(bgs, colorToBlit(fg))
                else
                    table.insert(fgs, colorToBlit(fg))
                    table.insert(bgs, colorToBlit(bg))
                end
            end
        end

        mon.setCursorPos(1, cy)
        mon.blit(table.concat(chars), table.concat(fgs), table.concat(bgs))
    end
end

-- =========================================================
-- === HITBOX DRAWING / TESTING
-- =========================================================

local function mergeHitboxes()
    local merged = {}
    for name, box in pairs(HITBOXES) do
        merged[name] = box
    end
    for name, box in pairs(EXTRA_HITBOXES) do
        merged[name] = box
    end
    return merged
end

local function zoneAt(x, y)
    local all = mergeHitboxes()

    -- Prefer extra hitboxes over built-in if overlapping.
    for name, box in pairs(EXTRA_HITBOXES) do
        if x >= box[1] and x <= box[3] and y >= box[2] and y <= box[4] then
            return name
        end
    end

    for name, box in pairs(HITBOXES) do
        if x >= box[1] and x <= box[3] and y >= box[2] and y <= box[4] then
            return name
        end
    end

    return nil
end

local function writeAt(x, y, text, fg, bg)
    local w, h = mon.getSize()
    if x < 1 or y < 1 or x > w or y > h then return end

    text = tostring(text or "")
    if #text > w - x + 1 then
        text = text:sub(1, w - x + 1)
    end

    mon.setCursorPos(x, y)
    mon.setTextColor(fg or colors.white)
    mon.setBackgroundColor(bg or colors.black)
    mon.write(text)
end

local function drawBox(box, name)
    local x1, y1, x2, y2 = box[1], box[2], box[3], box[4]

    for x = x1, x2 do
        writeAt(x, y1, " ", HITBOX_TEXT_COLOR, HITBOX_BORDER_COLOR)
        writeAt(x, y2, " ", HITBOX_TEXT_COLOR, HITBOX_BORDER_COLOR)
    end

    for y = y1, y2 do
        writeAt(x1, y, " ", HITBOX_TEXT_COLOR, HITBOX_BORDER_COLOR)
        writeAt(x2, y, " ", HITBOX_TEXT_COLOR, HITBOX_BORDER_COLOR)
    end

    -- Short center label, enough to identify zones without covering everything.
    local label = tostring(name)
    if label:match("^chip_") then
        label = label:gsub("chip_", "")
    elseif label == "2to1_top" then
        label = "2T"
    elseif label == "2to1_mid" then
        label = "2M"
    elseif label == "2to1_bot" then
        label = "2B"
    elseif label == "1to18" then
        label = "1-18"
    elseif label == "19to36" then
        label = "19-36"
    end

    label = label:sub(1, math.max(1, x2 - x1 - 1))
    local lx = x1 + 1
    local ly = y1 + math.floor((y2 - y1) / 2)
    if x2 - x1 >= 3 then
        writeAt(lx, ly, label, HITBOX_TEXT_COLOR, HITBOX_FILL_COLOR)
    end
end

local function drawHitboxOverlay()
    if not SHOW_HITBOXES then return end

    local all = mergeHitboxes()
    for name, box in pairs(all) do
        drawBox(box, name)
    end
end

local function redraw(lastX, lastY, lastZone)
    mon.setBackgroundColor(colors.green)
    mon.clear()
    drawPackedFrame()
    drawHitboxOverlay()

    local msg = "X=" .. tostring(lastX or "-") .. " Y=" .. tostring(lastY or "-")
    if lastZone then
        msg = msg .. " Zone=" .. lastZone
    else
        msg = msg .. " Zone=none"
    end

    writeAt(1, 1, msg, colors.yellow, colors.black)
end

local function printHitboxes()
    print("Current hitboxes:")
    print("name = {x1,y1,x2,y2}")
    local all = mergeHitboxes()
    local names = {}

    for name in pairs(all) do
        table.insert(names, name)
    end

    table.sort(names)

    for _, name in ipairs(names) do
        local b = all[name]
        print(name .. " = {" .. b[1] .. "," .. b[2] .. "," .. b[3] .. "," .. b[4] .. "}")
    end
end

