    if x > w then return end
    mon.setCursorPos(x, y)
    mon.setTextColor(fg or colors.white)
    mon.setBackgroundColor(bg or colors.black)
    mon.write(text)
end

local function drawPixel(mon, x, y, color)
    local w, h = mon.getSize()
    if x < 1 or x > w or y < 1 or y > h then return end
    mon.setCursorPos(x, y)
    mon.setBackgroundColor(color)
    mon.write(" ")
end

local function newSubCanvas(w, h, bg)
    local pix = {}
    for y = 1, h do
        pix[y] = {}
        for x = 1, w do pix[y][x] = bg end
    end
    return {w = w, h = h, bg = bg, pix = pix}
end

local function setSub(canvas, x, y, color)
    if x >= 1 and x <= canvas.w and y >= 1 and y <= canvas.h then
        canvas.pix[y][x] = color
    end
end

local function fillSubRect(canvas, x, y, w, h, color)
    for yy = y, y + h - 1 do
        for xx = x, x + w - 1 do setSub(canvas, xx, yy, color) end
    end
end

local function plotBitmap(canvas, bitmap, ox, oy, color, scale, rot180)
    scale = scale or 1
    local bh = #bitmap
    local bw = #bitmap[1]
    for row = 1, bh do
        local line = bitmap[row]
        for col = 1, bw do
            if line:sub(col, col) == "1" then
                local srcX, srcY = col, row
                if rot180 then srcX = bw - col + 1; srcY = bh - row + 1 end
                for sy = 0, scale - 1 do
                    for sx = 0, scale - 1 do
                        setSub(canvas, ox + (srcX - 1) * scale + sx, oy + (srcY - 1) * scale + sy, color)
                    end
                end
            end
        end
    end
end

local function rotateSubPoint(px, py, width, height, dir)
    if dir == "north" then return px, py, width, height
    elseif dir == "south" then return width - px + 1, height - py + 1, width, height
    elseif dir == "east" then return height - py + 1, px, height, width
    elseif dir == "west" then return py, width - px + 1, height, width end
    return px, py, width, height
end

local function renderSubCanvas(mon, x, y, canvas, dir)
    dir = dir or "north"
    local rawW, rawH = canvas.w, canvas.h
    if dir == "east" or dir == "west" then rawW, rawH = canvas.h, canvas.w end
    local outW, outH = rawW, rawH
    while outW % 2 ~= 0 do outW = outW + 1 end
    while outH % 3 ~= 0 do outH = outH + 1 end

    local rotated = newSubCanvas(outW, outH, canvas.bg)
    for sy = 1, canvas.h do
        for sx = 1, canvas.w do
            local rx, ry = rotateSubPoint(sx, sy, canvas.w, canvas.h, dir)
            rotated.pix[ry][rx] = canvas.pix[sy][sx]
        end
    end

    local charW = math.floor(outW / 2)
    local charH = math.floor(outH / 3)
    for cy = 1, charH do
        local chars, fgs, bgs = {}, {}, {}
        for cx = 1, charW do
            local bg = rotated.bg
            local points = {
                rotated.pix[(cy - 1) * 3 + 1][(cx - 1) * 2 + 1], rotated.pix[(cy - 1) * 3 + 1][(cx - 1) * 2 + 2],
                rotated.pix[(cy - 1) * 3 + 2][(cx - 1) * 2 + 1], rotated.pix[(cy - 1) * 3 + 2][(cx - 1) * 2 + 2],
                rotated.pix[(cy - 1) * 3 + 3][(cx - 1) * 2 + 1], rotated.pix[(cy - 1) * 3 + 3][(cx - 1) * 2 + 2],
            }
            local fg = nil
            for _, pointColor in ipairs(points) do if pointColor ~= bg then fg = pointColor; break end end
            fg = fg or colors.white
            local mask = 0
            local bitValues = {1, 2, 4, 8, 16, 32}
            for i, pointColor in ipairs(points) do if pointColor == fg then mask = mask + bitValues[i] end end
            if mask == 0 then
                chars[#chars + 1] = " "; fgs[#fgs + 1] = colorToBlit(bg); bgs[#bgs + 1] = colorToBlit(bg)
            else
                local ch, inverted = sixelChar(mask)
                chars[#chars + 1] = ch
                if inverted then fgs[#fgs + 1] = colorToBlit(bg); bgs[#bgs + 1] = colorToBlit(fg)
                else fgs[#fgs + 1] = colorToBlit(fg); bgs[#bgs + 1] = colorToBlit(bg) end
            end
        end
        local w, h = mon.getSize()
        local rowY = y + cy - 1
        if rowY >= 1 and rowY <= h then
            local rowText, rowFg, rowBg = table.concat(chars), table.concat(fgs), table.concat(bgs)
            local drawX = x
            if drawX < 1 then
                local trim = 2 - drawX
                rowText = rowText:sub(trim); rowFg = rowFg:sub(trim); rowBg = rowBg:sub(trim)
                drawX = 1
            end
            if drawX <= w and #rowText > 0 then
                local maxLen = w - drawX + 1
                mon.setCursorPos(drawX, rowY)
                mon.blit(rowText:sub(1, maxLen), rowFg:sub(1, maxLen), rowBg:sub(1, maxLen))
            end
        end
    end
end

local function buildPixelTextCanvas(text, fg, bg, scale)
    text = tostring(text or ""):upper()
    fg = fg or colors.white
    bg = bg or colors.green
    scale = scale or 1
    local glyphW, glyphH, spacing = 3 * scale, 5 * scale, 1 * scale
    local width = math.max(2, (#text * glyphW) + math.max(0, #text - 1) * spacing)
    local height = math.max(3, glyphH)
    while width % 2 ~= 0 do width = width + 1 end
    while height % 3 ~= 0 do height = height + 1 end
    local canvas = newSubCanvas(width, height, bg)
    local x = 1
    for i = 1, #text do
        local ch = text:sub(i, i)
        local glyph = PIXEL_FONT[ch] or PIXEL_FONT["?"]
        plotBitmap(canvas, glyph, x, 1, fg, scale, false)
        x = x + glyphW + spacing
    end
    return canvas
end

local function pixelTextCellWidth(text, scale, dir)
    local canvas = buildPixelTextCanvas(text, colors.white, colors.green, scale or 1)
    local w = canvas.w
    if w % 2 ~= 0 then w = w + 1 end
    return math.floor(w / 2)
end

local function drawPixelText(mon, x, y, text, dir, fg, bg, scale)
    local canvas = buildPixelTextCanvas(text, fg, bg, scale or 1)
    renderSubCanvas(mon, x, y, canvas, dir or "north")
end

local function drawPixelTextAligned(mon, x, y, text, dir, fg, bg, scale, align)
    align = align or "left"
    if align == "right" then
        local amount = pixelTextCellWidth(text, scale or 1, dir)
        if dir == "west" or dir == "east" then y = y - amount + 1 else x = x - amount + 1 end
    end
    drawPixelText(mon, x, y, text, dir, fg, bg, scale or 1)
end

local function buildCardCanvas(card, hidden, variant)
    variant = variant or "normal"
    local sideCard = (variant == "side_west" or variant == "side_east")
    local cw, ch = sideCard and 21 or 20, sideCard and 28 or 27
    local canvas = newSubCanvas(cw, ch, colors.white)
    fillSubRect(canvas, 1, 1, cw, ch, colors.white)
    for x = 1, cw do setSub(canvas, x, 1, colors.gray); setSub(canvas, x, ch, colors.gray) end
    for y = 1, ch do setSub(canvas, 1, y, colors.gray); setSub(canvas, cw, y, colors.gray) end

    if hidden then
        canvas.bg = colors.lightBlue
        local BACK_COLOR_MAP = { x = colors.gray, ['.'] = colors.lightBlue, y = colors.yellow, o = colors.orange, g = colors.lime }
        local BACK_ART = {
            "xxxxxxxxxxxxxxxxxxxx", "x..................x", "x..................x", "x...o....yy....o...x",
            "x...o...yyyy...o...x", "x...oo..yyyy..oo...x", "x..y.o...yy...o.y..x", "x.y..oo......oo..y.x",
            "x.....o......o.....x", "x.y...oo.oo.oo...y.x", "x..y...oooooo...y..x", "x.......o..o.......x",
            "x..................x", "x.......ggggg......x", "x..o..ggg...gg..o..x", "x.o..gg......gg..o.x",
            "x.o..g........gg.o.x", "x...gg.............x", "x...g..............x", "x...gg.............x",
            "x....g........gg...x", "x.o..gg......gg..o.x", "x.o...ggg...gg...o.x", "x..o....ggggg...o..x",
            "x..................x", "x..................x", "xxxxxxxxxxxxxxxxxxxx",
        }
        for yy, row in ipairs(BACK_ART) do
            if yy <= ch then
                for xx = 1, #row do
                    if xx <= cw then
                        local col = BACK_COLOR_MAP[row:sub(xx, xx)]
                        if col then setSub(canvas, xx, yy, col) end
                    end
                end
            end
        end
        return canvas
    end

    if not card then return canvas end
    local pipColor = suitColor(card.suit)
    local rankGlyph = PIXEL_FONT[card.rank] or PIXEL_FONT["?"]
    local centerSuit = CENTER_SUIT_ART[card.suit] or CENTER_SUIT_ART.S

    if sideCard then
        local rankX, rankY = 3, 3
        if variant == "side_west" then
            rankX, rankY = 4, 3
            local off = SIDE_RANK_MONITOR_OFFSETS.station1 or {x = 0, y = 0}
            rankX = rankX - (off.y or 0); rankY = rankY + (off.x or 0)
        elseif variant == "side_east" then
            rankX, rankY = 2, 4
            local off = SIDE_RANK_MONITOR_OFFSETS.station3 or {x = 0, y = 0}
            rankX = rankX + (off.y or 0); rankY = rankY - (off.x or 0)
        end
        plotBitmap(canvas, rankGlyph, rankX, rankY, pipColor, 1, false)
        local centerX, centerY = 5, 13
        if card.suit == "S" or card.suit == "D" or card.suit == "C" then centerY = 11 end
        plotBitmap(canvas, centerSuit, centerX, centerY, pipColor, 1, false)
    else
        plotBitmap(canvas, rankGlyph, 3, 4, pipColor, 1, false)
        local centerX, centerY = 4, 12
        if card.suit == "S" or card.suit == "D" or card.suit == "C" then centerY = 10 end
        plotBitmap(canvas, centerSuit, centerX, centerY, pipColor, 1, false)
    end

    return canvas
end

local function shiftCanvas(canvas, dx, dy, fillColor)
    dx, dy = dx or 0, dy or 0
    fillColor = fillColor or canvas.bg
    if dx == 0 and dy == 0 then return canvas end
    local shifted = newSubCanvas(canvas.w, canvas.h, fillColor)
    for yy = 1, canvas.h do
        for xx = 1, canvas.w do
            local nx, ny = xx + dx, yy + dy
            if nx >= 1 and nx <= canvas.w and ny >= 1 and ny <= canvas.h then shifted.pix[ny][nx] = canvas.pix[yy][xx] end
        end
    end
    return shifted
end

local function scaleCanvas(canvas, factor)
    factor = factor or 2
    if factor <= 1 then return canvas end
    local scaled = newSubCanvas(canvas.w * factor, canvas.h * factor, canvas.bg)
    for yy = 1, canvas.h do
        for xx = 1, canvas.w do
            local col = canvas.pix[yy][xx]
            for dy = 0, factor - 1 do
                for dx = 0, factor - 1 do
                    scaled.pix[((yy - 1) * factor) + dy + 1][((xx - 1) * factor) + dx + 1] = col
                end
            end
        end
    end
    return scaled
end

local function drawCard(mon, x, y, card, hidden, dir, cardSubX, cardSubY, scaleFactor)
    local variant = "normal"
    if dir == "west" then variant = "side_west" elseif dir == "east" then variant = "side_east" end
    local canvas = buildCardCanvas(card, hidden, variant)
    if cardSubX or cardSubY then canvas = shiftCanvas(canvas, cardSubX or 0, cardSubY or 0, canvas.bg) end
    if scaleFactor and scaleFactor > 1 then canvas = scaleCanvas(canvas, scaleFactor) end
    renderSubCanvas(mon, x, y, canvas, dir or "north")
end

local function handDisplayValue(hand)
    if not hand then return "" end
    local cards = safeCards(hand)
    if #cards == 0 then return "" end
    local v = handValue(hand)
    if v > 21 then return "BUST" end
    return tostring(v)
end

local function drawHand(mon, hand, x, y, dir, label, hideSecond, cardSubX, cardSubY, labelDy, labelDx, valDx, valDy, dealerBig)
    if not hand then return end
    local cards = safeCards(hand)
    label = tostring(label or "")
    drawPixelText(mon, x + (labelDx or 0), y - 1 + (labelDy or 0), label, dir, colors.white, colors.green, 1)

    if dealerBig and dir == "north" and #cards == 2 then
        local bigSpacing = 21
        for i, card in ipairs(cards) do drawCard(mon, x + ((i - 1) * bigSpacing), y, card, hideSecond and i == 2, "north", 0, 0, 2) end
        if not hideSecond then drawPixelText(mon, x + (valDx or 0), y + 19 + (valDy or 0), "VAL " .. handDisplayValue(hand), dir, colors.white, colors.green, 1) end
        return
    end

    if dir == "west" then
        for i, card in ipairs(cards) do drawCard(mon, x, y - ((i - 1) * 8), card, hideSecond and i == 2, "west", cardSubX, cardSubY) end
    elseif dir == "east" then
        for i, card in ipairs(cards) do drawCard(mon, x, y + ((i - 1) * 8), card, hideSecond and i == 2, "east", cardSubX, cardSubY) end
    else
        local colSpacing = 11
        local rowSpacing = (label == "DEALER") and 10 or 9
        for i, card in ipairs(cards) do
            local idx = i - 1
            local col = idx % 3
            local row = math.floor(idx / 3)
            local drawX, drawY
            if dir == "south" and label ~= "DEALER" then
                local flippedCol = 2 - col
                local flippedRow = 1 - row
                if flippedRow < 0 then flippedRow = 0 end
                drawX, drawY = x + (flippedCol * colSpacing), y + (flippedRow * rowSpacing)
            else
                drawX, drawY = x + (col * colSpacing), y + (row * rowSpacing)
            end
            drawCard(mon, drawX, drawY, card, hideSecond and i == 2, dir, cardSubX, cardSubY)
        end
    end

    if not hideSecond then
        local valueText = "VAL " .. handDisplayValue(hand)
        if dir == "west" or dir == "east" then drawPixelText(mon, x + 15 + (valDx or 0), y + (valDy or 0), valueText, dir, colors.white, colors.green, 1)
        else drawPixelText(mon, x + (valDx or 0), y + 18 + (valDy or 0), valueText, dir, colors.white, colors.green, 1) end
    end
end

local function clearMain()
    mainMonitor.setBackgroundColor(colors.green)
    mainMonitor.clear()
end

local function drawInnerDealerBorder()
    local w, h = mainMonitor.getSize()
    local x1, x2 = math.floor(w / 2) - 32, math.floor(w / 2) + 32
    local y1, y2 = math.floor(h / 2) - 15, math.floor(h / 2) + 15
    for x = x1, x2 do drawPixel(mainMonitor, x, y1, colors.lime); drawPixel(mainMonitor, x, y2, colors.lime) end
    for y = y1, y2 do drawPixel(mainMonitor, x1, y, colors.lime); drawPixel(mainMonitor, x2, y, colors.lime) end
    drawPixel(mainMonitor, x1 + 1, y1 + 1, colors.yellow); drawPixel(mainMonitor, x2 - 1, y1 + 1, colors.yellow)
    drawPixel(mainMonitor, x1 + 1, y2 - 1, colors.yellow); drawPixel(mainMonitor, x2 - 1, y2 - 1, colors.yellow)
end

local function getMainLayout()
    local w, h = mainMonitor.getSize()
    local function applyTweak(side, base)
        local t = TABLE_TWEAKS[side] or {}
        base.labelDx = t.labelDx or 0; base.labelDy = t.labelDy or 0; base.labelAlign = t.labelAlign or "left"
        base.betDx = t.betDx or 0; base.betDy = t.betDy or 0; base.valDx = t.valDx or 0; base.valDy = t.valDy or 0
        base.openDx = t.openDx or 0; base.openDy = t.openDy or 0
        base.x = base.x + (t.cardDx or 0); base.y = base.y + (t.cardDy or 0)
        return base
    end
    return {
        dealer = {x = math.floor(w / 2) - 19, y = math.floor(h / 2) - 9, dir = "north", labelDy = -1},
        north = applyTweak("north", {x = w - 27, y = math.floor(h / 2) - 2, dir = "west"}),
        east = applyTweak("east", {x = math.floor(w / 2) - 22, y = h - 19, dir = "north"}),
        south = applyTweak("south", {x = 17, y = math.floor(h / 2) - 18, dir = "east"}),
        west = applyTweak("west", {x = math.floor(w / 2) - 8, y = 16, dir = "south"})
    }
end

local function drawChipDecoration(mon, x, y, color, label)
    color = color or colors.red; label = label or "$"
    local rows = {" xxx ", "x...x", "x.c.x", "x...x", " xxx "}
    for yy, row in ipairs(rows) do
        for xx = 1, #row do
            local ch = row:sub(xx, xx); local px, py = x + xx - 1, y + yy - 1
            if ch == "x" then writeText(mon, px, py, " ", colors.white, colors.white)
            elseif ch == "." then writeText(mon, px, py, " ", color, color)
            elseif ch == "c" then writeText(mon, px, py, label, colors.white, color) end
        end
    end
end

local function drawCornerDecorations()
    local w, h = mainMonitor.getSize()
    drawChipDecoration(mainMonitor, 3, 4, colors.red, "$")
    drawChipDecoration(mainMonitor, w - 8, 4, colors.lime, "$")
    drawChipDecoration(mainMonitor, 3, h - 8, colors.orange, "$")
    drawChipDecoration(mainMonitor, w - 8, h - 8, colors.blue, "$")
    drawPixelText(mainMonitor, 10, 5, "+", "north", colors.yellow, colors.green, 1)
    drawPixelText(mainMonitor, w - 12, 5, "+", "north", colors.yellow, colors.green, 1)
    drawPixelText(mainMonitor, 10, h - 5, "+", "north", colors.yellow, colors.green, 1)
    drawPixelText(mainMonitor, w - 12, h - 5, "+", "north", colors.yellow, colors.green, 1)
end

local function drawTableStationLabel(station, p, showName)
    local anchorX = p.x + (p.labelDx or 0)
    local anchorY = p.y - 3 + (p.labelDy or 0)
    if station.id == 1 then
        drawPixelText(mainMonitor, anchorX, anchorY, station.label, p.dir, colors.yellow, colors.green, 1)
        if showName then
            local nameText = tostring(showName)
            if #nameText > 13 then nameText = nameText:sub(1, 13) end
            drawPixelTextAligned(mainMonitor, anchorX, anchorY + 5, nameText, p.dir, colors.yellow, colors.green, 1, "right")
        end
        return
    end
    local tableName = station.label
    if showName then tableName = station.label .. " " .. tostring(showName) end
    if #tableName > 18 then tableName = tableName:sub(1, 18) end
    drawPixelTextAligned(mainMonitor, anchorX, anchorY, tableName, p.dir, colors.yellow, colors.green, 1, p.labelAlign or "left")
end

local function drawMainTable()
    clearMain()
    local layout = getMainLayout()
    drawInnerDealerBorder()
    drawCornerDecorations()
    if dealerHand and #safeCards(dealerHand) > 0 then
        drawHand(mainMonitor, dealerHand, layout.dealer.x, layout.dealer.y, layout.dealer.dir, "DEALER", not dealerRevealed, 0, 0, layout.dealer.labelDy or 0, 0, 0, 0, #safeCards(dealerHand) == 2)
    else
        drawPixelText(mainMonitor, layout.dealer.x, layout.dealer.y + (layout.dealer.labelDy or 0), "DEALER", layout.dealer.dir, colors.white, colors.green, 1)
    end
    for _, station in ipairs(STATIONS) do
        local p = layout[station.side]
        local showName = station.lockedPlayer or station.player
        drawTableStationLabel(station, p, showName)
        if station.joined and station.hands and #station.hands > 0 then
            local hand = station.hands[station.currentHand or 1]
            local label = "BET" .. tostring(hand and hand.bet or 0)
            if #station.hands > 1 then label = label .. " H" .. tostring(station.currentHand or 1) .. "/" .. tostring(#station.hands) end
            drawHand(mainMonitor, hand, p.x, p.y, p.dir, label, false, 0, 0, p.betDy or 0, p.betDx or 0, p.valDx or 0, p.valDy or 0)
        end
    end
end

