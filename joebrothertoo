-- === Touch Handling
-- =========================================================

local function stationByMonitorName(name)
    for _, station in ipairs(STATIONS) do if station.monitorName == name then return station end end
    return nil
end

local function buttonAt(station, x, y)
    for _, button in ipairs(station.buttons or {}) do
        if x >= button.x1 and x <= button.x2 and y >= button.y1 and y <= button.y2 then return button.name end
    end
    return nil
end

local function normalizeBet(station)
    local chip = CHIP_VALUES[station.chipIndex] or CHIP_VALUES[1]
    if chip * station.quantity > MAX_BET then station.quantity = math.max(1, math.floor(MAX_BET / chip)) end
    if station.quantity < 1 then station.quantity = 1 end
end

local function joinStation(station)
    if not station.player then station.message = "No player"; return end
    if station.joined then station.message = "Already locked"; return end
    normalizeBet(station)
    local total = totalBet(station)
    station.balance = refreshBalance(station, true)
    if total > MAX_BET then station.message = "Max bet 25000"; return end
    if total > station.balance then station.message = "No balance"; return end
    station.balance = changeBalance(station.player, -total, "BLACKJACK BET: $" .. total)
    station.lockedPlayer = station.player
    station.player = station.lockedPlayer
    station.joined = true
    station.message = "Locked in $" .. total
    if not dealCountdownEnd then
        dealCountdownEnd = os.clock() + AUTO_DEAL_SECONDS
        roundMessage = "Dealing in " .. tostring(AUTO_DEAL_SECONDS) .. "..."
        for _, s in ipairs(STATIONS) do if s.player then s.message = "Dealing in " .. tostring(AUTO_DEAL_SECONDS) .. "..." end end
    end
end

local function handlePlayingButton(station, button)
    if state ~= "playing" then return end
    if currentTurnStationId ~= station.id then station.message = "Not your turn"; return end
    local hand = station.hands[currentTurnHandIndex]
    if not hand or hand.done then return end
    if button == "hit" then
        addCard(hand); stationDealSound(station)
        if handValue(hand) > 21 then hand.done = true; station.message = "Bust"; setNextTurn() else station.message = "Hit"; turnDecisionEnd = os.clock() + TURN_DECISION_SECONDS end
    elseif button == "stand" then
        hand.done = true; station.message = "Stand"; setNextTurn()
    elseif button == "double" then
        if not canDouble(hand) then station.message = "No double"; return end
        if station.balance < hand.bet then station.message = "Need $" .. hand.bet; return end
        station.balance = changeBalance(station.lockedPlayer, -hand.bet, "BLACKJACK DOUBLE: extra $" .. hand.bet)
        hand.bet = hand.bet * 2; hand.doubled = true
        addCard(hand); stationDealSound(station); hand.done = true
        if handValue(hand) > 21 then station.message = "Double bust" else station.message = "Doubled" end
        setNextTurn()
    elseif button == "split" then
        if not canSplit(hand) then station.message = "No split"; return end
        if station.balance < hand.bet then station.message = "Need $" .. hand.bet; return end
        station.balance = changeBalance(station.lockedPlayer, -hand.bet, "BLACKJACK SPLIT: extra $" .. hand.bet)
        local cards = safeCards(hand)
        local c1, c2, bet = cards[1], cards[2], hand.bet
        local h1, h2 = makeHand(bet, true), makeHand(bet, true)
        table.insert(h1.cards, c1); table.insert(h2.cards, c2)
        addCard(h1); stationDealSound(station); addCard(h2); stationDealSound(station)
        station.hands = {h1, h2}; station.currentHand = 1; currentTurnHandIndex = 1; turnDecisionEnd = os.clock() + TURN_DECISION_SECONDS
        station.message = "Split"
    end
end

local function handleStationTouch(station, x, y)
    if station.player then
        local now = os.clock()
        local last = lastBalanceRefreshAt[station.player] or 0
        refreshBalance(station, (now - last) >= TOUCH_BALANCE_REFRESH_SECONDS)
    end
    local button = buttonAt(station, x, y)
    if not button then return end
    if state == "betting" then
        if station.joined then station.message = "Already locked"; return end
        if button == "qty_down" then station.quantity = math.max(1, station.quantity - 1); station.message = station.quantity <= 1 and "Min qty" or "Qty " .. station.quantity
        elseif button == "qty_up" then station.quantity = station.quantity + 1; normalizeBet(station); if totalBet(station) >= MAX_BET then station.message = "Max bet" else station.message = "Qty " .. station.quantity end
        elseif button == "chip_down" then station.chipIndex = math.max(1, station.chipIndex - 1); normalizeBet(station); station.message = "Chip $" .. tostring(CHIP_VALUES[station.chipIndex])
        elseif button == "chip_up" then station.chipIndex = math.min(#CHIP_VALUES, station.chipIndex + 1); normalizeBet(station); station.message = "Chip $" .. tostring(CHIP_VALUES[station.chipIndex])
        elseif button == "particles_toggle" then station.particlesEnabled = not station.particlesEnabled; station.message = station.particlesEnabled and "FX on" or "FX off"
        elseif button == "deal" then joinStation(station) end
    elseif state == "playing" then
        handlePlayingButton(station, button)
    end
end

local function touchLoop()
    while true do
        local _, monitorName, x, y = os.pullEvent("monitor_touch")
        local station = stationByMonitorName(monitorName)
        if station then handleStationTouch(station, x, y) end
        sleep(0.08)
    end
end

