-- =========================================================
-- === Safe Task Runner
-- =========================================================

local taskFailures = {}

local function runSafeTask(name, fn, startupDelay)
    return function()
        if startupDelay and startupDelay > 0 then sleep(startupDelay) end
        while true do
            local ok, err = pcall(fn)
            if not ok then
                taskFailures[name] = (taskFailures[name] or 0) + 1
                print("[TASK ERROR] " .. name .. ": " .. tostring(err))
                print("[TASK ERROR] Restarting only this task in 2s.")
                sleep(2)
            else
                print("[TASK RETURNED] " .. name .. " returned; restarting in 2s.")
                sleep(2)
            end
        end
    end
end

