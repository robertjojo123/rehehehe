-- =========================================================
-- === Secure Cipher Helpers
-- =========================================================

local accountPublicKey = nil
local blackjackPublicKey = nil
local blackjackPrivateKey = nil

local function readSerializedFile(path)
    if not fs.exists(path) then return nil end
    local f = fs.open(path, "r")
    if not f then return nil end
    local text = f.readAll()
    f.close()
    return textutils.unserialize(text)
end

local function writeSerializedFile(path, value)
    local f = fs.open(path, "w")
    if not f then error("Could not write " .. tostring(path)) end
    f.write(textutils.serialize(value))
    f.close()
end

local function waitForKeySet(keyset, label)
    label = label or "keyset"

    while not keyset.finished() do
        print("Generating " .. label .. "...")
        sleep(1)
    end
end

local function loadOrCreateBlackjackKeys()
    local pub = readSerializedFile(BLACKJACK_PUBLIC_KEY_FILE)
    local priv = readSerializedFile(BLACKJACK_PRIVATE_KEY_FILE)

    if type(pub) == "table" and type(priv) == "table" then
        blackjackPublicKey = pub
        blackjackPrivateKey = priv
        print("Loaded blackjack reply keys.")
        return
    end

    print("Creating blackjack reply keyset...")
    local keyset = cipher.createRandomKeySet()
    waitForKeySet(keyset, "blackjack reply keyset")

    local publicKey, privateKey = keyset.getKeys()

    if type(publicKey) ~= "table" or type(privateKey) ~= "table" then
        error("Blackjack cipher key generation failed.")
    end

    blackjackPublicKey = publicKey
    blackjackPrivateKey = privateKey

    writeSerializedFile(BLACKJACK_PUBLIC_KEY_FILE, blackjackPublicKey)
    writeSerializedFile(BLACKJACK_PRIVATE_KEY_FILE, blackjackPrivateKey)

    print("Saved blackjack reply keys.")
end

local function requestAccountPublicKey()
    local cached = readSerializedFile(ACCOUNT_PUBLIC_KEY_CACHE_FILE)

    if type(cached) == "table" then
        accountPublicKey = cached
        print("Loaded cached account public key.")
        return true
    end

    print("Requesting account public key...")

    for attempt = 1, 5 do
        rednet.send(ACCOUNT_COMPUTER_ID, {
            action = "get_public_key"
        }, ACCOUNT_PROTOCOL)

        local id, msg = rednet.receive(ACCOUNT_PROTOCOL, 2)

        if id == ACCOUNT_COMPUTER_ID
            and type(msg) == "table"
            and msg.action == "account_public_key"
            and type(msg.publicKey) == "table" then

            accountPublicKey = msg.publicKey
            writeSerializedFile(ACCOUNT_PUBLIC_KEY_CACHE_FILE, accountPublicKey)
            print("Received and cached account public key.")
            return true
        end

        print("Account public key request attempt failed: " .. tostring(attempt))
        sleep(0.5)
    end

    return false
end

local function ensureSecureAccountReady()
    if not blackjackPublicKey or not blackjackPrivateKey then
        loadOrCreateBlackjackKeys()
    end

    if not accountPublicKey then
        if not requestAccountPublicKey() then
            error("Could not get account public key from account computer " .. tostring(ACCOUNT_COMPUTER_ID))
        end
    end
end

local function encryptPlainToKeyAsPacket(plain, publicKey, includeReplyKey)
    local chunks = {}

    for i = 1, #plain, SECURE_CHUNK_SIZE do
        local piece = plain:sub(i, i + SECURE_CHUNK_SIZE - 1)

        local ok, encryptedOrErr = pcall(function()
            return cipher.encrypt(piece, publicKey)
        end)

        if not ok then
            error("Encrypt failed on chunk " .. tostring(#chunks + 1) .. ": " .. tostring(encryptedOrErr))
        end

        table.insert(chunks, encryptedOrErr)
        sleep(0)
    end

    local packet = {
        secure = true,
        version = SECURE_VERSION,
        chunked = true,
        payloadChunks = chunks
    }

    if includeReplyKey then
        packet.replyPublicKey = blackjackPublicKey
    end

    return packet
end

local function secureEncryptForAccount(tbl)
    ensureSecureAccountReady()
    return encryptPlainToKeyAsPacket(textutils.serialize(tbl), accountPublicKey, true)
end

local function decryptPacketWithPrivateKey(packet, privateKey)
    if type(packet) ~= "table" then
        return nil, "reply not table"
    end

    if packet.secure ~= true then
        return packet, nil
    end

    if packet.version ~= SECURE_VERSION then
        return nil, "bad secure version"
    end

    local plain = ""

    if packet.chunked and type(packet.payloadChunks) == "table" then
        for i, encryptedPiece in ipairs(packet.payloadChunks) do
            if type(encryptedPiece) ~= "string" then
                return nil, "bad encrypted chunk " .. tostring(i)
            end

            local ok, pieceOrErr = pcall(function()
                return cipher.decrypt(encryptedPiece, privateKey)
            end)

            if not ok then
                return nil, "chunk decrypt failed " .. tostring(i) .. ": " .. tostring(pieceOrErr)
            end

            plain = plain .. tostring(pieceOrErr)
            sleep(0)
        end

    elseif type(packet.payload) == "string" then
        local ok, plainOrErr = pcall(function()
            return cipher.decrypt(packet.payload, privateKey)
        end)

        if not ok then
            return nil, "decrypt failed: " .. tostring(plainOrErr)
        end

        plain = tostring(plainOrErr)

    else
        return nil, "bad encrypted payload"
    end

    local data = textutils.unserialize(plain)

    if type(data) ~= "table" then
        return nil, "unserialize failed"
    end

    return data, nil
end

local function secureDecryptReply(packet)
    return decryptPacketWithPrivateKey(packet, blackjackPrivateKey)
end

local function secureSendAccount(tbl, timeout)
    timeout = timeout or ACCOUNT_TIMEOUT_SECONDS

    local packet = secureEncryptForAccount(tbl)

    rednet.send(ACCOUNT_COMPUTER_ID, packet, ACCOUNT_PROTOCOL)

    local id, replyPacket = rednet.receive(ACCOUNT_PROTOCOL, timeout)

    if id ~= ACCOUNT_COMPUTER_ID then
        return nil, "account timeout"
    end

    local reply, err = secureDecryptReply(replyPacket)

    if not reply then
        return nil, err or "bad reply"
    end

    return reply, nil
end

