-- =========================================================

local function getStationById(id)
    for _, station in ipairs(STATIONS) do
        if station.id == id then return station end
    end

    return nil
end

local function anyJoined()
    for _, station in ipairs(STATIONS) do
        if station.joined then return true end
    end

    return false
end

local function joinedStations()
    local list = {}

    for _, station in ipairs(STATIONS) do
        if station.joined then
            table.insert(list, station)
        end
    end

    table.sort(list, function(a, b)
        return a.id < b.id
    end)

    return list
end

local function allHandsDone()
    for _, station in ipairs(STATIONS) do
        if station.joined then
            for _, hand in ipairs(station.hands or {}) do
                if not hand.done then
                    return false
                end
            end
        end
    end

    return true
end

local function setNextTurn()
    if allHandsDone() then
        currentTurnStationId = nil
        currentTurnHandIndex = nil
        turnDecisionEnd = nil
        state = "dealer"
        roundMessage = "Dealer playing"
        return
    end

    local active = joinedStations()

    for _, station in ipairs(active) do
        for handIndex, hand in ipairs(station.hands or {}) do
            if not hand.done then
                station.currentHand = handIndex
                currentTurnStationId = station.id
                currentTurnHandIndex = handIndex
                turnDecisionEnd = os.clock() + TURN_DECISION_SECONDS
                roundMessage = station.label .. " turn"
                station.message = "Your turn"
                return
            end
        end
    end
end

local function startRound()
    if state ~= "betting" then return end
    if not anyJoined() then return end

    dealCountdownEnd = nil

    deck = buildDeck()
    dealerHand = makeHand(0, false)
    dealerRevealed = false

    addCard(dealerHand)
    addCard(dealerHand)

    for _, station in ipairs(STATIONS) do
        if station.joined then
            station.lockedPlayer = station.lockedPlayer or station.player
            station.player = station.lockedPlayer
            station.hands = {makeHand(totalBet(station), false)}
            station.currentHand = 1
            station.message = "Good luck"

            addCard(station.hands[1])
            stationDealSound(station)
            addCard(station.hands[1])
            stationDealSound(station)

            if isBlackjack(station.hands[1]) then
                station.hands[1].done = true
                station.message = "Blackjack!"
            end
        end
    end

    state = "playing"
    roundMessage = "Players playing"
    turnDecisionEnd = nil
    setNextTurn()
end

local function playDealer()
    dealerRevealed = true

    while handValue(dealerHand) < 17 or (DEALER_HITS_SOFT_17 and isSoft17(dealerHand)) do
        drawAll()
        sleep(0.8)
        addCard(dealerHand)
        for _, st in ipairs(STATIONS) do
            if st.joined then stationDealSound(st) end
        end
    end
end


-- =========================================================
-- === Local Particle FX
-- =========================================================

local particlePeripheral = nil
local particleSpawnFailCount = 0

local FX_AXIS = {
    px = {x = 1, z = 0},
    nx = {x = -1, z = 0},
    pz = {x = 0, z = 1},
    nz = {x = 0, z = -1},
}

local FX_FONT = {
    W = {"10001","10001","10101","10101","01010"},
    I = {"111","010","010","010","111"},
    N = {"1001","1101","1011","1001","1001"},
    E = {"1111","1000","1110","1000","1111"},
    R = {"1110","1001","1110","1010","1001"},
    L = {"1000","1000","1000","1000","1111"},
    O = {"111","101","101","101","111"},
    S = {"111","100","111","001","111"},
}

local function getParticlePeripheral()
    if particlePeripheral then
        return particlePeripheral
    end

    local p = peripheral.wrap(PARTICLE_SIDE)
    if p and type(p.spawn) == "function" then
        particlePeripheral = p
        if PARTICLE_DEBUG then
            print("[FX] particle peripheral found on " .. PARTICLE_SIDE)
        end
        return particlePeripheral
    end

    for _, name in ipairs(peripheral.getNames()) do
        local wrapped = peripheral.wrap(name)
        if wrapped and type(wrapped.spawn) == "function" then
            particlePeripheral = wrapped
            if PARTICLE_DEBUG then
                print("[FX] particle peripheral found on " .. tostring(name))
            end
            return particlePeripheral
        end
    end

    if PARTICLE_DEBUG then
        print("[FX] no particle peripheral with spawn() found")
    end

    return nil
end

local function spawnFxParticle(name, x, y, z)
    local p = getParticlePeripheral()
    if not p then return false end

    local attempts = {
        function() return p.spawn(name, x, y, z) end,
        function() return p.spawn(name, x, y, z, 0, 0, 0) end,
        function() return p.spawn(name, x, y, z, 0, 0, 0, 0) end,
        function() return p.spawn(name, x, y, z, 0, 0, 0, 0, 1) end,
    }

    for _, attempt in ipairs(attempts) do
        local ok = pcall(attempt)
        if ok then return true end
    end

    particleSpawnFailCount = particleSpawnFailCount + 1
    if PARTICLE_DEBUG and particleSpawnFailCount <= 5 then
        print("[FX] spawn failed for " .. tostring(name) .. " at " ..
              tostring(x) .. "," .. tostring(y) .. "," .. tostring(z))
    end

    return false
end

local function fxAdd(a, b)
    return {
        x = (a.x or 0) + (b.x or 0),
        y = (a.y or 0) + (b.y or 0),
        z = (a.z or 0) + (b.z or 0),
    }
end

local function fxMid(a, b)
    return {
        x = ((a.x or 0) + (b.x or 0)) / 2,
        y = ((a.y or 0) + (b.y or 0)) / 2,
        z = ((a.z or 0) + (b.z or 0)) / 2,
    }
end

local function fxTextWidth(text)
    local width = 0
    for i = 1, #text do
        local glyph = FX_FONT[text:sub(i, i)]
        if glyph then width = width + #glyph[1] + 1 end
    end
    return math.max(0, width - 1)
end

local function drawFxWordOnce(word, particle, cfg)
    local axis = FX_AXIS[cfg.wordAxis or "px"]
    if not axis then return end

    local center = fxAdd(fxMid(cfg.spiralA, cfg.spiralB), cfg.wordOffsetFromSpiralCenter or {x = 0, y = 2, z = 0})
    local width = fxTextWidth(word)
    local cursor = -((width * PARTICLE_TEXT_SCALE) / 2)

    for i = 1, #word do
        local glyph = FX_FONT[word:sub(i, i)]
        if glyph then
            local glyphW = #glyph[1]
            local glyphH = #glyph

            for row = 1, glyphH do
                local line = glyph[row]
                for col = 1, glyphW do
                    if line:sub(col, col) == "1" then
                        local along = cursor + ((col - 1) * PARTICLE_TEXT_SCALE)
                        local up = (glyphH - row) * PARTICLE_TEXT_SCALE

                        local x = center.x + (axis.x * along)
                        local y = center.y + up
                        local z = center.z + (axis.z * along)

                        for _ = 1, PARTICLE_DOT_STACK do
                            spawnFxParticle(particle, x, y, z)
                        end
                    end
                end
            end

            cursor = cursor + (glyphW * PARTICLE_TEXT_SCALE) + PARTICLE_TEXT_SCALE
        end
    end
end

local function drawFxWordHeld(word, particle, cfg)
    for _ = 1, PARTICLE_TEXT_REPEAT do
        drawFxWordOnce(word, particle, cfg)
        sleep(PARTICLE_TEXT_REPEAT_DELAY)
    end
end

local function drawFxTwoBlockSpiral(particle, cfg)
    local c = fxMid(cfg.spiralA, cfg.spiralB)
    local y0 = cfg.spiralA.y or 0

    for i = 1, PARTICLE_SPIRAL_STEPS do
        local t = i / PARTICLE_SPIRAL_STEPS
        local angle = i * 0.38
        local y = y0 + PARTICLE_SPIRAL_START_Y + ((PARTICLE_SPIRAL_END_Y - PARTICLE_SPIRAL_START_Y) * t)

        local x = c.x + math.cos(angle) * PARTICLE_SPIRAL_RADIUS
        local z = c.z + math.sin(angle) * PARTICLE_SPIRAL_RADIUS

        spawnFxParticle(particle, x, y, z)
        sleep(PARTICLE_SPIRAL_DELAY)
    end
end

local function playStationFx(stationId, outcome)
    local cfg = STATION_FX[tonumber(stationId)]
    if not cfg then
        if PARTICLE_DEBUG then print("[FX] no config for station " .. tostring(stationId)) end
        return
    end

    local word
    local particle

    if outcome == "lose" or outcome == "loser" then
        word = "LOSER"
        particle = PARTICLE_LOSE
    else
        word = "WINNER"
        particle = PARTICLE_WIN
    end

    if PARTICLE_DEBUG then
        print("[FX] playing " .. word .. " for station " .. tostring(stationId))
    end
        --function() drawFxTwoBlockSpiral(particle, cfg) end,
    drawFxWordHeld(word, particle, cfg)
end

local function triggerStationParticles(station, outcome, amount)
    if not station then return end

    if PARTICLE_DEBUG then
        print("[FX] trigger station=" .. tostring(station.id) ..
              " outcome=" .. tostring(outcome) ..
              " enabled=" .. tostring(station.particlesEnabled))
    end

    if not station.particlesEnabled then
        return
    end

    if outcome ~= "win" and outcome ~= "lose" then
        return
    end

    parallel.waitForAny(
        function()
            playStationFx(station.id, outcome)
        end,
        function()
            -- Safety timeout so blackjack can never get stuck if particle spawning is weird.
            sleep(PARTICLE_MAX_SECONDS)
        end
    )
end

local function settleRound()
    local dealerValue = handValue(dealerHand)
    local dealerBust = dealerValue > 21

    for _, station in ipairs(STATIONS) do
        if station.joined and station.lockedPlayer then
            local totalNet = 0

            for _, hand in ipairs(station.hands or {}) do
                local hv = handValue(hand)
                local payout = 0
                local result = ""

                if hv > 21 then
                    result = "Bust"
                    payout = 0

                elseif isBlackjack(hand) then
                    result = "Blackjack"
                    payout = math.floor(hand.bet * BLACKJACK_PAYOUT_MULT)

                elseif dealerBust then
                    result = "Win"
                    payout = hand.bet * 2

                elseif hv > dealerValue then
                    result = "Win"
                    payout = hand.bet * 2

                elseif hv == dealerValue then
                    result = "Push"
                    payout = hand.bet

                else
                    result = "Lose"
                    payout = 0
                end

                hand.result = result
                hand.payout = payout
                hand.net = payout - hand.bet

                if payout > 0 then
                    station.balance = changeBalance(
                        station.lockedPlayer,
                        payout,
                        "BLACKJACK " .. result .. ": payout $" .. payout .. " on bet $" .. hand.bet
                    )
                end

                if hand.net > 0 then
                    sendWinStat(station.lockedPlayer, hand.bet, payout, result)
                end

                totalNet = totalNet + hand.net
            end

            station.message = "Net " .. (totalNet >= 0 and "+" or "") .. tostring(totalNet)

            if totalNet > 0 then
                stationWinSound(station)
                parallel.waitForAny(
                    function() triggerStationParticles(station, "win", totalNet) end,
                    function() sleep(PARTICLE_MAX_SECONDS) end
                )
            elseif totalNet < 0 then
                stationLoseSound(station)
                parallel.waitForAny(
                    function() triggerStationParticles(station, "lose", totalNet) end,
                    function() sleep(PARTICLE_MAX_SECONDS) end
                )
            else
                stationPushSound(station)
            end
        end
    end

    state = "result"
    roundMessage = "Round complete"
end

local function resetToBetting()
    for _, station in ipairs(STATIONS) do
        station.joined = false
        station.lockedPlayer = nil
        station.hands = {}
        station.currentHand = 1

        if station.particlesEnabled == nil then
            station.particlesEnabled = PARTICLES_ENABLED_DEFAULT
        end

        if station.player then
            station.balance = refreshBalance(station, true)
            station.message = "Set bet"
        else
            station.balance = 0
            station.message = "Stand on pad"
        end
    end

    dealerHand = nil
    dealerRevealed = false
    currentTurnStationId = nil
    currentTurnHandIndex = nil
    turnDecisionEnd = nil
    dealCountdownEnd = nil
    roundMessage = "Place bets"
    state = "betting"
end

local function roundLoop()
    while true do
        if state == "betting" and dealCountdownEnd then
            local remaining = math.max(0, math.ceil(dealCountdownEnd - os.clock()))
            roundMessage = "Dealing in " .. tostring(remaining) .. "..."

            if os.clock() >= dealCountdownEnd then
                startRound()
            end

        elseif state == "playing" then
            if turnDecisionEnd and os.clock() >= turnDecisionEnd and currentTurnStationId and currentTurnHandIndex then
                local st = nil
                for _, candidate in ipairs(STATIONS) do
                    if candidate.id == currentTurnStationId then
                        st = candidate
                        break
                    end
                end

                local hand = st and st.hands and st.hands[currentTurnHandIndex] or nil
                if hand and not hand.done then
                    hand.done = true
                    if st then st.message = "Auto stand" end
                    setNextTurn()
                else
                    turnDecisionEnd = nil
                end
            end

        elseif state == "dealer" then
            playDealer()
            drawAll()
            sleep(1)
            settleRound()
            drawAll()
            sleep(ROUND_RESULT_SECONDS)
            resetToBetting()
        end

        sleep(0.1)
    end
end

