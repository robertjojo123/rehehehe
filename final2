local function stationSound(station, soundName, volume, pitch)
    if not station or not station.speaker then return end
    if not soundName then return end

    volume = volume or 0.7
    pitch = pitch or 1.0

    local ok = pcall(function()
        station.speaker.playSound(soundName, volume, pitch)
    end)

    if not ok and station.speaker.playNote then
        pcall(function()
            station.speaker.playNote("harp", volume, math.max(0, math.min(24, math.floor((pitch or 1) * 12))))
        end)
    end
end

local function stationDealSound(station)
