local function resetButtons(station)
    station.buttons = {}
end

local function addButton(station, name, x1, y1, x2, y2, label, bg, fg)
    table.insert(station.buttons, {
        name = name,
        x1 = x1,
        y1 = y1,
        x2 = x2,
        y2 = y2
    })

    local mon = station.monitor
    mon.setBackgroundColor(bg or colors.gray)
    mon.setTextColor(fg or colors.white)

    for y = y1, y2 do
        mon.setCursorPos(x1, y)
        mon.write(string.rep(" ", math.max(1, x2 - x1 + 1)))
    end

    local tx = x1 + math.floor(((x2 - x1 + 1) - #label) / 2)
    local ty = y1 + math.floor((y2 - y1) / 2)

    if tx < x1 then tx = x1 end

    mon.setCursorPos(tx, ty)
    mon.write(label)
end

local function addPixelButton(station, name, x1, y1, x2, y2, label, bg, fg)
    local mon = station.monitor
    local glyphColor = bg or colors.white
    local fillColor = fg or colors.black

    local tw = pixelTextCellWidth(label, 1, "north")
    local tx = x1 + math.floor(((x2 - x1 + 1) - tw) / 2)
    if tx < x1 then tx = x1 end

    local hitX1 = tx
    local hitX2 = tx + tw - 1
    local hitY1 = y1
    local hitY2 = y1 + 1 -- pixel text is 6 subpixels tall = 2 monitor rows

    table.insert(station.buttons, {
        name = name,
        x1 = hitX1,
        y1 = hitY1,
        x2 = hitX2,
        y2 = hitY2
    })

    mon.setBackgroundColor(fillColor)
    for y = hitY1, hitY2 do
        mon.setCursorPos(hitX1, y)
        mon.write(string.rep(" ", math.max(1, hitX2 - hitX1 + 1)))
    end

    drawPixelText(mon, tx, y1, label, "north", glyphColor, fillColor, 1)
end

local function getCountdownText()
    if state == "betting" and dealCountdownEnd then
        local remaining = math.max(0, math.ceil(dealCountdownEnd - os.clock()))
        return "Dealing in " .. tostring(remaining) .. "..."
    end

    return nil
end

local function getStationHandText(station)
    if not station.hands or not station.currentHand then
        return "Hand: --"
    end

    local hand = station.hands[station.currentHand]
    if not hand then
        return "Hand: --"
    end

    local value = handDisplayValue(hand)

    if value == "" then
        return "Hand: --"
    end

    return "Hand: " .. value
end

local function getDealerHandText()
    if not dealerHand then
        return "Dealer: --"
    end

    local cards = safeCards(dealerHand)
    if #cards == 0 then
        return "Dealer: --"
    end

    if not dealerRevealed and #cards >= 1 then
        local tempHand = makeHand(0, false)
        table.insert(tempHand.cards, cards[1])
        return "Dealer: " .. tostring(handValue(tempHand)) .. " + ?"
    end

    local value = handDisplayValue(dealerHand)
    if value == "" then
        return "Dealer: --"
    end

    return "Dealer: " .. value
end

local function getStationDisplayPlayer(station)
    return station.lockedPlayer or station.player
end

