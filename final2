local function colorToBlit(color)
    return BLIT_LOOKUP[color or colors.white] or "0"
end

local function sixelChar(mask)
    -- CC's usable geometric charset is 0x80-0x9F.
    -- That gives 32 direct shapes. For masks above 31, invert the shape
    -- and swap foreground/background. This covers all 64 possible 2x3 patterns.
    if mask > 31 then
        return string.char(0x80 + (63 - mask)), true
    end

    return string.char(0x80 + mask), false
end

local function writeText(mon, x, y, text, fg, bg)
    local w, h = mon.getSize()
    text = tostring(text or "")

    if y < 1 or y > h then return end
    if x < 1 then x = 1 end
    if x > w then return end

    mon.setCursorPos(x, y)
    mon.setTextColor(fg or colors.white)
    mon.setBackgroundColor(bg or colors.black)
    mon.write(text)
end

local function drawPixel(mon, x, y, color)
    local w, h = mon.getSize()
    if x < 1 or x > w or y < 1 or y > h then return end

    mon.setCursorPos(x, y)
    mon.setBackgroundColor(color)
    mon.write(" ")
end

local function newSubCanvas(w, h, bg)
    local pix = {}

    for y = 1, h do
        pix[y] = {}
        for x = 1, w do
            pix[y][x] = bg
        end
    end

    return {
        w = w,
        h = h,
        bg = bg,
        pix = pix
    }
end

local function setSub(canvas, x, y, color)
    if x >= 1 and x <= canvas.w and y >= 1 and y <= canvas.h then
        canvas.pix[y][x] = color
    end
end

local function fillSubRect(canvas, x, y, w, h, color)
    for yy = y, y + h - 1 do
        for xx = x, x + w - 1 do
            setSub(canvas, xx, yy, color)
        end
    end
end

local function plotBitmap(canvas, bitmap, ox, oy, color, scale, rot180)
    scale = scale or 1

    local bh = #bitmap
    local bw = #bitmap[1]

    for row = 1, bh do
        local line = bitmap[row]

        for col = 1, bw do
            if line:sub(col, col) == "1" then
                local srcX = col
                local srcY = row

                if rot180 then
                    srcX = bw - col + 1
                    srcY = bh - row + 1
                end

                for sy = 0, scale - 1 do
                    for sx = 0, scale - 1 do
                        setSub(
                            canvas,
                            ox + (srcX - 1) * scale + sx,
                            oy + (srcY - 1) * scale + sy,
                            color
                        )
                    end
                end
            end
        end
    end
end

local function rotateSubPoint(px, py, width, height, dir)
    if dir == "north" then
        return px, py, width, height
    elseif dir == "south" then
        return width - px + 1, height - py + 1, width, height
    elseif dir == "east" then
        return height - py + 1, px, height, width
    elseif dir == "west" then
        return py, width - px + 1, height, width
    end

    return px, py, width, height
end

local function renderSubCanvas(mon, x, y, canvas, dir)
    dir = dir or "north"

    local rawW = canvas.w
    local rawH = canvas.h

    if dir == "east" or dir == "west" then
        rawW = canvas.h
        rawH = canvas.w
    end

    -- Important for sideways cards:
    -- 20x27 rotated becomes 27x20, which is not divisible by 2x3.
    -- Round up so the far/right/bottom border is not clipped away.
    local outW = rawW
    local outH = rawH

    while outW % 2 ~= 0 do
        outW = outW + 1
    end

    while outH % 3 ~= 0 do
        outH = outH + 1
    end

    local rotated = newSubCanvas(outW, outH, canvas.bg)

    for sy = 1, canvas.h do
        for sx = 1, canvas.w do
            local rx, ry = rotateSubPoint(sx, sy, canvas.w, canvas.h, dir)
            rotated.pix[ry][rx] = canvas.pix[sy][sx]
        end
    end

    local charW = math.floor(outW / 2)
    local charH = math.floor(outH / 3)

    for cy = 1, charH do
        local chars = {}
        local fgs = {}
        local bgs = {}

        for cx = 1, charW do
            local bg = rotated.bg
            local points = {
                rotated.pix[(cy - 1) * 3 + 1][(cx - 1) * 2 + 1], -- top-left
                rotated.pix[(cy - 1) * 3 + 1][(cx - 1) * 2 + 2], -- top-right
                rotated.pix[(cy - 1) * 3 + 2][(cx - 1) * 2 + 1], -- mid-left
                rotated.pix[(cy - 1) * 3 + 2][(cx - 1) * 2 + 2], -- mid-right
                rotated.pix[(cy - 1) * 3 + 3][(cx - 1) * 2 + 1], -- bottom-left
                rotated.pix[(cy - 1) * 3 + 3][(cx - 1) * 2 + 2], -- bottom-right
            }

            local fg = nil

            for _, pointColor in ipairs(points) do
                if pointColor ~= bg then
                    fg = pointColor
                    break
                end
            end

            fg = fg or colors.white

            local mask = 0
            local bitValues = {1, 2, 4, 8, 16, 32}

            for i, pointColor in ipairs(points) do
                if pointColor == fg then
                    mask = mask + bitValues[i]
                end
            end

            if mask == 0 then
                -- Empty 2x3 cell: draw a normal blank with fg=bg.
                -- This is important because string.char(0x80) is not visually blank
                -- in ComputerCraft's custom font and caused white artifacts.
                chars[#chars + 1] = " "
                fgs[#fgs + 1] = colorToBlit(bg)
                bgs[#bgs + 1] = colorToBlit(bg)
            else
                local ch, inverted = sixelChar(mask)

                if inverted then
                    chars[#chars + 1] = ch
                    fgs[#fgs + 1] = colorToBlit(bg)
                    bgs[#bgs + 1] = colorToBlit(fg)
                else
                    chars[#chars + 1] = ch
                    fgs[#fgs + 1] = colorToBlit(fg)
                    bgs[#bgs + 1] = colorToBlit(bg)
                end
            end
        end

        local w, h = mon.getSize()
        local rowY = y + cy - 1

        if rowY >= 1 and rowY <= h then
            local rowText = table.concat(chars)
            local rowFg = table.concat(fgs)
            local rowBg = table.concat(bgs)

            if x < 1 then
                local trim = 2 - x
                rowText = rowText:sub(trim)
                rowFg = rowFg:sub(trim)
                rowBg = rowBg:sub(trim)
                x = 1
            end

            if x <= w and #rowText > 0 then
                local maxLen = w - x + 1
                rowText = rowText:sub(1, maxLen)
                rowFg = rowFg:sub(1, maxLen)
                rowBg = rowBg:sub(1, maxLen)

                mon.setCursorPos(x, rowY)
                mon.blit(rowText, rowFg, rowBg)
            end
        end
    end
end

local function buildPixelTextCanvas(text, fg, bg, scale)
    text = tostring(text or ""):upper()
    fg = fg or colors.white
    bg = bg or colors.green
    scale = scale or 1

    local glyphW = 3 * scale
    local glyphH = 5 * scale
    local spacing = 1 * scale
    local width = math.max(2, (#text * glyphW) + math.max(0, #text - 1) * spacing)
    local height = math.max(3, glyphH)

    -- Make the canvas multiples of 2x3 so the sixel renderer packs cleanly.
    while width % 2 ~= 0 do width = width + 1 end
    while height % 3 ~= 0 do height = height + 1 end

    local canvas = newSubCanvas(width, height, bg)

    local x = 1

    for i = 1, #text do
        local ch = text:sub(i, i)
        local glyph = PIXEL_FONT[ch] or PIXEL_FONT["?"]
        plotBitmap(canvas, glyph, x, 1, fg, scale, false)
        x = x + glyphW + spacing
    end

    return canvas
end

local function pixelTextCellWidth(text, scale, dir)
    local canvas = buildPixelTextCanvas(text, colors.white, colors.green, scale or 1)

    if dir == "east" or dir == "west" then
        -- After rotation, the text's vertical monitor-cell span comes from the original
        -- packed character width, which is based on 2 subpixels per cell across.
        local w = canvas.w
        if w % 2 ~= 0 then
            w = w + 1
        end
        return math.floor(w / 2)
    end

    local w = canvas.w
    if w % 2 ~= 0 then w = w + 1 end
    return math.floor(w / 2)
end

-- drawPixelTextAligned is defined after drawPixelText below, because Lua locals
-- must exist before they are referenced.
local function drawPixelText(mon, x, y, text, dir, fg, bg, scale)
    local canvas = buildPixelTextCanvas(text, fg, bg, scale or 1)
    renderSubCanvas(mon, x, y, canvas, dir or "north")
end

local function drawPixelTextAligned(mon, x, y, text, dir, fg, bg, scale, align)
    align = align or "left"

    if align == "right" then
        local amount = pixelTextCellWidth(text, scale or 1, dir)

        if dir == "west" then
            -- Station 1 west-facing text: anchor at the station corner and let longer
            -- names extend upward on the monitor (-Y), not downward.
            y = y - amount + 1
        elseif dir == "east" then
            y = y - amount + 1
        else
            x = x - amount + 1
        end
    end

    drawPixelText(mon, x, y, text, dir, fg, bg, scale or 1)
end

local function cardDims(dir)
    -- Side-facing north/south seats use a slightly larger rotated card.
    -- Dealer and east/west seats keep the sharper original card size.
    if dir == "east" or dir == "west" then
        return 14, 7 -- 21x28 rotated -> 28x21 -> 14x7 cells
    end

    return 10, 9 -- 20x27 -> 10x9 cells
end


local function buildCardCanvas(card, hidden, variant)
    variant = variant or "normal"

    local sideCard = (variant == "side_west" or variant == "side_east")
    local cw = sideCard and 21 or 20
    local ch = sideCard and 28 or 27

    local canvas = newSubCanvas(cw, ch, colors.white)

    fillSubRect(canvas, 1, 1, cw, ch, colors.white)

    for x = 1, cw do
        setSub(canvas, x, 1, colors.gray)
        setSub(canvas, x, ch, colors.gray)
    end

    for y = 1, ch do
        setSub(canvas, 1, y, colors.gray)
        setSub(canvas, cw, y, colors.gray)
    end

    if hidden then
        -- Dealer card back stays on the sharper original 20x27 canvas.
        canvas.bg = colors.lightBlue

        local BACK_COLOR_MAP = {
            x = colors.gray,
            ['.'] = colors.lightBlue,
            y = colors.yellow,
            o = colors.orange,
            g = colors.lime,
        }

        local BACK_ART = {
            -- 27 rows total. The extra light-blue interior row near the top shifts the
            -- emblem down by 1 subpixel so the sun and orange tips are no longer clipped.
            "xxxxxxxxxxxxxxxxxxxx",
            "x..................x",
            "x..................x",
            "x...o....yy....o...x",
            "x...o...yyyy...o...x",
            "x...oo..yyyy..oo...x",
            "x..y.o...yy...o.y..x",
            "x.y..oo......oo..y.x",
            "x.....o......o.....x",
            "x.y...oo.oo.oo...y.x",
            "x..y...oooooo...y..x",
            "x.......o..o.......x",
            "x..................x",
            "x.......ggggg......x",
            "x..o..ggg...gg..o..x",
            "x.o..gg......gg..o.x",
            "x.o..g........gg.o.x",
            "x...gg.............x",
            "x...g..............x",
            "x...gg.............x",
            "x....g........gg...x",
            "x.o..gg......gg..o.x",
            "x.o...ggg...gg...o.x",
            "x..o....ggggg...o..x",
            "x..................x",
            "x..................x",
            "xxxxxxxxxxxxxxxxxxxx",
        }

        -- Paint the 20x27 art into the current canvas. For normal dealer cards this is exact.
        -- If a hidden side card were ever drawn, it will stay anchored at the top-left inside the border.
        for yy, row in ipairs(BACK_ART) do
            if yy <= ch then
                for xx = 1, #row do
                    if xx <= cw then
                        local chv = row:sub(xx, xx)
                        local col = BACK_COLOR_MAP[chv]
                        if col then
                            setSub(canvas, xx, yy, col)
                        end
                    end
                end
            end
        end

        return canvas
    end

    if not card then
        return canvas
    end

    local pipColor = suitColor(card.suit)
    local rankGlyph = PIXEL_FONT[card.rank] or PIXEL_FONT["?"]
    local centerSuit = CENTER_SUIT_ART[card.suit] or CENTER_SUIT_ART.S

    if sideCard then
        -- Side-facing north/south seats use the slightly larger 21x28 card.
        -- Rank placement can be fine-tuned in monitor-space using SIDE_RANK_MONITOR_OFFSETS.
        local rankX = 3
        local rankY = 3

        if variant == "side_west" then
            -- Base anchor for station 1 / north seat.
            rankX = 4
            rankY = 3

            local off = SIDE_RANK_MONITOR_OFFSETS.station1 or { x = 0, y = 0 }
            -- west rotation: monitor dx/dy -> source dx/dy = (-dy, +dx)
            rankX = rankX - (off.y or 0)
            rankY = rankY + (off.x or 0)
        elseif variant == "side_east" then
            -- Base anchor for station 3 / south seat.
            rankX = 2
            rankY = 4

            local off = SIDE_RANK_MONITOR_OFFSETS.station3 or { x = 0, y = 0 }
            -- east rotation: monitor dx/dy -> source dx/dy = (+dy, -dx)
            rankX = rankX + (off.y or 0)
            rankY = rankY - (off.x or 0)
        end

        plotBitmap(canvas, rankGlyph, rankX, rankY, pipColor, 1, false)

        local centerX = 5
        local centerY = 13
        if card.suit == "S" or card.suit == "D" or card.suit == "C" then
            centerY = 11
        end
        plotBitmap(canvas, centerSuit, centerX, centerY, pipColor, 1, false)
    else
        -- Dealer and east/west seats keep the original sharper 20x27 card.
        plotBitmap(canvas, rankGlyph, 3, 4, pipColor, 1, false)

        local centerX = 4
        local centerY = 12
        if card.suit == "S" or card.suit == "D" or card.suit == "C" then
            centerY = 10
        end
        plotBitmap(canvas, centerSuit, centerX, centerY, pipColor, 1, false)
    end

    return canvas
end

local function shiftCanvas(canvas, dx, dy, fillColor)
    dx = dx or 0
    dy = dy or 0
    fillColor = fillColor or canvas.bg

    if dx == 0 and dy == 0 then
        return canvas
    end

    local shifted = newSubCanvas(canvas.w, canvas.h, fillColor)

    for yy = 1, canvas.h do
        for xx = 1, canvas.w do
            local nx = xx + dx
            local ny = yy + dy

            if nx >= 1 and nx <= canvas.w and ny >= 1 and ny <= canvas.h then
                shifted.pix[ny][nx] = canvas.pix[yy][xx]
            end
        end
    end

    return shifted
end

local function scaleCanvas(canvas, factor)
    factor = factor or 2

    if factor <= 1 then
        return canvas
    end

    local scaled = newSubCanvas(canvas.w * factor, canvas.h * factor, canvas.bg)

    for yy = 1, canvas.h do
        for xx = 1, canvas.w do
            local col = canvas.pix[yy][xx]

            for dy = 0, factor - 1 do
                for dx = 0, factor - 1 do
                    scaled.pix[((yy - 1) * factor) + dy + 1][((xx - 1) * factor) + dx + 1] = col
                end
            end
        end
    end

    return scaled
end

local function drawCard(mon, x, y, card, hidden, dir, cardSubX, cardSubY, scaleFactor)
    local variant = "normal"
    if dir == "west" then
        variant = "side_west"
    elseif dir == "east" then
        variant = "side_east"
    end

    local canvas = buildCardCanvas(card, hidden, variant)

    if cardSubX or cardSubY then
        canvas = shiftCanvas(canvas, cardSubX or 0, cardSubY or 0, canvas.bg)
    end

    if scaleFactor and scaleFactor > 1 then
        canvas = scaleCanvas(canvas, scaleFactor)
    end

    renderSubCanvas(mon, x, y, canvas, dir or "north")
end

local function handDisplayValue(hand)
    if not hand then return "" end

    local cards = safeCards(hand)
    if #cards == 0 then return "" end

    local v = handValue(hand)
    if v > 21 then return "BUST" end

    return tostring(v)
end



local function drawHand(mon, hand, x, y, dir, label, hideSecond, cardSubX, cardSubY, labelDy, labelDx, valDx, valDy, dealerBig)
    if not hand then return end

    local cards = safeCards(hand)
    label = tostring(label or "")

    -- Pixel label, oriented with the station/cards.
    drawPixelText(mon, x + (labelDx or 0), y - 1 + (labelDy or 0), label, dir, colors.white, colors.green, 1)

    -- Dealer special: while the dealer only has 2 cards, show those cards 2x.
    -- 20x27 subpixels becomes 40x54 subpixels = 20x18 monitor cells.
    if dealerBig and dir == "north" and #cards == 2 then
        local bigSpacing = 21

        for i, card in ipairs(cards) do
            drawCard(
                mon,
                x + ((i - 1) * bigSpacing),
                y,
                card,
                hideSecond and i == 2,
                "north",
                0,
                0,
                2
            )
        end

        if not hideSecond then
            local valueText = "VAL " .. handDisplayValue(hand)
            drawPixelText(mon, x + (valDx or 0), y + 19 + (valDy or 0), valueText, dir, colors.white, colors.green, 1)
        end

        return
    end

    -- Card drawing:
    -- north/south stay normal.
    -- west/east cards are rotated again so they face the side players.
    -- Renderer padding now preserves the gray border on sideways cards.
    if dir == "west" then
        -- Station 1: deal toward player-right, which is upward on the monitor.
        local stepY = 8

        for i, card in ipairs(cards) do
            drawCard(
                mon,
                x,
                y - ((i - 1) * stepY),
                card,
                hideSecond and i == 2,
                "west",
                cardSubX,
                cardSubY
            )
        end

    elseif dir == "east" then
        -- Station 3: turn card 90 degrees clockwise so it faces the south-side player.
        local stepY = 8

        for i, card in ipairs(cards) do
            drawCard(
                mon,
                x,
                y + ((i - 1) * stepY),
                card,
                hideSecond and i == 2,
                "east",
                cardSubX,
                cardSubY
            )
        end

    else
        local colSpacing = 11
        local rowSpacing = (label == "DEALER") and 10 or 9

        for i, card in ipairs(cards) do
            local idx = i - 1
            local col = idx % 3
            local row = math.floor(idx / 3)

            local drawX
            local drawY

            if dir == "south" and label ~= "DEALER" then
                -- Station 4 / top seat:
                -- Deal player-facing order as right-bottom, middle-bottom, left-bottom,
                -- then right-top, middle-top, left-top.
                local flippedCol = 2 - col
                local flippedRow = 1 - row
                if flippedRow < 0 then flippedRow = 0 end

                drawX = x + (flippedCol * colSpacing)
                drawY = y + (flippedRow * rowSpacing)
            else
                drawX = x + (col * colSpacing)
                drawY = y + (row * rowSpacing)
            end

            drawCard(
                mon,
                drawX,
                drawY,
                card,
                hideSecond and i == 2,
                dir,
                cardSubX,
                cardSubY
            )
        end
    end

    if not hideSecond then
        local valueText = "VAL " .. handDisplayValue(hand)

        if dir == "west" then
            drawPixelText(mon, x + 15 + (valDx or 0), y + (valDy or 0), valueText, dir, colors.white, colors.green, 1)
        elseif dir == "east" then
            drawPixelText(mon, x + 15 + (valDx or 0), y + (valDy or 0), valueText, dir, colors.white, colors.green, 1)
        else
            drawPixelText(mon, x + (valDx or 0), y + 18 + (valDy or 0), valueText, dir, colors.white, colors.green, 1)
        end
    end
end

local function clearMain()
    mainMonitor.setBackgroundColor(colors.green)
    mainMonitor.clear()
end

local function drawInnerDealerBorder()
    local w, h = mainMonitor.getSize()

    local x1 = math.floor(w / 2) - 32
    local x2 = math.floor(w / 2) + 32
    local y1 = math.floor(h / 2) - 15
    local y2 = math.floor(h / 2) + 15

    local borderColor = colors.lime

    for x = x1, x2 do
        drawPixel(mainMonitor, x, y1, borderColor)
        drawPixel(mainMonitor, x, y2, borderColor)
    end

    for y = y1, y2 do
        drawPixel(mainMonitor, x1, y, borderColor)
        drawPixel(mainMonitor, x2, y, borderColor)
    end

    -- small corner accents
    drawPixel(mainMonitor, x1 + 1, y1 + 1, colors.yellow)
    drawPixel(mainMonitor, x2 - 1, y1 + 1, colors.yellow)
    drawPixel(mainMonitor, x1 + 1, y2 - 1, colors.yellow)
    drawPixel(mainMonitor, x2 - 1, y2 - 1, colors.yellow)
end


local function getMainLayout()
    local w, h = mainMonitor.getSize()

    local function applyTweak(side, base)
        local t = TABLE_TWEAKS[side] or {}

        base.labelDx = t.labelDx or 0
        base.labelDy = t.labelDy or 0
        base.labelAlign = t.labelAlign or "left"
        base.betDx = t.betDx or 0
        base.betDy = t.betDy or 0
        base.valDx = t.valDx or 0
        base.valDy = t.valDy or 0
        base.openDx = t.openDx or 0
        base.openDy = t.openDy or 0

        base.x = base.x + (t.cardDx or 0)
        base.y = base.y + (t.cardDy or 0)

        return base
    end

    -- Base positions. Fine tune with TABLE_TWEAKS at the top of the file.
    return {
        dealer = {
            x = math.floor(w / 2) - 19,
            y = math.floor(h / 2) - 9,
            dir = "north",
            labelDy = -1
        },

        north = applyTweak("north", {
            x = w - 27,
            y = math.floor(h / 2) - 2,
            dir = "west"
        }),

        east = applyTweak("east", {
            x = math.floor(w / 2) - 22,
            y = h - 19,
            dir = "north"
        }),

        south = applyTweak("south", {
            x = 17,
            y = math.floor(h / 2) - 18,
            dir = "east"
        }),

        west = applyTweak("west", {
            x = math.floor(w / 2) - 8,
            y = 16,
            dir = "south"
        })
    }
end


local function drawChipDecoration(mon, x, y, color, label)
    color = color or colors.red
    label = label or "$"

    -- Simple 5x5 chip made from monitor cells. Cards will overwrite this naturally
    -- whenever they draw over the same area.
    local rows = {
        " xxx ",
        "x...x",
        "x.c.x",
        "x...x",
        " xxx "
    }

    for yy, row in ipairs(rows) do
        for xx = 1, #row do
            local ch = row:sub(xx, xx)
            local px = x + xx - 1
            local py = y + yy - 1

            if ch == "x" then
                writeText(mon, px, py, " ", colors.white, colors.white)
            elseif ch == "." then
                writeText(mon, px, py, " ", color, color)
            elseif ch == "c" then
                writeText(mon, px, py, label, colors.white, color)
            end
        end
    end
end

local function drawCornerDecorations()
    local w, h = mainMonitor.getSize()

    -- Corner chip stacks / casino accents. Keep these outside the dealer box.
    drawChipDecoration(mainMonitor, 3, 4, colors.red, "$")
    drawChipDecoration(mainMonitor, w - 8, 4, colors.lime, "$")
    drawChipDecoration(mainMonitor, 3, h - 8, colors.orange, "$")
    drawChipDecoration(mainMonitor, w - 8, h - 8, colors.blue, "$")

    -- Small corner sparkle marks.
    drawPixelText(mainMonitor, 10, 5, "+", "north", colors.yellow, colors.green, 1)
    drawPixelText(mainMonitor, w - 12, 5, "+", "north", colors.yellow, colors.green, 1)
    drawPixelText(mainMonitor, 10, h - 5, "+", "north", colors.yellow, colors.green, 1)
    drawPixelText(mainMonitor, w - 12, h - 5, "+", "north", colors.yellow, colors.green, 1)
end


local function drawTableStationLabel(station, p, showName)
    local anchorX = p.x + (p.labelDx or 0)
    local anchorY = p.y - 3 + (p.labelDy or 0)

    -- Chair 1 was jumping because the whole "CHAIR 1 name" string was being right-aligned.
    -- Keep "CHAIR 1" fixed, then draw the player name as its own right-aligned vertical string
    -- above it, extending in monitor -Y.
    if station.id == 1 then
        drawPixelText(mainMonitor, anchorX, anchorY, station.label, p.dir, colors.yellow, colors.green, 1)

        if showName then
            local nameText = tostring(showName)
            if #nameText > 13 then
                nameText = nameText:sub(1, 13)
            end

            drawPixelTextAligned(
                mainMonitor,
                anchorX,
                anchorY + 5,
                nameText,
                p.dir,
                colors.yellow,
                colors.green,
                1,
                "right"
            )
        end

        return
    end

    local tableName = station.label
    if showName then
        tableName = station.label .. " " .. tostring(showName)
    end

    if #tableName > 18 then
        tableName = tableName:sub(1, 18)
    end

    drawPixelTextAligned(
        mainMonitor,
        anchorX,
        anchorY,
        tableName,
        p.dir,
        colors.yellow,
        colors.green,
        1,
        p.labelAlign or "left"
    )
end


local function drawMainTable()
    clearMain()

    local layout = getMainLayout()

    drawInnerDealerBorder()
    drawCornerDecorations()

    -- Table header intentionally hidden.

    if dealerHand and #safeCards(dealerHand) > 0 then
        drawHand(mainMonitor, dealerHand, layout.dealer.x, layout.dealer.y, layout.dealer.dir, "DEALER", not dealerRevealed, 0, 0, layout.dealer.labelDy or 0, 0, 0, 0, #safeCards(dealerHand) == 2)
    else
        drawPixelText(mainMonitor, layout.dealer.x, layout.dealer.y + (layout.dealer.labelDy or 0), "DEALER", layout.dealer.dir, colors.white, colors.green, 1)
    end

    for _, station in ipairs(STATIONS) do
        local p = layout[station.side]
        local showName = station.lockedPlayer or station.player

        drawTableStationLabel(station, p, showName)

        if station.joined and station.hands and #station.hands > 0 then
            local hand = station.hands[station.currentHand or 1]

            local label = "BET" .. tostring(hand and hand.bet or 0)

            if #station.hands > 1 then
                label = label .. " H" .. tostring(station.currentHand or 1) .. "/" .. tostring(#station.hands)
            end

            drawHand(mainMonitor, hand, p.x, p.y, p.dir, label, false, 0, 0, p.betDy or 0, p.betDx or 0, p.valDx or 0, p.valDy or 0)
        end
    end
end

