local function listAccountNames()
    local names = {}

    if not fs.exists("/accounts") then
        return names
    end

    for _, file in ipairs(fs.list("/accounts")) do
        if type(file) == "string" and file:match("%.txt$") then
            local name = file:gsub("%.txt$", "")

            if name ~= "logs" then
                table.insert(names, name)
            end
        end
    end

    table.sort(names)
    return names
end

local function findMatchingAccount(partial)
    partial = cleanPlayerName(partial):lower()

    if partial == "" then
        return nil, "No player name entered."
    end

    local accounts = listAccountNames()
    local exactMatches = {}
    local prefixMatches = {}
    local containsMatches = {}

    for _, account in ipairs(accounts) do
        local lower = account:lower()

        if lower == partial then
            table.insert(exactMatches, account)
        elseif lower:sub(1, #partial) == partial then
            table.insert(prefixMatches, account)
        elseif lower:find(partial, 1, true) then
            table.insert(containsMatches, account)
        end
    end

    if #exactMatches == 1 then
        return exactMatches[1]
    elseif #prefixMatches == 1 then
        return prefixMatches[1]
    elseif #containsMatches == 1 then
        return containsMatches[1]
    end

    local combined = {}

    for _, v in ipairs(exactMatches) do table.insert(combined, v) end
    for _, v in ipairs(prefixMatches) do table.insert(combined, v) end
    for _, v in ipairs(containsMatches) do table.insert(combined, v) end

    if #combined == 0 then
        return nil, "No account matched: " .. partial
    end

    local preview = {}
    for i = 1, math.min(5, #combined) do
        table.insert(preview, combined[i])
    end

    return nil, "Ambiguous name: " .. table.concat(preview, ", ")
end

local function parseAdminAdjustCommand(message)
    message = cleanChatText(message)

    -- Quoted name:
    -- + "rado" 5000
    local sign, quotedName, amount = message:match("^%s*([+%-])%s*\"([^\"]+)\"%s*(%d+)%s*$")

    if sign and quotedName and amount then
        amount = tonumber(amount)

        if sign == "-" then
            amount = -amount
        end

        return quotedName, amount
    end

    -- Unquoted name:
    -- + rado 5000
    local sign2, name2, amount2 = message:match("^%s*([+%-])%s*(%S+)%s*(%d+)%s*$")

    if sign2 and name2 and amount2 then
        amount2 = tonumber(amount2)

        if sign2 == "-" then
            amount2 = -amount2
        end

        return name2, amount2
    end

    return nil, nil, "Bad format. Use: + \"name\" 5000 or - \"name\" 5000"
end

local function adminAdjustTellPrivate(adminName, text)
    text = cleanChatText(text)

    if #text > 230 then
        text = text:sub(1, 230)
    end

    local safeAdmin = cleanPlayerName(adminName)
    local adminChat = adminChats[safeAdmin]

    -- In your Plethora setup, tell() is one argument and sends privately
    -- to the bound player. So each admin must have their own bound manipulator.
    if adminChat and adminChat.tell then
        local ok, err = pcall(function()
            adminChat.tell(text)
        end)

        if not ok then
            print("chat.tell failed for admin adjustment:")
            print(err)
            print("Admin was:", safeAdmin)
            print("Private message was:", text)
            print("ADMIN ADJUST OUT:", text)
        end
    else
        print("ADMIN ADJUST OUT for " .. tostring(safeAdmin) .. ":", text)
    end

    sleep(0.25)
end

local function handleAdminAdjustCommand(rawPlayer, message)
    local admin = cleanPlayerName(rawPlayer)

    if not ADMIN_PLAYERS[admin] then
        print("Rejected balance adjustment from non-admin:", tostring(rawPlayer))
        print("Message:", tostring(message))
        return
    end

    local partialName, delta, parseErr = parseAdminAdjustCommand(message)

    if not partialName then
        adminAdjustTellPrivate(admin, "Account edit failed: " .. tostring(parseErr))
        return
    end

    local target, findErr = findMatchingAccount(partialName)

    if not target then
        adminAdjustTellPrivate(admin, "Account edit failed: " .. tostring(findErr))
        return
    end

    local protectedAdmins = PROTECTED_ACCOUNT_ADJUSTMENTS[target]
    if protectedAdmins and not protectedAdmins[admin] then
        adminAdjustTellPrivate(admin, "naughty naughty")
        adminAdjustTellPrivate("HughJaynis1234", "Blocked balance edit: " .. tostring(admin) .. " tried to change " .. tostring(target))
        print("Blocked protected account edit.")
        print("Admin:", tostring(admin))
        print("Target:", tostring(target))
        print("Message:", tostring(message))
        return
    end

    delta = tonumber(delta) or 0

    if delta == 0 then
        adminAdjustTellPrivate(admin, "Account edit failed: amount was 0.")
        return
    end

    local oldBalance = getBalance(target)
    local newBalance = math.max(0, oldBalance + delta)
    local actualDelta = newBalance - oldBalance

    setBalance(target, newBalance)

    logTransaction(
        target,
        "ADMIN CHAT ADJUST by " .. admin,
        actualDelta
    )

    local deltaText = (actualDelta >= 0 and "+" or "") .. tostring(actualDelta)

    adminAdjustTellPrivate(admin, "Account updated: " .. target .. " " .. deltaText .. " -> $" .. newBalance)

    print("Admin balance adjustment complete.")
    print("Admin:", admin)
    print("Target:", target)
    print("Old:", oldBalance)
    print("Delta:", actualDelta)
    print("New:", newBalance)
end

local function isHiddenFromCasinoStats(player)
    local clean = cleanPlayerName(player)

    if HIDE_FROM_CASINO_STATS_CHAT[clean] then
        return true
