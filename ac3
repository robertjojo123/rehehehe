-- =========================================================

local function rednetListener()
    print("Account Computer Rednet Listener starting...")
    print("Local gambling win stats file:", WIN_STATS_FILE)
    print("Roulette stat rule: total payout - total spin wager.")
    print("Losses do not subtract from leaderboard.")
    printTopGambleStats(5)

    while true do
        heartbeat("rednet")
        local sender, msg, protocol = rednet.receive(nil, REDNET_IDLE_TIMEOUT_SECONDS)

        print("Rednet received from:", sender, "via protocol:", protocol)
        print("Message:", textutils.serialize(msg))
      
        if protocol == "casino" and type(msg) == "table" then
            if msg.action == "get_Players" then
                print("Sending player list...")

                local fileList = fs.list("/accounts")
                local accountList = {}

                for _, name in ipairs(fileList) do
                    if type(name) == "string" and name:match("%.txt$") and not name:match("logs") then
                        table.insert(accountList, name:gsub("%.txt$", ""))
                    end
                end

                table.sort(accountList)
                rednet.send(sender, {action = "players_list", players = accountList}, "casino")

            elseif msg.action == "get_balance" then
                rednet.send(sender, {player = msg.player, balance = getBalance(msg.player)}, "casino")

            elseif msg.action == "transfer" then
                local old = getBalance(msg.player)
                local new = math.max(0, old + msg.delta)

                setBalance(msg.player, new)
                logTransaction(msg.player, msg.note or "Transfer", msg.delta)

                handleCasinoTransferForStats(msg.player, msg.note)

                if msg.player == activePlayer then
                    balance = new
                    markUiDirty()
                end

                rednet.send(sender, {player = msg.player, balance = new}, "casino")

            elseif msg.action == "gamble_win_stat" then
                handleDirectGambleWinStat(msg)

            elseif msg.action == "list_accounts" then
                local fileList = fs.list("/accounts")
                local accountList = {}

                for _, name in ipairs(fileList) do
                    if type(name) == "string" and name:match("%.txt$") and not name:match("logs") then
                        table.insert(accountList, name:gsub("%.txt$", ""))
                    end
                end

                rednet.send(sender, {accounts = accountList}, "casino")

            elseif msg.action == "get_gamble_leaderboard" then
                local month = msg.month
                local limit = tonumber(msg.limit) or 10
                local list = getSortedWinLeaderboard(month)

                local trimmed = {}

                for i = 1, math.min(limit, #list) do
                    table.insert(trimmed, list[i])
                end

                rednet.send(sender, {
                    action = "gamble_leaderboard",
                    month = month or "all_time",
                    leaders = trimmed
                }, "casino")
            end
        end

        sleep(0)
    end
end


-- =========================================================
-- === Watchdog / Safe Task Runner
-- =========================================================

local function watchdogLoop()
    sleep(STARTUP_STEP_DELAY * 5)

    while true do
        if WATCHDOG_ENABLED then
            local now = os.clock()

            for _, name in ipairs({"radar", "display", "touch", "rednet"}) do
                local last = taskHeartbeat[name]

                if last and now - last > WATCHDOG_SECONDS then
                    print("[WATCHDOG] " .. name .. " stalled for " .. string.format("%.1f", now - last) .. "s. Rebooting.")
                    sleep(0.5)
                    os.reboot()
                end
            end
        end

        sleep(WATCHDOG_CHECK_SECONDS)
    end
end

local function runWatchedTask(name, fn, delay)
    return function()
        if delay and delay > 0 then sleep(delay) end
        heartbeat(name)

        while true do
            local ok, err = pcall(fn)

            if not ok then
                print("[TASK ERROR] " .. name .. ": " .. tostring(err))
                sleep(0.75)
                os.reboot()
            end

            print("[TASK RETURNED] " .. name .. " restarting.")
            sleep(1)
        end
    end
end

