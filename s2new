-- startup protected runtime wrapper
-- Copy this whole file to /startup.
-- Native program starts automatically on reboot.
-- Shell/edit access is only exposed after the password if the program stops,
-- crashes, exits, or Ctrl+T is pressed.

local PASSWORD_HASH = "161274240"
local SALT = "casino_lock_v1"
local LOCK_SIGNAL = "__CASINO_STARTUP_LOCK_REQUEST__"

pcall(function()
    settings.set("shell.allow_disk_startup", false)
    settings.save(".settings")
end)

local nativePullEventRaw = os.pullEventRaw
local unpackFn = table.unpack or unpack

local function hashPassword(s)
    s = tostring(SALT) .. tostring(s or "")
    local h = 5381

    for i = 1, #s do
        h = ((h * 33) + s:byte(i)) % 2147483647
    end

    return tostring(h)
end

local function safeColor(color)
    if term.isColor and not term.isColor() then return end
    if term.setTextColor and color then term.setTextColor(color) end
end

local function clearScreen()
    if term.setBackgroundColor then term.setBackgroundColor(colors.black) end
    safeColor(colors.white)
    term.clear()
    term.setCursorPos(1, 1)
end

local function centerWrite(y, text, color)
    local w, h = term.getSize()
    safeColor(color or colors.white)
    term.setCursorPos(math.max(1, math.floor((w - #tostring(text)) / 2) + 1), y)
    term.write(tostring(text))
    safeColor(colors.white)
end

local function drawPasswordScreen(message, messageColor)
    clearScreen()
    centerWrite(3, "CASINO COMPUTER PROTECTED", colors.red)
    centerWrite(5, "Password required for shell access.", colors.yellow)

    if message and message ~= "" then
        centerWrite(7, tostring(message), messageColor or colors.white)
    end

    safeColor(colors.white)
    term.setCursorPos(1, 10)
    term.write("Password: ")
end

local function readPasswordMasked()
    local password = ""

    while true do
        local event, a = nativePullEventRaw()

        if event == "char" then
            password = password .. a
            term.write("*")

        elseif event == "paste" then
            -- Paste blocked intentionally.

        elseif event == "key" then
            if a == keys.enter then
                print("")
                return password

            elseif a == keys.backspace then
                if #password > 0 then
                    password = password:sub(1, -2)
                    local x, y = term.getCursorPos()
                    if x > 1 then
                        term.setCursorPos(x - 1, y)
                        term.write(" ")
                        term.setCursorPos(x - 1, y)
                    end
                end
            end

        elseif event == "terminate" then
            drawPasswordScreen("Terminate blocked.", colors.red)
        end
    end
end

local function passwordGate(reason)
    local attempts = 0

    while true do
        drawPasswordScreen(reason or "")
        local input = readPasswordMasked()

        if hashPassword(input) == PASSWORD_HASH then
            clearScreen()
            centerWrite(6, "Access granted. Shell unlocked.", colors.lime)
            sleep(0.5)
            clearScreen()
            return
        end

        attempts = attempts + 1
        drawPasswordScreen("Access denied. Attempts: " .. tostring(attempts), colors.red)
        sleep(1.5)
    end
end

local function installTerminateLock()
    os.pullEvent = function(filter)
        local ev = {nativePullEventRaw(filter)}
        if ev[1] == "terminate" then
            error(LOCK_SIGNAL, 0)
        end
        return unpackFn(ev)
    end
end

local function protectedNativeProgram()
    -- monitor_slots_channel_1.lua
    -- Slot Game Computer Script
    --
    -- Added:
    --   - Idle reel animation at 1 pixel per frame
    --   - Active spin animation at 2 pixels per frame
    --   - After payout/payment finishes, reels return to idle spinning

    math.randomseed(os.epoch and os.epoch("utc") or os.time())

    -- =========================================================
    -- === Peripherals
    -- =========================================================

    local modem = peripheral.wrap("bottom")
    local speaker = peripheral.find("speaker")

    if not modem then error("No modem on bottom") end
    modem.open(1)

    local leftMonitor = peripheral.wrap("monitor_960")
    local middleMonitor = peripheral.wrap("monitor_961")
    local rightMonitor = peripheral.wrap("monitor_962")

    if not leftMonitor then error("Missing left reel monitor_960") end
    if not middleMonitor then error("Missing middle reel monitor_961") end
    if not rightMonitor then error("Missing right reel monitor_962") end

    local REEL_MONITORS = {
        left = leftMonitor,
        middle = middleMonitor,
        right = rightMonitor
    }

    -- =========================================================
    -- === Config
    -- =========================================================

    local STATS_FILE = "stats.txt"

    -- Overall spin duration.
    -- Left stops at 4s, middle at 8s, right at 12s.
    local PLAY_TIME = 12

    local LEFT_REEL_TIME = PLAY_TIME / 3
    local MIDDLE_REEL_TIME = (PLAY_TIME * 2) / 3
    local RIGHT_REEL_TIME = PLAY_TIME

    local FINAL_RESULT_HOLD_TIME = 2.5
    local POST_ROUND_DELAY = 4.5

    -- Visual reel movement speed.
    local FRAME_DELAY = 0.05
    local FINAL_APPROACH_DELAY = 0.05

    -- Reel movement:
    -- Idle = 1 pixel per frame
    -- Active spin = 2 pixels per frame
    local IDLE_REEL_STEP_PIXELS = 1
    local ACTIVE_REEL_STEP_PIXELS = 2

    -- Custom palette slots.
    local GOLD_BORDER_COLOR = colors.orange  -- #806f3e
    local NICKEL_COLOR = colors.yellow       -- #ffd45a

    -- =========================================================
    -- === Odds Tuning
    -- =========================================================

    local SECOND_REEL_MATCH_CHANCE_PER_1000 = 800
    local THIRD_REEL_MATCH_CHANCE_PER_1000 = 386

    -- Internal names.
    -- RUBY is now drawn as emerald/lime green, but still pays 2x.
    local RUBY = "ruby"
    local NICKEL = "nickel"
    local SAPPHIRE = "sapphire"

    local SYMBOL_SEQUENCE = {RUBY, NICKEL, SAPPHIRE}

    local SYMBOL_LABEL = {
        [SAPPHIRE] = "SAPPHIRE",
        [NICKEL] = "NICKEL",
        [RUBY] = "EMERALD"
    }

    local SYMBOL_SHORT = {
        [SAPPHIRE] = "S",
        [NICKEL] = "N",
        [RUBY] = "E"
    }

    -- =========================================================
    -- === Monitor Setup
    -- =========================================================

    for _, mon in pairs(REEL_MONITORS) do
        mon.setTextScale(0.5)

        if mon.setPaletteColor then
            -- Dark gold border: #806f3e
            mon.setPaletteColor(GOLD_BORDER_COLOR, 0x806F3E)

            -- Vibrant soft coin/nickel gold: #ffd45a
            mon.setPaletteColor(NICKEL_COLOR, 0xFFD45A)

            -- Vibrant sapphire colors
            mon.setPaletteColor(colors.cyan, 0x00E5FF)
            mon.setPaletteColor(colors.lightBlue, 0x66F2FF)
            mon.setPaletteColor(colors.blue, 0x006BFF)

            -- Emerald/lime colors for the old Ruby symbol.
            -- Still uses RUBY internally and still pays 2x.
            mon.setPaletteColor(colors.red, 0x00FF55)
            mon.setPaletteColor(colors.pink, 0x7DFFA3)

            -- Emerald shadow tone
            mon.setPaletteColor(colors.brown, 0x007A2B)
        end

        mon.setBackgroundColor(colors.black)
        mon.setTextColor(colors.white)
        mon.clear()
    end

    -- =========================================================
    -- === Filled Pixel Symbol Art
    -- =========================================================

    local PIXEL_ART = {
        [SAPPHIRE] = {
            "0000110000",
            "0001111000",
            "0011111100",
            "0111111110",
            "1111111111",
            "0111111110",
            "0011111100",
            "0001111000",
            "0000110000"
        },

        [NICKEL] = {
            "0011111100",
            "0111111110",
            "1111111111",
            "1111001111",
            "1111001111",
            "1111001111",
            "1111111111",
            "0111111110",
            "0011111100"
        },

        -- Visually emerald now, but uses RUBY internal symbol for the 2x payout logic.
        [RUBY] = {
            "0001111000",
            "0011111100",
            "0111111110",
            "1111111111",
            "1111111111",
            "0111111110",
            "0011111100",
            "0011111100",
            "0001111000"
        }
    }

    local SYMBOL_BG_COLOR = {
        [SAPPHIRE] = colors.cyan,
        [NICKEL] = NICKEL_COLOR,
        [RUBY] = colors.red
    }

    local SYMBOL_HIGHLIGHT_COLOR = {
        [SAPPHIRE] = colors.white,
        [NICKEL] = colors.white,
        [RUBY] = colors.pink
    }

    local SYMBOL_SHADOW_COLOR = {
        [SAPPHIRE] = colors.blue,
        [NICKEL] = colors.orange,
        [RUBY] = colors.brown
    }

    -- =========================================================
    -- === Persistent Stats
    -- =========================================================

    local function loadStats()
        if fs.exists(STATS_FILE) then
            local f = fs.open(STATS_FILE, "r")
            local data = textutils.unserialize(f.readAll())
            f.close()
            return data or {}
        end
        return {}
    end

    local function saveStats(stats)
        local f = fs.open(STATS_FILE, "w")
        f.write(textutils.serialize(stats))
        f.close()
    end

    local stats = loadStats()
    stats.totalPlays = stats.totalPlays or 0
    stats.wins2x = stats.wins2x or 0
    stats.wins5x = stats.wins5x or 0
    stats.payoutBalance = stats.payoutBalance or 0

    -- =========================================================
    -- === Bank Messaging: channel 1
    -- =========================================================

    local function sendMessage(msg)
        modem.transmit(1, 1, msg)
    end

    local function receiveMessage(timeout)
        local timer = os.startTimer(timeout or 2)

        while true do
            local event, side, ch, _, msg = os.pullEvent()

            if event == "modem_message" and ch == 1 then
                return msg
            elseif event == "timer" and side == timer then
                return nil
            end
        end
    end

    -- =========================================================
    -- === Sounds
    -- =========================================================

    local function playNote(instrument, volume, pitch)
        if speaker then
            pcall(function()
                speaker.playNote(instrument, volume or 1, pitch or 12)
            end)
        end
    end

    local function playAcceptSound()
        playNote("pling", 1, 7)
    end

    local function playSpinTick()
        playNote("hat", 0.25, 12)
    end

    local function playReelStopSound()
        playNote("pling", 1, 10)
        sleep(0.08)
        playNote("pling", 1, 14)
    end

    local function playDenialSound()
        playNote("bass", 1, 3)
    end

    local function playDenialSequence()
        for i = 1, 3 do
            playDenialSound()
            sleep(0.2)
        end
    end

    local function playWinSequence(count)
        for i = 1, count do
            playAcceptSound()
            sleep(0.18)
        end
    end

    local function playStartSpinSound()
        playNote("pling", 1, 5)
        sleep(0.08)
        playNote("pling", 1, 8)
        sleep(0.08)
        playNote("pling", 1, 12)
    end

    -- =========================================================
    -- === Bank Item Request
    -- =========================================================

    local function waitForBankItem()
        while redstone.getInput("top") do
            sendMessage("request_item")

            local reply = receiveMessage(2)

            if reply == "item_transferred" then
                playAcceptSound()
                return true
            elseif reply == "no_item" then
                playDenialSequence()
            end

            sleep(0.1)
        end

        return false
    end

    -- =========================================================
    -- === Slot Logic
    -- =========================================================

    local function randomSymbol()
        local roll = math.random(1, 3)
        if roll == 1 then return RUBY end
        if roll == 2 then return NICKEL end
        return SAPPHIRE
    end

    local function randomNonMatchingSymbol(symbol)
        local alt
        repeat
            alt = randomSymbol()
        until alt ~= symbol
        return alt
    end

    local function biasedLeftSymbol()
        -- First reel weighting:
        -- 75% chance for 2x symbols: Emerald/Nickel
        -- 25% chance for 5x symbol: Sapphire
        if math.random(100) <= 75 then
            if math.random(2) == 1 then
                return RUBY
            else
                return NICKEL
            end
        else
            return SAPPHIRE
        end
    end

    local function decideMiddle(left)
        -- Middle matches left 80% of the time.
        if math.random(1000) <= SECOND_REEL_MATCH_CHANCE_PER_1000 then
            return left
        end

        return randomNonMatchingSymbol(left)
    end

    local function decideRight(left, middle)
        if left == middle then
            if math.random(1000) <= THIRD_REEL_MATCH_CHANCE_PER_1000 then
                return left
            end

            return randomNonMatchingSymbol(left)
        end

        return randomSymbol()
    end

    local function getPayout(left, middle, right)
        if left == middle and middle == right then
            if right == SAPPHIRE then
                return 5
            elseif right == NICKEL or right == RUBY then
                return 2
            end
        end

        return 0
    end

    -- =========================================================
    -- === Monitor Reel Drawing
    -- =========================================================

    local function prevIndex(i, max)
        i = i - 1
        if i < 1 then i = max end
        return i
    end

    local function offsetIndex(baseIndex, delta)
        local count = #SYMBOL_SEQUENCE
        local i = ((baseIndex - 1 + delta) % count) + 1
        return i
    end

    local function getSymbolIndex(symbol)
        for i, s in ipairs(SYMBOL_SEQUENCE) do
            if s == symbol then return i end
        end
        return 1
    end

    local function clearMonitor(mon)
        mon.setBackgroundColor(colors.black)
        mon.setTextColor(colors.white)
        mon.clear()
    end

    local function drawPixel(mon, x, y, color)
        local w, h = mon.getSize()

        if x < 1 or x > w or y < 1 or y > h then
            return
        end

        mon.setCursorPos(x, y)
        mon.setBackgroundColor(color)
        mon.write(" ")
    end

    local function drawPayline(mon)
        local w, h = mon.getSize()
        local mid = math.floor(h / 2) + 1

        local top = mid - 5
        local bottom = mid + 5

        if top < 1 then top = 1 end
        if bottom > h then bottom = h end

        mon.setBackgroundColor(GOLD_BORDER_COLOR)
        mon.setTextColor(GOLD_BORDER_COLOR)

        mon.setCursorPos(1, top)
        mon.write(string.rep(" ", w))

        mon.setCursorPos(1, bottom)
        mon.write(string.rep(" ", w))
    end

    local function drawSymbol(mon, symbol, topY)
        local art = PIXEL_ART[symbol]
        if not art then return end

        local w, h = mon.getSize()
        local symbolColor = SYMBOL_BG_COLOR[symbol] or colors.white
        local highlightColor = SYMBOL_HIGHLIGHT_COLOR[symbol] or symbolColor
        local shadowColor = SYMBOL_SHADOW_COLOR[symbol] or symbolColor

        local artW = #art[1]
        local startX = math.max(1, math.floor((w - artW) / 2) + 1)

        for rowIndex, row in ipairs(art) do
            local y = topY + rowIndex - 1

            if y >= 1 and y <= h then
                for col = 1, #row do
                    local ch = row:sub(col, col)

                    if ch == "1" then
                        local color = symbolColor

                        if rowIndex <= 3 and col <= math.ceil(artW / 2) then
                            color = highlightColor
                        end

                        if rowIndex >= #art - 2 and col >= math.floor(artW / 2) then
                            color = shadowColor
                        end

                        drawPixel(mon, startX + col - 1, y, color)
                    end
                end
            end
        end
    end

    local function drawReelFrame(mon, centerIndex, offset)
        clearMonitor(mon)

        local w, h = mon.getSize()
        local mid = math.floor(h / 2) + 1

        local symbolH = 9
        local spacing = 11
        local centerTop = mid - math.floor(symbolH / 2)

        local minSlot = math.floor((1 - (centerTop + offset)) / spacing) - 2
        local maxSlot = math.ceil((h - (centerTop + offset)) / spacing) + 2

        for slot = minSlot, maxSlot do
            local symbolIndex = offsetIndex(centerIndex, slot)
            local symbol = SYMBOL_SEQUENCE[symbolIndex]
            local topY = centerTop + (slot * spacing) + offset

            drawSymbol(mon, symbol, topY)
        end

        drawPayline(mon)
    end

    local function drawFinalReel(mon, finalSymbol)
        clearMonitor(mon)

        local w, h = mon.getSize()
        local mid = math.floor(h / 2) + 1

        local symbolH = 9
        local spacing = 11
        local centerTop = mid - math.floor(symbolH / 2)

        local finalIndex = getSymbolIndex(finalSymbol)

        local minSlot = math.floor((1 - centerTop) / spacing) - 2
        local maxSlot = math.ceil((h - centerTop) / spacing) + 2

        for slot = minSlot, maxSlot do
            local symbolIndex = offsetIndex(finalIndex, slot)
            local symbol = SYMBOL_SEQUENCE[symbolIndex]
            local topY = centerTop + (slot * spacing)

            drawSymbol(mon, symbol, topY)
        end

        drawPayline(mon)
    end

    local function animateOneDrop(mon, centerIndex, frameDelay, stepPixels, playTick)
        local spacing = 11
        stepPixels = stepPixels or ACTIVE_REEL_STEP_PIXELS

        for offset = 0, spacing - 1, stepPixels do
            drawReelFrame(mon, centerIndex, offset)

            if playTick then
                playSpinTick()
            end

            sleep(frameDelay or FRAME_DELAY)
        end

        return prevIndex(centerIndex, #SYMBOL_SEQUENCE)
    end

    local function approachFinal(mon, currentIndex, finalSymbol)
        local finalIndex = getSymbolIndex(finalSymbol)

        if currentIndex == finalIndex then
            currentIndex = animateOneDrop(mon, currentIndex, FINAL_APPROACH_DELAY, ACTIVE_REEL_STEP_PIXELS, true)
            currentIndex = animateOneDrop(mon, currentIndex, FINAL_APPROACH_DELAY, ACTIVE_REEL_STEP_PIXELS, true)
        end

        while currentIndex ~= finalIndex do
            currentIndex = animateOneDrop(mon, currentIndex, FINAL_APPROACH_DELAY, ACTIVE_REEL_STEP_PIXELS, true)
        end

        drawFinalReel(mon, finalSymbol)
        playReelStopSound()

        return currentIndex
    end

    local function spinReel(mon, reelName, duration, finalSymbol)
        local currentIndex = math.random(1, #SYMBOL_SEQUENCE)
        local startTime = os.clock()

        print(reelName .. " reel spinning...")

        while os.clock() - startTime < duration do
            currentIndex = animateOneDrop(mon, currentIndex, FRAME_DELAY, ACTIVE_REEL_STEP_PIXELS, true)
        end

        currentIndex = approachFinal(mon, currentIndex, finalSymbol)

        print(reelName .. " reel stopped on " .. SYMBOL_LABEL[finalSymbol])

        return currentIndex
    end

    -- =========================================================
    -- === Idle Reel Animation
    -- =========================================================

    local IDLE_SPACING = 11

    local idleReels = {
        left = {
            monitor = leftMonitor,
            centerIndex = getSymbolIndex(RUBY),
            offset = 0
        },
        middle = {
            monitor = middleMonitor,
            centerIndex = getSymbolIndex(NICKEL),
            offset = 0
        },
        right = {
            monitor = rightMonitor,
            centerIndex = getSymbolIndex(SAPPHIRE),
            offset = 0
        }
    }

    local function setIdleReelsTo(leftSymbol, middleSymbol, rightSymbol)
        idleReels.left.centerIndex = getSymbolIndex(leftSymbol)
        idleReels.left.offset = 0

        idleReels.middle.centerIndex = getSymbolIndex(middleSymbol)
        idleReels.middle.offset = 0

        idleReels.right.centerIndex = getSymbolIndex(rightSymbol)
        idleReels.right.offset = 0

        drawReelFrame(leftMonitor, idleReels.left.centerIndex, idleReels.left.offset)
        drawReelFrame(middleMonitor, idleReels.middle.centerIndex, idleReels.middle.offset)
        drawReelFrame(rightMonitor, idleReels.right.centerIndex, idleReels.right.offset)
    end

    local function updateIdleReel(reel)
        reel.offset = reel.offset + IDLE_REEL_STEP_PIXELS

        while reel.offset >= IDLE_SPACING do
            reel.offset = reel.offset - IDLE_SPACING
            reel.centerIndex = prevIndex(reel.centerIndex, #SYMBOL_SEQUENCE)
        end

        drawReelFrame(reel.monitor, reel.centerIndex, reel.offset)
    end

    local function updateIdleReelsOnce()
        updateIdleReel(idleReels.left)
        updateIdleReel(idleReels.middle)
        updateIdleReel(idleReels.right)
        sleep(FRAME_DELAY)
    end

    local function idleFor(seconds)
        local startTime = os.clock()

        while os.clock() - startTime < seconds do
            updateIdleReelsOnce()
        end
    end

    -- =========================================================
    -- === Main Loop
    -- =========================================================

    setIdleReelsTo(RUBY, NICKEL, SAPPHIRE)

    print("Monitor slot machine ready.")
    print("Reel monitors:")
    print("LEFT   = monitor_960")
    print("MIDDLE = monitor_961")
    print("RIGHT  = monitor_962")
    print("Channel: 1")
    print("Sapphire = vibrant cyan diamond = 5x")
    print("Nickel   = vibrant gold coin = 2x")
    print("Emerald  = vibrant lime gem = 2x")
    print("Gold border #806f3e uses color slot:", GOLD_BORDER_COLOR)
    print("Nickel #ffd45a uses color slot:", NICKEL_COLOR)
    print("Speaker:", speaker and "found" or "NOT FOUND")
    print("Second reel match chance:", SECOND_REEL_MATCH_CHANCE_PER_1000 .. "/1000")
    print("Third reel match chance:", THIRD_REEL_MATCH_CHANCE_PER_1000 .. "/1000")
    print("Target expected payout/RTP: about 42%")
    print("Spin time:", PLAY_TIME)
    print("Frame delay:", FRAME_DELAY)
    print("Idle reel step pixels:", IDLE_REEL_STEP_PIXELS)
    print("Active reel step pixels:", ACTIVE_REEL_STEP_PIXELS)
    print("")

    while true do
        if redstone.getInput("top") then
            if waitForBankItem() then
                playStartSpinSound()

                local left = biasedLeftSymbol()
                local middle = decideMiddle(left)
                local right = decideRight(left, middle)

                print("Target result:")
                print("L:" .. SYMBOL_LABEL[left] .. " M:" .. SYMBOL_LABEL[middle] .. " R:" .. SYMBOL_LABEL[right])

                parallel.waitForAll(
                    function()
                        spinReel(leftMonitor, "LEFT", LEFT_REEL_TIME, left)
                    end,
                    function()
                        spinReel(middleMonitor, "MIDDLE", MIDDLE_REEL_TIME, middle)
                    end,
                    function()
                        spinReel(rightMonitor, "RIGHT", RIGHT_REEL_TIME, right)
                    end
                )

                stats.totalPlays = stats.totalPlays + 1
                stats.payoutBalance = stats.payoutBalance - 1

                local payout = getPayout(left, middle, right)

                print(
                    "Final: L:" .. SYMBOL_SHORT[left]
                    .. " M:" .. SYMBOL_SHORT[middle]
                    .. " R:" .. SYMBOL_SHORT[right]
                )

                sleep(FINAL_RESULT_HOLD_TIME)

                if payout == 5 then
                    stats.wins5x = stats.wins5x + 1
                    stats.payoutBalance = stats.payoutBalance + 5

                    sendMessage({type = "payout", amount = 5})
                    playWinSequence(5)
                    print(">>> SAPPHIRE JACKPOT 5x WIN!")

                elseif payout == 2 then
                    stats.wins2x = stats.wins2x + 1
                    stats.payoutBalance = stats.payoutBalance + 2

                    sendMessage({type = "payout", amount = 2})
                    playWinSequence(2)
                    print(">>> 2x WIN!")

                else
                    playDenialSequence()
                    print("No win.")
                end

                saveStats(stats)

                print(string.format(
                    "Plays: %d | 2x Wins: %d | 5x Wins: %d | Payout: %+d",
                    stats.totalPlays,
                    stats.wins2x,
                    stats.wins5x,
                    stats.payoutBalance
                ))

                print("Returning to idle reel movement...")

                setIdleReelsTo(left, middle, right)
                idleFor(POST_ROUND_DELAY)
            end
        else
            updateIdleReelsOnce()
        end
    end
end

installTerminateLock()

local ok, err = pcall(protectedNativeProgram)

-- Restore default behavior after password unlock, so maintenance shell feels normal.
os.pullEvent = nativePullEventRaw

if not ok then
    if tostring(err) == LOCK_SIGNAL then
        passwordGate("Program terminated. Shell locked.")
    else
        clearScreen()
        safeColor(colors.red)
        print("Protected program stopped/crashed:")
        safeColor(colors.white)
        print(tostring(err))
        print("")
        print("Password required for shell access.")
        sleep(2)
        passwordGate("Program crashed. Shell locked.")
    end
else
    passwordGate("Program exited. Shell locked.")
end
