local BASE = "https://cc-yt-bridge.onrender.com"

local function urlEncode(s)
    return tostring(s):gsub("([^%w%-_%.~])", function(c)
        return string.format("%%%02X", string.byte(c))
    end)
end

local function get(url)
    local res, err = http.get(url)
    if not res then
        return nil, err
    end

    local body = res.readAll()
    res.close()
    return body, nil
end

print("Testing bridge...")
local pong, err = get(BASE .. "/ping")

if not pong then
    print("Ping failed:")
    print(tostring(err))
    return
end

print("Ping: " .. tostring(pong))
print("")
print("Search YouTube:")
local q = read()

local url = BASE .. "/search?q=" .. urlEncode(q) .. "&max_results=5"
print("Requesting...")
print(url)

local body, err = get(url)

if not body then
    print("HTTP failed:")
    print(tostring(err))
    return
end

local data = textutils.unserializeJSON(body)

if not data then
    print("Bad JSON response:")
    print(body)
    return
end

if data.ok == false then
    print("Bridge error:")
    print(body)
    return
end

print("")
print("Results:")

local results = data.results or {}

if #results == 0 then
    print("No results.")
    return
end

for i, v in ipairs(results) do
    print("")
    print(i .. ". " .. tostring(v.title))
    print("   Channel: " .. tostring(v.channel))
    print("   ID: " .. tostring(v.id))
end

print("")
print("Done.")
