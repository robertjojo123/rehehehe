local function getZoneAt(x, y)
    for _, zone in ipairs(zoneRects) do
        if x >= zone.x1
            and x <= zone.x2
            and y >= zone.y1
            and y <= zone.y2 then

            return zone.name
        end
    end

    return nil
end

