local zoneRects = {}

local function addRectZone(name, x1, y1, x2, y2)
    table.insert(zoneRects, {
        name = name,
        x1 = x1,
        y1 = y1,
        x2 = x2,
        y2 = y2
    })

    monitorHitboxes[name] = {
        {
            math.floor((x1 + x2) / 2),
            math.floor((y1 + y2) / 2)
        }
    }
end

