local midRow = {2, 5, 8, 11, 14, 17, 20, 23, 26, 29, 32, 35}
local botRow = {1, 4, 7, 10, 13, 16, 19, 22, 25, 28, 31, 34}

local function addNumberRow(nums, y1, y2)
    for i, n in ipairs(nums) do
        local x1 = 5 + ((i - 1) * 4)

        -- Give the right-edge separator/boundary column to the number on the LEFT.
        -- Example: x=9,y=7 should hit 3, not 6.
        -- This intentionally overlaps adjacent number hitboxes by 1 x-column.
        -- Since zones are checked in insertion order left-to-right, the left number wins.
        addRectZone(tostring(n), x1, y1, x1 + 4, y2)
    end
end

