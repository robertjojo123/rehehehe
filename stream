clearScreen()
print("Testing AV server...")
local pong, pingErr = get(BASE .. "/ping")
if not pong then
    print("Ping failed:")
    print(tostring(pingErr))
    print("")
    print("Check BASE in this Lua file.")
    waitKey()
    return
end

local chosen = chooseVideo()
if not chosen then return end

clearScreen()
print("Selected:")
print(chosen)
print("")
print("Audio: true 0.5x pitch+speed")
print("Tape: 2x playback")
print("Video: starts after tape starts")
print("")
print("Continue?")
print("[y] yes")
write("> ")

if tostring(read() or ""):lower() ~= "y" then return end

clearScreen()
print("Queuing audio generation...")

local prepUrl = BASE
    .. "/audio_prepare?name=" .. urlEncode(chosen)
    .. "&max_seconds=" .. tostring(DEFAULT_MAX_SECONDS)
    .. "&sample_rate=" .. tostring(AUDIO_SAMPLE_RATE)
    .. "&slow_factor=" .. tostring(AUDIO_SLOW_FACTOR)

local prep, prepErr = getJson(prepUrl)
if not prep then
    print("Audio prepare failed:")
    print(tostring(prepErr))
    waitKey()
    return
end

local audioStatus = waitForAudio(prep.job)
if not audioStatus then return end

local audioUrl = audioStatus.audio_url or (BASE .. "/files/current/audio.dfpwm")
if audioUrl:sub(1, 1) == "/" then audioUrl = BASE .. audioUrl end

local ok, tape = downloadAudioToTape(audioUrl, audioStatus.tape_speed or 2.0)
if not ok then return end

clearScreen()
print("Starting tape...")
local tapeStarted = startTape(tape, audioStatus.tape_speed or 2.0)
print("Tape started: " .. tostring(tapeStarted))
print("Starting video stream in 1 second...")
sleep(1)

streamVideo(chosen)
