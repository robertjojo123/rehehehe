-- =========================================================
-- === Sixel / 2x3 subpixel renderer
-- =========================================================

local BLIT_LOOKUP = {
    [colors.white] = "0", [colors.orange] = "1", [colors.magenta] = "2", [colors.lightBlue] = "3",
    [colors.yellow] = "4", [colors.lime] = "5", [colors.pink] = "6", [colors.gray] = "7",
    [colors.lightGray] = "8", [colors.cyan] = "9", [colors.purple] = "a", [colors.blue] = "b",
    [colors.brown] = "c", [colors.green] = "d", [colors.red] = "e", [colors.black] = "f",
}

local function colorToBlit(color)
    return BLIT_LOOKUP[color or colors.white] or "0"
end

local function sixelChar(mask)
    if mask > 31 then
        return string.char(0x80 + (63 - mask)), true
    end
    return string.char(0x80 + mask), false
end

local function newSubCanvas(w, h, bg)
    local pix = {}
    for y = 1, h do
        pix[y] = {}
        for x = 1, w do pix[y][x] = bg end
    end
    return { w = w, h = h, bg = bg, pix = pix }
end

local function setSub(canvas, x, y, color)
    if x >= 1 and x <= canvas.w and y >= 1 and y <= canvas.h then
        canvas.pix[y][x] = color
    end
end

local function plotSprite(canvas, sprite, color)
    for y = 1, #sprite do
        local row = sprite[y]
        for x = 1, #row do
            if row:sub(x, x) == "#" then
                setSub(canvas, x, y, color)
            end
        end
    end
end

local function spriteMask(sprite)
    local mask = {}
    for y = 1, #sprite do
        mask[y] = {}
        local row = sprite[y]
        for x = 1, #row do
            mask[y][x] = row:sub(x, x) == "#"
        end
    end
    return mask
end

local function plotOutlinedSprite(canvas, sprite, fillColor, outlineColor)
    local mask = spriteMask(sprite)
    local h = #mask
    local w = #mask[1]

    -- outline first
    for y = 1, h do
        for x = 1, w do
            if mask[y][x] then
                for dy = -1, 1 do
                    for dx = -1, 1 do
                        local nx, ny = x + dx, y + dy
                        if nx >= 1 and nx <= w and ny >= 1 and ny <= h then
                            if not mask[ny][nx] then
                                setSub(canvas, nx, ny, outlineColor)
                            end
                        end
                    end
                end
            end
        end
    end

    -- fill on top
    for y = 1, h do
        for x = 1, w do
            if mask[y][x] then
                setSub(canvas, x, y, fillColor)
            end
        end
    end

    canvas.pieceFill = fillColor
    canvas.pieceOutline = outlineColor
end

local function renderSubCanvas(target, x, y, canvas)
    local outW, outH = canvas.w, canvas.h
    while outW % 2 ~= 0 do outW = outW + 1 end
    while outH % 3 ~= 0 do outH = outH + 1 end

    local charW = math.floor(outW / 2)
    local charH = math.floor(outH / 3)
    local tw, th = target.getSize()

    for cy = 1, charH do
        local chars, fgs, bgs = {}, {}, {}

        for cx = 1, charW do
            local bg = canvas.bg
            local px = (cx - 1) * 2
            local py = (cy - 1) * 3

            local points = {
                canvas.pix[py + 1] and canvas.pix[py + 1][px + 1] or bg,
                canvas.pix[py + 1] and canvas.pix[py + 1][px + 2] or bg,
                canvas.pix[py + 2] and canvas.pix[py + 2][px + 1] or bg,
                canvas.pix[py + 2] and canvas.pix[py + 2][px + 2] or bg,
                canvas.pix[py + 3] and canvas.pix[py + 3][px + 1] or bg,
                canvas.pix[py + 3] and canvas.pix[py + 3][px + 2] or bg,
            }

            local function countColor(col)
                local n = 0
                for _, c in ipairs(points) do
                    if c == col then n = n + 1 end
                end
                return n
            end

            local fill = canvas.pieceFill
            local outline = canvas.pieceOutline
            local fillCount = fill and countColor(fill) or 0
            local outlineCount = outline and countColor(outline) or 0
            local bgCount = countColor(bg)

            local fgColor = nil
            local bgColor = bg

            -- Leak-safe priority:
            -- If the 2x3 cell has board background AND both fill/outline,
            -- keep the real board background as bg instead of turning the whole
            -- empty part of the cell into outline. This is what caused crown/rook leaks.
            if fillCount > 0 then
                fgColor = fill
                bgColor = bg
            elseif outlineCount > 0 then
                fgColor = outline
                bgColor = bg
            else
                -- Fallback for non-piece drawings with arbitrary colors.
                local counts, unique = {}, {}
                for _, c in ipairs(points) do
                    if not counts[c] then counts[c] = 0; unique[#unique + 1] = c end
                    counts[c] = counts[c] + 1
                end
                if #unique == 1 then
                    fgColor = nil
                    bgColor = unique[1]
                else
                    local best = nil
                    for _, c in ipairs(unique) do
                        if c ~= bg and (not best or counts[c] > counts[best]) then best = c end
                    end
                    fgColor = best
                    bgColor = bg
                end
            end

            local function addChar(ch, fg, bkg)
                chars[#chars + 1] = ch
                fgs[#fgs + 1] = colorToBlit(fg or bkg or bg)
                bgs[#bgs + 1] = colorToBlit(bkg or bg)
            end

            if not fgColor or fgColor == bgColor then
                addChar(" ", bgColor, bgColor)
            else
                local bitValues = {1, 2, 4, 8, 16, 32}
                local mask = 0
                for i, c in ipairs(points) do
                    if c == fgColor then mask = mask + bitValues[i] end
                end

                if mask == 0 then
                    addChar(" ", bgColor, bgColor)
                elseif mask == 63 then
                    addChar(" ", fgColor, fgColor)
                else
                    local ch, inverted = sixelChar(mask)
                    if inverted then
                        addChar(ch, bgColor, fgColor)
                    else
                        addChar(ch, fgColor, bgColor)
                    end
                end
            end
        end

        local rowY = y + cy - 1
        if rowY >= 1 and rowY <= th then
            local rowText, rowFg, rowBg = table.concat(chars), table.concat(fgs), table.concat(bgs)
            local drawX = x
            if drawX < 1 then
                local trim = 2 - drawX
                rowText = rowText:sub(trim)
                rowFg = rowFg:sub(trim)
                rowBg = rowBg:sub(trim)
                drawX = 1
            end
            if drawX <= tw and #rowText > 0 then
                local maxLen = tw - drawX + 1
                target.setCursorPos(drawX, rowY)
                target.blit(rowText:sub(1, maxLen), rowFg:sub(1, maxLen), rowBg:sub(1, maxLen))
            end
        end
    end
end

