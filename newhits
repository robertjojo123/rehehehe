    ["even"] = {left = 2, right = 3, up = 0, down = 2},
    ["odd"] = {left = 3, right = 3, up = 0, down = 2},
    ["19to36"] = {left = 1, right = 2, up = 0, down = 2},
    ["1to18"] = {left = 0, right = 3, up = 0, down = 2},

    -- Dozens
    ["1st12"] = {left = 5, right = 7, up = 1, down = 1},
    ["2nd12"] = {left = 4, right = 8, up = 1, down = 1},
    ["3rd12"] = {left = 5, right = 7, up = 1, down = 1},

    -- Zeroes
    ["0"] = {left = 0, right = 0, up = 4, down = 5},
