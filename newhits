    ["2to1_bot"] = {left = 0, right = 0, up = 2, down = 2},
}

local FIXED_HEIGHT_HITBOXES = {
  ["red"] = 3,
  ["black"] = 3,
}

for n = 1, 36 do
  local key = tostring(n)

  if n % 3 == 0 then
    HITBOX_EXPANSIONS[key] = {left = 0, right = 0, up = 2, down = 2}
  elseif n % 3 == 2 then
    HITBOX_EXPANSIONS[key] = {left = 0, right = 0, up = 2, down = 1}
  elseif n % 3 == 1 then
    HITBOX_EXPANSIONS[key] = {left = 0, right = 0, up = 2, down = 2}
  end
end

local function addNumberExpansion(num, addLeft, addRight)
  local key = tostring(num)
  HITBOX_EXPANSIONS[key] = HITBOX_EXPANSIONS[key] or {
    left = 0,
    right = 0,
    up = 0,
    down = 0
  }

  HITBOX_EXPANSIONS[key].left = (HITBOX_EXPANSIONS[key].left or 0) + (addLeft or 0)
  HITBOX_EXPANSIONS[key].right = (HITBOX_EXPANSIONS[key].right or 0) + (addRight or 0)
end

for _, n in ipairs({1, 2, 3, 4, 5, 6, 7}) do
  addNumberExpansion(n, 1, 0)
end

-- Expand 8, 9, 10 one pixel left, and shrink one pixel right
for _, n in ipairs({8, 9, 10}) do
    local key = tostring(n)

    HITBOX_EXPANSIONS[key] = HITBOX_EXPANSIONS[key] or {
        left = 0,
        right = 0,
        up = 0,
        down = 0
    }

    HITBOX_EXPANSIONS[key].left = (HITBOX_EXPANSIONS[key].left or 0) + 1
    HITBOX_EXPANSIONS[key].right = math.max(0, (HITBOX_EXPANSIONS[key].right or 0) - 1)
end

for _, n in ipairs({11, 12, 17, 18}) do
  addNumberExpansion(n, 1, 0)
end

addNumberExpansion(16, 1, 1)

for _, n in ipairs({31, 32, 33, 34, 35, 36}) do
  addNumberExpansion(n, 0, 1)
end

for _, n in ipairs({20, 21}) do
    addNumberExpansion(n, 0, 1)
end

for _, n in ipairs({25, 26, 27}) do
    addNumberExpansion(n, 1, 0)
end

local function pointInsideExpandedHitbox(x, y, hx, hy, expansion)
    expansion = expansion or {left = 0, right = 0, up = 0, down = 0}

    local left = expansion.left or 0
    local right = expansion.right or 0
    local up = expansion.up or 0
    local down = expansion.down or 0

    return x >= hx - left
        and x <= hx + right
        and y >= hy - up
        and y <= hy + down
end

local function getHitboxBounds(positions)
    local minX, maxX, minY, maxY = nil, nil, nil, nil

    for _, pos in ipairs(positions) do
        local px = pos[1]
        local py = pos[2]

        if not minX or px < minX then minX = px end
        if not maxX or px > maxX then maxX = px end
        if not minY or py < minY then minY = py end
        if not maxY or py > maxY then maxY = py end
    end

    return minX, maxX, minY, maxY
end

local function getZoneAt(x, y)
    -- New shifted SPIN button: old spin pixels + 9 x-offset.
    -- Keeping this separate from the old spin/UNDO area.
    if monitorHitboxes["spin"] then
        for _, pos in ipairs(monitorHitboxes["spin"]) do
            local hx = pos[1] + 9
            local hy = pos[2]

            if x == hx and y == hy then
                return "spin"
            end
        end
    end

    for name, positions in pairs(monitorHitboxes) do
        local fixedDown = FIXED_HEIGHT_HITBOXES[name]

        if fixedDown then
            local minX, maxX, minY, maxY = getHitboxBounds(positions)
            local expansion = HITBOX_EXPANSIONS[name] or {}

            local left = expansion.left or 0
            local right = expansion.right or 0
            local up = expansion.up or 0

            -- Keep top where it currently is, unless you set up > 0.
            -- End exactly fixedDown pixels below that top.
            local fixedMinX = minX - left
            local fixedMaxX = maxX + right
            local fixedMinY = minY - up
            local fixedMaxY = minY + fixedDown

            if x >= fixedMinX
                and x <= fixedMaxX
                and y >= fixedMinY
                and y <= fixedMaxY then
                return name
            end

        else
            for _, pos in ipairs(positions) do
                local hx = pos[1]
                local hy = pos[2]
                local expansion = HITBOX_EXPANSIONS[name]

                if pointInsideExpandedHitbox(x, y, hx, hy, expansion) then
                    -- Old spin hitbox became UNDO button.
                    if name == "spin" then
                        return "undo"
                    end

                    return name
                end
            end
        end
    end

    return nil
end

