-- STATE
-- =========================
local selected = nil
local legalMoves = {}
local statusMessage = "White to move."
local currentTurn = "w"
local boardBusy = false

local function freshBoard()
    return {
        {"bR","bN","bB","bQ","bK","bB","bN","bR"}, -- rank 8
        {"bP","bP","bP","bP","bP","bP","bP","bP"}, -- rank 7
        {nil,nil,nil,nil,nil,nil,nil,nil},
        {nil,nil,nil,nil,nil,nil,nil,nil},
        {nil,nil,nil,nil,nil,nil,nil,nil},
        {nil,nil,nil,nil,nil,nil,nil,nil},
        {"wP","wP","wP","wP","wP","wP","wP","wP"}, -- rank 2
        {"wR","wN","wB","wQ","wK","wB","wN","wR"}, -- rank 1
    }
end

local board = freshBoard()

-- =========================
-- HELPERS
-- =========================
local files = {"a","b","c","d","e","f","g","h"}

local function writeAt(x, y, text, fg, bg)
    if x < 1 or y < 1 or x > W or y > H then return end
    if bg then mon.setBackgroundColor(bg) end
    if fg then mon.setTextColor(fg) end
    mon.setCursorPos(x, y)
    mon.write(text)
end

local function fill(x, y, w, h, bg)
    mon.setBackgroundColor(bg)
    local line = string.rep(" ", math.max(0, w))
    for yy = y, y + h - 1 do
        if yy >= 1 and yy <= H then
            mon.setCursorPos(x, yy)
            mon.write(line)
        end
    end
end

local function centerText(x, y, w, text, fg, bg)
    local tx = x + math.floor((w - #text) / 2)
    writeAt(tx, y, text, fg, bg)
end

local function sideOf(piece)
    return piece and piece:sub(1,1) or nil
end

local function kindOf(piece)
    return piece and piece:sub(2,2) or nil
end

local function boardToArray(rank, file)
    -- rank 8 at row 1, rank 1 at row 8
    return 9 - rank, file
end

local function getPiece(file, rank)
    if file < 1 or file > 8 or rank < 1 or rank > 8 then return nil end
    local row, col = boardToArray(rank, file)
    return board[row][col]
end

local function setPiece(file, rank, piece)
    local row, col = boardToArray(rank, file)
    board[row][col] = piece
end

local function squareName(file, rank)
    return files[file] .. tostring(rank)
end

local function inBounds(file, rank)
    return file >= 1 and file <= 8 and rank >= 1 and rank <= 8
end

local function addMove(moves, file, rank)
    if inBounds(file, rank) then
        table.insert(moves, {file = file, rank = rank})
    end
end

local function containsMove(moves, file, rank)
    for _, m in ipairs(moves) do
        if m.file == file and m.rank == rank then
            return true
        end
    end
    return false
end

local function traceLineMoves(moves, file, rank, df, dr, side)
    local f = file + df
    local r = rank + dr
    while inBounds(f, r) do
        local p = getPiece(f, r)
        if not p then
            addMove(moves, f, r)
        else
            if sideOf(p) ~= side then
                addMove(moves, f, r)
            end
            break
        end
        f = f + df
        r = r + dr
    end
end

-- =========================
-- BASIC LEGAL MOVES
-- =========================
local function getLegalMoves(file, rank)
    local piece = getPiece(file, rank)
    if not piece then return {} end

    local side = sideOf(piece)
    local kind = kindOf(piece)
    local moves = {}

    if kind == "P" then
        local dir = (side == "w") and 1 or -1
        local startRank = (side == "w") and 2 or 7

        if inBounds(file, rank + dir) and not getPiece(file, rank + dir) then
            addMove(moves, file, rank + dir)

            if rank == startRank and not getPiece(file, rank + 2 * dir) then
                addMove(moves, file, rank + 2 * dir)
            end
        end

        for _, df in ipairs({-1, 1}) do
            local target = getPiece(file + df, rank + dir)
            if target and sideOf(target) ~= side then
                addMove(moves, file + df, rank + dir)
            end
        end

    elseif kind == "N" then
        local jumps = {
            { 1,  2}, { 2,  1}, { 2, -1}, { 1, -2},
            {-1, -2}, {-2, -1}, {-2,  1}, {-1,  2},
        }
        for _, j in ipairs(jumps) do
            local f, r = file + j[1], rank + j[2]
            if inBounds(f, r) then
                local p = getPiece(f, r)
                if not p or sideOf(p) ~= side then
                    addMove(moves, f, r)
                end
            end
        end

    elseif kind == "B" then
        traceLineMoves(moves, file, rank,  1,  1, side)
        traceLineMoves(moves, file, rank,  1, -1, side)
        traceLineMoves(moves, file, rank, -1,  1, side)
        traceLineMoves(moves, file, rank, -1, -1, side)

    elseif kind == "R" then
        traceLineMoves(moves, file, rank,  1,  0, side)
        traceLineMoves(moves, file, rank, -1,  0, side)
        traceLineMoves(moves, file, rank,  0,  1, side)
        traceLineMoves(moves, file, rank,  0, -1, side)

    elseif kind == "Q" then
        traceLineMoves(moves, file, rank,  1,  0, side)
        traceLineMoves(moves, file, rank, -1,  0, side)
        traceLineMoves(moves, file, rank,  0,  1, side)
        traceLineMoves(moves, file, rank,  0, -1, side)
        traceLineMoves(moves, file, rank,  1,  1, side)
        traceLineMoves(moves, file, rank,  1, -1, side)
        traceLineMoves(moves, file, rank, -1,  1, side)
        traceLineMoves(moves, file, rank, -1, -1, side)

    elseif kind == "K" then
        for df = -1, 1 do
            for dr = -1, 1 do
                if not (df == 0 and dr == 0) then
                    local f, r = file + df, rank + dr
                    if inBounds(f, r) then
                        local p = getPiece(f, r)
                        if not p or sideOf(p) ~= side then
                            addMove(moves, f, r)
                        end
                    end
                end
            end
        end
    end

    return moves
end

