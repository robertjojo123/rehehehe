-- Converts six 2x3 subpixels into a ComputerCraft extended character.
-- Pixel order assumed:
--   1 2
--   4 8
--   16 32
-- If the sprites look scrambled on your pack, only this bit order needs changing.
local function subpixelChar(p1, p2, p3, p4, p5, p6)
    local mask = 0
    if p1 then mask = mask + 1 end
    if p2 then mask = mask + 2 end
    if p3 then mask = mask + 4 end
    if p4 then mask = mask + 8 end
    if p5 then mask = mask + 16 end
    if p6 then mask = mask + 32 end
    if mask == 0 then return " " end
    return string.char(128 + mask)
end

local function spritePixel(sprite, px, py)
    local row = sprite[py]
    if not row then return false end
    return row:sub(px, px) == "#"
end

local function drawPieceSprite(piece, squareX, squareY, squareBg)
    local kind = kindOf(piece)
    local sprite = PIECE_SPRITES[kind]
    if not sprite then return end

    local fg = (sideOf(piece) == "w") and colors.white or colors.black

    mon.setTextColor(fg)
    mon.setBackgroundColor(squareBg)

    -- 14x18 sprite -> 7x6 text cells
    for cy = 0, 5 do
        for cx = 0, 6 do
            local px = cx * 2 + 1
            local py = cy * 3 + 1

            local ch = subpixelChar(
                spritePixel(sprite, px,     py),
                spritePixel(sprite, px + 1, py),
                spritePixel(sprite, px,     py + 1),
                spritePixel(sprite, px + 1, py + 1),
                spritePixel(sprite, px,     py + 2),
                spritePixel(sprite, px + 1, py + 2)
            )

            mon.setCursorPos(squareX + cx, squareY + cy)
            mon.write(ch)
        end
    end
end

-- =========================
-- DRAWING
-- =========================
local function squareScreenRect(file, rank)
    local x = BOARD_X + (file - 1) * SQ_W
    local y = BOARD_Y + (8 - rank) * SQ_H
    return x, y, SQ_W, SQ_H
end

local function drawSquare(file, rank)
    local x, y, w, h = squareScreenRect(file, rank)

    local isLight = ((file + rank) % 2 == 0)
    local bg = isLight and LIGHT_SQUARE or DARK_SQUARE

    if selected and selected.file == file and selected.rank == rank then
        bg = SELECT_SQUARE
    elseif containsMove(legalMoves, file, rank) then
        bg = HIGHLIGHT_SQUARE
    end

    fill(x, y, w, h, bg)

    local piece = getPiece(file, rank)
    if piece then
        drawPieceSprite(piece, x, y, bg)
    elseif containsMove(legalMoves, file, rank) then
        local px = x + math.floor(w / 2)
        local py = y + math.floor(h / 2)
        writeAt(px, py, "*", colors.black, bg)
    end
end

local function drawBoard()
    fill(1, 1, BOARD_X + BOARD_W, H, colors.black)

    for rank = 1, 8 do
        for file = 1, 8 do
            drawSquare(file, rank)
        end
    end

    for file = 1, 8 do
        local x = BOARD_X + (file - 1) * SQ_W
        centerText(x, FILE_LABEL_Y + 1, SQ_W, files[file], colors.white, colors.black)
    end

    for rank = 8, 1, -1 do
        local y = BOARD_Y + (8 - rank) * SQ_H
        centerText(RANK_LABEL_X, y + math.floor(SQ_H / 2), 1, tostring(rank), colors.white, colors.black)
    end

    centerText(BOARD_X, 1, BOARD_W, "LIVING MOB CHESS", colors.white, colors.black)
end

local function drawPanelBox(x, y, w, h, title)
    fill(x, y, w, h, PANEL_BG)
    writeAt(x, y, "+" .. string.rep("-", w - 2) .. "+", PANEL_TEXT, PANEL_BG)
    for yy = y + 1, y + h - 2 do
        writeAt(x, yy, "|", PANEL_TEXT, PANEL_BG)
        writeAt(x + w - 1, yy, "|", PANEL_TEXT, PANEL_BG)
    end
    writeAt(x, y + h - 1, "+" .. string.rep("-", w - 2) .. "+", PANEL_TEXT, PANEL_BG)

    if title then
        local label = " " .. title .. " "
        local tx = x + math.max(1, math.floor((w - #label) / 2))
        writeAt(tx, y, label, PANEL_TEXT, PANEL_BG)
    end
end

local function panelWriteLine(x, y, w, text, fg, bg)
    bg = bg or PANEL_BG
    fill(x, y, w, 1, bg)
    writeAt(x, y, tostring(text or ""):sub(1, w), fg or PANEL_TEXT, bg)
end

local function drawButton(x, y, w, h, label, bg, fg)
    fill(x, y, w, h, bg)
    centerText(x, y + math.floor(h / 2), w, label, fg, bg)
end

local function drawPanel()
    fill(PANEL_X, PANEL_Y, PANEL_W, PANEL_H, colors.black)

    drawPanelBox(PANEL_X, 1, PANEL_W, 10, "STATUS")
    drawPanelBox(PANEL_X, 12, PANEL_W, 16, "MESSAGE")
    drawPanelBox(PANEL_X, 29, PANEL_W, 14, "SELECTION")
    drawPanelBox(PANEL_X, 44, PANEL_W, 9, "ACTIONS")

    local turnText = (currentTurn == "w") and "White turn" or "Black turn"
    panelWriteLine(PANEL_X + 2, 3, PANEL_W - 4, "Turn: " .. turnText)
    panelWriteLine(PANEL_X + 2, 4, PANEL_W - 4, "Board: " .. (boardBusy and "BUSY" or "READY"))

    if selected then
        local p = getPiece(selected.file, selected.rank)
        if p then
            panelWriteLine(PANEL_X + 2, 6, PANEL_W - 4, "Selected:")
            panelWriteLine(PANEL_X + 2, 7, PANEL_W - 4, p .. " @ " .. squareName(selected.file, selected.rank))
        else
            panelWriteLine(PANEL_X + 2, 6, PANEL_W - 4, "Selected: none")
        end
    else
        panelWriteLine(PANEL_X + 2, 6, PANEL_W - 4, "Selected: none")
    end

    local width = PANEL_W - 4
    local msg = statusMessage or ""
    panelWriteLine(PANEL_X + 2, 14, width, msg:sub(1, width))
    panelWriteLine(PANEL_X + 2, 15, width, msg:sub(width + 1, width * 2))
    panelWriteLine(PANEL_X + 2, 16, width, msg:sub(width * 2 + 1, width * 3))
    panelWriteLine(PANEL_X + 2, 17, width, msg:sub(width * 3 + 1, width * 4))

    panelWriteLine(PANEL_X + 2, 19, width, "Tap piece, then square.")
    panelWriteLine(PANEL_X + 2, 20, width, "Green = valid moves.")
    panelWriteLine(PANEL_X + 2, 21, width, "Orange = selected.")

    if selected then
        local piece = getPiece(selected.file, selected.rank)
        panelWriteLine(PANEL_X + 2, 31, width, "Piece: " .. (piece or "none"))
        panelWriteLine(PANEL_X + 2, 32, width, "At: " .. squareName(selected.file, selected.rank))
        panelWriteLine(PANEL_X + 2, 33, width, "Moves: " .. tostring(#legalMoves))
    else
        panelWriteLine(PANEL_X + 2, 31, width, "Piece: none")
        panelWriteLine(PANEL_X + 2, 32, width, "At: -")
        panelWriteLine(PANEL_X + 2, 33, width, "Moves: 0")
    end

    panelWriteLine(PANEL_X + 2, 35, width, "NI/mob state goes")
    panelWriteLine(PANEL_X + 2, 36, width, "here later.")

    drawButton(PANEL_X + 2, 46, PANEL_W - 4, 2, "RESET BOARD", BTN_WARN, colors.white)
    drawButton(PANEL_X + 2, 49, PANEL_W - 4, 2, "CLEAR SELECT", BTN_BG, BTN_TEXT)
end

local function redraw()
    drawBoard()
    drawPanel()
end

-- =========================
-- INTERACTION
-- =========================
local function screenToSquare(x, y)
    if x < BOARD_X or x >= BOARD_X + BOARD_W or y < BOARD_Y or y >= BOARD_Y + BOARD_H then
        return nil
    end

    local file = math.floor((x - BOARD_X) / SQ_W) + 1
    local rank = 8 - math.floor((y - BOARD_Y) / SQ_H)

    if inBounds(file, rank) then
        return file, rank
    end
    return nil
end

local function movePiece(fromFile, fromRank, toFile, toRank)
    local moving = getPiece(fromFile, fromRank)
    local target = getPiece(toFile, toRank)

    if not moving then
        statusMessage = "No piece selected."
        return false
    end

    -- Later replace this instant move with:
    --   boardBusy = true
    --   send NI command to the real mob
    --   wait for ARRIVED/CAPTURED confirmation
    --   update board
    --   boardBusy = false

    setPiece(toFile, toRank, moving)
    setPiece(fromFile, fromRank, nil)

    local movedText = moving .. " " .. squareName(fromFile, fromRank) .. " -> " .. squareName(toFile, toRank)
    if target then
        movedText = movedText .. " captures " .. target
    end

    statusMessage = movedText
    currentTurn = (currentTurn == "w") and "b" or "w"
    return true
end

local function clearSelection()
    selected = nil
    legalMoves = {}
end

local function resetBoard()
    board = freshBoard()
    currentTurn = "w"
    selected = nil
    legalMoves = {}
    boardBusy = false
    statusMessage = "Board reset. White to move."
end

local function panelButtonHit(x, y)
    if x >= PANEL_X + 2 and x <= PANEL_X + PANEL_W - 3 and y >= 46 and y <= 47 then
        return "reset"
    end
    if x >= PANEL_X + 2 and x <= PANEL_X + PANEL_W - 3 and y >= 49 and y <= 50 then
        return "clear"
    end
    return nil
end

local function handleBoardTap(file, rank)
    if boardBusy then
        statusMessage = "Board is busy. Wait for piece move/reset."
        return
    end

    local piece = getPiece(file, rank)

    if not selected then
        if not piece then
            statusMessage = "No piece there."
            return
        end

        if sideOf(piece) ~= currentTurn then
            statusMessage = "Not your turn for that piece."
            return
        end

        selected = {file = file, rank = rank}
        legalMoves = getLegalMoves(file, rank)
        statusMessage = "Selected " .. piece .. " at " .. squareName(file, rank) .. "."
        return
    end

    if selected.file == file and selected.rank == rank then
        clearSelection()
        statusMessage = "Selection cleared."
        return
    end

    if piece and sideOf(piece) == currentTurn then
        selected = {file = file, rank = rank}
        legalMoves = getLegalMoves(file, rank)
        statusMessage = "Selected " .. piece .. " at " .. squareName(file, rank) .. "."
        return
    end

    if containsMove(legalMoves, file, rank) then
        local ok = movePiece(selected.file, selected.rank, file, rank)
        clearSelection()
        if not ok then
            statusMessage = "Move failed."
        end
    else
        statusMessage = "Invalid move for selected piece."
    end
end

-- =========================
-- MAIN
-- =========================
resetBoard()
redraw()

while true do
    local event, side, x, y = os.pullEvent()

    if event == "monitor_touch" then
        local action = panelButtonHit(x, y)
        if action == "reset" then
            resetBoard()
            redraw()
        elseif action == "clear" then
            clearSelection()
            statusMessage = "Selection cleared."
            redraw()
        else
            local file, rank = screenToSquare(x, y)
            if file and rank then
                handleBoardTap(file, rank)
                redraw()
            end
        end

    elseif event == "monitor_resize" then
        mon.setTextScale(0.5)
        W, H = mon.getSize()
        redraw()
    end
end
