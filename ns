local SQ_H = 6

local BOARD_X = 2
local BOARD_Y = 2

local BOARD_W = SQ_W * 8   -- 56
local BOARD_H = SQ_H * 8   -- 48

local PANEL_X = BOARD_X + BOARD_W + 2
local PANEL_Y = 1
local PANEL_W = W - PANEL_X + 1
local PANEL_H = H

local FILE_LABEL_Y = BOARD_Y + BOARD_H
local RANK_LABEL_X = 1

