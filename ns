-- mob_chess_ui_sprites.lua
-- Living Mob Chess monitor UI with 2x3 subpixel chess-piece sprites
-- Target: 4x4 advanced monitor at text scale 0.5, about 79x52 chars.
-- Features:
--   - 8x8 chess board
--   - right-side status/message panel
--   - tap piece to highlight legal moves
--   - tap destination to move piece locally
--   - reset/clear buttons
--   - 14x18 pixel sprites compressed into 7x6 monitor cells
--
-- Notes:
--   - Basic movement only. No check/checkmate/castling/en passant/promotion yet.
--   - This is ready to later replace instant moves with NI/mob movement commands.

local mon = peripheral.find("monitor")
if not mon then error("No monitor found") end

mon.setTextScale(0.5)
local W, H = mon.getSize()

if W < 79 or H < 52 then
    error("This UI expects about 79x52 at scale 0.5. Current size: " .. W .. "x" .. H)
end

-- =========================
-- PALETTE TWEAKS
-- =========================
if mon.setPaletteColor then
    -- board colors, roughly like the reference image
    mon.setPaletteColor(colors.white,     0.84, 0.84, 0.84) -- light squares
    mon.setPaletteColor(colors.lightBlue, 0.49, 0.58, 0.78) -- dark squares

    -- interaction colors
    mon.setPaletteColor(colors.orange,    0.95, 0.65, 0.20) -- selected
    mon.setPaletteColor(colors.lime,      0.55, 0.82, 0.42) -- valid move

    -- panel
    mon.setPaletteColor(colors.gray,      0.22, 0.22, 0.24)
    mon.setPaletteColor(colors.lightGray, 0.65, 0.65, 0.68)
end

