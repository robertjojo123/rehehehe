local function getMonthKey()
    if os.date then
        local ok, val = pcall(function()
            return os.date("%Y-%m")
        end)

        if ok and val and type(val) == "string" and #val > 0 then
            return val
        end
    end

    return "current"
end

local function loadWinStats()
    if fs.exists(WIN_STATS_FILE) then
        local f = fs.open(WIN_STATS_FILE, "r")
        local text = f.readAll()
        f.close()

        local data = textutils.unserialize(text)

        if type(data) == "table" then
            data.allTime = data.allTime or {}
            data.months = data.months or {}
            return data
        end
    end

    return {
        allTime = {},
        months = {}
    }
end

local function saveWinStats(data)
    local f = fs.open(WIN_STATS_FILE, "w")
