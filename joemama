local function getRouletteRoundKey(player, result)
    return tostring(player) .. "|" .. tostring(result)
end

local function cleanupOldPendingRouletteRounds()
    local now = os.clock()

    for key, round in pairs(pendingRouletteRounds) do
        if round.lastUpdate and now - round.lastUpdate > 45 then
            pendingRouletteRounds[key] = nil
        end
    end
end

local function trackRouletteOutcomeNote(player, note)
    if not player or type(note) ~= "string" then return end

    local winBet, winZone, winResult, winPayout = note:match(
        "ROULETTE RESULT:%s*WIN%s*%-%s*bet%s*%$(%d+)%s*on%s*(.-),%s*landed%s*(.-),%s*payout%s*%$(%d+)"
    )

    if winBet and winResult and winPayout then
        winBet = tonumber(winBet) or 0
        winPayout = tonumber(winPayout) or 0

        local key = getRouletteRoundKey(player, winResult)

        pendingRouletteRounds[key] = pendingRouletteRounds[key] or {
            player = player,
            result = winResult,
            wager = 0,
            payout = 0,
            lastUpdate = os.clock()
        }

        pendingRouletteRounds[key].wager = pendingRouletteRounds[key].wager + winBet
        pendingRouletteRounds[key].payout = pendingRouletteRounds[key].payout + winPayout
        pendingRouletteRounds[key].lastUpdate = os.clock()
        return
    end

    local lossBet, lossZone, lossResult = note:match(
        "ROULETTE RESULT:%s*LOSS%s*%-%s*bet%s*%$(%d+)%s*on%s*(.-),%s*landed%s*(.-)$"
    )

    if lossBet and lossResult then
        lossBet = tonumber(lossBet) or 0

        local key = getRouletteRoundKey(player, lossResult)

        pendingRouletteRounds[key] = pendingRouletteRounds[key] or {
            player = player,
            result = lossResult,
            wager = 0,
            payout = 0,
            lastUpdate = os.clock()
        }

        pendingRouletteRounds[key].wager = pendingRouletteRounds[key].wager + lossBet
        pendingRouletteRounds[key].lastUpdate = os.clock()
        return
    end
end

local function finalizeRoulettePayoutNote(player, note)
    if not player or type(note) ~= "string" then return end

    local payout, result = note:match(
        "ROULETTE WIN PAYOUT:%s*%$(%d+),%s*landed%s*(.-)$"
    )

    if not payout or not result then
        return
    end

    payout = tonumber(payout) or 0

    local key = getRouletteRoundKey(player, result)
    local round = pendingRouletteRounds[key]

    if not round then
        print("Roulette payout note received but no pending round found.")
        print(" Player:", player)
        print(" Result:", result)
        print(" Payout:", payout)
        return
    end

    local totalWager = tonumber(round.wager) or 0
    local totalPayout = payout

    addGamblingWinStat(
        player,
        "roulette",
        totalWager,
        totalPayout,
        "landed " .. tostring(result)
    )

    pendingRouletteRounds[key] = nil
end

local function handleCasinoTransferForStats(player, note)
    if not player or type(note) ~= "string" then return end

    trackRouletteOutcomeNote(player, note)
    finalizeRoulettePayoutNote(player, note)
    cleanupOldPendingRouletteRounds()
end

