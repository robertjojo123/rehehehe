local accountPublicKey = nil
local accountPrivateKey = nil

local function safeSerialize(value)
    local ok, result = pcall(textutils.serialize, value)
    if ok then return result end
    return tostring(value)
end

local function readSerializedFile(path)
    if not fs.exists(path) then
        return nil
    end

    local f = fs.open(path, "r")
    if not f then return nil end

    local text = f.readAll()
    f.close()

    return textutils.unserialize(text)
end

local function writeSerializedFile(path, value)
    local f = fs.open(path, "w")
    if not f then
        error("Could not write " .. tostring(path))
    end

    f.write(textutils.serialize(value))
    f.close()
end

local function waitForKeySet(keyset)
    while not keyset.finished() do
        print("Generating account cipher keyset...")
        sleep(1)
    end
end

local function loadOrCreateAccountKeys()
    local pub = readSerializedFile(ACCOUNT_PUBLIC_KEY_FILE)
    local priv = readSerializedFile(ACCOUNT_PRIVATE_KEY_FILE)

    if type(pub) == "table" and type(priv) == "table" then
        accountPublicKey = pub
        accountPrivateKey = priv
        print("Loaded account cipher keys from disk.")
        return
    end

    print("No saved account cipher keys found.")
    print("Creating random account keyset. This may take a little bit...")

    local keyset = cipher.createRandomKeySet()
    waitForKeySet(keyset)

    local publicKey, privateKey = keyset.getKeys()

    if type(publicKey) ~= "table" or type(privateKey) ~= "table" then
        error("Cipher key generation failed: getKeys() did not return two key tables.")
    end

    accountPublicKey = publicKey
    accountPrivateKey = privateKey

    writeSerializedFile(ACCOUNT_PUBLIC_KEY_FILE, accountPublicKey)
    writeSerializedFile(ACCOUNT_PRIVATE_KEY_FILE, accountPrivateKey)

    print("Created and saved new account cipher keys.")
    print("Public key saved to: " .. ACCOUNT_PUBLIC_KEY_FILE)
    print("Private key saved to: " .. ACCOUNT_PRIVATE_KEY_FILE)
end

local function secureDecryptPacket(packet)
    if type(packet) ~= "table" then
        return nil, "packet not table"
    end

    if packet.secure ~= true then
        return nil, "packet not secure"
    end

    if packet.version ~= SECURE_VERSION then
        return nil, "bad secure version"
    end

    if type(packet.payload) ~= "string" then
        return nil, "payload missing/not string"
    end

    local ok, plainOrErr = pcall(function()
        return cipher.decrypt(packet.payload, accountPrivateKey)
    end)

    if not ok then
        return nil, "decrypt failed: " .. tostring(plainOrErr)
    end

    local plain = plainOrErr
    local data = textutils.unserialize(plain)

    if type(data) == "table" then
        return data, nil
    end

    -- Also support compact pipe messages if RSA max message size becomes a problem.
    -- Examples:
    -- get_balance|HughJaynis1234
    -- transfer|HughJaynis1234|-500|ROULETTE BET
    if type(plain) == "string" then
        local parts = {}
        for part in plain:gmatch("[^|]+") do
            table.insert(parts, part)
        end

        if parts[1] == "get_balance" then
            return {
                action = "get_balance",
                player = parts[2]
            }, nil
        elseif parts[1] == "transfer" then
            return {
                action = "transfer",
                player = parts[2],
                delta = tonumber(parts[3]) or 0,
                note = parts[4] or "secure transfer"
            }, nil
        elseif parts[1] == "gamble_win_stat" then
            return {
                action = "gamble_win_stat",
                player = parts[2],
                game = parts[3],
                wager = tonumber(parts[4]) or 0,
                payout = tonumber(parts[5]) or 0,
                detail = parts[6] or "secure stat"
            }, nil
        end
    end

    return nil, "unserialize/parse failed"
end

local function secureEncryptForReply(replyTable, replyPublicKey)
    if type(replyPublicKey) ~= "table" then
        return nil, "missing reply public key"
    end

    local plain = textutils.serialize(replyTable)

    local ok, encryptedOrErr = pcall(function()
        return cipher.encrypt(plain, replyPublicKey)
    end)

    if not ok then
        return nil, "reply encrypt failed: " .. tostring(encryptedOrErr)
    end

    return {
        secure = true,
        version = SECURE_VERSION,
        payload = encryptedOrErr
    }, nil
end

local function sendSecureReply(targetId, replyTable, replyPublicKey)
    local packet, err = secureEncryptForReply(replyTable, replyPublicKey)

    if packet then
        rednet.send(targetId, packet, ACCOUNT_PROTOCOL)
        return true
    end

    print("Secure reply failed:", tostring(err))
    rednet.send(targetId, {
        secure = false,
        action = "secure_error",
        error = tostring(err)
    }, ACCOUNT_PROTOCOL)

    return false
end

local function getSenderGameName(sender)
    return TRUSTED_CASINO_SENDERS[tonumber(sender)] or "unknown"
end

local function isTrustedSender(sender)
    return TRUSTED_CASINO_SENDERS[tonumber(sender)] ~= nil
end

local function validateSecureTransfer(sender, msg)
    if not ENFORCE_TRUSTED_TRANSFER_SENDERS then
        return true, "trusted enforcement disabled"
    end

    if not isTrustedSender(sender) then
        return false, "untrusted sender " .. tostring(sender)
    end

    local game = getSenderGameName(sender)
    local limits = TRUSTED_TRANSFER_LIMITS[game] or TRUSTED_TRANSFER_LIMITS.unknown
    local delta = tonumber(msg.delta) or 0

    if delta < 0 and math.abs(delta) > (limits.maxDebit or 0) then
        return false, "debit over cap"
    end

    if delta > 0 and delta > (limits.maxCredit or 0) then
        return false, "credit over cap"
    end

    return true, "ok"
end

