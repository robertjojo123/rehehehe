local function getSortedWinLeaderboard(monthKey)
    local data = loadWinStats()
    local source

    if monthKey and data.months and data.months[monthKey] then
        source = data.months[monthKey]
    else
        source = data.allTime or {}
    end

    local list = {}

    for player, stats in pairs(source) do
        table.insert(list, {
            player = player,
            profit = tonumber(stats.profit) or 0,
            payout = tonumber(stats.payout) or 0,
            wager = tonumber(stats.wager) or 0,
            wins = tonumber(stats.wins) or 0
        })
    end

    table.sort(list, function(a, b)
        return a.profit > b.profit
    end)

    return list
end

