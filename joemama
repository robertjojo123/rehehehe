    print("Protocol:", ACCOUNT_PROTOCOL)
    print("Cipher:", CIPHER_NAME)
    print("Public key file:", ACCOUNT_PUBLIC_KEY_FILE)
    print("Private key file:", ACCOUNT_PRIVATE_KEY_FILE)
    print("Transfer sender whitelist enforced:", tostring(ENFORCE_TRUSTED_TRANSFER_SENDERS))
    print("Local gambling win stats file:", WIN_STATS_FILE)
    print("Roulette stat rule: total payout - total spin wager.")
    print("Losses do not subtract from leaderboard.")
    printTopGambleStats(5)

    while true do
        local sender, packet, protocol = rednet.receive()

        if protocol == ACCOUNT_PROTOCOL and type(packet) == "table" then
            if packet.action == "get_public_key" then
                rednet.send(sender, {
                    action = "account_public_key",
                    publicKey = accountPublicKey,
                    version = SECURE_VERSION
                }, ACCOUNT_PROTOCOL)

            elseif packet.secure == true then
                local replyPublicKey = packet.replyPublicKey

                local msg, err = secureDecryptPacket(packet)

                if not msg then
                    print("Rejected secure packet from:", tostring(sender), tostring(err))

                    if type(replyPublicKey) == "table" then
                        sendSecureReply(sender, {
                            action = "secure_error",
                            error = tostring(err)
                        }, replyPublicKey)
                    else
                        rednet.send(sender, {
                            action = "secure_error",
                            error = tostring(err)
                        }, ACCOUNT_PROTOCOL)
                    end
                else
                    print("Secure rednet received from:", sender)
                    print("Message:", safeSerialize(msg))

                    local reply = processCasinoMessage(sender, msg)

                    if type(replyPublicKey) == "table" then
                        sendSecureReply(sender, reply, replyPublicKey)
                    else
                        -- Fallback, should not be used by the new roulette/BJ code.
                        rednet.send(sender, reply, ACCOUNT_PROTOCOL)
                    end
                end

            else
                print("Rejected plaintext casino packet from:", tostring(sender))
                print("Packet:", safeSerialize(packet))

                rednet.send(sender, {
                    action = "secure_required",
                    error = "Account computer now requires encrypted packets. Send get_public_key first."
                }, ACCOUNT_PROTOCOL)
            end
        end
    end
end

