local function buildAccountList()
    local fileList = fs.list("/accounts")
    local accountList = {}

    for _, name in ipairs(fileList) do
        if type(name) == "string" and name:match("%.txt$") and not name:match("logs") then
            table.insert(accountList, name:gsub("%.txt$", ""))
        end
    end

    table.sort(accountList)
    return accountList
end

local function processCasinoMessage(sender, msg)
    if type(msg) ~= "table" then
        return {
            action = "error",
            error = "bad message"
        }
    end

    if msg.action == "get_Players" then
        return {
            action = "players_list",
            players = buildAccountList()
        }

    elseif msg.action == "get_balance" then
        return {
            action = "balance",
            player = msg.player,
            balance = getBalance(msg.player)
        }

    elseif msg.action == "transfer" then
        local okTransfer, reason = validateSecureTransfer(sender, msg)

        if not okTransfer then
            print("Rejected secure transfer:", tostring(reason))
            print("Sender:", tostring(sender))
            print("Message:", safeSerialize(msg))

            return {
                action = "transfer_rejected",
                player = msg.player,
                balance = getBalance(msg.player),
                error = tostring(reason)
            }
        end

        local delta = tonumber(msg.delta) or 0
        local old = getBalance(msg.player)
        local new = math.max(0, old + delta)
        local actualDelta = new - old

        setBalance(msg.player, new)
        logTransaction(msg.player, msg.note or "Secure Transfer", actualDelta)

        handleCasinoTransferForStats(msg.player, msg.note)

        return {
            action = "balance",
            player = msg.player,
            balance = new
        }

    elseif msg.action == "gamble_win_stat" then
        handleDirectGambleWinStat(msg)

        return {
            action = "stat_ack",
            ok = true
        }

    elseif msg.action == "list_accounts" then
        return {
            action = "accounts_list",
            accounts = buildAccountList()
        }

    elseif msg.action == "get_gamble_leaderboard" then
        local month = msg.month
        local limit = tonumber(msg.limit) or 10
        local list = getSortedWinLeaderboard(month)
        local trimmed = {}

        for i = 1, math.min(limit, #list) do
            table.insert(trimmed, list[i])
        end

        return {
            action = "gamble_leaderboard",
            month = month or "all_time",
            leaders = trimmed
        }
    end

    return {
        action = "error",
        error = "unknown action: " .. tostring(msg.action)
    }
end

