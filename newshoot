-- =========================================================
-- === Better RNG Helper
-- =========================================================

rngSpinCounter = 0

function reseedRouletteRNG()
    rngSpinCounter = rngSpinCounter + 1

    local epoch = 0
    if os.epoch then
        epoch = os.epoch("utc") or 0
    end

    local clockPart = math.floor((os.clock() or 0) * 1000000)
    local timePart = math.floor((os.time() or 0) * 100000)
    local idPart = os.getComputerID() or 0

    local seed =
        epoch
        + clockPart
        + timePart
        + (idPart * 7919)
        + (rngSpinCounter * 104729)

    seed = seed % 2147483647

    math.randomseed(seed)

    for i = 1, 32 do
        math.random()
    end

    print("Roulette RNG reseeded:", seed)
end

function rouletteRandom(minVal, maxVal)
    for i = 1, 5 do
        math.random()
    end

    return math.random(minVal, maxVal)
end

