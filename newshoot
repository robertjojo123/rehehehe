function getCountdownText(station)
    if roundState == "countdown" and countdownEndsAt then
        local remaining = math.max(0, math.ceil(countdownEndsAt - os.clock()))
        return "SPIN IN: " .. remaining

    elseif roundState == "spinning" then
        return "NO MORE BETS - SPINNING"

    elseif roundState == "payout" then
        if station and station.message and station.message:match("^Result") then
            return station.message
        end

        if lastResult then
            return "RESULT: " .. tostring(lastResult)
        end

        return "RESULT"

    else
        return tableMessage or "Bets open"
    end
end

function formatBetAmount(amount)
    return tostring(math.floor((amount or 0) / 100))
end

function shortZoneName(zone)
    zone = tostring(zone or "")

    if zone:sub(1, 6) == "split_" then
        return "SPL " .. zone:sub(7):gsub("_", "/")
    elseif zone:sub(1, 7) == "corner_" then
        return "COR " .. zone:sub(8):gsub("_", "/")
    elseif zone:sub(1, 7) == "street_" then
        return "STR " .. zone:sub(8):gsub("_", "/")
    elseif zone:sub(1, 4) == "six_" then
        return "SIX " .. zone:sub(5):gsub("_", "/")
    end

    return zone
end


function drawSingleStationBet(mon, x, y, stationIndex, amount)
    if not amount or amount <= 0 then return end

    local colorData = STATION_CHIP_COLORS[stationIndex]
    local textColor = colorData and colorData.slot or colors.white
    local text = formatBetAmount(amount)

    mon.setCursorPos(x, y)
    mon.setBackgroundColor(colors.black)
    mon.setTextColor(textColor)
    mon.write(text)
end

function drawBetTotals(mon, viewingStation)
    local viewingIndex = viewingStation and viewingStation.index or nil
    local stackOffsets = {0, 2, 3}

    for zone, positions in pairs(monitorHitboxes) do
        if not zone:match("chip_") and zone ~= "clear" and zone ~= "spin" then
            local center = positions[1]

            if center then
                local stationAmounts = {}
                local hasAny = false

                for i = 1, #STATIONS do
                    local amt = getStationZoneBet(i, zone)
                    stationAmounts[i] = amt

                    if amt > 0 then
                        hasAny = true
                    end
                end

                if hasAny then
                    local displayOrder = {}

                    if viewingIndex and stationAmounts[viewingIndex] and stationAmounts[viewingIndex] > 0 then
                        table.insert(displayOrder, viewingIndex)
                    end

                    for i = 1, #STATIONS do
                        if i ~= viewingIndex and stationAmounts[i] and stationAmounts[i] > 0 then
                            table.insert(displayOrder, i)
                        end
                    end

                    for displaySlot, stationIndex in ipairs(displayOrder) do
                        local offset = stackOffsets[displaySlot] or (displaySlot + 1)
                        local amount = stationAmounts[stationIndex]

                        drawSingleStationBet(
                            mon,
                            center[1],
                            center[2] + offset,
                            stationIndex,
                            amount
                        )
                    end
                end
            end
        end
    end
end

function writeClipped(mon, x, y, text, textColor, bgColor, maxWidth)
    text = tostring(text or "")
    maxWidth = maxWidth or 999

    local monW, monH = mon.getSize()
    if y < 1 or y > monH or x > monW then
        return
    end

    local available = math.min(maxWidth, monW - x + 1)
    if available < 1 then
        return
    end

    if #text > available then
        text = text:sub(1, available)
    end

    -- Important: do NOT pad with spaces.
    -- The frame is redrawn first every display refresh, so writing only the
    -- actual string avoids black/green bars cutting into the SPIN button/art.
    mon.setCursorPos(x, y)
    mon.setBackgroundColor(bgColor or colors.green)
    mon.setTextColor(textColor or colors.white)
    mon.write(text)
end

function betsSignatureForStation(stationIndex)
    local parts = {}

    for player, bets in pairs(placedBets) do
        if playerStationNumber[player] == stationIndex then
            for zone, amount in pairs(bets) do
                if amount and amount > 0 then
                    parts[#parts + 1] = tostring(zone) .. ":" .. tostring(amount)
                end
            end
        end
    end

    table.sort(parts)
    return table.concat(parts, "|")
end

function countdownBucket()
    if roundState == "countdown" and countdownEndsAt then
        return tostring(math.max(0, math.ceil(countdownEndsAt - os.clock())))
    end

    return ""
end

function stationSnapshot(station)
    local displayPlayer = getStationDisplayPlayer(station) or ""
    local bal = 0

    if displayPlayer ~= "" then
        bal = balances[displayPlayer] or station.balance or 0
    end

    return table.concat({
        roundState or "",
        countdownBucket(),
        tostring(lastResult or ""),
        tostring(tableMessage or ""),
        tostring(displayPlayer),
        tostring(station.activePlayer or ""),
        tostring(station.lockedPlayer or ""),
        tostring(bal),
        tostring(station.selectedChip or ""),
        tostring(station.message or ""),
        betsSignatureForStation(station.index)
    }, "\31")
end

function lastRollSnapshot()
    return table.concat(lastRolls or {}, "|")
end

markStationDirty = function(station)
    if station then
        lastStationSnapshots[station.index] = nil
    end
end

markAllStationsDirty = function()
    for _, station in ipairs(STATIONS) do
        markStationDirty(station)
    end
end

markLastRollsDirty = function()
    lastLastRollSnapshot = nil
end

function drawStation(station)
    local mon = station.monitor
    local displayPlayer = getStationDisplayPlayer(station)

    drawBackground(mon)

    -- Keep dynamic status tucked into the lower-left so it does not fight the table hitboxes.
    if displayPlayer then
        local bal = balances[displayPlayer] or station.balance or 0
        writeClipped(mon, 2, 35, "Bal: $" .. tostring(bal), colors.yellow, colors.green, 56)

        local chipText = station.selectedChip and ("Chip $" .. station.selectedChip) or "Select chip"
        local tableStateText = getCountdownText(station)

        writeClipped(mon, 2, 36, tostring(displayPlayer), colors.white, colors.green, 56)
        writeClipped(mon, 2, 37, chipText .. "    " .. tableStateText, colors.orange, colors.green, 56)
    else
        local tableStateText = getCountdownText(station)

        writeClipped(mon, 2, 35, "Stand at table", colors.yellow, colors.green, 56)
        writeClipped(mon, 2, 36, "No player", colors.white, colors.green, 56)
        writeClipped(mon, 2, 37, "Select chip    " .. tableStateText, colors.orange, colors.green, 56)
    end

    writeClipped(mon, 2, 38, station.message or "", colors.yellow, colors.green, 56)

    drawBetTotals(mon, station)
end

-- =========================================================
-- === Radar / Player Detection
-- =========================================================

function scanStation(station)
    local players = station.radar.getPlayers()
    local valid = {}
    local present = {}

    for _, p in ipairs(players) do
        if p.distance <= MAX_DISTANCE then
            present[p.name] = true
        end

        if p.distance >= MIN_DISTANCE and p.distance <= MAX_DISTANCE then
            table.insert(valid, p)
        end
    end

    table.sort(valid, function(a, b)
        return a.distance < b.distance
    end)

    if #valid == 1 then
        return valid[1].name, "", present
    elseif #valid > 1 then
        return nil, "Too many players!", present
    else
        return nil, "", present
    end
end

function getAllPresentPlayers()
    local present = {}

    for _, station in ipairs(STATIONS) do
        local _, _, stationPresent = scanStation(station)

        for player in pairs(stationPresent) do
            present[player] = true
        end
    end

    return present
end

function autoRefundLeftPlayers(present)
    if not autoRefundAllowed() then return end

    -- radarLoop passes a freshly built present map so we do not scan every
    -- radar twice per cycle. Fallback keeps this safe if called elsewhere.
    present = present or getAllPresentPlayers()

    for player in pairs(placedBets) do
        if not present[player] then
            refundPlayerBets(player, "ROULETTE AUTO-REFUND: left table before spin")
        end
    end
end

-- =========================================================
-- === Round Logic
-- =========================================================

function payAllPlayers(result)
    markAllStationsDirty()

    for player, bets in pairs(placedBets) do
        local totalPayout = 0
        local totalLost = 0

        for zone, amount in pairs(bets) do
            local won, mult = betWon(zone, result)

            if won then
                local payout = amount * mult
                totalPayout = totalPayout + payout

                local msg = "ROULETTE RESULT: WIN - bet $" .. amount
                    .. " on " .. shortZoneName(zone)
                    .. ", landed " .. result
                    .. ", payout $" .. payout

                logRoulette(player, msg)
                -- Account log suppressed here to reduce rednet spam; local log still records it.
            else
                totalLost = totalLost + amount

                local msg = "ROULETTE RESULT: LOSS - bet $" .. amount
                    .. " on " .. shortZoneName(zone)
                    .. ", landed " .. result

                logRoulette(player, msg)
                -- Account log suppressed here to reduce rednet spam; local log still records it.
            end
        end

        local station = getStationForPlayer(player)

        if totalPayout > 0 then
            local resultMsg = "Result " .. result .. ": paying $" .. totalPayout
            setStationMessageForPlayer(player, resultMsg)

            if station then
                station.message = resultMsg
            end

            playStationWinSound(station)

            if station then
                parallel.waitForAny(
                    function() burstParticlesAt(station.index, true) end,
                    function() sleep(PARTICLE_MAX_SECONDS) end
                )
            end

            sendBalanceChange(
                player,
                totalPayout,
                "ROULETTE WIN PAYOUT: $" .. totalPayout .. ", landed " .. result
            )

            balances[player] = refreshBalanceThrottled(player, true)
        else
            local resultMsg = "Result " .. result .. ": lost $" .. totalLost
            setStationMessageForPlayer(player, resultMsg)

            if station then
                station.message = resultMsg
            end

            playStationLoseSound(station)

            if station then
                parallel.waitForAny(
                    function() burstParticlesAt(station.index, false) end,
                    function() sleep(PARTICLE_MAX_SECONDS) end
                )
            end
        end

        refreshStationBalanceForPlayer(player)
    end
end

function startCountdown(player, station)
    if roundState == "open" then
        -- Lock only the player who pressed SPIN to that terminal during countdown.
        -- They can still clear/undo until the countdown ends and bets hard-lock.
        if station and player and getPlayerTotalBet(player) > 0 then
            station.lockedPlayer = player
            playerLastStation[player] = station
            playerStationNumber[player] = station.index
        end

        roundState = "countdown"
        countdownEndsAt = os.clock() + COUNTDOWN_SECONDS
        tableMessage = "Spin countdown started"
        markAllStationsDirty()

    elseif roundState == "countdown" then
        if station then
            station.message = "Spin already starting!"
        end
    else
        if station then
            station.message = "Wheel is locked."
        end
    end
end

function roundLoop()
    while true do
        heartbeat("round")

        if roundState == "countdown" and countdownEndsAt and os.clock() >= countdownEndsAt then
            lockCurrentBettingPlayersToStations()

            roundState = "spinning"
            tableMessage = "No more bets!"
            markAllStationsDirty()

            local result, err = runLocalSpin()

            if result then
                lastResult = tostring(result)
                addLastRoll(lastResult)

                roundState = "payout"
                tableMessage = "Result: " .. lastResult
                markAllStationsDirty()

                payAllPlayers(lastResult)
                sleep(RESULT_DISPLAY_SECONDS)

                clearAllBets()
                tableMessage = "Bets open"
                lastResult = nil
                countdownEndsAt = nil
                markAllStationsDirty()

                sleep(RESET_DELAY_SECONDS)

                roundState = "open"
                clearStationLocks()
                markAllStationsDirty()
            else
                tableMessage = err or "Spin failed - refunding"

                for player in pairs(placedBets) do
                    refundPlayerBets(player, "ROULETTE REFUND: spin failed")
                end

                clearAllBets()
                lastResult = nil
                countdownEndsAt = nil
                roundState = "open"
                clearStationLocks()
                markAllStationsDirty()
            end
        end

        sleep(0.15)
    end
end

-- =========================================================
-- === Touch Handling
-- =========================================================

function findStationByMonitorName(name)
    for _, station in ipairs(STATIONS) do
        if station.monitorName == name then
            return station
        end

        if station.touchAliases then
            for _, alias in ipairs(station.touchAliases) do
                if alias == name then
                    return station
                end
            end
        end
    end

    return nil
end

function placeBet(station, zone)
    if not station.activePlayer then return end

    if not bettingOpen() then
        station.message = "Bets are locked."
        return
    end

    if not station.selectedChip then
        station.message = "Select a chip first."
        return
    end

    local player = station.activePlayer
    local chip = station.selectedChip
    local balance = balances[player] or station.balance or 0

    if balance < chip then
        station.message = "Not enough balance."
        return
    end

    local stationIndex = station.index

    local zoneMax = getZoneMax(zone)
    local stationZoneCurrent = getStationZoneBet(stationIndex, zone)
    local zoneAvailable = math.max(0, zoneMax - stationZoneCurrent)

    local payoutCapAvailable = getMaxAllowedByPayoutCap(stationIndex, zone)

    local allowable = math.min(chip, zoneAvailable, payoutCapAvailable)

    if allowable <= 0 then
        if zoneAvailable <= 0 then
            station.message = "Your zone max reached."
        elseif payoutCapAvailable <= 0 then
            station.message = "Max payout reached."
        else
            station.message = "No more allowed here."
        end
        return
    end

    local newBal = sendBalanceChange(
        player,
        -allowable,
        "ROULETTE BET: $" .. allowable .. " on " .. shortZoneName(zone)
    )

    balances[player] = newBal
    station.balance = newBal

    placedBets[player] = placedBets[player] or {}
    placedBets[player][zone] = (placedBets[player][zone] or 0) + allowable

    betHistory[player] = betHistory[player] or {}
    table.insert(betHistory[player], {
        zone = zone,
        amount = allowable
    })

    playerLastStation[player] = station
    playerStationNumber[player] = station.index

    if roundState == "countdown" then
        station.lockedPlayer = player
    end

    logRoulette(player, "BET: $" .. allowable .. " on " .. shortZoneName(zone))

    if allowable < chip then
        station.message = "Only $" .. allowable .. " allowed."
    else
        station.message = "Placed $" .. allowable .. " on " .. shortZoneName(zone)
    end

    markStationDirty(station)
end

function undoLastBet(station)
    if not station.activePlayer then return end

    if not bettingOpen() then
        station.message = "Bets are locked."
        return
    end

    local player = station.activePlayer
    local history = betHistory[player]

    if not history or #history <= 0 then
        station.message = "No bet to undo."
        return
    end

    local lastBet = table.remove(history)
    local zone = lastBet.zone
    local amount = lastBet.amount or 0

    if amount <= 0 or not zone then
        station.message = "Undo failed."
        return
    end

    if placedBets[player] and placedBets[player][zone] then
        placedBets[player][zone] = placedBets[player][zone] - amount

        if placedBets[player][zone] <= 0 then
            placedBets[player][zone] = nil
        end

        local hasAny = false
        for _, amt in pairs(placedBets[player]) do
            if amt and amt > 0 then
                hasAny = true
                break
            end
        end

        if not hasAny then
            placedBets[player] = nil
        end
    end

    if #history <= 0 then
        betHistory[player] = nil
    end

    local newBal = sendBalanceChange(
        player,
        amount,
        "ROULETTE UNDO BET: refunded $" .. amount .. " from " .. shortZoneName(zone)
    )

    balances[player] = newBal
    station.balance = newBal

    logRoulette(player, "UNDO BET: refunded $" .. amount .. " from " .. shortZoneName(zone))

    station.message = "Undid $" .. amount .. " on " .. shortZoneName(zone)

    if getPlayerTotalBet(player) <= 0 and station.lockedPlayer == player and roundState == "countdown" then
        station.lockedPlayer = nil
    end

    markStationDirty(station)
end

function clearPlayerBets(station)
    if not station.activePlayer then return end

    if not bettingOpen() then
        station.message = "Bets are locked."
        return
    end

    local player = station.activePlayer
    local refund = refundPlayerBets(player, "ROULETTE REFUND: cleared bets")
    betHistory[player] = nil

    if refund > 0 then
        station.balance = balances[station.activePlayer] or requestBalance(station.activePlayer)
        station.message = "Refunded $" .. refund

        if station.lockedPlayer == player and roundState == "countdown" then
            station.lockedPlayer = nil
        end
    else
        station.message = "No bets to clear."
    end

    markStationDirty(station)
end

function handleStationTouch(station, x, y)
    if not station.activePlayer then
        station.message = "Stand at this station."
        return
    end

    playerLastStation[station.activePlayer] = station
    playerStationNumber[station.activePlayer] = station.index

    if FORCE_BALANCE_REFRESH_ON_TOUCH then
        local now = os.clock()
        local last = lastBalanceRefreshAt[station.activePlayer] or 0
        local force = (now - last) >= TOUCH_BALANCE_REFRESH_SECONDS

        station.balance = refreshBalanceThrottled(station.activePlayer, force)
        balances[station.activePlayer] = station.balance
    end

    local zone = getZoneAt(x, y)
    if not zone then return end

    if zone:match("chip_") then
        local val = tonumber(zone:match("chip_(%d+)"))

        if val and (balances[station.activePlayer] or 0) >= val then
            station.selectedChip = val
            station.message = "Selected chip $" .. val
        else
            station.message = "Not enough for $" .. tostring(val or "?")
        end

    elseif zone == "clear" then
        clearPlayerBets(station)

    elseif zone == "undo" then
        undoLastBet(station)

    elseif zone == "spin" then
        if getTotalTableBet() <= 0 then
            station.message = "No bets on table."
        else
            startCountdown(station.activePlayer, station)
            station.message = "Spin countdown started."
        end

    else
        placeBet(station, zone)
    end

    markStationDirty(station)
end

function touchLoop()
    while true do
        heartbeat("touch")
        local _, monitorName, x, y = os.pullEvent("monitor_touch")
        local station = findStationByMonitorName(monitorName)

        if station then
            handleStationTouch(station, x, y)
        else
            print("Unmatched monitor_touch from: " .. tostring(monitorName) .. " at " .. x .. "," .. y)
        end

        sleep(0.03)
    end
end

-- =========================================================
-- === Main Loops
-- =========================================================

function radarLoop()
    while true do
        heartbeat("radar")

        local presentAtTable = {}

        for _, station in ipairs(STATIONS) do
            local oldActive = station.activePlayer
            local oldLocked = station.lockedPlayer
            local oldMessage = station.message
            local oldChip = station.selectedChip
            local oldBalance = station.balance

            local player, status, present = scanStation(station)

            for seenPlayer in pairs(present or {}) do
                presentAtTable[seenPlayer] = true
            end

            if player then
                playerLastStation[player] = station
                playerStationNumber[player] = station.index

                if station.activePlayer ~= player then
                    station.activePlayer = player
                    station.lastPlayer = player

                    -- Balance refresh happens on enter. Do not poll every radar tick.
                    station.balance = refreshBalanceThrottled(player, true)
                    balances[player] = station.balance
                    station.selectedChip = nil

                    if not station.lockedPlayer then
                        station.message = "Welcome, " .. player
                    end
                end
            else
                station.activePlayer = nil

                if not station.lockedPlayer then
                    station.balance = 0
                    station.selectedChip = nil

                    if status and status ~= "" then
                        station.message = status
                    end
                end
            end

            if oldActive ~= station.activePlayer
                or oldLocked ~= station.lockedPlayer
                or oldMessage ~= station.message
                or oldChip ~= station.selectedChip
                or oldBalance ~= station.balance then
                markStationDirty(station)
            end

            sleepYield(0)
        end

        autoRefundLeftPlayers(presentAtTable)

        sleep(RADAR_SCAN_SECONDS)
    end
end

function displayLoop()
    local lastRollDrawAt = 0

    while true do
        heartbeat("display")

        for _, station in ipairs(STATIONS) do
            local snap = stationSnapshot(station)

            if lastStationSnapshots[station.index] ~= snap then
                drawStation(station)
                lastStationSnapshots[station.index] = snap
                sleepYield(0)
            end
        end

        local now = os.clock()
        local lrSnap = lastRollSnapshot()

        if lastLastRollSnapshot ~= lrSnap and now - lastRollDrawAt >= LAST_ROLL_REFRESH_SECONDS then
            drawLastRollMonitors()
            lastLastRollSnapshot = lrSnap
            lastRollDrawAt = now
        end

        sleep(DISPLAY_CHECK_SECONDS)
    end
end

-- =========================================================
-- === Task Watchdog / Safe Restart Helpers
-- =========================================================

function watchdogLoop()
    -- Give other loops time to start.
    sleep(STARTUP_STEP_DELAY * 8)

    while true do
        if WATCHDOG_ENABLED then
            local now = os.clock()

            for _, name in ipairs({"radar", "display", "touch", "lamps", "round"}) do
                local last = taskHeartbeat[name]

                if last and now - last > WATCHDOG_SECONDS then
                    print("[WATCHDOG] Task '" .. name .. "' stalled for "
                        .. string.format("%.1f", now - last)
                        .. "s. Rebooting.")
                    sleep(0.5)
                    os.reboot()
                end
            end
        end

        sleep(WATCHDOG_CHECK_SECONDS)
    end
end

function runWatchedTask(name, fn, startupDelay)
    return function()
        if startupDelay and startupDelay > 0 then
            sleep(startupDelay)
        end

        heartbeat(name)

        while true do
            local ok, err = pcall(fn)

            if not ok then
                taskFailures[name] = (taskFailures[name] or 0) + 1
                print("[TASK ERROR] " .. name .. ": " .. tostring(err))

                if AUTO_REBOOT_ON_TASK_ERROR then
                    print("[TASK ERROR] Rebooting after " .. name .. " failure.")
                    sleep(0.75)
                    os.reboot()
                end

                sleep(1)
            else
                -- Most task functions are infinite loops. If one returns,
                -- restart it after a small delay rather than leaving the table half-dead.
                print("[TASK RETURNED] " .. name .. " returned; restarting.")
                sleep(1)
            end
        end
    end
end

