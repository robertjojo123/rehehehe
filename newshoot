-- =========================================================
-- === Particle Turtle Win/Loss Effects
-- =========================================================
-- Blackjack-style particle code: simple spawn(name,x,y,z), no velocity args.
-- This matches the method that worked on the blackjack turtle.
-- Ender modem is on MODEM_SIDE = "right"; particle peripheral is on LEFT.

PARTICLES_ENABLED = true
PARTICLE_SIDE = "left"
PARTICLE_DEBUG = DEBUG_PARTICLES

-- Working particle names from blackjack.
PARTICLE_WIN = "happyVillager"
PARTICLE_LOSE = "reddust"

-- Relative origins from the turtle.
-- y=6 means the effect begins 6 blocks above the turtle.
STATION_PARTICLE_POS = {
    [1] = {x = 0,   y = 6, z = -14},
    [2] = {x = -10, y = 6, z = -10},
    [3] = {x = -10, y = 6, z = 0},
}

particlePeripheral = nil
particleSpawnFailCount = 0

function getParticlePeripheral()
    if particlePeripheral then
        return particlePeripheral
    end

    local p = peripheral.wrap(PARTICLE_SIDE)
    if p and type(p.spawn) == "function" then
        particlePeripheral = p
        if PARTICLE_DEBUG then
            print("[FX] particle peripheral found on " .. PARTICLE_SIDE)
        end
        return particlePeripheral
    end

    for _, name in ipairs(peripheral.getNames()) do
        local wrapped = peripheral.wrap(name)
        if wrapped and type(wrapped.spawn) == "function" then
            particlePeripheral = wrapped
            if PARTICLE_DEBUG then
                print("[FX] particle peripheral found on " .. tostring(name))
            end
            return particlePeripheral
        end
    end

    if PARTICLE_DEBUG then
        print("[FX] no particle peripheral with spawn() found")
    end

    return nil
end

function spawnFxParticle(name, x, y, z)
    local p = getParticlePeripheral()
    if not p then return false end

    -- Blackjack-proven spawn pattern first. Keep these simple/stationary.
    local attempts = {
        function() return p.spawn(name, x, y, z) end,
        function() return p.spawn(name, x, y, z, 0, 0, 0) end,
        function() return p.spawn(name, x, y, z, 0, 0, 0, 0) end,
        function() return p.spawn(name, x, y, z, 0, 0, 0, 0, 1) end,
    }

    for _, attempt in ipairs(attempts) do
        local ok = pcall(attempt)
        if ok then return true end
    end

    particleSpawnFailCount = particleSpawnFailCount + 1
    if PARTICLE_DEBUG and particleSpawnFailCount <= 8 then
        print("[FX] spawn failed for " .. tostring(name) .. " at "
            .. tostring(x) .. "," .. tostring(y) .. "," .. tostring(z))
    end

    return false
end

function burstParticlesAt(stationIndex, won)
    if not PARTICLES_ENABLED then return end

    local pos = STATION_PARTICLE_POS[tonumber(stationIndex)]
    if not pos then
        if PARTICLE_DEBUG then print("[FX] no config for station " .. tostring(stationIndex)) end
        return
    end

    local particle = won and PARTICLE_WIN or PARTICLE_LOSE
    local particleFallback = won and "villagerHappy" or "smoke"

    if PARTICLE_DEBUG then
        print("[FX] " .. (won and "WIN" or "LOSE")
            .. " burst station=" .. tostring(stationIndex)
            .. " particle=" .. tostring(particle)
            .. " origin=" .. pos.x .. "," .. pos.y .. "," .. pos.z)
    end

    -- Small visible burst: a few rings around the target area.
    -- No velocity args, so it behaves like blackjack's visible particle method.
    local totalSpawned = 0

    for ring = 1, 2 do
        local radius = 0.35 + (ring * 0.22)
        local dots = 8 + (ring * 3)

        for i = 1, dots do
            local angle = (i / dots) * math.pi * 2
            local x = pos.x + math.cos(angle) * radius
            local y = pos.y + ((ring - 1) * 0.35)
            local z = pos.z + math.sin(angle) * radius

            if spawnFxParticle(particle, x, y, z) then
                totalSpawned = totalSpawned + 1
            else
                -- Try alternate legacy name if primary silently fails on this pack.
                if spawnFxParticle(particleFallback, x, y, z) then
                    totalSpawned = totalSpawned + 1
                end
            end
        end

        sleep(0.03)
    end

    -- Center sparkle/smoke column so it is obvious even if the ring is hard to see.
    for i = 1, 8 do
        local y = pos.y + ((i % 6) * 0.22)
        if spawnFxParticle(particle, pos.x, y, pos.z) then
            totalSpawned = totalSpawned + 1
        else
            if spawnFxParticle(particleFallback, pos.x, y, pos.z) then
                totalSpawned = totalSpawned + 1
            end
        end
        sleep(0.02)
    end

    if PARTICLE_DEBUG then
        print("[FX] spawned visible burst count=" .. tostring(totalSpawned))
    end
end

