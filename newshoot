    ["9"] = colors.lightBlue,

    a = colors.purple,
    b = colors.gray,
    c = DARK_BUTTON_BG,
    d = colors.red,
    e = colors.green,
    f = colors.white
}

BLIT_BY_COLOR = {
    [colors.white] = "0",
    [colors.orange] = "1",
    [colors.magenta] = "2",
    [colors.lightBlue] = "3",
    [colors.yellow] = "4",
    [colors.lime] = "5",
    [colors.pink] = "6",
    [colors.gray] = "7",
    [colors.lightGray] = "8",
    [colors.cyan] = "9",
    [colors.purple] = "a",
    [colors.blue] = "b",
    [colors.brown] = "c",
    [colors.green] = "d",
    [colors.red] = "e",
    [colors.black] = "f"
}

function colorToBlit(color)
    return BLIT_BY_COLOR[color or colors.white] or "0"
end

function sixelChar(mask)
    if mask > 31 then
        return string.char(0x80 + (63 - mask)), true
    end

    return string.char(0x80 + mask), false
end

function splitLines(text)
    local lines = {}
    text = tostring(text or ""):gsub("\r\n", "\n"):gsub("\r", "\n")

    for line in (text .. "\n"):gmatch("(.-)\n") do
        table.insert(lines, line)
    end

    while #lines > 0 and lines[#lines] == "" do
        table.remove(lines)
    end

    return lines
end

function loadSubpixelFrame(path)
    local file = fs.open(path, "r")
    if not file then
        error("Could not open " .. path .. ". Save your 114x114 art as frame.txt on this computer.")
    end

    local raw = file.readAll()
    file.close()

    local lines = splitLines(raw)
    if #lines < 2 then
        error(path .. " is too short.")
    end

    local width, height = lines[1]:match("^(%d+)%s+(%d+)$")
    width = tonumber(width)
    height = tonumber(height)

    if not width or not height then
        error("First line of " .. path .. " must be like: 114 114")
    end

    if width % 2 ~= 0 or height % 3 ~= 0 then
        error(path .. " must be sized for 2x3 packing. Got " .. width .. "x" .. height)
    end

    local grid = {}

    for y = 1, height do
        local row = lines[y + 1] or ""
        if #row < width then
            row = row .. string.rep("e", width - #row)
        end

        grid[y] = {}

        for x = 1, width do
            local ch = row:sub(x, x)
            grid[y][x] = FRAME_COLOR[ch] or colors.green
        end
    end

    return {
        width = width,
        height = height,
        grid = grid
    }
end

backgroundFrame = loadSubpixelFrame(FRAME_FILE)

function drawPackedFrame(mon, frame)
    local grid = frame.grid
    local charW = math.floor(frame.width / 2)
    local charH = math.floor(frame.height / 3)
    local bitValues = {1, 2, 4, 8, 16, 32}

    for cy = 1, charH do
        local chars = {}
        local fgs = {}
        local bgs = {}

        for cx = 1, charW do
            local pts = {
                grid[(cy - 1) * 3 + 1][(cx - 1) * 2 + 1],
                grid[(cy - 1) * 3 + 1][(cx - 1) * 2 + 2],
                grid[(cy - 1) * 3 + 2][(cx - 1) * 2 + 1],
                grid[(cy - 1) * 3 + 2][(cx - 1) * 2 + 2],
                grid[(cy - 1) * 3 + 3][(cx - 1) * 2 + 1],
                grid[(cy - 1) * 3 + 3][(cx - 1) * 2 + 2],
            }

            local counts = {}
            local ordered = {}

            for i = 1, 6 do
                local color = pts[i]
                local key = tostring(color)

                if not counts[key] then
                    counts[key] = {
                        color = color,
                        count = 0,
                        first = i
                    }

                    table.insert(ordered, counts[key])
                end

                counts[key].count = counts[key].count + 1
            end

            table.sort(ordered, function(a, b)
                if a.count == b.count then
                    return a.first < b.first
                end

                return a.count > b.count
            end)

            local bg = ordered[1].color
            local fg = ordered[2] and ordered[2].color or bg

            local mask = 0

            if fg ~= bg then
                for i = 1, 6 do
                    if pts[i] == fg then
                        mask = mask + bitValues[i]
                    end
                end
            end

            if mask == 0 then
                table.insert(chars, " ")
                table.insert(fgs, colorToBlit(bg))
                table.insert(bgs, colorToBlit(bg))
            else
                local ch, inverted = sixelChar(mask)

                table.insert(chars, ch)

                if inverted then
                    table.insert(fgs, colorToBlit(bg))
                    table.insert(bgs, colorToBlit(fg))
                else
                    table.insert(fgs, colorToBlit(fg))
                    table.insert(bgs, colorToBlit(bg))
                end
            end
        end

        mon.setCursorPos(1, cy)
        mon.blit(table.concat(chars), table.concat(fgs), table.concat(bgs))
    end
end

function drawBackground(mon)
    if mon.setPaletteColor then
        pcall(function()
            mon.setPaletteColor(DARK_BUTTON_BG, DARK_BUTTON_BG_HEX)
        end)
    end

    mon.setBackgroundColor(colors.green)
    mon.clear()
    drawPackedFrame(mon, backgroundFrame)
end

