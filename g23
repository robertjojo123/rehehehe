-- Set this to the closest sensible range. Smaller = less lag.
local senseRange = 24

-- Laser settings.
local attackRange = 15
local laserPotency = 0.5
local attackDelay = 0.20

-- Owner follow settings.
local followOwner = true
local followDistance = 6

-- Print nearby non-whitelisted entities every X seconds.
local printSeenEntities = true
local printEverySeconds = 2.0

-- If true, it will shoot likely-player names even if the sensor does not provide
-- an explicit player/entity type. This helps older Plethora versions where players
-- may only show as name/displayName.
--
-- If you want the safest "only confirmed players" behavior, set this false.
local allowNameHeuristicPlayerTargeting = true

-- If true, it will never shoot unless the entity is inside attackRange AND looks
-- like a player. Keep true.
local playerOnlyTargeting = true

