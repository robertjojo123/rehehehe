-- First message should be WS_VIDEO_OK because the server accepts immediately.
local hello = ws.receive()
if hello ~= "WS_VIDEO_OK" then
    print("Unexpected WS hello:")
    print(tostring(hello))
    waitKey()
    return
end

clearTerm()
print("Prebuffering WebSocket video...")
print("Target frames: " .. tostring(VIDEO_PREBUFFER_FRAMES))

local frameBuffer = {}
local streamEndedEarly = false
local streamEndReason = nil

while #frameBuffer < VIDEO_PREBUFFER_FRAMES do
    local frame, reason = readWsFrame(ws)
    if not frame then
        streamEndedEarly = true
        streamEndReason = reason
        break
    end

    frameBuffer[#frameBuffer + 1] = frame

    if #frameBuffer % 5 == 0 then
        clearTerm()
        print("Prebuffering WebSocket video...")
        print("Frames: " .. tostring(#frameBuffer) .. "/" .. tostring(VIDEO_PREBUFFER_FRAMES))
    end

    sleep(0)
end

if #frameBuffer == 0 then
    print("No frames buffered: " .. tostring(streamEndReason))
    waitKey()
    return
end

clearTerm()
print("Buffered " .. tostring(#frameBuffer) .. " frame(s).")
print("Starting tape + WebSocket video...")
sleep(0.05)

startTape(tape, man.tape_speed or 1.0)
local playback = makePlaybackClock(tape, man.tape_speed or 1.0, DEFAULT_FPS)

local function presentFrame(frame)
    if not frame then return end
    waitForFrame(playback, frame.number)
    drawFrame(mon, frame)
    playback.frames = frame.number
    playback.rendered = playback.rendered + 1
end

local function drawNow(frame)
    if not frame then return end
    drawFrame(mon, frame)
    playback.frames = frame.number
    playback.rendered = playback.rendered + 1
end

local function nextBufferedOrWs()
    if frameBuffer and #frameBuffer > 0 then
        return table.remove(frameBuffer, 1), nil
    end
    if streamEndedEarly then
        return nil, streamEndReason
    end
    return readWsFrame(ws)
end

local currentFrame, currentErr = nextBufferedOrWs()

while currentFrame do
    if not CLOCK_SKIP_RENDER then
        presentFrame(currentFrame)
        currentFrame, currentErr = nextBufferedOrWs()
        sleep(0)
    else
        local target = currentTargetFrame(playback)
        local latest = nil
        local drained = 0

        -- Drain old frames without drawing them. This is the key fix.
        while currentFrame and currentFrame.number <= (target + LATE_FRAME_TOLERANCE) and drained < MAX_PACKET_DRAIN_PER_DRAW do
            latest = currentFrame
            currentFrame, currentErr = nextBufferedOrWs()
            drained = drained + 1
            target = currentTargetFrame(playback)
        end

        if latest then
            drawNow(latest)
        elseif currentFrame then
            -- We are ahead of audio. Wait until this frame is due, then draw it.
            presentFrame(currentFrame)
            currentFrame, currentErr = nextBufferedOrWs()
        end

        sleep(0)
    end
end

if currentErr then
    clearTerm()
    print("Video stream ended: " .. tostring(currentErr))
end

pcall(function() ws.close() end)

clearTerm()
print("Done.")
print("Frames rendered: " .. tostring(playback.rendered))
print("Last frame: " .. tostring(playback.frames))
print("Tape clock: " .. tostring(playback.useTapeClock))
print("BPS1x: " .. tostring(playback.bps1x))
print("Offset ms: " .. tostring(AUDIO_VIDEO_OFFSET_MS))
waitKey()
