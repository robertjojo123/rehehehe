local ni = peripheral.find("neuralInterface")
if not ni then error("Neural Interface not found") end

local label = tostring(os.getComputerLabel() or ""):lower()
local identity = PIECE_BY_LABEL[label]

if not identity then
    error("Unknown piece label '" .. tostring(os.getComputerLabel()) .. "'.")
end

local PIECE_LABEL = label
local PIECE_ID = identity.pieceId
local PIECE_KIND = identity.kind
local PIECE_SIDE = identity.side

local START_FILE = identity.file
local START_RANK = identity.rank
local START_SQUARE = identity.square

local currentFile = START_FILE
local currentRank = START_RANK
local currentSquare = START_SQUARE

local pendingCapture = false
local pendingCapturedPiece = nil
local pendingTargetVector = nil
