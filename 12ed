local function suppressAI()
    local attempts = {
        function() return callIfExists(ni, "disableAI") end,
        function() return callIfExists(ni, "setAI", false) end,
        function() return callIfExists(ni, "setNoAI", true) end,
        function() return callIfExists(ni, "setMobAI", false) end,
        function() return callIfExists(ni, "setEntityAI", false) end,
        function() return callIfExists(ni, "clearTarget") end,
        function() return callIfExists(ni, "setTarget", nil) end,
    }

    local worked = false
    for _, fn in ipairs(attempts) do
        local ok = fn()
        if ok then worked = true end
    end
    return worked
end

local function facePositiveZ()
    local attempts = {
        function() return callIfExists(ni, "look", 0, 0) end,
        function() return callIfExists(ni, "setYaw", 0) end,
        function() return callIfExists(ni, "face", 0, 0, 1) end,
        function() return callIfExists(ni, "lookAt", 0, 0, 10) end,
    }

    for _, fn in ipairs(attempts) do
        local ok = fn()
        if ok then return true end
    end
    return false
end


local function findCaptureTargetEntity()
    -- Choose an entity near the INTENDED destination square/line, not just the nearest entity.
    -- This prevents the attacker from firing through or at unrelated nearby pieces.
    if not pendingTargetVector then return nil, nil, "no target vector" end

    local tx = tonumber(pendingTargetVector.x) or 0
    local ty = tonumber(pendingTargetVector.y) or 0
    local tz = tonumber(pendingTargetVector.z) or 0

    local targetDist = math.sqrt(tx * tx + ty * ty + tz * tz)
    if targetDist < 0.01 then return nil, nil, "target vector too small" end

    local ok, entities = pcall(function()
        return ni.sense(ATTACK_SENSE_RANGE)
    end)
    if not ok or type(entities) ~= "table" then return nil, nil, "sense failed" end

    local ux, uy, uz = tx / targetDist, ty / targetDist, tz / targetDist

    local best, bestScore = nil, 999999
    local bestDebug = nil

    for _, e in ipairs(entities) do
        local name = lower(cleanName(e))
        local internal = lower(e.name or "")

        local isBoat = name:find("boat", 1, true) or internal:find("boat", 1, true)
        local isItem = name:find("item", 1, true) or internal:find("item", 1, true)
        local isXp = name:find("xp", 1, true) or internal:find("xp", 1, true)

        if not isBoat and not isItem and not isXp then
            local ex = tonumber(e.x) or 0
            local ey = tonumber(e.y) or 0
            local ez = tonumber(e.z) or 0

            -- Projection of entity onto intended shot line.
            local along = ex * ux + ey * uy + ez * uz

            -- Perpendicular distance to shot line.
            local px = ex - ux * along
            local py = ey - uy * along
            local pz = ez - uz * along
            local lineD = math.sqrt(px * px + py * py + pz * pz)

            -- Distance to intended destination point.
            local destD = math.sqrt((ex - tx)^2 + (ey - ty)^2 + (ez - tz)^2)

            -- Must be in front of us, close to the line, and close to the intended destination.
            if along > 0
                and along <= ATTACK_LOS_RANGE
                and lineD <= ATTACK_LINE_WIDTH
                and destD <= ATTACK_ENTITY_RADIUS_AT_TARGET then

                -- Score favors closest to intended destination, then closest to line.
                local score = destD * 10 + lineD
                if score < bestScore then
                    best = e
                    bestScore = score
                    bestDebug = {
                        along = along,
                        lineD = lineD,
                        destD = destD,
                        name = cleanName(e),
                    }
                end
            end
        end
    end

    if best then
        return best, bestDebug and bestDebug.destD or nil, bestDebug
    end

    return nil, nil, "no entity on intended line/target square"
end

local function tryAttackPulse()
    -- Uses your working shooter guide:
    --   local yaw, pitch = getYawPitch(dx, 0.5-dy, dz)
    --   ni.fire(yaw, pitch, potency)
    --
    -- Still refuses to fire unless the target is the intended capture-square entity
    -- found by the LOS/target-square filter.
    local target, dist, debugInfo = findCaptureTargetEntity()
    if not target then
        return false, tostring(debugInfo or "no lined-up target")
    end

    local dx = tonumber(target.x) or 0
    local dy = tonumber(target.y) or 0
    local dz = tonumber(target.z) or 0

    local yaw, pitch = getLaserYawPitch(dx, 0.5 - dy, dz)

    local ok, err = pcall(function()
        return ni.fire(yaw, pitch, LASER_FULL_POWER)
    end)
    if ok then return true end

    -- Fallbacks only if this specific Plethora build exposes a different laser name.
    local attempts = {
        function() return callIfExists(ni, "fireLaser", yaw, pitch, LASER_FULL_POWER) end,
        function() return callIfExists(ni, "laser", yaw, pitch, LASER_FULL_POWER) end,
        function() return callIfExists(ni, "shoot", yaw, pitch, LASER_FULL_POWER) end,
    }

    for _, fn in ipairs(attempts) do
        local ok2 = fn()
        if ok2 then return true end
    end

    return false, tostring(err or "ni.fire yaw/pitch failed")
end

local function performAttackIfNeeded()
    if not pendingCapture then return end

    currentAction = "attack"
    print("Attack move: waiting for intended target line. Expected piece:", tostring(pendingCapturedPiece))

    sendToController({
        type = "piece_attack_aiming",
        targetSquare = currentSquare,
        capturedPiece = pendingCapturedPiece,
        targetVector = pendingTargetVector,
    })

    local started = os.clock()
    local target, targetDist, debugInfo = nil, nil, nil

    while os.clock() - started < ATTACK_WAIT_TIMEOUT do
        target, targetDist, debugInfo = findCaptureTargetEntity()
        if target then break end
        sleep(0.10)
    end

    if not target then
        print("Attack aborted/no shot: no intended target in line.")
        sendToController({
            type = "piece_attack_no_target",
            capturedPiece = pendingCapturedPiece,
            detail = tostring(debugInfo or "no lined-up target"),
        })
        return
    end

    print("Attack target lined up:", cleanName(target), "distToTargetSquare:", tostring(targetDist))

    sendToController({
        type = "piece_attack_started",
        targetSquare = currentSquare,
        capturedPiece = pendingCapturedPiece,
        sawEntity = true,
        entityDistance = targetDist,
        detail = type(debugInfo) == "table" and textutils.serialize(debugInfo) or tostring(debugInfo),
    })

    for i = 1, ATTACK_PULSES do
        local ok, err = tryAttackPulse()
        if not ok then
            print("Attack pulse failed:", tostring(err))
        end
        sleep(ATTACK_PULSE_DELAY)
    end

    sendToController({
        type = "piece_attack_finished",
        capturedPiece = pendingCapturedPiece,
    })
end

-- =========================================================
-- Boat sensing and coordinate mapping
-- =========================================================

local lastBoat = nil
local lastBoatScan = -999

local function findReferenceBoat()
    local ok, entities = pcall(function()
        return ni.sense(SENSE_RANGE)
    end)

    if not ok or type(entities) ~= "table" then
        return nil, "sense failed"
    end

    local best = nil
    local bestDist = 999999

    for _, e in ipairs(entities) do
        local display = lower(cleanName(e))
        local internal = lower(e.name or "")

        if display:find(BOAT_NAME_CONTAINS, 1, true) or internal:find(BOAT_NAME_CONTAINS, 1, true) then
            local x = tonumber(e.x) or 0
            local y = tonumber(e.y) or 0
            local z = tonumber(e.z) or 0
            local d = dist3(x, y, z)

            if d < bestDist then
                best = {x=x, y=y, z=z, name=cleanName(e), dist=d}
                bestDist = d
            end
        end
    end

    if not best then return nil, "no boat found" end
    return best
end

local function getBoat()
    local now = os.clock()

    if lastBoat and now - lastBoatScan < BOAT_RESCAN_SECONDS then
        return lastBoat
    end

    local boat, err = findReferenceBoat()
    lastBoatScan = now

    if boat then
        lastBoat = boat
        return boat
    end

    return nil, err
end

local function targetRelativeFromBoat(boat)
    -- Boat is A1 / 1,1.
    -- Rotated coordinate map:
    --   rank +1 => X -2
    --   file +1 => Z -2
    local worldXOffset = -((currentRank - 1) * SQUARE_SIZE)
    local worldZOffset = -((currentFile - 1) * SQUARE_SIZE)

    return {
        x = boat.x + worldXOffset,
        y = boat.y + PIECE_Y_ABOVE_BOAT + TARGET_Y_EXTRA_UP,
        z = boat.z + worldZOffset,
    }
end

-- =========================================================
-- Kinetic movement
-- =========================================================

local function launchToward(vec)
    local d = dist3(vec.x, vec.y, vec.z)

    if d < HOLD_TOLERANCE then
        return true, "already centered"
    end



    local yaw, pitch = vectorToYawPitch(vec.x, vec.y, vec.z)
    local power = clamp(d * POWER_PER_BLOCK, MIN_LAUNCH_POWER, MAX_LAUNCH_POWER)

    local attempts = {
        function() return callIfExists(ni, "launch", yaw, pitch, power) end,
        function() return callIfExists(ni, "launch", power, yaw, pitch) end,
        function() return callIfExists(ni, "launch", {yaw = yaw, pitch = pitch, power = power}) end,
        function() return callIfExists(ni, "kinetic", yaw, pitch, power) end,
        function() return callIfExists(ni, "move", vec.x, vec.y, vec.z, power) end,
    }

    local lastErr = nil
    for _, fn in ipairs(attempts) do
        local ok, err = fn()
        if ok then return true end
        lastErr = err
    end

    return false, tostring(lastErr or "no kinetic launch method worked")
end



local function pitLaunchTowardWithPower(vec, minPower, maxPower, perBlock)
    minPower = tonumber(minPower) or 0.05
    maxPower = tonumber(maxPower) or 0.30
    perBlock = tonumber(perBlock) or 0.10

    local d = dist3(vec.x or 0, vec.y or 0, vec.z or 0)
    if d < 0.01 then return true, "already centered" end

    local yaw, pitch = vectorToYawPitch(vec.x or 0, vec.y or 0, vec.z or 0)
    local power = clamp(d * perBlock, minPower, maxPower)

    local attempts = {
        function() return callIfExists(ni, "launch", yaw, pitch, power) end,
        function() return callIfExists(ni, "launch", power, yaw, pitch) end,
        function() return callIfExists(ni, "launch", {yaw = yaw, pitch = pitch, power = power}) end,
        function() return callIfExists(ni, "kinetic", yaw, pitch, power) end,
        function() return callIfExists(ni, "move", vec.x or 0, vec.y or 0, vec.z or 0, power) end,
    }

    local lastErr = nil
    for _, fn in ipairs(attempts) do
        local ok, err = fn()
        if ok then return true end
        lastErr = err
    end

    return false, tostring(lastErr or "no kinetic launch method worked")
end

local function startupPitEscape()
    if not ENABLE_STARTUP_PIT_ESCAPE then return end

    print("Startup pit escape: flying above board Y, then moving out while still propelled upward.")
    sendToController({
        type = "piece_pit_escape_started",
        targetSquare = currentSquare,
    })

    local started = os.clock()

    -- Phase 1:
    -- Climb until we are not just at the normal target Y, but about 2 blocks above it.
    while os.clock() - started < PIT_ESCAPE_MAX_SECONDS do
        local boat = getBoat()
        if not boat then
            print("Pit escape waiting for boat reference...")
            sleep(PIT_ESCAPE_STEP_SLEEP)
        else
            local target = targetRelativeFromBoat(boat)
            local yErr = (tonumber(target.y) or 0) + PIT_ESCAPE_EXTRA_Y_UP
            local hErr = math.sqrt(target.x * target.x + target.z * target.z)

            print(("Pit escape high-Y phase: yErr=%.2f hErr=%.2f"):format(yErr, hErr))

            if yErr <= PIT_Y_TOLERANCE then
                break
            end

            pitLaunchTowardWithPower(
                {x = 0, y = math.min(yErr, 5.5), z = 0},
                PIT_UP_MIN_POWER,
                PIT_UP_MAX_POWER,
                PIT_UP_POWER_PER_BLOCK
            )
            sleep(PIT_ESCAPE_STEP_SLEEP)
        end
    end

    -- Phase 2:
    -- Move horizontally toward assigned square, BUT keep adding upward propulsion
    -- until the mob is within 2 blocks horizontally. This prevents falling back into
    -- the pit while it is still over the opening/lip.
    while os.clock() - started < PIT_ESCAPE_MAX_SECONDS do
        local boat = getBoat()
        if not boat then
            sleep(PIT_ESCAPE_STEP_SLEEP)
        else
            local target = targetRelativeFromBoat(boat)
            local yErr = tonumber(target.y) or 0
            local hErr = math.sqrt(target.x * target.x + target.z * target.z)

            print(("Pit escape out phase: yErr=%.2f hErr=%.2f"):format(yErr, hErr))

            if hErr <= PIT_HORIZONTAL_EXIT_TOLERANCE then
                break
            end

            local launchY = 0
            if hErr > PIT_KEEP_UPWARD_UNTIL_HORIZONTAL_WITHIN then
                -- Maintain upward push while it is still trying to clear the pit.
                launchY = math.max(PIT_COMBINED_UPWARD_BIAS, yErr + PIT_ESCAPE_EXTRA_Y_UP)
                launchY = math.min(launchY, 4.5)
            elseif yErr > PIT_Y_TOLERANCE + 0.4 then
                -- If it is still low, keep a smaller correction.
                launchY = math.min(yErr, 3.0)
            end

            pitLaunchTowardWithPower(
                {x = target.x, y = launchY, z = target.z},
                PIT_SIDE_MIN_POWER,
                PIT_SIDE_MAX_POWER,
                PIT_SIDE_POWER_PER_BLOCK
            )

            sleep(PIT_ESCAPE_STEP_SLEEP)
        end
    end

    -- Phase 3:
    -- Let normal holding take over at the actual board target Y.
    sendToController({
        type = "piece_pit_escape_finished",
        targetSquare = currentSquare,
    })

    print("Startup pit escape finished; normal hold loop taking over.")
end

local function holdTarget()
    local boat, err = getBoat()
    if not boat then return false, err or "missing boat" end

    local target = targetRelativeFromBoat(boat)
    local horizontalD = math.sqrt(target.x * target.x + target.z * target.z)
    local fullD = dist3(target.x, target.y, target.z)

    if horizontalD > HOLD_TOLERANCE then
        currentAction = pendingCapture and "attack_move" or "move"
        local ok, moveErr = launchToward({x=target.x, y=0, z=target.z})
        if not ok then return false, moveErr end
    else
        if currentAction ~= "hold" then
            sendToController({
                type = "piece_arrived",
                targetSquare = currentSquare,
                capture = pendingCapture,
                capturedPiece = pendingCapturedPiece,
            })
        end
        currentAction = "hold"
    end

    if horizontalD <= FACE_TOLERANCE then
        facePositiveZ()
    end

    return true, ("square=%s action=%s delta x=%.2f y=%.2f z=%.2f h=%.2f full=%.2f"):format(
        currentSquare, currentAction, target.x, target.y, target.z, horizontalD, fullD
    )
end

