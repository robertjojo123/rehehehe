local function setAssignedSquare(file, rank, square)
    file = tonumber(file)
    rank = tonumber(rank)

    if not file or not rank or file < 1 or file > 8 or rank < 1 or rank > 8 then
        return false, "bad square assignment"
    end

    currentFile = file
    currentRank = rank
    currentSquare = square or squareName(file, rank)

    print("Assigned new square:", currentSquare, "file", currentFile, "rank", currentRank)

    sendToController({
        type = "piece_assignment",
        state = "ASSIGNED",
        targetFile = currentFile,
        targetRank = currentRank,
        targetSquare = currentSquare,
        action = currentAction,
        capture = pendingCapture,
        capturedPiece = pendingCapturedPiece,
    })

    return true
end

local function rednetLoop()
    while true do
        if not rednetReady then rednetReady = tryOpenRednet() end

        if rednetReady then
            local sender, msg = rednet.receive(PROTOCOL, REDNET_TIMEOUT)

            if type(msg) == "table" then
                if msg.type == "particle_identity_query" and (sender == PARTICLE_TURTLE_ID or msg.fromParticleTurtle == PARTICLE_TURTLE_ID) then
                    pcall(rednet.send, PARTICLE_TURTLE_ID, {
                        type = "piece_particle_identity",
                        pieceId = PIECE_ID,
                        label = PIECE_LABEL,
                        side = PIECE_SIDE,
                        kind = PIECE_KIND,
                        square = currentSquare,
                        targetSquare = currentSquare,
                        active = true,
                        computerId = os.getComputerID(),
                    }, PROTOCOL)
                elseif sender == FLOOR_COMPUTER_ID or msg.controllerId == FLOOR_COMPUTER_ID then
                    if msg.type == "piece_move_command" then
                    local matchesPiece = (msg.pieceId == PIECE_ID) or (tostring(msg.label or ""):lower() == PIECE_LABEL)

                    if matchesPiece then
                        pendingCapture = msg.capture or msg.action == "attack" or false
                        pendingCapturedPiece = msg.capturedPiece
                        pendingTargetVector = {
                            x = tonumber(msg.targetRelX) or 0,
                            y = tonumber(msg.targetRelY) or 0,
                            z = tonumber(msg.targetRelZ) or 0,
                        }
                        currentAction = pendingCapture and "attack_pending" or "move_pending"

                        sendToController({
                            type = "piece_move_received",
                            from = msg.from,
                            to = msg.to,
                            action = currentAction,
                            capture = pendingCapture,
                            capturedPiece = pendingCapturedPiece,
                            targetVector = pendingTargetVector,
                        })

                        if pendingCapture then
                            performAttackIfNeeded()
                        end

                        local ok, err = setAssignedSquare(msg.targetFile, msg.targetRank, msg.to)

                        sendToController({
                            type = ok and "piece_move_accepted" or "piece_move_rejected",
                            ok = ok,
                            detail = err,
                            from = msg.from,
                            to = msg.to,
                            action = currentAction,
                            capture = pendingCapture,
                            capturedPiece = pendingCapturedPiece,
                        })
                    end

                elseif msg.type == "piece_reset" then
                    if not msg.pieceId or msg.pieceId == PIECE_ID or tostring(msg.label or ""):lower() == PIECE_LABEL then
                        pendingCapture = false
                        pendingCapturedPiece = nil
                        pendingTargetVector = nil
                        currentAction = "reset"
                        setAssignedSquare(START_FILE, START_RANK, START_SQUARE)
                    end
                end
                end
            end
        else
            sleep(1)
        end
    end
end

local function holdLoop()
    local lastStatus = 0
    local lastAiSuppress = 0

    while true do
        local now = os.clock()

        if KEEP_SUPPRESSING_AI or now - lastAiSuppress > 5 then
            suppressAI()
            lastAiSuppress = now
        end

        local ok, msg = holdTarget()

        if now - lastStatus >= STATUS_SECONDS then
            lastStatus = now
            print((ok and "OK " or "WAIT ") .. tostring(msg))
            sendToController({
                type = "piece_status",
                state = ok and ("HOLDING_" .. currentSquare) or "WAITING",
                ok = ok,
                detail = msg,
                targetSquare = currentSquare,
                targetFile = currentFile,
                targetRank = currentRank,
                action = currentAction,
                capture = pendingCapture,
                capturedPiece = pendingCapturedPiece,
            })
        end

        sleep(LOOP_DELAY)
    end
end

