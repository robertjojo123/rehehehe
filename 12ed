-- wizard_chess_piece_agent_reusable_v7.lua
-- Reusable Wizard Chess NI/mob agent for all mapped pieces.
--
-- Labels / IDs:
--   White pawns: wp1..wp8 = 10342..10349
--   Black pawns: bp1..bp8 = 10350..10357
--   White back row: wr1, wn1, wb1, wq, wk, wb2, wn2, wr2 = 10358..10365
--   Black back row: br1, bn1, bb1, bk, bq, bb2, bn2, br2 = 10366..10373
--
-- Main flow:
--   floor monitor selects/moves piece
--   floor computer 8898 validates chess move
--   floor sends direct rednet packet to this NI
--   this NI updates current board coord and walks/holds there
--   if action/capture says attack, it fires/attacks first, then moves
--
-- Coordinate map:
--   reference boat = A1
--   rank +1 => world X -2
--   file +1 => world Z -2
--   board square size = 2 blocks

