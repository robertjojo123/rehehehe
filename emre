-- shark_emc_generator_rod_sweeper.lua
-- Faster rod-clearing replacement for Z's Shark Machine / DragonCraft EMC Generator.
--
-- Fixes from the lighter version:
--   1. Powder condensers are detected by blaze_powder OR blaze_rod, not just blaze_rod.
--      This matters because your first half can be blaze powder while rods appear on the other side.
--   2. Rod transfer now scans every non-empty slot reported by inv.list().
--   3. If one RMF condenser rejects rods / is full, it tries multiple RMF destinations instead of giving up.
--   4. Uses a small number of staggered sweeper lanes instead of 48 hot threads.
--   5. Monitor animation is still only one display thread, so it does not fight the transfer threads.
--
-- Copy to /startup or run directly.

-- =========================================================
-- === Config
-- =========================================================

local MONITOR_TEXT_SCALE = 1

local BG_COLOR = colors.blue
local STAT_COLOR = colors.green

local TRACKED_EMC_PER_RMF = 10059784
local ROD_EMC = 1536
local RESERVE_RODS = 64

-- Peripheral rescanning.
local RESCAN_SECONDS = 25

-- Rod sweeper tuning.
-- These are the main performance knobs.
local SWEEPER_LANES = 6                  -- More lanes now, still far safer than 48 hot workers.
local SWEEPER_PASS_SLEEP = 0.02          -- Short delay after a lane finishes one full pass.
local SWEEPER_STAGGER_SECONDS = 0.08     -- Spaces lanes apart on boot.
local MAX_RODS_PER_CONDENSER_PASS = 20000 -- Drain aggressively; stop when source/dest stops accepting.
local MAX_RODS_PER_PUSH = 512            -- Bigger pushes into RMF condensers.
local MAX_DEST_TRIES_PER_PUSH = 64       -- Try hard when some RMF condensers are full.

-- Drain/output tuning.
local DRAIN_TICK_SECONDS = 0.08
local RMF_DRAIN_CONDENSERS_PER_TICK = 20

local BHU_TO_ENDER_SECONDS = 0.35
local BHU_SLOTS_PER_TICK = 64

-- Display/animation tuning.
local ENABLE_ANIMATION = true
local ANIMATION_TICK_SECONDS = 0.16
local SHARK_STEP_EVERY_TICKS = 2
local FISH_STEP_EVERY_TICKS = 1
local STATS_SECONDS = 5

-- Classification item names.
local BLAZE_ROD = "minecraft:blaze_rod"
local BLAZE_POWDER = "minecraft:blaze_powder"
local RMF_ITEM = "projecte:rm_furnace"

-- Condensers in this list are ALWAYS treated as RMF destination condensers,
-- even if they temporarily contain blaze rods/powder and would otherwise be
-- auto-classified as powder-side.
local FORCE_RMF_CONDENSERS = {
    ["projecte:condenser_mk2_13821"] = true,
}

-- =========================================================
-- === Monitor Setup
-- =========================================================

local monitor = peripheral.find("monitor")
if not monitor then error("Monitor not found") end

monitor.setTextScale(MONITOR_TEXT_SCALE)
local monW, monH = monitor.getSize()
monitor.setBackgroundColor(BG_COLOR)
monitor.setTextColor(colors.white)
monitor.clear()

local function setPixel(x, y, color)
    if x < 1 or x > monW or y < 1 or y > monH then return end
    monitor.setCursorPos(x, y)
    monitor.setBackgroundColor(color)
    monitor.write(" ")
end

local function clearLine(y)
    if y < 1 or y > monH then return end
    monitor.setCursorPos(1, y)
    monitor.setBackgroundColor(BG_COLOR)
    monitor.write(string.rep(" ", monW))
end

local function clearRows(y1, y2)
    for y = y1, y2 do
        clearLine(y)
    end
end

local function writeCentered(text, y, color)
    text = tostring(text or "")
    clearLine(y)
    monitor.setTextColor(color or STAT_COLOR)
    monitor.setBackgroundColor(BG_COLOR)
    local x = math.max(1, math.floor((monW - #text) / 2) + 1)
    monitor.setCursorPos(x, y)
    monitor.write(text:sub(1, monW))
end

