        sharkX = sharkX - 1
        if sharkX < -sharkWidth then sharkX = monW end
    end

    if animationTick % FISH_STEP_EVERY_TICKS == 0 then
        fishX = fishX - 1
        if fishX < -fishWidth - 8 then fishX = monW + 1 end
    end

    clearRows(ANIM_TOP, ANIM_BOTTOM)
    drawFloorAndCoral()
    drawFish()
    drawShark()
end

-- =========================================================
-- === State / Peripheral Cache
-- =========================================================

local totalTransferred = 0
local lastTransferredForRate = 0
local startTime = os.clock()

local bhuName, bhu
local enderChestName, enderChest

local allCondensers = {}
local powderCondensers = {}
local rmfCondensers = {}

local rmfDestIndex = 1
local rmfDrainIndex = 1
local bhuSlotCursor = 1

-- Condensers that recently had many rods get revisited constantly.
local hotRodCondensers = {}
local hotRodSet = {}

-- Forward declaration because classifyCondensers() marks hot condensers during scan.
local markHotRodCondenser

local lastScanSummary = ""

local function shortNumber(n)
    n = tonumber(n) or 0
    local abs = math.abs(n)

    if abs >= 1e12 then return string.format("%.2fT", n / 1e12)
    elseif abs >= 1e9 then return string.format("%.2fB", n / 1e9)
    elseif abs >= 1e6 then return string.format("%.2fM", n / 1e6)
    elseif abs >= 1e3 then return string.format("%.2fK", n / 1e3)
    else return tostring(math.floor(n)) end
end

local function wrapSafe(name)
    if not name then return nil end
    local ok, p = pcall(peripheral.wrap, name)
    if ok then return p end
    return nil
end

local function getPeripheralName(p)
    local ok, name = pcall(function()
        return peripheral.getName(p)
    end)

    if ok then return name end
    return nil
end

local function findPeripheralByPattern(predicate)
    for _, name in ipairs(peripheral.getNames()) do
        if predicate(name) then
            return name, peripheral.wrap(name)
        end
    end

    return nil, nil
end

local function itemSummary(items)
    local hasRod = false
    local hasPowder = false
    local hasRmf = false
    local rodCount = 0

    if type(items) ~= "table" then
        return hasRod, hasPowder, hasRmf, rodCount
    end

    for _, item in pairs(items) do
        if item and item.name == BLAZE_ROD then
            hasRod = true
            rodCount = rodCount + (tonumber(item.count) or 0)
        elseif item and item.name == BLAZE_POWDER then
            hasPowder = true
        elseif item and item.name == RMF_ITEM then
            hasRmf = true
        end
    end

    return hasRod, hasPowder, hasRmf, rodCount
end

local function classifyCondensers()
    allCondensers = {}
    powderCondensers = {}
    rmfCondensers = {}

    bhuName, bhu = findPeripheralByPattern(function(name)
        return tostring(name):find("industrialforegoing:black_hole_unit_tile") ~= nil
    end)

    enderChestName, enderChest = findPeripheralByPattern(function(name)
        local lower = tostring(name):lower()
        return lower:find("ender_chest") ~= nil or lower:find("enderchest") ~= nil
    end)

    local rodTotal = 0
    local powderMarked = 0
    local rmfMarked = 0

    for _, name in ipairs(peripheral.getNames()) do
        if tostring(name):match("^projecte:condenser_mk2_") then
            local inv = peripheral.wrap(name)
            local ok, items = pcall(function()
                return inv.list()
            end)

            local hasRod, hasPowder, hasRmf, rods = itemSummary(ok and items or {})
            rodTotal = rodTotal + rods

            local entry = {
                name = name,
                inv = inv,
                hasRod = hasRod,
                hasPowder = hasPowder,
                hasRmf = hasRmf,
                lastRodCount = rods,
            }

            table.insert(allCondensers, entry)

            if rods > RESERVE_RODS then
                markHotRodCondenser(entry)
            end

            -- Manual override first:
            -- These are destination RMF condensers even if their inventory happens
            -- to contain blaze rods/powder during a transition.
            if FORCE_RMF_CONDENSERS[name] then
                table.insert(rmfCondensers, entry)
                rmfMarked = rmfMarked + 1

            -- Important fix:
            -- A powder condenser can be recognized by either blaze powder OR blaze rods.
            -- Previously, a condenser with powder but temporarily no rods could be treated as RMF-side.
            elseif hasPowder or hasRod then
                table.insert(powderCondensers, entry)
                powderMarked = powderMarked + 1
            else
                table.insert(rmfCondensers, entry)
                rmfMarked = rmfMarked + 1
            end
        end
    end

    rmfDestIndex = 1
    rmfDrainIndex = 1

    lastScanSummary =
        "Powder:" .. tostring(#powderCondensers)
        .. " RMF:" .. tostring(#rmfCondensers)
        .. " rodsSeen:" .. tostring(rodTotal)

    print("Rescan complete.")
    print(lastScanSummary)
    print("BHU: " .. tostring(bhuName or "missing"))
    print("Ender chest: " .. tostring(enderChestName or "missing"))
end

local function rescanLoop()
    while true do
        classifyCondensers()
        sleep(RESCAN_SECONDS)
    end
end

local function getNextRmfDestination()
    if #rmfCondensers == 0 then return nil end

    for _ = 1, #rmfCondensers do
        if rmfDestIndex > #rmfCondensers then
            rmfDestIndex = 1
        end

        local entry = rmfCondensers[rmfDestIndex]
        rmfDestIndex = rmfDestIndex + 1

        if entry and entry.name then
            return entry.name
        end
    end

    return nil
end


function markHotRodCondenser(entry)
    if not entry or not entry.name then return end
    if hotRodSet[entry.name] then return end
    hotRodSet[entry.name] = true
    table.insert(hotRodCondensers, entry)
end

local function popHotRodCondenser()
    while #hotRodCondensers > 0 do
        local entry = table.remove(hotRodCondensers, 1)
        if entry and entry.name and hotRodSet[entry.name] then
            hotRodSet[entry.name] = nil
            return entry
        end
    end

    return nil
end

-- =========================================================
-- === Rod Sweeper Logic
-- =========================================================

local function tryPushRodSlotToManyRmf(inv, slot, wanted)
    local remaining = wanted
    local totalMoved = 0
    local tries = 0
    local noMoveStreak = 0

    while remaining > 0 and tries < MAX_DEST_TRIES_PER_PUSH and #rmfCondensers > 0 do
        tries = tries + 1

        local destName = getNextRmfDestination()
        if not destName then break end

        local moveAmount = math.min(MAX_RODS_PER_PUSH, remaining)

        local okMove, moved = pcall(function()
            return inv.pushItems(destName, slot, moveAmount)
        end)

        moved = (okMove and tonumber(moved)) or 0

        if moved > 0 then
            totalMoved = totalMoved + moved
            remaining = remaining - moved
            totalTransferred = totalTransferred + moved
            noMoveStreak = 0
            sleep(0)
        else
            noMoveStreak = noMoveStreak + 1

            -- If every known RMF destination has rejected recently, stop this slot for now.
            -- The drain loop may free room, and hot queue will retry soon.
            if noMoveStreak >= #rmfCondensers then
                break
            end

            sleep(0)
        end
    end

    return totalMoved
end

local function sweepOnePowderCondenser(entry)
    if not entry or not entry.name then return 0 end

    if not entry.inv then
        entry.inv = wrapSafe(entry.name)
        if not entry.inv then return 0 end
    end

    if #rmfCondensers == 0 then
        return 0
    end

    local ok, items = pcall(function()
        return entry.inv.list()
    end)

    if not ok or type(items) ~= "table" then
        entry.inv = wrapSafe(entry.name)
        return 0
    end

    -- Re-check contents live. This also handles condensers that were powder-only
    -- at rescan time and later generated rods.
    local rodSlots = {}
    local totalRods = 0
    local hasPowder = false

    for slot, item in pairs(items) do
        if item and item.name == BLAZE_ROD then
            local count = tonumber(item.count) or 0
            totalRods = totalRods + count
            table.insert(rodSlots, {slot = slot, count = count})
        elseif item and item.name == BLAZE_POWDER then
            hasPowder = true
        end
    end

    entry.hasPowder = hasPowder or entry.hasPowder
    entry.lastRodCount = totalRods

    if totalRods <= RESERVE_RODS then
        return 0
    end

    -- Keep this condenser on the hot retry list while it still has excess rods.
    markHotRodCondenser(entry)

    local toMove = math.min(totalRods - RESERVE_RODS, MAX_RODS_PER_CONDENSER_PASS)
    local movedTotal = 0

    -- Sort slots descending. In many modded inventories, output slots are later/higher slots.
    -- This helps attack the "other side" full of rods first.
    table.sort(rodSlots, function(a, b)
        return a.slot > b.slot
    end)

    for _, rodSlot in ipairs(rodSlots) do
        if toMove <= 0 then break end

        local wantedFromSlot = math.min(rodSlot.count, toMove)
        local moved = tryPushRodSlotToManyRmf(entry.inv, rodSlot.slot, wantedFromSlot)

        movedTotal = movedTotal + moved
        toMove = toMove - moved

        if moved <= 0 then
            -- Could not move from this slot. Keep going; other rod slots might be accessible.
            sleep(0)
        end
    end

    -- If we moved some but probably left excess rods, retry this condenser very soon.
    if movedTotal > 0 and (totalRods - movedTotal) > RESERVE_RODS then
        markHotRodCondenser(entry)
    elseif movedTotal == 0 and totalRods > RESERVE_RODS then
        -- Destinations were likely full. Retry once drain loop frees space.
        markHotRodCondenser(entry)
    end

    return movedTotal
end

local function sweeperLane(laneId)
    sleep((laneId - 1) * SWEEPER_STAGGER_SECONDS)

    while true do
        if #powderCondensers == 0 or #rmfCondensers == 0 then
            sleep(0.5)
        else
            local movedThisPass = 0

            -- Priority pass: immediately revisit condensers known to be rod-heavy.
            -- Each lane grabs a few hot entries so full rod buffers do not wait for a whole broad scan.
            for _ = 1, 4 do
                local hot = popHotRodCondenser()
                if not hot then break end

                local moved = sweepOnePowderCondenser(hot)
                movedThisPass = movedThisPass + moved
                sleep(0)
            end

            -- Partition the powder condensers between lanes:
            -- lane 1 scans 1, 1+lanes, ...
            -- lane 2 scans 2, 2+lanes, ...
            for i = laneId, #powderCondensers, SWEEPER_LANES do
                local moved = sweepOnePowderCondenser(powderCondensers[i])
                movedThisPass = movedThisPass + moved

                -- Important: yield between condenser inventories.
                sleep(0)
            end

            if movedThisPass > 0 then
                sleep(SWEEPER_PASS_SLEEP)
            else
                -- If no work happened, back off a little more.
                sleep(0.20)
            end
        end
    end
end

-- =========================================================
-- === RMF Output Drain / BHU Drain
-- =========================================================

local function drainRmfOutputsOnce()
    if not bhu or #rmfCondensers == 0 then
        sleep(DRAIN_TICK_SECONDS)
        return
    end

    local bhuDest = getPeripheralName(bhu) or bhuName
    if not bhuDest then
        sleep(DRAIN_TICK_SECONDS)
        return
    end

    for _ = 1, RMF_DRAIN_CONDENSERS_PER_TICK do
        if rmfDrainIndex > #rmfCondensers then
            rmfDrainIndex = 1
        end

        local entry = rmfCondensers[rmfDrainIndex]
        rmfDrainIndex = rmfDrainIndex + 1

        if entry and entry.inv then
            local ok, items = pcall(function()
                return entry.inv.list()
            end)

            if ok and type(items) == "table" then
                for slot, item in pairs(items) do
                    if item and item.name == RMF_ITEM then
                        pcall(function()
                            entry.inv.pushItems(bhuDest, slot, item.count)
                        end)
                        sleep(0)
                    end
                end
            else
                entry.inv = wrapSafe(entry.name)
            end
        end
    end

    sleep(DRAIN_TICK_SECONDS)
end

local function drainLoop()
    while true do
        drainRmfOutputsOnce()
    end
end

local function bhuToEnderLoop()
    while true do
        if bhu and enderChest then
            local enderDest = getPeripheralName(enderChest) or enderChestName

            local ok, items = pcall(function()
                return bhu.list()
            end)

            if ok and type(items) == "table" and enderDest then
                local checked = 0
                local maxSlotSeen = 0

                for slot, item in pairs(items) do
                    if slot > maxSlotSeen then maxSlotSeen = slot end

                    if slot >= bhuSlotCursor then
                        checked = checked + 1

                        if item and item.name == RMF_ITEM then
                            pcall(function()
                                bhu.pushItems(enderDest, slot, item.count)
                            end)
                            sleep(0)
                        end

                        if checked >= BHU_SLOTS_PER_TICK then
                            bhuSlotCursor = slot + 1
                            break
                        end
                    end
                end

                if checked < BHU_SLOTS_PER_TICK or bhuSlotCursor > maxSlotSeen then
                    bhuSlotCursor = 1
                end
            end
        end

        sleep(BHU_TO_ENDER_SECONDS)
    end
end

-- =========================================================
-- === Display
-- =========================================================

local lastStatsDrawAt = 0

local function countStoredRmfEmc()
    if not bhu then return 0 end

    local ok, items = pcall(function()
        return bhu.list()
    end)

    if not ok or type(items) ~= "table" then
        return 0
    end

    local totalEMC = 0

    for _, item in pairs(items) do
        if item and item.name == RMF_ITEM then
            totalEMC = totalEMC + ((tonumber(item.count) or 0) * TRACKED_EMC_PER_RMF)
        end
    end

    return totalEMC
end

local function drawStats()
    local elapsed = os.clock() - startTime
    if elapsed <= 0 then elapsed = 1 end

    local totalEMCGenerated = totalTransferred * ROD_EMC
    local emcPerMinute = totalEMCGenerated / (elapsed / 60)
    local macerators = #powderCondensers * 3
    local emcPerMacMin = (macerators > 0) and (emcPerMinute / macerators) or 0
    local totalStoredEMC = countStoredRmfEmc()

    local rodsSinceLast = totalTransferred - lastTransferredForRate
    lastTransferredForRate = totalTransferred

    writeCentered("EMC/m: " .. shortNumber(emcPerMinute) .. "  EMC/M: " .. shortNumber(emcPerMacMin), 1, STAT_COLOR)
    writeCentered("Pow:" .. #powderCondensers .. " RMF:" .. #rmfCondensers .. " Stored:" .. shortNumber(totalStoredEMC), 2, STAT_COLOR)
    writeCentered("Rod/s:" .. shortNumber(rodsSinceLast / STATS_SECONDS) .. " Hot:" .. #hotRodCondensers .. " " .. lastScanSummary, 3, STAT_COLOR)
end

local function displayLoop()
    monitor.setBackgroundColor(BG_COLOR)
    monitor.clear()

    while true do
        local now = os.clock()

        if now - lastStatsDrawAt >= STATS_SECONDS then
            drawStats()
            lastStatsDrawAt = now
        end

        drawAnimationFrame()
        sleep(ANIMATION_TICK_SECONDS)
    end
end

-- =========================================================
-- === Safe Task Runner
-- =========================================================

local function safeLoop(name, fn, restartDelay)
    return function()
        restartDelay = restartDelay or 2

        while true do
            local ok, err = pcall(fn)

            if not ok then
                print("[TASK ERROR] " .. tostring(name) .. ": " .. tostring(err))
            else
                print("[TASK RETURNED] " .. tostring(name))
            end

            sleep(restartDelay)
        end
    end
end

-- =========================================================
-- === Main
-- =========================================================

print("Starting Shark EMC rod sweeper.")
print("This version aggressively clears blaze rods from powder condensers.")
print("Hot-queue enabled: rod-heavy condensers are retried immediately.")
print("Sweeper lanes: " .. tostring(SWEEPER_LANES))
print("Max rods per condenser pass: " .. tostring(MAX_RODS_PER_CONDENSER_PASS))
print("Dest tries per push: " .. tostring(MAX_DEST_TRIES_PER_PUSH))
print("RMF drain tick: " .. tostring(DRAIN_TICK_SECONDS))
print("Forced RMF condenser: projecte:condenser_mk2_13820")

classifyCondensers()
drawStats()

local tasks = {
    safeLoop("display", displayLoop, 1),
    safeLoop("rescan", rescanLoop, 3),
    safeLoop("rmf_drain", drainLoop, 1),
    safeLoop("bhu_to_ender", bhuToEnderLoop, 1),
}

for lane = 1, SWEEPER_LANES do
    table.insert(tasks, safeLoop("rod_sweeper_" .. tostring(lane), function()
        sweeperLane(lane)
    end, 1))
end

parallel.waitForAll(table.unpack(tasks))
