    [SAPPHIRE] = {
        "0000110000",
        "0001111000",
        "0011111100",
        "0111111110",
        "1111111111",
        "0111111110",
        "0011111100",
        "0001111000",
        "0000110000"
    },

    [NICKEL] = {
        "0011111100",
        "0111111110",
        "1111111111",
        "1111001111",
        "1111001111",
        "1111001111",
        "1111111111",
        "0111111110",
        "0011111100"
    },

    -- Visually emerald now, but uses RUBY internal symbol for the 2x payout logic.
    [RUBY] = {
        "0001111000",
        "0011111100",
        "0111111110",
        "1111111111",
        "1111111111",
        "0111111110",
        "0011111100",
        "0011111100",
        "0001111000"
    }
}

local SYMBOL_BG_COLOR = {
    [SAPPHIRE] = colors.cyan,
    [NICKEL] = NICKEL_COLOR,
    [RUBY] = colors.red
}

local SYMBOL_HIGHLIGHT_COLOR = {
    [SAPPHIRE] = colors.white,
    [NICKEL] = colors.white,
    [RUBY] = colors.pink
}

local SYMBOL_SHADOW_COLOR = {
    [SAPPHIRE] = colors.blue,
    [NICKEL] = colors.orange,
    [RUBY] = colors.brown
}

-- =========================================================
-- === Persistent Stats
-- =========================================================

local function loadStats()
    if fs.exists(STATS_FILE) then
        local f = fs.open(STATS_FILE, "r")
        local data = textutils.unserialize(f.readAll())
        f.close()
        return data or {}
    end
    return {}
end

local function saveStats(stats)
    local f = fs.open(STATS_FILE, "w")
    f.write(textutils.serialize(stats))
    f.close()
end

local stats = loadStats()
stats.totalPlays = stats.totalPlays or 0
stats.wins2x = stats.wins2x or 0
stats.wins5x = stats.wins5x or 0
stats.payoutBalance = stats.payoutBalance or 0

-- =========================================================
-- === Bank Messaging: channel 1
-- =========================================================

local function sendMessage(msg)
    modem.transmit(1, 1, msg)
end

local function receiveMessage(timeout)
    local timer = os.startTimer(timeout or 2)

    while true do
        local event, side, ch, _, msg = os.pullEvent()

        if event == "modem_message" and ch == 1 then
            return msg
        elseif event == "timer" and side == timer then
            return nil
        end
    end
end

-- =========================================================
-- === Sounds
-- =========================================================

local function playNote(instrument, volume, pitch)
    if speaker then
        pcall(function()
            speaker.playNote(instrument, volume or 1, pitch or 12)
        end)
    end
end

local function playAcceptSound()
    playNote("pling", 1, 7)
end

local function playSpinTick()
    playNote("hat", 0.25, 12)
end

local function playReelStopSound()
    playNote("pling", 1, 10)
    sleep(0.08)
    playNote("pling", 1, 14)
end

local function playDenialSound()
    playNote("bass", 1, 3)
end

local function playDenialSequence()
    for i = 1, 3 do
        playDenialSound()
        sleep(0.2)
    end
end

local function playWinSequence(count)
    for i = 1, count do
        playAcceptSound()
        sleep(0.18)
    end
end

local function playStartSpinSound()
    playNote("pling", 1, 5)
    sleep(0.08)
    playNote("pling", 1, 8)
    sleep(0.08)
    playNote("pling", 1, 12)
end

-- =========================================================
-- === Bank Item Request
-- =========================================================

local function waitForBankItem()
    while redstone.getInput("top") do
        sendMessage("request_item")

        local reply = receiveMessage(2)

        if reply == "item_transferred" then
            playAcceptSound()
            return true
        elseif reply == "no_item" then
            playDenialSequence()
        end

        sleep(0.1)
    end

    return false
end

-- =========================================================
-- === Slot Logic
-- =========================================================

local function randomSymbol()
    local roll = math.random(1, 3)
    if roll == 1 then return RUBY end
    if roll == 2 then return NICKEL end
    return SAPPHIRE
end

local function randomNonMatchingSymbol(symbol)
    local alt
    repeat
        alt = randomSymbol()
    until alt ~= symbol
    return alt
end

local function biasedLeftSymbol()
    -- First reel weighting:
    -- 75% chance for 2x symbols: Emerald/Nickel
    -- 25% chance for 5x symbol: Sapphire
    if math.random(100) <= 75 then
        if math.random(2) == 1 then
            return RUBY
        else
            return NICKEL
        end
    else
        return SAPPHIRE
    end
end

local function decideMiddle(left)
    -- Middle matches left 80% of the time.
    if math.random(1000) <= SECOND_REEL_MATCH_CHANCE_PER_1000 then
        return left
    end

    return randomNonMatchingSymbol(left)
end

local function decideRight(left, middle)
    if left == middle then
        -- Third reel completes the match 19.1% of the time.
        -- This gives about 42% expected payout/RTP with the current first reel weighting.
        if math.random(1000) <= THIRD_REEL_MATCH_CHANCE_PER_1000 then
            return left
        end

        -- If the win fails, force a different symbol so it cannot accidentally win.
        return randomNonMatchingSymbol(left)
    end

    -- If first two reels do not match, third can be anything.
    -- No triple is possible because left ~= middle.
    return randomSymbol()
end

local function getPayout(left, middle, right)
    if left == middle and middle == right then
        if right == SAPPHIRE then
            return 5
        elseif right == NICKEL or right == RUBY then
            return 2
        end
    end

    return 0
end

-- =========================================================
-- === Monitor Reel Drawing
-- =========================================================

local function prevIndex(i, max)
    i = i - 1
    if i < 1 then i = max end
    return i
end

local function offsetIndex(baseIndex, delta)
    local count = #SYMBOL_SEQUENCE
    local i = ((baseIndex - 1 + delta) % count) + 1
    return i
end

local function getSymbolIndex(symbol)
    for i, s in ipairs(SYMBOL_SEQUENCE) do
        if s == symbol then return i end
    end
    return 1
end

local function clearMonitor(mon)
    mon.setBackgroundColor(colors.black)
    mon.setTextColor(colors.white)
    mon.clear()
end

local function drawPixel(mon, x, y, color)
    local w, h = mon.getSize()

    if x < 1 or x > w or y < 1 or y > h then
        return
    end

    mon.setCursorPos(x, y)
    mon.setBackgroundColor(color)
    mon.write(" ")
end

local function drawPayline(mon)
    local w, h = mon.getSize()
    local mid = math.floor(h / 2) + 1

    local top = mid - 5
    local bottom = mid + 5

    if top < 1 then top = 1 end
    if bottom > h then bottom = h end

    mon.setBackgroundColor(GOLD_BORDER_COLOR)
    mon.setTextColor(GOLD_BORDER_COLOR)

    mon.setCursorPos(1, top)
    mon.write(string.rep(" ", w))

    mon.setCursorPos(1, bottom)
    mon.write(string.rep(" ", w))
end

local function drawSymbol(mon, symbol, topY)
    local art = PIXEL_ART[symbol]
    if not art then return end

    local w, h = mon.getSize()
    local symbolColor = SYMBOL_BG_COLOR[symbol] or colors.white
    local highlightColor = SYMBOL_HIGHLIGHT_COLOR[symbol] or symbolColor
    local shadowColor = SYMBOL_SHADOW_COLOR[symbol] or symbolColor

    local artW = #art[1]
    local startX = math.max(1, math.floor((w - artW) / 2) + 1)

    for rowIndex, row in ipairs(art) do
        local y = topY + rowIndex - 1

        if y >= 1 and y <= h then
            for col = 1, #row do
                local ch = row:sub(col, col)

                if ch == "1" then
                    local color = symbolColor

                    if rowIndex <= 3 and col <= math.ceil(artW / 2) then
                        color = highlightColor
                    end

                    if rowIndex >= #art - 2 and col >= math.floor(artW / 2) then
                        color = shadowColor
                    end

                    drawPixel(mon, startX + col - 1, y, color)
                end
            end
        end
    end
end

local function drawReelFrame(mon, centerIndex, offset)
    clearMonitor(mon)

    local w, h = mon.getSize()
    local mid = math.floor(h / 2) + 1

    local symbolH = 9
    local spacing = 11
    local centerTop = mid - math.floor(symbolH / 2)

    local minSlot = math.floor((1 - (centerTop + offset)) / spacing) - 2
    local maxSlot = math.ceil((h - (centerTop + offset)) / spacing) + 2

    for slot = minSlot, maxSlot do
        local symbolIndex = offsetIndex(centerIndex, slot)
        local symbol = SYMBOL_SEQUENCE[symbolIndex]
        local topY = centerTop + (slot * spacing) + offset

        drawSymbol(mon, symbol, topY)
    end

    drawPayline(mon)
end

local function drawFinalReel(mon, finalSymbol)
    clearMonitor(mon)

    local w, h = mon.getSize()
    local mid = math.floor(h / 2) + 1

    local symbolH = 9
    local spacing = 11
    local centerTop = mid - math.floor(symbolH / 2)

    local finalIndex = getSymbolIndex(finalSymbol)

    local minSlot = math.floor((1 - centerTop) / spacing) - 2
    local maxSlot = math.ceil((h - centerTop) / spacing) + 2

    for slot = minSlot, maxSlot do
        local symbolIndex = offsetIndex(finalIndex, slot)
        local symbol = SYMBOL_SEQUENCE[symbolIndex]
        local topY = centerTop + (slot * spacing)

        drawSymbol(mon, symbol, topY)
    end

    drawPayline(mon)
end

local function animateOneDrop(mon, centerIndex, frameDelay)
    local spacing = 11

    -- The third parameter makes the symbols move 2 pixels per frame.
    for offset = 0, spacing - 1, REEL_STEP_PIXELS do
        drawReelFrame(mon, centerIndex, offset)
        playSpinTick()
        sleep(frameDelay or FRAME_DELAY)
    end

    return prevIndex(centerIndex, #SYMBOL_SEQUENCE)
end

local function approachFinal(mon, currentIndex, finalSymbol)
    local finalIndex = getSymbolIndex(finalSymbol)

    if currentIndex == finalIndex then
        currentIndex = animateOneDrop(mon, currentIndex, FINAL_APPROACH_DELAY)
        currentIndex = animateOneDrop(mon, currentIndex, FINAL_APPROACH_DELAY)
    end

    while currentIndex ~= finalIndex do
        currentIndex = animateOneDrop(mon, currentIndex, FINAL_APPROACH_DELAY)
    end

    drawFinalReel(mon, finalSymbol)
    playReelStopSound()

    return currentIndex
end

local function spinReel(mon, reelName, duration, finalSymbol)
    local currentIndex = math.random(1, #SYMBOL_SEQUENCE)
    local startTime = os.clock()

    print(reelName .. " reel spinning...")

    while os.clock() - startTime < duration do
        currentIndex = animateOneDrop(mon, currentIndex, FRAME_DELAY)
    end

    currentIndex = approachFinal(mon, currentIndex, finalSymbol)

    print(reelName .. " reel stopped on " .. SYMBOL_LABEL[finalSymbol])

    return currentIndex
end

local function drawIdleReels()
    drawFinalReel(leftMonitor, RUBY)
    drawFinalReel(middleMonitor, NICKEL)
    drawFinalReel(rightMonitor, SAPPHIRE)
end

-- =========================================================
-- === Main Loop
-- =========================================================

drawIdleReels()

print("Monitor slot machine ready.")
print("Reel monitors:")
print("LEFT   = monitor_960")
print("MIDDLE = monitor_961")
print("RIGHT  = monitor_962")
print("Channel: 1")
print("Sapphire = vibrant cyan diamond = 5x")
print("Nickel   = vibrant gold coin = 2x")
print("Emerald  = vibrant lime gem = 2x")
print("Gold border #806f3e uses color slot:", GOLD_BORDER_COLOR)
print("Nickel #ffd45a uses color slot:", NICKEL_COLOR)
print("Speaker:", speaker and "found" or "NOT FOUND")
print("Second reel match chance:", SECOND_REEL_MATCH_CHANCE_PER_1000 .. "/1000")
print("Third reel match chance:", THIRD_REEL_MATCH_CHANCE_PER_1000 .. "/1000")
print("Target expected payout/RTP: about 42%")
print("Spin time:", PLAY_TIME)
print("Frame delay:", FRAME_DELAY)
print("Reel step pixels:", REEL_STEP_PIXELS)
print("")

while true do
    if redstone.getInput("top") then
        if waitForBankItem() then
            playStartSpinSound()

            local left = biasedLeftSymbol()
            local middle = decideMiddle(left)
            local right = decideRight(left, middle)

            print("Target result:")
            print("L:" .. SYMBOL_LABEL[left] .. " M:" .. SYMBOL_LABEL[middle] .. " R:" .. SYMBOL_LABEL[right])

            parallel.waitForAll(
                function()
                    spinReel(leftMonitor, "LEFT", LEFT_REEL_TIME, left)
                end,
                function()
                    spinReel(middleMonitor, "MIDDLE", MIDDLE_REEL_TIME, middle)
                end,
                function()
                    spinReel(rightMonitor, "RIGHT", RIGHT_REEL_TIME, right)
                end
            )

            stats.totalPlays = stats.totalPlays + 1
            stats.payoutBalance = stats.payoutBalance - 1

            local payout = getPayout(left, middle, right)

            print(
                "Final: L:" .. SYMBOL_SHORT[left]
                .. " M:" .. SYMBOL_SHORT[middle]
                .. " R:" .. SYMBOL_SHORT[right]
            )

            sleep(FINAL_RESULT_HOLD_TIME)

            if payout == 5 then
                stats.wins5x = stats.wins5x + 1
                stats.payoutBalance = stats.payoutBalance + 5

                sendMessage({type = "payout", amount = 5})
                playWinSequence(5)
                print(">>> SAPPHIRE JACKPOT 5x WIN!")

            elseif payout == 2 then
                stats.wins2x = stats.wins2x + 1
                stats.payoutBalance = stats.payoutBalance + 2

                sendMessage({type = "payout", amount = 2})
                playWinSequence(2)
                print(">>> 2x WIN!")

            else
                playDenialSequence()
                print("No win.")
            end

            saveStats(stats)

            print(string.format(
                "Plays: %d | 2x Wins: %d | 5x Wins: %d | Payout: %+d",
                stats.totalPlays,
                stats.wins2x,
                stats.wins5x,
                stats.payoutBalance
            ))

            print("Resetting soon...")
            sleep(POST_ROUND_DELAY)
        end
    end

    sleep(0.1)
end
