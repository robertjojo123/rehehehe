-- monitor_slots_channel_1.lua
-- Slot Game Computer Script
--
-- Uses:
--   - Left reel monitor:   monitor_960
--   - Middle reel monitor: monitor_961
--   - Right reel monitor:  monitor_962
--
-- Features:
--   - 3 vertical monitor reels
--   - filled pixel-art symbols
--   - symbols slide downward like slot reels
--   - symbols flow in from the top of the monitor
--   - symbols move 2 pixels per frame for faster top-to-bottom motion
--   - missed symbols stay visible above and below when stopped
--   - custom hex gold payline border: #806f3e
--   - custom hex nickel symbol: #ffd45a
--   - sapphire = cyan diamond = 5x
--   - nickel = gold coin = 2x
--   - emerald/lime symbol = old Ruby logic = 2x
--   - text scale 0.5 for sharper/bigger pixel shapes
--   - only top/bottom gold payline bars, no side border
--
-- Odds:
--   - First reel: 75% Emerald/Nickel, 25% Sapphire
--   - Second reel matches first reel 80% of the time
--   - Third reel completes match 19.1% of the time
--   - Expected payout/RTP is about 42%
--
-- Preserved from channel 1 base:
--   - Bank/message system on modem channel 1
--   - top redstone input starts game
--   - stats.txt tracking
--   - payout messages to bank computer

math.randomseed(os.epoch and os.epoch("utc") or os.time())

-- =========================================================
-- === Peripherals
-- =========================================================

local modem = peripheral.wrap("bottom")
local speaker = peripheral.find("speaker")

if not modem then error("No modem on bottom") end
modem.open(1)

local leftMonitor = peripheral.wrap("monitor_960")
local middleMonitor = peripheral.wrap("monitor_961")
local rightMonitor = peripheral.wrap("monitor_962")

if not leftMonitor then error("Missing left reel monitor_960") end
if not middleMonitor then error("Missing middle reel monitor_961") end
if not rightMonitor then error("Missing right reel monitor_962") end

local REEL_MONITORS = {
    left = leftMonitor,
    middle = middleMonitor,
    right = rightMonitor
}

-- =========================================================
-- === Config
-- =========================================================

local STATS_FILE = "stats.txt"

-- Overall spin duration.
-- Left stops at 4s, middle at 8s, right at 12s.
local PLAY_TIME = 12

local LEFT_REEL_TIME = PLAY_TIME / 3
local MIDDLE_REEL_TIME = (PLAY_TIME * 2) / 3
local RIGHT_REEL_TIME = PLAY_TIME

local FINAL_RESULT_HOLD_TIME = 2.5
local POST_ROUND_DELAY = 4.5

-- Visual reel movement speed.
-- Keeping this around the CC tick-safe speed.
local FRAME_DELAY = 0.012
local FINAL_APPROACH_DELAY = 0.018

-- Reel moves this many monitor pixels per animation frame.
-- 1 = smoother/slower
-- 2 = faster, still readable
-- 3 = very fast/choppy
local REEL_STEP_PIXELS = 2

-- Custom palette slots.
local GOLD_BORDER_COLOR = colors.orange  -- #806f3e
local NICKEL_COLOR = colors.yellow       -- #ffd45a

-- =========================================================
-- === Odds Tuning
-- =========================================================
-- Goal:
--   - First two reels match 80% of the time
--   - Expected payout/RTP around 42%
--
-- Math:
--   First reel is weighted:
--     75% Emerald/Nickel, paying 2x
--     25% Sapphire, paying 5x
--
--   Expected payout = 0.80 * thirdMatchChance * ((0.75 * 2) + (0.25 * 5))
--                   = 0.80 * thirdMatchChance * 2.75
--                   = 2.2 * thirdMatchChance
--
--   For 42% RTP:
--     0.42 / 2.2 = 0.1909
--
-- So third reel match chance is about 191/1000.

local SECOND_REEL_MATCH_CHANCE_PER_1000 = 800
local THIRD_REEL_MATCH_CHANCE_PER_1000 = 191

-- Internal names.
-- RUBY is now drawn as emerald/lime green, but still pays 2x.
local RUBY = "ruby"
local NICKEL = "nickel"
local SAPPHIRE = "sapphire"

local SYMBOL_SEQUENCE = {RUBY, NICKEL, SAPPHIRE}

local SYMBOL_LABEL = {
    [SAPPHIRE] = "SAPPHIRE",
    [NICKEL] = "NICKEL",
    [RUBY] = "EMERALD"
}

local SYMBOL_SHORT = {
    [SAPPHIRE] = "S",
    [NICKEL] = "N",
    [RUBY] = "E"
}

-- =========================================================
-- === Monitor Setup
-- =========================================================

for _, mon in pairs(REEL_MONITORS) do
    mon.setTextScale(0.5)

    -- Custom hex palette colors.
    -- Requires advanced monitors.
    if mon.setPaletteColor then
        -- Dark gold border: #806f3e
        mon.setPaletteColor(GOLD_BORDER_COLOR, 0x806F3E)

        -- Vibrant soft coin/nickel gold: #ffd45a
        mon.setPaletteColor(NICKEL_COLOR, 0xFFD45A)

        -- Vibrant sapphire colors
        mon.setPaletteColor(colors.cyan, 0x00E5FF)
        mon.setPaletteColor(colors.lightBlue, 0x66F2FF)
        mon.setPaletteColor(colors.blue, 0x006BFF)

        -- Emerald/lime colors for the old Ruby symbol.
        -- Still uses RUBY internally and still pays 2x.
        mon.setPaletteColor(colors.red, 0x00FF55)
        mon.setPaletteColor(colors.pink, 0x7DFFA3)

        -- Emerald shadow tone
        mon.setPaletteColor(colors.brown, 0x007A2B)
    end

    mon.setBackgroundColor(colors.black)
    mon.setTextColor(colors.white)
    mon.clear()
end

-- =========================================================
-- === Filled Pixel Symbol Art
-- =========================================================

