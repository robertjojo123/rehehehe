local function waitForVideoCacheRunwayBeforeTape(job, expectedFrames, totalSeconds)
    if not REQUIRE_SAFE_SERVER_RUNWAY_BEFORE_TAPE then return true end

    clearTerm()
    print("Waiting for adaptive safe server runway...")
    print("V29 estimates frame-prep speed and starts when")
    print("the prepared runway should cover the rest.")
    sleep(0.25)

    expectedFrames = tonumber(expectedFrames or 0) or 0
    totalSeconds = tonumber(totalSeconds or 0) or 0
    local fps = tonumber(DEFAULT_FPS or 10) or 10
    local safety = tonumber(RUNWAY_FACTOR_OF_SAFETY or 1.2) or 1.2
    if safety < 1.0 then safety = 1.0 end
    local minRunwaySeconds = tonumber(MIN_RUNWAY_TO_START_SECONDS or 20) or 20
    local shortNeedsDone = totalSeconds > 0 and totalSeconds <= (SHORT_REQUIRE_SERVER_DONE_SECONDS or 60)

    local lastReady = -1
    local stallStart = os.clock()
    local waitStart = os.clock()

    while true do
        local st = getJson(BASE .. "/status?job=" .. urlEncode(job))
        clearTerm()
        print("Waiting for adaptive safe server runway...")
        if st then
            local ready = tonumber(st.ws_frames_ready or 0) or 0
            local done = st.ws_frames_done == true
            local genFps = tonumber(st.ws_frame_gen_fps or 0) or 0
            local genFpm = tonumber(st.ws_frame_gen_fpm or (genFps * 60)) or 0
            local totalEst = tonumber(st.ws_total_frames_est or expectedFrames or 0) or 0
            if expectedFrames <= 0 and totalEst > 0 then expectedFrames = totalEst end
            if totalEst <= 0 then totalEst = expectedFrames end

            local remaining = 0
            if totalEst > 0 then remaining = math.max(0, totalEst - ready) end

            local readyPlaybackSeconds = ready / math.max(0.001, fps)
            local remainingPrepSeconds = 999999
            if genFps > 0 then
                remainingPrepSeconds = remaining / genFps
            end

            -- V29 core rule:
            -- start once the prepared runway duration is at least safety times
            -- the estimated time needed to prepare the not-yet-cached frames.
            local requiredRunwaySeconds = math.max(minRunwaySeconds, remainingPrepSeconds * safety)
            local requiredFrames = math.ceil(requiredRunwaySeconds * fps)
            if totalEst > 0 and requiredFrames > totalEst then requiredFrames = totalEst end

            -- Avoid starting on a wildly unstable early average. Require at least a
            -- small minimum number of frames unless the whole cache is done.
            local absoluteMinimumFrames = math.ceil(minRunwaySeconds * fps)
            if totalEst > 0 and absoluteMinimumFrames > totalEst then absoluteMinimumFrames = totalEst end
            if requiredFrames < absoluteMinimumFrames then requiredFrames = absoluteMinimumFrames end

            local etaText = "?"
            if remainingPrepSeconds < 999998 then etaText = tostring(math.floor(remainingPrepSeconds + 0.5)) .. "s" end

            print("Ready frames: " .. tostring(ready) .. (totalEst > 0 and ("/" .. tostring(totalEst)) or ""))
            print("Ready runway: " .. tostring(math.floor(readyPlaybackSeconds + 0.5)) .. "s")
            print("Frames/min avg: " .. tostring(math.floor(genFpm + 0.5)))
            print("Gen FPS avg: " .. tostring(math.floor(genFps * 100 + 0.5) / 100) .. "   Play FPS: " .. tostring(fps))
            print("Remaining prep ETA: " .. etaText)
            print("Safety factor: " .. tostring(safety))
            print("Required runway: " .. tostring(requiredFrames) .. " frames (" .. tostring(math.floor(requiredRunwaySeconds + 0.5)) .. "s)")
            print("Done: " .. tostring(done))
            print("Mode: " .. tostring(st.ws_video_mode or "?"))
            print(tostring(st.message or ""))

            if st.status == "error" then
                print(tostring(st.error or "unknown error"))
                waitKey()
                return false
            end

            if done then
                sleep(0.15)
                return true
            end

            if shortNeedsDone then
                print("Short clip: waiting for full server cache for perfect playback.")
            elseif genFps > 0 and ready >= requiredFrames and ready >= absoluteMinimumFrames then
                sleep(0.15)
                return true
            else
                if genFps <= 0 then print("Waiting for enough frames to measure prep speed...") end
            end

            if ready ~= lastReady then
                lastReady = ready
                stallStart = os.clock()
            elseif os.clock() - stallStart > 60 then
                print("")
                print("Cache has not advanced for 60s.")
                print("Press any key to continue anyway, or terminate to wait/fix server.")
                waitKey()
                return true
            end

            if os.clock() - waitStart > (MAX_RUNWAY_WAIT_SECONDS or 1200) then
                print("")
                print("Reached max runway wait time; continuing anyway.")
                sleep(2)
                return true
            end
        else
            print("No status yet.")
        end
        sleep(0.5)
    end
end

