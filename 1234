local DEFAULT_FPS = 10
local TOTAL_SECONDS = 0 -- 0 = detected full video

local AUDIO_VIDEO_OFFSET_MS = 0
local USE_TAPE_BYTE_CLOCK = false -- V30 default: use audio_bytes/(6000*tapeSpeed)/frames wall timing; tape position APIs drift on some drives
local TAPE_BPS_1X_OVERRIDE = 0 -- try 5800 if 2x tape audio is slightly fast
local TAPE_BYTES_PER_SECOND_1X = 6000

-- V26 tape clock tuning. In 2x mode, expected byte clock is 6000*2 = 12000 B/s.
-- Larger value = video believes tape/audio is farther along = shorter delay.
-- Smaller value = video believes tape/audio is less far along = longer delay.
local TAPE_POSITION_SCALE = 1.0
local TAPE_CLOCK_DEBUG = true

-- V30 sync rule: divide the actual heard audio length from audio_bytes by the actual/estimated frame count.
-- This avoids tape-position drift and prevents the video from walking off the audio over long clips.
local VIDEO_CLOCK_MODE = "audio_bytes_wall"
local AUDIO_LENGTH_TUNE = 1.000
local FORCE_AUDIO_LOCKED_FRAME_TIME = true

