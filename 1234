    while #frameBuffer < VIDEO_PREBUFFER_FRAMES do
        local packet, reason = readWsPacket(ws)
        if not packet then
            streamEndedEarly = true
            streamEndReason = reason
            break
        end

        frameBuffer[#frameBuffer + 1] = packet

        if #frameBuffer % 5 == 0 then
            clearTerm()
            print("Prebuffering WebSocket video...")
            print("Frames: " .. tostring(#frameBuffer) .. "/" .. tostring(VIDEO_PREBUFFER_FRAMES))
        end

        sleep(0)
    end
end

if #frameBuffer == 0 then
    print("No frames buffered: " .. tostring(streamEndReason))
    waitKey()
    return
end

clearTerm()
print("Buffered " .. tostring(#frameBuffer) .. " frame(s).")
print("Starting queued WebSocket player...")
sleep(0.05)

local playback = nil

-- Legacy helpers intentionally unused in v28 raw/RLE-packet mode.

-- V11 queue architecture:
-- One coroutine reads WebSocket frames continuously.
-- Another coroutine renders every frame in order.
local queue = {}
local queueFirst = 1
local queueLast = 0
local readerDone = false
local readerErr = nil
local lastRenderedFrame = 0

local function queueLen()
    return queueLast - queueFirst + 1
end

local function pushFrame(frame)
    queueLast = queueLast + 1
    queue[queueLast] = frame
end

local function popFrame()
    if queueFirst > queueLast then return nil end
    local frame = queue[queueFirst]
    queue[queueFirst] = nil
    queueFirst = queueFirst + 1

    if queueFirst > 1000 then
        local n = 0
        for i = queueFirst, queueLast do
            n = n + 1
            queue[n] = queue[i]
            queue[i] = nil
        end
        queueFirst = 1
        queueLast = n
    end

    return frame
end

if frameBuffer then
    for i = 1, #frameBuffer do
        pushFrame(frameBuffer[i])
    end
end
frameBuffer = nil

local function readerLoop()
    local ok, errOuter = pcall(function()
        while not streamEndedEarly do
            while queueLen() >= FRAME_QUEUE_MAX do
                sleep(0.05)
            end

            local packet, err = readWsPacket(ws)
            if not packet then
                readerDone = true
                readerErr = err
                return
            end

            pushFrame(packet)
            sleep(0)
        end

        readerDone = true
        readerErr = streamEndReason
    end)

    if not ok then
        readerDone = true
        readerErr = "reader_crash: " .. tostring(errOuter)
    end
end

local function waitForQueueStart()
    clearTerm()
    print("Filling video queue...")
    local lastPrint = os.clock()

    -- V21: the runway lives on the Python server, not in CC RAM.
    -- Keep only a small local buffer so memory does not explode with full-redraw packets.
    local target = QUEUE_START_FRAMES
    if shortFullPreload then target = 1 end

    while queueLen() < target and not readerDone do
        if os.clock() - lastPrint > 0.25 then
            clearTerm()
            print("Filling video queue...")
            print("Frames queued: " .. tostring(queueLen()) .. "/" .. tostring(target))
            print("Reader: active")
            print("Mode: full redraw every frame; RLE rows")
            lastPrint = os.clock()
        end
        sleep(0.05)
    end

    if readerDone and queueLen() < QUEUE_START_FRAMES then
        clearTerm()
        print("Reader ended before target queue.")
        print("Frames queued: " .. tostring(queueLen()) .. "/" .. tostring(target))
        print("Reason: " .. tostring(readerErr))
        print("")
        print("Continuing with available frames...")
        sleep(1.25)
    end
end

local function adaptiveFrameDelay(playbackState, frame, renderCost)
    -- V30 rule:
    --   * every real frame packet is drawn; no skip-to-current-frame logic
    --   * default timing is audio_bytes wall-clock: audioBytes/(6000*tapeSpeed)/totalFrames
    --   * if behind: sleep exactly 0.05s, never 0
    --   * if on/near target: sleep 0.10s
    --   * if clearly ahead: sleep longer so video cannot run away from audio
    local nextFrameNumber = (tonumber(frame.number or 1) or 1) + 1
    local delay = nil

    local targetByte = frameTargetByte(playbackState, nextFrameNumber)
    local deltaBytes = playbackTapeDeltaBytes(playbackState)

    if VIDEO_CLOCK_MODE == "tape_bytes" and targetByte and deltaBytes then
        local byteEarly = targetByte - deltaBytes
        playbackState.lastTargetByte = targetByte
        playbackState.lastByteEarly = byteEarly

        local byteRate = tonumber(playbackState.bytesPerSecond or 0) or 0
        if byteRate <= 0 then byteRate = 6000 * (tonumber(playbackState.speed or 1.0) or 1.0) end
        delay = byteEarly / byteRate
    else
        local targetNextMs = frameTargetMs(playbackState, nextFrameNumber)
        local nowMs = playbackAudioMs(playbackState)
        delay = (targetNextMs - nowMs) / 1000
    end

    local slept = GOOD_FRAME_SLEEP

    if not delay then
        slept = GOOD_FRAME_SLEEP
    elseif delay <= MIN_FRAME_SLEEP then
        slept = MIN_FRAME_SLEEP
    elseif delay <= (GOOD_FRAME_SLEEP + 0.025) then
        -- Close enough to normal 10 FPS pacing: use the exact .1s feel.
        slept = GOOD_FRAME_SLEEP
    else
        -- We are ahead of the tape/audio. Slow down by the real amount needed.
        slept = math.min(MAX_FRAME_SLEEP, delay)
    end

    playbackState.lastDelay = slept
    playbackState.lastBehindMs = (delay and delay < 0) and (-delay * 1000) or 0
    playbackState.lastAheadMs = (delay and delay > 0) and (delay * 1000) or 0
    sleep(slept)
end


local function rendererLoop()
    waitForQueueStart()

    clearTerm()
    print("Starting tape + queued video...")
    print("Initial queue: " .. tostring(queueLen()) .. " frames")
    if shortFullPreload then print("Short mode: all frames are already loaded.") end
    sleep(0.05)

    startTape(tape, man.tape_speed or 1.0)
    playback = makePlaybackClock(tape, man.tape_speed or 1.0, DEFAULT_FPS, man.audio_bytes or 0, expectedTotalFrames)

    local lastFrameObject = nil

    local function holdFrameSlot(frameNumber)
        -- Do not redraw; just keep the previous picture on screen for this timeline slot.
        playback.frames = frameNumber
        playback.held = (playback.held or 0) + 1
        lastRenderedFrame = frameNumber
        adaptiveFrameDelay(playback, { number = frameNumber }, 0)
    end

    local function drawFrameSlot(packet)
        local t0 = os.clock()
        local n, rows = drawRawPacket(mon, packet)
        local renderCost = os.clock() - t0
        if not n or n <= 0 then n = lastRenderedFrame + 1 end
        playback.frames = n
        playback.rendered = playback.rendered + 1
        playback.lastRenderCost = renderCost
        playback.lastRows = rows or 0
        if rows and rows < MON_H_EXPECTED then
            playback.partialPackets = (playback.partialPackets or 0) + 1
        end
        lastRenderedFrame = n
        lastFrameObject = packet
        adaptiveFrameDelay(playback, { number = n }, renderCost)
    end

    while true do
        local packet = popFrame()

        if packet then
            local n = packetFrameNumber(packet)

            -- V27 strict mode: every actual packet is drawn. No skipping to the
            -- current audio frame. If packet numbers jump, record the gap, but
            -- still draw the packet we have.
            if lastRenderedFrame > 0 and n > lastRenderedFrame + 1 then
                playback.gaps = (playback.gaps or 0) + (n - lastRenderedFrame - 1)
            end

            if n <= lastRenderedFrame then
                playback.duplicates = (playback.duplicates or 0) + 1
            else
                drawFrameSlot(packet)
            end
        else
            if readerDone then
                -- If ffmpeg/websocket produced fewer frames than the audio duration
                -- implies, hold the final image until the expected frame count.
                if FILL_TAIL_TO_AUDIO_WITH_HOLD and expectedTotalFrames > 0 and lastRenderedFrame > 0 and lastRenderedFrame < expectedTotalFrames then
                    holdFrameSlot(lastRenderedFrame + 1)
                else
                    clearTerm()
                    print("Video stream ended: " .. tostring(readerErr))
                    print("Rendered frame slots: " .. tostring(playback.rendered))
                    print("Last timeline frame: " .. tostring(lastRenderedFrame))
                    if expectedTotalFrames > 0 then print("Expected frames: " .. tostring(expectedTotalFrames)) end
                    return
                end
            else
                -- Queue underrun. Do not skip; wait for reader to catch up.
                sleep(0.05)
            end
        end
    end
end

parallel.waitForAll(readerLoop, rendererLoop)

pcall(function() ws.close() end)

clearTerm()
print("Done.")
if playback then
    print("Actual frames drawn: " .. tostring(playback.rendered))
    print("Held/fake slots: " .. tostring(playback.held or 0))
    print("Missing packet gaps: " .. tostring(playback.gaps or 0))
    print("Last timeline frame: " .. tostring(playback.frames))
    if expectedTotalFrames > 0 then print("Expected frames: " .. tostring(expectedTotalFrames)) end
    print("Tape clock: " .. tostring(playback.useTapeClock))
    print("BPS1x: " .. tostring(playback.bps1x))
    print("Clock mode: " .. tostring(playback.clockMode))
    print("ms/frame audio-byte: " .. tostring(playback.msPer))
    print("Audio heard seconds est: " .. tostring(playback.audioHeardSeconds))
    print("Last render cost: " .. tostring(playback.lastRenderCost or 0))
    print("Last delay: " .. tostring(playback.lastDelay or 0))
    print("Last tape pos: " .. tostring(playback.lastTapePos or "?"))
    print("Last delta bytes: " .. tostring(playback.lastDeltaBytes or "?"))
    print("Audio bytes: " .. tostring(playback.audioBytes or "?"))
    print("Last target byte: " .. tostring(playback.lastTargetByte or "?"))
    print("Last byte early: " .. tostring(playback.lastByteEarly or "?"))
    print("Tape pos scale: " .. tostring(playback.tapePositionScale or 1.0))
else
    print("Playback never started.")
end
print("Offset ms: " .. tostring(AUDIO_VIDEO_OFFSET_MS))
waitKey()
