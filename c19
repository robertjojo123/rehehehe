-- mob_chess_ui_sixel_v2.lua
-- Living Mob Chess monitor prototype
-- 4x4 advanced monitor at text scale 0.5 should be about 79x52.
-- Uses 2x3 subpixel/sixel blit sprites, selectable squares, legal-move highlights,
-- and same-screen self-play for both sides.

-- =========================================================
-- === Monitor Setup
-- =========================================================

local mon = peripheral.find("monitor")
if not mon then error("No monitor found") end

mon.setTextScale(0.5)
local W, H = mon.getSize()

-- =========================================================
-- === Config
-- =========================================================

local SQ_W, SQ_H = 7, 6          -- character cells per chess square
local BOARD_X, BOARD_Y = 2, 2
local BOARD_W, BOARD_H = SQ_W * 8, SQ_H * 8
local PANEL_X = BOARD_X + BOARD_W + 2
local PANEL_Y = 1
local PANEL_W = math.max(18, W - PANEL_X + 1)

local LIGHT_SQUARE = colors.lightGray
local DARK_SQUARE  = colors.lightBlue
local SELECT_SQUARE = colors.orange
local MOVE_SQUARE = colors.lime
local CAPTURE_SQUARE = colors.red
local PANEL_BG = colors.gray
local PANEL_EDGE = colors.black

local WHITE_PIECE = colors.white
local BLACK_PIECE = colors.black

local files = {"a","b","c","d","e","f","g","h"}

-- Palette tweaks are optional, but make the board closer to your reference image.
if mon.setPaletteColor then
    pcall(function()
        mon.setPaletteColor(colors.lightGray, 0.84, 0.84, 0.84)
        mon.setPaletteColor(colors.lightBlue, 0.46, 0.55, 0.75)
        mon.setPaletteColor(colors.orange, 0.95, 0.58, 0.18)
        mon.setPaletteColor(colors.lime, 0.42, 0.80, 0.36)
        mon.setPaletteColor(colors.red, 0.85, 0.20, 0.18)
        mon.setPaletteColor(colors.gray, 0.20, 0.20, 0.22)
    end)
end

-- =========================================================
-- === Subpixel / Sixel Blit Renderer
-- =========================================================

local BLIT_LOOKUP = {
    [colors.white] = "0", [colors.orange] = "1", [colors.magenta] = "2", [colors.lightBlue] = "3",
    [colors.yellow] = "4", [colors.lime] = "5", [colors.pink] = "6", [colors.gray] = "7",
    [colors.lightGray] = "8", [colors.cyan] = "9", [colors.purple] = "a", [colors.blue] = "b",
    [colors.brown] = "c", [colors.green] = "d", [colors.red] = "e", [colors.black] = "f",
}

local function colorToBlit(color)
    return BLIT_LOOKUP[color or colors.white] or "0"
end

-- This is the same sixel trick as your blackjack renderer.
local function sixelChar(mask)
    if mask > 31 then
        return string.char(0x80 + (63 - mask)), true
    end
    return string.char(0x80 + mask), false
end

local function newSubCanvas(w, h, bg)
    local pix = {}
    for y = 1, h do
        pix[y] = {}
        for x = 1, w do pix[y][x] = bg end
    end
    return { w = w, h = h, bg = bg, pix = pix }
end

local function setSub(canvas, x, y, color)
    if x >= 1 and x <= canvas.w and y >= 1 and y <= canvas.h then
        canvas.pix[y][x] = color
    end
end

local function plotSprite(canvas, sprite, color)
    for y = 1, #sprite do
        local row = sprite[y]
        for x = 1, #row do
            if row:sub(x, x) ~= "." then
                setSub(canvas, x, y, color)
            end
        end
    end
end

local function renderSubCanvas(target, x, y, canvas)
    local outW, outH = canvas.w, canvas.h
    while outW % 2 ~= 0 do outW = outW + 1 end
    while outH % 3 ~= 0 do outH = outH + 1 end

    local charW = math.floor(outW / 2)
    local charH = math.floor(outH / 3)
    local tw, th = target.getSize()

    for cy = 1, charH do
        local chars, fgs, bgs = {}, {}, {}

        for cx = 1, charW do
            local bg = canvas.bg
            local px = (cx - 1) * 2
            local py = (cy - 1) * 3

            local points = {
                canvas.pix[py + 1] and canvas.pix[py + 1][px + 1] or bg,
                canvas.pix[py + 1] and canvas.pix[py + 1][px + 2] or bg,
                canvas.pix[py + 2] and canvas.pix[py + 2][px + 1] or bg,
                canvas.pix[py + 2] and canvas.pix[py + 2][px + 2] or bg,
                canvas.pix[py + 3] and canvas.pix[py + 3][px + 1] or bg,
                canvas.pix[py + 3] and canvas.pix[py + 3][px + 2] or bg,
            }

            -- Pick the first non-background color as the foreground. This renderer is meant
            -- for two-color sprite cells, which is exactly what the sixel monitor trick does best.
            local fg = nil
            for _, c in ipairs(points) do
                if c ~= bg then fg = c; break end
            end
            fg = fg or bg

            local mask = 0
            local bitValues = {1, 2, 4, 8, 16, 32}
            for i, c in ipairs(points) do
                if c == fg and fg ~= bg then
                    mask = mask + bitValues[i]
                end
            end

            if mask == 0 then
                chars[#chars + 1] = " "
                fgs[#fgs + 1] = colorToBlit(bg)
                bgs[#bgs + 1] = colorToBlit(bg)
            else
                local ch, inverted = sixelChar(mask)
                chars[#chars + 1] = ch
                if inverted then
                    fgs[#fgs + 1] = colorToBlit(bg)
                    bgs[#bgs + 1] = colorToBlit(fg)
                else
                    fgs[#fgs + 1] = colorToBlit(fg)
                    bgs[#bgs + 1] = colorToBlit(bg)
                end
            end
        end

        local rowY = y + cy - 1
        if rowY >= 1 and rowY <= th then
            local rowText, rowFg, rowBg = table.concat(chars), table.concat(fgs), table.concat(bgs)
            local drawX = x
            if drawX < 1 then
                local trim = 2 - drawX
                rowText = rowText:sub(trim)
                rowFg = rowFg:sub(trim)
                rowBg = rowBg:sub(trim)
                drawX = 1
            end
            if drawX <= tw and #rowText > 0 then
                local maxLen = tw - drawX + 1
                target.setCursorPos(drawX, rowY)
                target.blit(rowText:sub(1, maxLen), rowFg:sub(1, maxLen), rowBg:sub(1, maxLen))
            end
        end
    end
end

