-- =========================================================
-- === Account Helpers
-- =========================================================

local function accountLock()
    while accountBusy do sleep(0.05) end
    accountBusy = true
end

local function accountUnlock()
    accountBusy = false
end

local function requestBalance(player)
    if not player then return 0 end

    accountLock()

    rednet.send(ACCOUNT_COMPUTER_ID, {
        action = "get_balance",
        player = player
    }, ACCOUNT_PROTOCOL)

    local id, msg = rednet.receive(ACCOUNT_PROTOCOL, 2)

    accountUnlock()

    if id == ACCOUNT_COMPUTER_ID and type(msg) == "table" and msg.player == player then
        return tonumber(msg.balance) or 0
    end

    return 0
end

local function changeBalance(player, delta, note)
    if not player then return 0 end
    if delta == 0 then return requestBalance(player) end

    accountLock()

    rednet.send(ACCOUNT_COMPUTER_ID, {
        action = "transfer",
        player = player,
        delta = delta,
        note = note or "BLACKJACK TRANSFER"
    }, ACCOUNT_PROTOCOL)

    local id, msg = rednet.receive(ACCOUNT_PROTOCOL, 2)

    accountUnlock()

    if id == ACCOUNT_COMPUTER_ID and type(msg) == "table" and msg.player == player then
        return tonumber(msg.balance) or 0
    end

    return requestBalance(player)
end

local function sendWinStat(player, wager, payout, detail)
    wager = tonumber(wager) or 0
    payout = tonumber(payout) or 0

    if not player or payout - wager <= 0 then return end

    rednet.send(ACCOUNT_COMPUTER_ID, {
        action = "gamble_win_stat",
        player = player,
        game = "blackjack",
        wager = wager,
        payout = payout,
        detail = detail or "blackjack"
    }, ACCOUNT_PROTOCOL)
end

-- =========================================================
-- === Card Logic
-- =========================================================

local SUITS = {"H", "D", "S", "C"}
local RANKS = {"A", "2", "3", "4", "5", "6", "7", "8", "9", "T", "J", "Q", "K"}

local function makeHand(bet, fromSplit)
    return {
        cards = {},
        bet = bet or 0,
        done = false,
        doubled = false,
        fromSplit = fromSplit or false,
        result = "",
        payout = 0,
        net = 0
    }
end

local function safeCards(hand)
    if type(hand) ~= "table" then return {} end
    if type(hand.cards) ~= "table" then
        hand.cards = {}
    end
    return hand.cards
end

local function cardValue(card)
    if not card then return 0 end
    if card.rank == "A" then return 11 end
    if card.rank == "T" or card.rank == "J" or card.rank == "Q" or card.rank == "K" then return 10 end
    return tonumber(card.rank) or 0
end

local function handValue(hand)
    local cards = safeCards(hand)
    local total = 0
    local aces = 0

    for _, card in ipairs(cards) do
        total = total + cardValue(card)
        if card.rank == "A" then aces = aces + 1 end
    end

    while total > 21 and aces > 0 do
        total = total - 10
        aces = aces - 1
    end

    return total
end

local function isSoft17(hand)
    local cards = safeCards(hand)
    local total = 0
    local aces = 0

    for _, card in ipairs(cards) do
        if card.rank == "A" then
            total = total + 11
            aces = aces + 1
        else
            total = total + cardValue(card)
        end
    end

    while total > 21 and aces > 0 do
        total = total - 10
        aces = aces - 1
    end

    return total == 17 and aces > 0
end

local function isBlackjack(hand)
    local cards = safeCards(hand)
    return #cards == 2 and handValue(hand) == 21 and not hand.fromSplit
end

local function canDouble(hand)
    local cards = safeCards(hand)
    return not hand.done and #cards == 2 and not hand.doubled
end

local function canSplit(hand)
    local cards = safeCards(hand)

    if hand.done then return false end
    if hand.fromSplit then return false end
    if #cards ~= 2 then return false end

    return cardValue(cards[1]) == cardValue(cards[2])
end

local function buildDeck()
    local d = {}

    for _, suit in ipairs(SUITS) do
        for _, rank in ipairs(RANKS) do
            table.insert(d, {
                rank = rank,
                suit = suit
            })
        end
    end

    for i = #d, 2, -1 do
        local j = math.random(i)
        d[i], d[j] = d[j], d[i]
    end

    return d
end

local function drawCardFromDeck()
    if #deck <= 10 then
        deck = buildDeck()
    end

    return table.remove(deck)
end

local function addCard(hand)
    table.insert(safeCards(hand), drawCardFromDeck())
end

local function totalBet(station)
    local chip = CHIP_VALUES[station.chipIndex] or CHIP_VALUES[1]
    return chip * station.quantity
end

