local function resetButtons(station)
    station.buttons = {}
end

local function addButton(station, name, x1, y1, x2, y2, label, bg, fg)
    table.insert(station.buttons, {
        name = name,
        x1 = x1,
        y1 = y1,
        x2 = x2,
        y2 = y2
    })

    local mon = station.monitor
    mon.setBackgroundColor(bg or colors.gray)
    mon.setTextColor(fg or colors.white)

    for y = y1, y2 do
        mon.setCursorPos(x1, y)
        mon.write(string.rep(" ", math.max(1, x2 - x1 + 1)))
    end

    local tx = x1 + math.floor(((x2 - x1 + 1) - #label) / 2)
    local ty = y1 + math.floor((y2 - y1) / 2)

    if tx < x1 then tx = x1 end

    mon.setCursorPos(tx, ty)
    mon.write(label)
end

local function getCountdownText()
    if state == "betting" and dealCountdownEnd then
        local remaining = math.max(0, math.ceil(dealCountdownEnd - os.clock()))
        return "Dealing in " .. tostring(remaining) .. "..."
    end

    return nil
end

local function getStationHandText(station)
    if not station.hands or not station.currentHand then
        return "Hand: --"
    end

    local hand = station.hands[station.currentHand]
    if not hand then
        return "Hand: --"
    end

    local value = handDisplayValue(hand)

    if value == "" then
        return "Hand: --"
    end

    return "Hand: " .. value
end

local function getDealerHandText()
    if not dealerHand then
        return "Dealer: --"
    end

    local cards = safeCards(dealerHand)
    if #cards == 0 then
        return "Dealer: --"
    end

    if not dealerRevealed and #cards >= 1 then
        local tempHand = makeHand(0, false)
        table.insert(tempHand.cards, cards[1])
        return "Dealer: " .. tostring(handValue(tempHand)) .. " + ?"
    end

    local value = handDisplayValue(dealerHand)
    if value == "" then
        return "Dealer: --"
    end

    return "Dealer: " .. value
end

local function getStationDisplayPlayer(station)
    return station.lockedPlayer or station.player
end

local function drawStationMonitor(station)
    local mon = station.monitor
    local w, h = mon.getSize()

    mon.setTextScale(0.5)
    mon.setBackgroundColor(colors.black)
    mon.clear()
    resetButtons(station)

    local playerName = getStationDisplayPlayer(station) or "No Player"
    local chip = CHIP_VALUES[station.chipIndex] or CHIP_VALUES[1]
    local total = totalBet(station)
    local countdownText = getCountdownText()
    local messageText = countdownText or station.message or ""

    writeText(mon, 1, 1, playerName, colors.white, colors.black)

    local balText = "$" .. tostring(station.balance or 0)
    writeText(mon, math.max(1, w - #balText), 1, balText, colors.lime, colors.black)

    writeText(mon, 1, 2, "Qty", colors.yellow, colors.black)
    addButton(station, "qty_down", 5, 2, 7, 2, "-", colors.gray, colors.white)
    writeText(mon, 9, 2, tostring(station.quantity), colors.white, colors.black)
    addButton(station, "qty_up", 13, 2, 15, 2, "+", colors.gray, colors.white)

    local chipLabelX = math.max(20, w - 25)
    writeText(mon, chipLabelX, 2, "Chip", colors.yellow, colors.black)
    addButton(station, "chip_down", chipLabelX + 5, 2, chipLabelX + 7, 2, "<", colors.gray, colors.white)
    writeText(mon, chipLabelX + 9, 2, tostring(chip), colors.orange, colors.black)
    addButton(station, "chip_up", math.min(w - 2, chipLabelX + 17), 2, math.min(w, chipLabelX + 19), 2, ">", colors.gray, colors.white)

    writeText(mon, 1, 3, "Total $" .. tostring(total), colors.orange, colors.black)
    writeText(mon, math.max(20, w - 34), 3, messageText, colors.lightBlue, colors.black)

    if state == "betting" then
        if not station.player then
            writeText(mon, 1, 5, "Stand in range to play.", colors.red, colors.black)
            return
        end

        if station.joined then
            writeText(mon, 1, 5, "LOCKED IN", colors.lime, colors.black)
            writeText(mon, 1, 7, "Waiting for deal.", colors.lime, colors.black)
        else
            addButton(station, "deal", 1, 5, 12, 5, "DEAL", colors.green, colors.black)
        end

    elseif state == "playing" then
        local isTurn = currentTurnStationId == station.id
        local hand = nil

        if station.hands and station.currentHand then
            hand = station.hands[station.currentHand]
        end

        if not station.joined then
            writeText(mon, 1, 5, "Waiting for next round.", colors.lightGray, colors.black)
            return
        end

        if not isTurn then
            writeText(mon, 1, 5, "Waiting for your turn.", colors.lightGray, colors.black)
            writeText(mon, 1, 9, getStationHandText(station), colors.white, colors.black)
            writeText(mon, 1, 10, getDealerHandText(), colors.lightGray, colors.black)
            return
        end

        local turnText = "Your turn"
        if #station.hands > 1 then
            turnText = turnText .. " H" .. tostring(station.currentHand or 1) .. "/" .. tostring(#station.hands)
        end
        writeText(mon, 1, 5, turnText, colors.lime, colors.black)

        addButton(station, "hit", 1, 7, 8, 7, "HIT", colors.green, colors.black)
        addButton(station, "stand", 10, 7, 19, 7, "STAND", colors.red, colors.white)

        if hand and canDouble(hand) and station.balance >= hand.bet then
            addButton(station, "double", 21, 7, 28, 7, "X2", colors.orange, colors.black)
        end

        if hand and canSplit(hand) and station.balance >= hand.bet then
            addButton(station, "split", 30, 7, 40, 7, "SPLIT", colors.purple, colors.white)
        end

        writeText(mon, 1, 9, getStationHandText(station), colors.white, colors.black)
        writeText(mon, 1, 10, getDealerHandText(), colors.lightGray, colors.black)

    elseif state == "dealer" then
        writeText(mon, 1, 5, "Dealer playing...", colors.orange, colors.black)
        writeText(mon, 1, 9, getStationHandText(station), colors.white, colors.black)
        writeText(mon, 1, 10, getDealerHandText(), colors.lightGray, colors.black)

    elseif state == "result" then
        writeText(mon, 1, 5, station.message or "Round over", colors.yellow, colors.black)
        writeText(mon, 1, 9, getStationHandText(station), colors.white, colors.black)
        writeText(mon, 1, 10, getDealerHandText(), colors.lightGray, colors.black)
    end
end

