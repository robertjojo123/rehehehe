-- =========================================================
-- === Radar Detection
-- =========================================================

local function detectStationPlayer(station)
    local found = {}

    for _, radar in ipairs(station.radars) do
        local ok, players = pcall(function()
            return radar.getPlayers()
        end)

        if ok and type(players) == "table" then
            for _, p in ipairs(players) do
                if p.name and p.distance and p.distance <= DETECT_RADIUS then
                    found[p.name] = true
                end
            end
        end
    end

    local list = {}

    for name in pairs(found) do
        table.insert(list, name)
    end

    table.sort(list)

    if #list == 1 then
        return list[1], "Ready"
    elseif #list > 1 then
        return nil, "Too many players"
    else
        return nil, "Stand on pad"
    end
end
      
local function radarLoop()
    while true do
        if state == "betting" then
            for _, station in ipairs(STATIONS) do

                -- If the station already pressed DEAL, keep it locked to that player.
                -- Do NOT let radar movement clear the player during countdown.
                if station.joined and station.lockedPlayer then
                    station.player = station.lockedPlayer
                    station.message = getCountdownText() or station.message or "Locked in"

                else
                    local p, msg = detectStationPlayer(station)

                    if p ~= station.player then
                        station.player = p
                        station.lockedPlayer = nil
                        station.joined = false
                        station.hands = {}
                        station.currentHand = 1

                        if p then
                            station.balance = requestBalance(p)
                            station.message = dealCountdownEnd and "Dealing soon" or "Set bet"
                        else
                            station.balance = 0
                            station.message = msg
                        end

                    elseif p then
                        station.balance = requestBalance(p)

                    else
                        station.message = msg
                    end
                end
            end
        end

        sleep(0.75)
    end
end

-- =========================================================
-- === Round Helpers
-- =========================================================

local function getStationById(id)
    for _, station in ipairs(STATIONS) do
        if station.id == id then return station end
    end

    return nil
end

local function anyJoined()
    for _, station in ipairs(STATIONS) do
        if station.joined then return true end
    end

    return false
end

local function joinedStations()
    local list = {}

    for _, station in ipairs(STATIONS) do
        if station.joined then
            table.insert(list, station)
        end
    end

    table.sort(list, function(a, b)
        return a.id < b.id
    end)

    return list
end

local function allHandsDone()
    for _, station in ipairs(STATIONS) do
        if station.joined then
            for _, hand in ipairs(station.hands or {}) do
                if not hand.done then
                    return false
                end
            end
        end
    end

    return true
end

local function setNextTurn()
    if allHandsDone() then
        currentTurnStationId = nil
        currentTurnHandIndex = nil
        state = "dealer"
        roundMessage = "Dealer playing"
        return
    end

    local active = joinedStations()

    for _, station in ipairs(active) do
        for handIndex, hand in ipairs(station.hands or {}) do
            if not hand.done then
                station.currentHand = handIndex
                currentTurnStationId = station.id
                currentTurnHandIndex = handIndex
                roundMessage = station.label .. " turn"
                station.message = "Your turn"
                return
            end
        end
    end
end

local function startRound()
    if state ~= "betting" then return end
    if not anyJoined() then return end

    dealCountdownEnd = nil

    deck = buildDeck()
    dealerHand = makeHand(0, false)
    dealerRevealed = false

    addCard(dealerHand)
    addCard(dealerHand)

    for _, station in ipairs(STATIONS) do
        if station.joined then
            station.lockedPlayer = station.lockedPlayer or station.player
            station.player = station.lockedPlayer
            station.hands = {makeHand(totalBet(station), false)}
            station.currentHand = 1
            station.message = "Good luck"

            addCard(station.hands[1])
            addCard(station.hands[1])

            if isBlackjack(station.hands[1]) then
                station.hands[1].done = true
                station.message = "Blackjack!"
            end
        end
    end

    state = "playing"
    roundMessage = "Players playing"
    setNextTurn()
end

local function playDealer()
    dealerRevealed = true

    while handValue(dealerHand) < 17 or (DEALER_HITS_SOFT_17 and isSoft17(dealerHand)) do
        drawAll()
        sleep(1)
        addCard(dealerHand)
    end
end

local function settleRound()
    local dealerValue = handValue(dealerHand)
    local dealerBust = dealerValue > 21

    for _, station in ipairs(STATIONS) do
        if station.joined and station.lockedPlayer then
            local totalNet = 0

            for _, hand in ipairs(station.hands or {}) do
                local hv = handValue(hand)
                local payout = 0
                local result = ""

                if hv > 21 then
                    result = "Bust"
                    payout = 0

                elseif isBlackjack(hand) then
                    result = "Blackjack"
                    payout = math.floor(hand.bet * BLACKJACK_PAYOUT_MULT)

                elseif dealerBust then
                    result = "Win"
                    payout = hand.bet * 2

                elseif hv > dealerValue then
                    result = "Win"
                    payout = hand.bet * 2

                elseif hv == dealerValue then
                    result = "Push"
                    payout = hand.bet

                else
                    result = "Lose"
                    payout = 0
                end

                hand.result = result
                hand.payout = payout
                hand.net = payout - hand.bet

                if payout > 0 then
                    station.balance = changeBalance(
                        station.lockedPlayer,
                        payout,
                        "BLACKJACK " .. result .. ": payout $" .. payout .. " on bet $" .. hand.bet
                    )
                end

                if hand.net > 0 then
                    sendWinStat(station.lockedPlayer, hand.bet, payout, result)
                end

                totalNet = totalNet + hand.net
            end

            station.message = "Net " .. (totalNet >= 0 and "+" or "") .. tostring(totalNet)
        end
    end

    state = "result"
    roundMessage = "Round complete"
end

local function resetToBetting()
    for _, station in ipairs(STATIONS) do
        station.joined = false
        station.lockedPlayer = nil
        station.hands = {}
        station.currentHand = 1

        if station.player then
            station.balance = requestBalance(station.player)
            station.message = "Set bet"
        else
            station.balance = 0
            station.message = "Stand on pad"
        end
    end

    dealerHand = nil
    dealerRevealed = false
    currentTurnStationId = nil
    currentTurnHandIndex = nil
    dealCountdownEnd = nil
    roundMessage = "Place bets"
    state = "betting"
end

local function roundLoop()
    while true do
        if state == "betting" and dealCountdownEnd then
            local remaining = math.max(0, math.ceil(dealCountdownEnd - os.clock()))
            roundMessage = "Dealing in " .. tostring(remaining) .. "..."

            if os.clock() >= dealCountdownEnd then
                startRound()
            end

        elseif state == "dealer" then
            playDealer()
            drawAll()
            sleep(1)
            settleRound()
            drawAll()
            sleep(ROUND_RESULT_SECONDS)
            resetToBetting()
        end

        sleep(0.1)
    end
end

-- =========================================================
-- === Touch Handling
-- =========================================================

local function stationByMonitorName(name)
    for _, station in ipairs(STATIONS) do
        if station.monitorName == name then
            return station
        end
    end

    return nil
end

local function buttonAt(station, x, y)
    for _, button in ipairs(station.buttons or {}) do
        if x >= button.x1 and x <= button.x2 and y >= button.y1 and y <= button.y2 then
            return button.name
        end
    end

    return nil
end

local function normalizeBet(station)
    local chip = CHIP_VALUES[station.chipIndex] or CHIP_VALUES[1]

    if chip * station.quantity > MAX_BET then
        station.quantity = math.max(1, math.floor(MAX_BET / chip))
    end

    if station.quantity < 1 then
        station.quantity = 1
    end
end

local function joinStation(station)
    if not station.player then
        station.message = "No player"
        return
    end

    if station.joined then
        station.message = "Already locked"
        return
    end

    normalizeBet(station)

    local total = totalBet(station)
    station.balance = requestBalance(station.player)

    if total > MAX_BET then
        station.message = "Max bet 25000"
        return
    end

    if total > station.balance then
        station.message = "No balance"
        return
    end

    station.balance = changeBalance(
        station.player,
        -total,
        "BLACKJACK BET: $" .. total
    )

    station.lockedPlayer = station.player
    station.player = station.lockedPlayer
    station.joined = true
    station.message = "Locked in $" .. total

    if not dealCountdownEnd then
        dealCountdownEnd = os.clock() + AUTO_DEAL_SECONDS
        roundMessage = "Dealing in " .. tostring(AUTO_DEAL_SECONDS) .. "..."

        for _, s in ipairs(STATIONS) do
            if s.player then
                s.message = "Dealing in " .. tostring(AUTO_DEAL_SECONDS) .. "..."
            end
        end
    end
end

local function handlePlayingButton(station, button)
    if state ~= "playing" then return end

    if currentTurnStationId ~= station.id then
        station.message = "Not your turn"
        return
    end

    local hand = station.hands[currentTurnHandIndex]
    if not hand or hand.done then return end

    if button == "hit" then
        addCard(hand)

        if handValue(hand) > 21 then
            hand.done = true
            station.message = "Bust"
            setNextTurn()
        else
            station.message = "Hit"
        end

    elseif button == "stand" then
        hand.done = true
        station.message = "Stand"
        setNextTurn()

    elseif button == "double" then
        if not canDouble(hand) then
            station.message = "No double"
            return
        end

        if station.balance < hand.bet then
            station.message = "Need $" .. hand.bet
            return
        end

        station.balance = changeBalance(
            station.lockedPlayer,
            -hand.bet,
            "BLACKJACK DOUBLE: extra $" .. hand.bet
        )

        hand.bet = hand.bet * 2
        hand.doubled = true

        addCard(hand)
        hand.done = true

        if handValue(hand) > 21 then
            station.message = "Double bust"
        else
            station.message = "Doubled"
        end

        setNextTurn()

    elseif button == "split" then
        if not canSplit(hand) then
            station.message = "No split"
            return
        end

        if station.balance < hand.bet then
            station.message = "Need $" .. hand.bet
            return
        end

        station.balance = changeBalance(
            station.lockedPlayer,
            -hand.bet,
            "BLACKJACK SPLIT: extra $" .. hand.bet
        )

        local cards = safeCards(hand)
        local c1 = cards[1]
        local c2 = cards[2]
        local bet = hand.bet

        local h1 = makeHand(bet, true)
        local h2 = makeHand(bet, true)

        table.insert(h1.cards, c1)
        table.insert(h2.cards, c2)

        addCard(h1)
        addCard(h2)

        station.hands = {h1, h2}
        station.currentHand = 1
        currentTurnHandIndex = 1

        station.message = "Split"
    end
end

local function handleStationTouch(station, x, y)
    local button = buttonAt(station, x, y)
    if not button then return end

    if state == "betting" then
        if station.joined then
            station.message = "Already locked"
            return
        end

        if button == "qty_down" then
            station.quantity = math.max(1, station.quantity - 1)
            station.message = station.quantity <= 1 and "Min qty" or "Qty " .. station.quantity

        elseif button == "qty_up" then
            station.quantity = station.quantity + 1
            normalizeBet(station)

            if totalBet(station) >= MAX_BET then
                station.message = "Max bet"
            else
                station.message = "Qty " .. station.quantity
            end

        elseif button == "chip_down" then
            station.chipIndex = math.max(1, station.chipIndex - 1)
            normalizeBet(station)
            station.message = "Chip $" .. tostring(CHIP_VALUES[station.chipIndex])

        elseif button == "chip_up" then
            station.chipIndex = math.min(#CHIP_VALUES, station.chipIndex + 1)
            normalizeBet(station)
            station.message = "Chip $" .. tostring(CHIP_VALUES[station.chipIndex])

        elseif button == "deal" then
            joinStation(station)
        end

    elseif state == "playing" then
        handlePlayingButton(station, button)
    end
end

local function touchLoop()
    while true do
        local _, monitorName, x, y = os.pullEvent("monitor_touch")
        local station = stationByMonitorName(monitorName)

        if station then
            handleStationTouch(station, x, y)
        end

        sleep(0.05)
    end
end

