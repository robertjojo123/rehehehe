    local function prefetchNext()
        local target = segmentIndex + 1
        local seg = refreshManifestUntilSegment(target)
        if not seg then return end
        local url = absoluteUrl(seg.url)
        local h, err = http.get(url)
        nextHandle, nextSeg, nextErr = h, seg, err
    end

    -- If there is probably a next segment, prefetch while playing.
    -- If this is the last segment, prefetchNext will return after status says ready/no segment.
    parallel.waitForAll(playCurrent, prefetchNext)

    if currentHandle and currentHandle.close then currentHandle.close() end

    segmentIndex = segmentIndex + 1

    if nextHandle and nextSeg then
        currentHandle, currentSeg = nextHandle, nextSeg
    else
        -- Confirm if video is done or just not ready.
        local stWait = getJson(BASE .. "/status?job=" .. urlEncode(prep.job))
        if stWait and stWait.ready then
            break
        end

        currentHandle, currentSeg, currentErr = openSegmentNow(segmentIndex)
        if not currentHandle then break end
    end
end

clearTerm()
print("Done.")
print("Frames clocked: " .. tostring(playback.frames))
print("Frames rendered: " .. tostring(playback.rendered))
print("Frames dropped intentionally: 0")
print("Tape byte clock: " .. tostring(playback.useTapeClock))
print("A/V offset ms: " .. tostring(AUDIO_VIDEO_OFFSET_MS))
waitKey()
