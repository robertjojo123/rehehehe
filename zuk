local function search()
    clearTerm()
    print("YouTube search or URL:")
    write("> ")
    local q = read()

    clearTerm()
    print("Searching...")
    local data, err = getJson(BASE .. "/yt_search?q=" .. urlEncode(q) .. "&max_results=5")
    if not data then
        print(err)
        waitKey()
        return nil
    end

    local r = data.results or {}
    for i, v in ipairs(r) do
        print(i .. ". " .. trim(v.title, 42))
        print("   " .. trim(v.channel, 34))
    end

    print("")
    write("Pick: ")
    local n = tonumber(read())
    if n and r[n] then return r[n] end
    return nil
end

local function waitForPrepared(job)
    while true do
        local st = getJson(BASE .. "/status?job=" .. urlEncode(job))
        clearTerm()
        print("Preparing YouTube job...")
        if st then
            print("Status: " .. tostring(st.status))
            print("Mode: " .. tostring(st.quality_mode) .. " / " .. tostring(st.video_codec))
            print("Audio: " .. tostring(st.audio_ready) .. " bytes " .. tostring(st.audio_bytes or 0))
            print("Segments: " .. tostring(st.segments_ready or 0) .. "/" .. tostring(st.segment_count or 0))
            print(tostring(st.message or ""))

            if st.status == "error" then
                print(st.error)
                waitKey()
                return nil
            end

            local needed = START_BUFFER_SEGMENTS
            local total = tonumber(st.segment_count or 0)
            if total > 0 and total < needed then needed = total end

            if st.audio_ready and tonumber(st.segments_ready or 0) >= needed then
                return st
            end
        end
        sleep(1)
    end
end

local function getManifest(job)
    return getJson(BASE .. "/manifest?job=" .. urlEncode(job))
end

