local mon = getDisplay()

local function absoluteUrl(u)
    if u and u:sub(1, 1) == "/" then return BASE .. u end
    return u
end

local function refreshManifestUntilSegment(index)
    while true do
        man = getManifest(prep.job)
        if man and man.segments and man.segments[index] then
            return man.segments[index]
        end

        local stWait = getJson(BASE .. "/status?job=" .. urlEncode(prep.job))
        if stWait and stWait.ready then return nil end

        clearTerm()
        print("Waiting for segment " .. tostring(index) .. "...")
        if stWait then
            print("Ready: " .. tostring(stWait.segments_ready or 0) .. "/" .. tostring(stWait.segment_count or "?"))
        end
        sleep(0.5)
    end
end

local function openSegmentNow(index)
    local seg = refreshManifestUntilSegment(index)
    if not seg then return nil, nil, "no segment" end

    local url = absoluteUrl(seg.url)
    local h, err = http.get(url)
    return h, seg, err
end

local function drawFirstFrameFromHandle(seg, res)
    local codec = seg.codec or man.video_codec or "CVD2"
    local firstFrame = nil

    if codec == "CVD4" then
        local fps, err, firstLine = readCVD4Header(res)
        man.fps = fps or man.fps or DEFAULT_FPS
        firstFrame = readCVD4Frame(res, firstLine)
        if firstFrame then drawCVD4Frame(mon, firstFrame) end
    else
        local state = {
            mon = mon,
            palette = {},
            paletteApplied = false,
            fps = man.fps or DEFAULT_FPS,
            lastFrame = 0,
        }
        firstFrame = readCVD2Frame(res, state)
        if firstFrame then drawCVD2Frame(mon, firstFrame) end
    end

    return firstFrame
end

local function playSegmentHandle(seg, res, playback)
    local codec = seg.codec or man.video_codec or "CVD2"

    if codec == "CVD4" then
        return playCVD4Segment(res, mon, playback, nil)
    else
        return playCVD2Segment(res, mon, playback)
    end
end

