    br2 = {pieceId="B_ROOK_A", side="black", kind="rook", file=1, rank=8, square="A8"},

    -- Optional aliases in case you label white back pieces without the w prefix.
    r1 = nil, n1 = nil, b1 = nil, k = nil, q = nil, b2 = nil, n2 = nil, r2 = nil,
