-- wizard_chess_piece_agent_reusable_v6.lua
-- Reusable Wizard Chess NI/mob agent for all currently mapped pieces.
--
-- Labels / IDs:
--   White pawns: wp1..wp8 = 10342..10349
--   Black pawns: bp1..bp8 = 10350..10357
--   White back row: wr1, wn1, wb1, wq, wk, wb2, wn2, wr2 = 10358..10365
--   Black back row: br1, bn1, bb1, bk, bq, bb2, bn2, br2 = 10366..10373
--
-- Important left/right convention:
--   White labels are left-to-right from White's side: A..H.
--   Black labels are left-to-right from Black's side: H..A in absolute board files.
--
-- This script:
--   - reads its own computer label
--   - maps that label to pieceId + starting square
--   - senses reference boat at A1
--   - uses rotated coordinate map:
--       rank +1 => world X -2
--       file +1 => world Z -2
--   - holds the assigned square
--   - listens for direct rednet commands from floor computer 8898
--   - if capture=true, tries a safe laser/attack pulse before moving/holding target square

-- =========================================================
-- Config
-- =========================================================

local FLOOR_COMPUTER_ID = 8898
local MODEM_SIDE = "front"
local PROTOCOL = "wizard_chess"

local SENSE_RANGE = 24
local BOAT_NAME_CONTAINS = "boat"

local SQUARE_SIZE = 2
local PIECE_Y_ABOVE_BOAT = 2.0
local TARGET_Y_EXTRA_UP = 1.14

local HOLD_TOLERANCE = 0.20
local FACE_TOLERANCE = 0.65

-- One Minecraft tick. Do not set below 0.05.
local LOOP_DELAY = 0.05
local BOAT_RESCAN_SECONDS = 0.75
local STATUS_SECONDS = 1.0

-- Slow movement pulses.
local MIN_LAUNCH_POWER = 0.012
local MAX_LAUNCH_POWER = 0.105
local POWER_PER_BLOCK = 0.035

local KEEP_SUPPRESSING_AI = true

local FILES = {"A","B","C","D","E","F","G","H"}

-- Absolute board files/ranks.
-- file 1=A, file 8=H. rank 1=White back rank, rank 8=Black back rank.
