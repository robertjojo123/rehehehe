    bp4 = {pieceId="B_PAWN_E", side="black", kind="pawn", file=5, rank=7, square="E7"},
    bp5 = {pieceId="B_PAWN_D", side="black", kind="pawn", file=4, rank=7, square="D7"},
    bp6 = {pieceId="B_PAWN_C", side="black", kind="pawn", file=3, rank=7, square="C7"},
