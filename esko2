-- === Incoming Stat Handlers
-- =========================================================

local function handleDirectGambleWinStat(msg)
    if type(msg) ~= "table" then return end
    if msg.action ~= "gamble_win_stat" then return end

    local player = msg.player
    local game = msg.game or "unknown"
    local wager = tonumber(msg.wager) or 0
    local payout = tonumber(msg.payout) or 0

    addGamblingWinStat(
        player,
        game,
        wager,
        payout,
        "direct stat"
    )
end

local function getRouletteRoundKey(player, result)
    return tostring(player) .. "|" .. tostring(result)
end

local function cleanupOldPendingRouletteRounds()
    local now = os.clock()

    for key, round in pairs(pendingRouletteRounds) do
        if round.lastUpdate and now - round.lastUpdate > 45 then
            pendingRouletteRounds[key] = nil
        end
    end
end

local function trackRouletteOutcomeNote(player, note)
    if not player or type(note) ~= "string" then return end

    local winBet, winZone, winResult, winPayout = note:match(
        "ROULETTE RESULT:%s*WIN%s*%-%s*bet%s*%$(%d+)%s*on%s*(.-),%s*landed%s*(.-),%s*payout%s*%$(%d+)"
    )

    if winBet and winResult and winPayout then
        winBet = tonumber(winBet) or 0
        winPayout = tonumber(winPayout) or 0

        local key = getRouletteRoundKey(player, winResult)

        pendingRouletteRounds[key] = pendingRouletteRounds[key] or {
            player = player,
            result = winResult,
            wager = 0,
            payout = 0,
            lastUpdate = os.clock()
        }

        pendingRouletteRounds[key].wager = pendingRouletteRounds[key].wager + winBet
        pendingRouletteRounds[key].payout = pendingRouletteRounds[key].payout + winPayout
        pendingRouletteRounds[key].lastUpdate = os.clock()

        print("Tracked roulette WIN outcome note:")
        print(" Player:", player)
        print(" Bet:", winBet)
        print(" Payout:", winPayout)
        print(" Result:", winResult)
        return
    end

    local lossBet, lossZone, lossResult = note:match(
        "ROULETTE RESULT:%s*LOSS%s*%-%s*bet%s*%$(%d+)%s*on%s*(.-),%s*landed%s*(.-)$"
    )

    if lossBet and lossResult then
        lossBet = tonumber(lossBet) or 0

        local key = getRouletteRoundKey(player, lossResult)

        pendingRouletteRounds[key] = pendingRouletteRounds[key] or {
            player = player,
            result = lossResult,
            wager = 0,
            payout = 0,
            lastUpdate = os.clock()
        }

        pendingRouletteRounds[key].wager = pendingRouletteRounds[key].wager + lossBet
        pendingRouletteRounds[key].lastUpdate = os.clock()

        print("Tracked roulette LOSS outcome note:")
        print(" Player:", player)
        print(" Bet:", lossBet)
        print(" Result:", lossResult)
        return
    end
end

local function finalizeRoulettePayoutNote(player, note)
    if not player or type(note) ~= "string" then return end

    local payout, result = note:match(
        "ROULETTE WIN PAYOUT:%s*%$(%d+),%s*landed%s*(.-)$"
    )

    if not payout or not result then
        return
    end

    payout = tonumber(payout) or 0

    local key = getRouletteRoundKey(player, result)
    local round = pendingRouletteRounds[key]

    if not round then
        print("Roulette payout note received but no pending round found.")
        print(" Player:", player)
        print(" Result:", result)
        print(" Payout:", payout)
        return
    end

    local totalWager = tonumber(round.wager) or 0
    local totalPayout = payout

    addGamblingWinStat(
        player,
        "roulette",
        totalWager,
        totalPayout,
        "landed " .. tostring(result)
    )

    pendingRouletteRounds[key] = nil
end

local function handleCasinoTransferForStats(player, note)
    if not player or type(note) ~= "string" then return end

    trackRouletteOutcomeNote(player, note)
    finalizeRoulettePayoutNote(player, note)
    cleanupOldPendingRouletteRounds()
end

-- =========================================================
-- === Deposit / Payout Logic
-- =========================================================

local function processDeposit(player)
    local total = 0

    for slot, item in pairs(shulkerBox.list()) do
        if item.nbtHash then
            local prefix = string.sub(item.nbtHash, 1, 6)
            local value = VALID_ITEMS[prefix]

            if value then
                local moved = shulkerBox.pushItems(obCN, slot, item.count)
                total = total + (moved * value)
            end
        end
    end

    if total > 0 then
        local newBal = getBalance(player) + total
        setBalance(player, newBal)
        logTransaction(player, "DEPOSIT: Book tokens deposited", total)
        return newBal, "Deposited!"
    end

    return getBalance(player), "No valid tokens."
end

local function processPayout(player)
    local value = PAYOUT_OPTIONS[selectedValueIndex]
    local qtyToMove = selectedQty
    local total = value * qtyToMove
    local bal = getBalance(player)

    if bal < total then
        message = "Insufficient balance."
        return bal
    end

    local prefix = nil

    for k, v in pairs(VALID_ITEMS) do
        if v == value then
            prefix = k
            break
        end
    end

    if not prefix then
        message = "Token type error."
        return bal
    end

    local chest = peripheral.wrap(obCN)
    local movedTotal = 0

    for slot, item in pairs(chest.list()) do
        if item.nbtHash and string.sub(item.nbtHash, 1, 6) == prefix then
            while movedTotal < qtyToMove and item.count > 0 do
                local moved = chest.pushItems(dropper, slot, 1)

                if moved > 0 then
                    movedTotal = movedTotal + 1
                    sleep(0.05)
                else
                    break
                end
            end
        end

        if movedTotal >= qtyToMove then break end
    end

    if movedTotal < qtyToMove then
        message = "Only moved " .. movedTotal .. "/" .. qtyToMove
        return bal
    end

    setBalance(player, bal - total)
    logTransaction(player, "PAYOUT: " .. qtyToMove .. " x $" .. value, -total)
    message = "Dispensed " .. qtyToMove .. " x $" .. value
    return getBalance(player)
end

-- =========================================================
-- === Radar Loop
-- =========================================================

local activePlayer, balance, distance, message = nil, 0, nil, ""
local smalrad, largerad = 1.75, 4

local function radarLoop()
    while true do
        local players = radar.getPlayers()
        local valP, cP = {}, nil

        for _, p in ipairs(players) do
            if p.distance <= largerad then
                table.insert(valP, p)

                if p.distance <= smalrad then
                    if not cP or p.distance < cP.distance then
                        cP = p
                    end
                end 
            end
        end

        if not rip then
            print("no rip")

        elseif #valP == 1 and cP then
            activePlayer = cP.name
            distance = cP.distance
            balance = getBalance(activePlayer)
            rip.setOutput("bottom", true)
            message = ""

        elseif #valP == 1 and not cP then
            activePlayer, distance = nil, nil
            rip.setOutput("bottom", false)
            message = "Not Close Enough!"

        elseif #valP > 1 then
            activePlayer, distance = nil, nil
            rip.setOutput("bottom", false)
            message = "Too Many Players!"

        else
            activePlayer, distance = nil, nil
            rip.setOutput("bottom", false)
            message = ""
        end

        sleep(0.05)
    end
end

