-- =========================================================
-- === Account Helpers
-- =========================================================

local function getPlayerFile(player)
    return "/accounts/" .. player .. ".txt"
end

local function getBalance(player)
    local path = getPlayerFile(player)
    if fs.exists(path) then
        local f = fs.open(path, "r")
        local val = tonumber(f.readAll())
        f.close()
        return val or 0
    end
    return 0
end

local function setBalance(player, amount)
    local f = fs.open(getPlayerFile(player), "w")
    f.write(tostring(amount))
    f.close()
end

local function logTransaction(player, message, change)
    if not fs.exists("/accounts/logs") then fs.makeDir("/accounts/logs") end

    local logPath = "/accounts/logs/" .. player .. ".txt"
    local time = textutils.formatTime(os.time(), true)
    local newBalance = getBalance(player)
    local delta = (change >= 0 and "+" or "") .. tostring(change)
    local entry = "[" .. time .. "] " .. message .. " " .. delta .. " (Balance: " .. newBalance .. ")"

    local lines = {}

    if fs.exists(logPath) then
        local file = fs.open(logPath, "r")
        while true do
            local line = file.readLine()
            if not line then break end
            table.insert(lines, line)
        end
        file.close()
    end

    table.insert(lines, entry)

    while #lines > 500 do
        table.remove(lines, 1)
    end

    local file = fs.open(logPath, "w")
    for _, line in ipairs(lines) do
        file.writeLine(line)
    end
    file.close()
end

-- =========================================================
-- === Gambling Win Stats Helpers
-- =========================================================

local function getMonthKey()
    if os.date then
        local ok, val = pcall(function()
            return os.date("%Y-%m")
        end)

        if ok and val and type(val) == "string" and #val > 0 then
            return val
        end
    end

    return "current"
end

local function loadWinStats()
    if fs.exists(WIN_STATS_FILE) then
        local f = fs.open(WIN_STATS_FILE, "r")
        local text = f.readAll()
        f.close()

        local data = textutils.unserialize(text)

        if type(data) == "table" then
            data.allTime = data.allTime or {}
            data.months = data.months or {}
            return data
        end
    end

    return {
        allTime = {},
        months = {}
    }
end

local function saveWinStats(data)
    local f = fs.open(WIN_STATS_FILE, "w")
    f.write(textutils.serialize(data))
    f.close()
end

local function appendWinStatsLog(line)
    local lines = {}

    if fs.exists(WIN_STATS_LOG_FILE) then
        local f = fs.open(WIN_STATS_LOG_FILE, "r")
        while true do
            local l = f.readLine()
            if not l then break end
            table.insert(lines, l)
        end
        f.close()
    end

    table.insert(lines, line)

    while #lines > 1000 do
        table.remove(lines, 1)
    end

    local f = fs.open(WIN_STATS_LOG_FILE, "w")
    for _, l in ipairs(lines) do
        f.writeLine(l)
    end
    f.close()
end

local function ensurePlayerStats(bucket, player)
    bucket[player] = bucket[player] or {
        profit = 0,
        payout = 0,
        wager = 0,
        wins = 0,
        games = {}
    }

    return bucket[player]
end

local function ensureGameStats(playerStats, game)
    playerStats.games[game] = playerStats.games[game] or {
        profit = 0,
        payout = 0,
        wager = 0,
        wins = 0
    }

    return playerStats.games[game]
end

local function addGamblingWinStat(player, game, wager, payout, detail)
    player = tostring(player or "")
    game = tostring(game or "unknown")
    wager = tonumber(wager) or 0
    payout = tonumber(payout) or 0

    local profit = payout - wager

    if player == "" then return false end
    if profit <= 0 then return false end

    local data = loadWinStats()
    local month = getMonthKey()

    data.allTime = data.allTime or {}
    data.months = data.months or {}
    data.months[month] = data.months[month] or {}

    local allPlayer = ensurePlayerStats(data.allTime, player)
    local monthPlayer = ensurePlayerStats(data.months[month], player)

    local allGame = ensureGameStats(allPlayer, game)
    local monthGame = ensureGameStats(monthPlayer, game)

    allPlayer.profit = allPlayer.profit + profit
    allPlayer.payout = allPlayer.payout + payout
    allPlayer.wager = allPlayer.wager + wager
    allPlayer.wins = allPlayer.wins + 1

    monthPlayer.profit = monthPlayer.profit + profit
    monthPlayer.payout = monthPlayer.payout + payout
    monthPlayer.wager = monthPlayer.wager + wager
    monthPlayer.wins = monthPlayer.wins + 1

    allGame.profit = allGame.profit + profit
    allGame.payout = allGame.payout + payout
    allGame.wager = allGame.wager + wager
    allGame.wins = allGame.wins + 1

    monthGame.profit = monthGame.profit + profit
    monthGame.payout = monthGame.payout + payout
    monthGame.wager = monthGame.wager + wager
    monthGame.wins = monthGame.wins + 1

    saveWinStats(data)

    local time = textutils.formatTime(os.time(), true)
    local logLine = "[" .. time .. "] "
        .. player
        .. " | " .. game
        .. " | wager $" .. wager
        .. " | payout $" .. payout
        .. " | leaderboard +" .. profit

    if detail then
        logLine = logLine .. " | " .. tostring(detail)
    end

    appendWinStatsLog(logLine)

    print("Recorded gambling win stat:")
    print(" Player:", player)
    print(" Game:", game)
    print(" Wager:", wager)
    print(" Payout:", payout)
    print(" Profit:", profit)

    return true
end

local function getSortedWinLeaderboard(monthKey)
    local data = loadWinStats()
    local source

    if monthKey and data.months and data.months[monthKey] then
        source = data.months[monthKey]
    else
        source = data.allTime or {}
    end

    local list = {}

    for player, stats in pairs(source) do
        table.insert(list, {
            player = player,
            profit = tonumber(stats.profit) or 0,
            payout = tonumber(stats.payout) or 0,
            wager = tonumber(stats.wager) or 0,
            wins = tonumber(stats.wins) or 0
        })
    end

    table.sort(list, function(a, b)
        return a.profit > b.profit
    end)

    return list
end

local function printTopGambleStats(limit, monthKey)
    limit = limit or 10
    local list = getSortedWinLeaderboard(monthKey)

    print("=== Gambling Win Leaderboard ===")

    if monthKey then
        print("Month:", monthKey)
    else
        print("All Time")
    end

    for i = 1, math.min(limit, #list) do
        local row = list[i]
        print(i .. ". " .. row.player
            .. " +" .. row.profit
            .. " | payout $" .. row.payout
            .. " | wager $" .. row.wager
            .. " | wins " .. row.wins)
    end

    if #list == 0 then
        print("No gambling win stats yet.")
    end
end

-- =========================================================
-- === Chat Sanitization / Public Casino Stats
-- =========================================================

local function cleanPlayerName(name)
    name = tostring(name or "")
    name = name:gsub("§.", "")
    name = name:gsub("[^%w_]", "")
    return name
end

local function cleanChatText(text)
    text = tostring(text or "")
    text = text:gsub("§.", "")
    text = text:gsub("[\r\n\t]", " ")
    text = text:gsub("[^%w%s%p]", "")
    return text
end

local function normalizeChatMessage(msg)
    msg = tostring(msg or "")
    msg = msg:gsub("§.", "")
    return msg:lower():gsub("^%s+", ""):gsub("%s+$", "")
end

local function isHiddenFromCasinoStats(player)
    local clean = cleanPlayerName(player)

    if HIDE_FROM_CASINO_STATS_CHAT[clean] then
        return true
    end

    for name, hidden in pairs(HIDE_FROM_CASINO_STATS_CHAT) do
        if hidden and cleanPlayerName(name):lower() == clean:lower() then
            return true
        end
    end

    return false
end

local function casinoStatsSayPublic(text)
    text = cleanChatText(text)

    if #text > 230 then
        text = text:sub(1, 230)
    end

    if chat and chat.say then
        local ok, err = pcall(function()
            chat.say(text)
        end)

        if not ok then
            print("chat.say failed:")
            print(err)
            print("Message was:", text)
        end
    else
        print("CHAT OUT:", text)
    end

    sleep(0.25)
end

local function shortMoney(n)
    n = tonumber(n) or 0
    local sign = ""

    if n < 0 then
        sign = "-"
        n = math.abs(n)
    end

    if n >= 1000000 then
        local v = math.floor((n / 1000000) * 10 + 0.5) / 10
        return sign .. "$" .. tostring(v) .. "M"
    elseif n >= 1000 then
        local v = math.floor((n / 1000) * 10 + 0.5) / 10
        return sign .. "$" .. tostring(v) .. "k"
    else
        return sign .. "$" .. tostring(math.floor(n))
    end
end

local function announceCasinoStatsPublic(requester)
    local leaders = getSortedWinLeaderboard(nil)

    if not leaders or #leaders == 0 then
        casinoStatsSayPublic("Casino Stats: no winners logged yet.")
        return
    end

    local parts = {}
    local shown = 0

    for i = 1, #leaders do
        local row = leaders[i]
        local player = cleanChatText(row.player or "unknown")
        local profit = tonumber(row.profit) or 0

        if not isHiddenFromCasinoStats(player) then
            shown = shown + 1
            table.insert(parts, "#" .. shown .. " " .. player .. " +" .. shortMoney(profit))

            if shown >= CHAT_TOP_COUNT then
                break
            end
        end
    end

    if shown == 0 then
        casinoStatsSayPublic("Casino Stats: no visible winners yet.")
    else
        casinoStatsSayPublic("Casino Top " .. shown .. ": " .. table.concat(parts, " | "))
    end
end

local function chatCommandLoop()
    if not chat then
        print(CHAT_MANIPULATOR_NAME .. " chat peripheral missing. Chat command loop disabled.")
        while true do sleep(10) end
    end

    if not chat.say then
        print(CHAT_MANIPULATOR_NAME .. " found, but no say() method. Chat command loop disabled.")
        while true do sleep(10) end
    end

    if chat.capture then
        pcall(function()
            chat.capture(CHAT_CAPTURE_PATTERN)
        end)
    end

    print("Casino chat command ready: " .. CHAT_COMMAND)
    print("Using public chat.say() output.")
    print("Listening for both chat_capture and chat_message.")
    print("Hidden casino stats players:")
    for name, hidden in pairs(HIDE_FROM_CASINO_STATS_CHAT) do
        if hidden then print("  " .. tostring(name)) end
    end

    while true do
        local event = {os.pullEvent()}
        local eventName = event[1]

        local message = nil
        local player = nil
        local pattern = nil
        local matched = false

        if eventName == "chat_capture" then
            -- Plethora capture format:
            -- local _, message, pattern, player, uuid = os.pullEvent("chat_capture")
            message = event[2]
            pattern = event[3]
            player = event[4]

            if pattern == CHAT_CAPTURE_PATTERN and normalizeChatMessage(message) == CHAT_COMMAND then
                matched = true
            end

        elseif eventName == "chat_message" then
            -- Common format:
            -- local _, player, message, uuid = os.pullEvent("chat_message")
            player = event[2]
            message = event[3]

            if normalizeChatMessage(message) == CHAT_COMMAND then
                matched = true
            end
        end

        if matched then
            local requester = cleanPlayerName(player)
            local now = os.clock()

            print("Casino stats command detected.")
            print("Event:", tostring(eventName))
            print("Message:", tostring(message))
            print("Pattern:", tostring(pattern))
            print("Raw player:", tostring(player))
            print("Safe player:", tostring(requester))

            if now - lastChatCommandAt >= CHAT_COOLDOWN_SECONDS then
                lastChatCommandAt = now
                announceCasinoStatsPublic(requester)
            else
                print("Casino stats command ignored: cooldown")
            end
        end
    end
end

