-- winParticleTest_spiralWinner.lua
-- Uses particle peripheral on LEFT with method: spawn

local p = peripheral.wrap("left")
if not p then error("No particle peripheral on left") end
if type(p.spawn) ~= "function" then error("Left peripheral has no spawn method") end

-- Change this to match the turtle's facing direction.
local FACING = "north" -- north/south/east/west

local PARTICLE = "happyVillager"

local DIR = {
    north = {front = {x = 0, z = -1}, right = {x = 1, z = 0}},
    south = {front = {x = 0, z = 1},  right = {x = -1, z = 0}},
    east  = {front = {x = 1, z = 0},  right = {x = 0, z = 1}},
    west  = {front = {x = -1, z = 0}, right = {x = 0, z = -1}},
}

local facing = DIR[FACING]
if not facing then error("Bad FACING. Use north/south/east/west.") end

local function spawnParticle(x, y, z)
    -- Try the simple signature first, then fallbacks.
    local ok = pcall(function()
        p.spawn(PARTICLE, x, y, z)
    end)

    if ok then return end

    ok = pcall(function()
        p.spawn(PARTICLE, x, y, z, 0, 0, 0)
    end)

    if ok then return end

    ok = pcall(function()
        p.spawn(PARTICLE, x, y, z, 0, 0, 0, 0)
    end)

    if ok then return end

    pcall(function()
        p.spawn(PARTICLE, x, y, z, 0, 0, 0, 0, 1)
    end)
end

local function drawTwoBlockSpiral()
    local STEPS = 160
    local START_Y = 1.0
    local END_Y = 6.0
    local DELAY = 0.015

    -- Center between turtle block and block to its right
    local centerX = facing.right.x / 2
    local centerZ = facing.right.z / 2

    local radius = 0.75

    for i = 1, STEPS do
        local t = i / STEPS
        local angle = i * 0.35

        local y = START_Y + ((END_Y - START_Y) * t)

        local x = centerX + math.cos(angle) * radius
        local z = centerZ + math.sin(angle) * radius

        spawnParticle(x, y, z)
        sleep(DELAY)
    end
end

local FONT = {
    W = {
        "10001",
        "10001",
        "10101",
        "10101",
        "01010",
    },
    I = {
        "111",
        "010",
        "010",
        "010",
        "111",
    },
    N = {
        "1001",
        "1101",
        "1011",
        "1001",
        "1001",
    },
    E = {
        "1111",
        "1000",
        "1110",
        "1000",
        "1111",
    },
    R = {
        "1110",
        "1001",
        "1110",
        "1010",
        "1001",
    },
}

local function getTextWidth(text)
    local width = 0

    for i = 1, #text do
        local ch = text:sub(i, i)
        local glyph = FONT[ch]

        if glyph then
            width = width + #glyph[1] + 1
        end
    end

    return math.max(0, width - 1)
end

local function textPointToWorld(localX, localY, localZ)
    -- localX = horizontal across the word, using turtle-right direction
    -- localY = vertical
    -- localZ = distance in front, using turtle-front direction
    local wx = (facing.right.x * localX) + (facing.front.x * localZ)
    local wz = (facing.right.z * localX) + (facing.front.z * localZ)
    return wx, localY, wz
end

local function drawWinnerText()
    local text = "WINNER"

    -- Particle-letter settings
    local pixelSpacing = 0.18
    local letterSpacing = pixelSpacing
    local heightStep = 0.18

    -- Position:
    -- 2 blocks in front, 1 block above.
    local frontDistance = 2.0
    local baseY = 1.0

    -- Center the word in front of the turtle.
    local textWidthPixels = getTextWidth(text)
    local startX = -(textWidthPixels * pixelSpacing) / 2

    local cursorX = startX

    for i = 1, #text do
        local ch = text:sub(i, i)
        local glyph = FONT[ch]

        if glyph then
            local glyphW = #glyph[1]
            local glyphH = #glyph

            for row = 1, glyphH do
                local line = glyph[row]

                for col = 1, glyphW do
                    if line:sub(col, col) == "1" then
                        local lx = cursorX + ((col - 1) * pixelSpacing)
                        local ly = baseY + ((glyphH - row) * heightStep)

                        local wx, wy, wz = textPointToWorld(lx, ly, frontDistance)

                        -- Spawn a couple particles per dot so the letters read better.
                        spawnParticle(wx, wy, wz)
                        spawnParticle(wx, wy + 0.03, wz)
                    end
                end
            end

            cursorX = cursorX + (glyphW * pixelSpacing) + letterSpacing
        end
    end
end

print("Starting winner spiral + text...")
parallel.waitForAll(
    drawTwoBlockSpiral,
    function()
        -- Draw WINNER repeatedly while the spiral runs so it hangs in the air longer.
        for i = 1, 18 do
            drawWinnerText()
            sleep(0.08)
        end
    end
)
print("Done.")
