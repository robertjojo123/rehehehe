local function ensureBaseUrl()
    local b = trimSpaces(BASE or "")
    if b ~= "" then return b end
    if fs and fs.exists and fs.open and fs.exists(BASE_CONFIG_FILE) then
        local h = fs.open(BASE_CONFIG_FILE, "r")
        if h then
            b = trimSpaces(h.readAll())
            h.close()
            if b ~= "" then return b end
        end
    end

    clearTerm()
    print("Paste Cloudflare Tunnel base URL:")
    print("Example: https://abc-def.trycloudflare.com")
    write("> ")
    b = trimSpaces(read())
    if b:sub(-1) == "/" then b = b:sub(1, -2) end
    if fs and fs.open and b ~= "" then
        local h = fs.open(BASE_CONFIG_FILE, "w")
        if h then h.write(b) h.close() end
    end
    return b
end

local function monitorClear(mon)
    if not mon then return end
    mon.setBackgroundColor(colors.black)
    mon.setTextColor(colors.white)
    mon.clear()
    mon.setCursorPos(1, 1)
end

local function monitorWrite(mon, x, y, text, fg, bg)
    if not mon then return end
    if fg then mon.setTextColor(fg) else mon.setTextColor(colors.white) end
    if bg then mon.setBackgroundColor(bg) else mon.setBackgroundColor(colors.black) end
    mon.setCursorPos(x, y)
    mon.write(tostring(text or ""))
end

