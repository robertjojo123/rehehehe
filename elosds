local function drawResultsOnMonitor(mon, results, typed)
    monitorClear(mon)
    monitorWrite(mon, 2, 1, "Pick a video: touch an option or type number in terminal", colors.yellow)
    if typed and typed ~= "" then
        monitorWrite(mon, 2, 3, "Terminal pick: " .. typed, colors.lightBlue)
    end
    local startY = 5
    for i, v in ipairs(results or {}) do
        local y = startY + (i - 1) * 3
        monitorWrite(mon, 2, y, tostring(i) .. ". " .. trim(v.title or "?", 70), colors.white)
        monitorWrite(mon, 5, y + 1, trim(v.channel or "", 60), colors.gray)
    end
    monitorWrite(mon, 2, startY + #(results or {}) * 3 + 1, "Backspace edits. Enter confirms. Q cancels.", colors.lightGray)
end

local function chooseResultOnTerminalOrMonitor(mon, results)
    local typed = ""
    drawResultsOnMonitor(mon, results, typed)

    clearTerm()
    print("Search results:")
    for i, v in ipairs(results or {}) do
        print(i .. ". " .. trim(v.title, 55))
        print("   " .. trim(v.channel or "", 45))
    end
    print("")
    print("Type number + Enter, or touch option on monitor. Q cancels.")
    write("> ")

    while true do
        local ev, a, b, c = os.pullEvent()
        if ev == "char" then
            local ch = tostring(a or "")
            if ch:match("%d") then
                typed = typed .. ch
                write(ch)
                drawResultsOnMonitor(mon, results, typed)
            elseif ch:lower() == "q" then
                return nil
            end
        elseif ev == "key" then
            if a == keys.enter then
                print("")
                local n = tonumber(typed)
                if n and results[n] then return results[n] end
                write("> ")
                typed = ""
                drawResultsOnMonitor(mon, results, typed)
            elseif a == keys.backspace then
                if #typed > 0 then
                    typed = typed:sub(1, -2)
                    clearTerm()
                    print("Search results:")
                    for i, v in ipairs(results or {}) do
                        print(i .. ". " .. trim(v.title, 55))
                        print("   " .. trim(v.channel or "", 45))
                    end
                    print("")
                    print("Type number + Enter, or touch option on monitor. Q cancels.")
                    write("> " .. typed)
                    drawResultsOnMonitor(mon, results, typed)
                end
            elseif a == keys.q then
                return nil
            end
        elseif ev == "monitor_touch" then
            local x, y = b, c
            local startY = 5
            for i = 1, #(results or {}) do
                local oy = startY + (i - 1) * 3
                if y >= oy and y <= oy + 1 then
                    return results[i]
                end
            end
        end
    end
end

