-- V32 loop UI + rewind sync-fix RLE full-frame player: per-frame palette, full redraw, adaptive runway, exact audio-byte/frame timing with tape-byte correction.
-- Cloudflare Quick Tunnel URLs change. Put the URL in yt_base.txt, or paste it when prompted.
local BASE_CONFIG_FILE = "yt_base.txt"
local DEFAULT_BASE = "https://apparatus-filtering-sku-wearing.trycloudflare.com" -- example: https://your-random-name.trycloudflare.com
local BASE = DEFAULT_BASE

local function trimSpaces(s)
    return tostring(s or ""):gsub("^%s+", ""):gsub("%s+$", "")
end

local function loadBaseUrl()
    local b = trimSpaces(BASE)
    if b ~= "" then return b end
    if fs and fs.exists and fs.open and fs.exists(BASE_CONFIG_FILE) then
        local h = fs.open(BASE_CONFIG_FILE, "r")
        if h then
            b = trimSpaces(h.readAll())
            h.close()
            if b ~= "" then return b end
        end
    end
    clearTerm()
    print("Paste Cloudflare Tunnel base URL:")
    print("Example:")
    print("https://abc-def.trycloudflare.com")
    write("> ")
    b = trimSpaces(read())
    if b:sub(-1) == "/" then b = b:sub(1, -2) end
    if fs and fs.open and b ~= "" then
        local h = fs.open(BASE_CONFIG_FILE, "w")
        if h then h.write(b) h.close() end
    end
    return b
end


