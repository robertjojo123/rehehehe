    monitorClear(mon)
    monitorWrite(mon, 2, 2, "Searching...", colors.yellow)
    monitorWrite(mon, 2, 4, trim(q, 70), colors.white)

    local data, err = getJson(BASE .. "/yt_search?q=" .. urlEncode(q) .. "&max_results=5")
    if not data then
        print(err)
        monitorWrite(mon, 2, 6, "Search failed: " .. trim(err, 70), colors.red)
        waitKey()
        return nil
    end
    if data.ok == false then
        print("Search failed:")
        print(tostring(data.error or "unknown"))
        monitorWrite(mon, 2, 6, "Search failed: " .. trim(data.error or "unknown", 70), colors.red)
        waitKey()
        return nil
    end

    local r = data.results or {}
    if #r == 0 then
        print("No results.")
        monitorWrite(mon, 2, 6, "No results.", colors.red)
        sleep(1.5)
        return nil
    end
    return chooseResultOnTerminalOrMonitor(mon, r)
end

local function callCancel(job)
    if job and job ~= "" then
        pcall(function() get(BASE .. "/cancel?job=" .. urlEncode(job)) end)
    else
        pcall(function() get(BASE .. "/cancel") end)
    end
end

local function callReset()
    pcall(function() get(BASE .. "/reset") end)
end

