local function preparePickedVideo(mon, picked)
    clearTerm()
    print("Picked:")
    print(trim(picked.title, 50))
    print("")
    print("WebSocket v32 loop UI RLE full-redraw per-frame palette sync-fix mode")
    print("Audio writes first; tape starts after adaptive safe runway estimate")
    print("Offset ms: " .. tostring(AUDIO_VIDEO_OFFSET_MS))
    print("")
    print("Continue? y")
    monitorClear(mon)
    monitorWrite(mon, 2, 2, "Picked:", colors.yellow)
    monitorWrite(mon, 2, 4, trim(picked.title, 70), colors.white)
    monitorWrite(mon, 2, 6, "Type y in terminal to prepare/play.", colors.lightGray)
    if tostring(read()):lower() ~= "y" then return nil end

    local prep, prepErr = getJson(
        BASE .. "/yt_prepare?id=" .. urlEncode(picked.id)
        .. "&total_seconds=" .. tostring(TOTAL_SECONDS)
        .. "&segment_seconds=120"
        .. "&fps=" .. tostring(DEFAULT_FPS)
    )

    if not prep then print("prepare failed: " .. tostring(prepErr)) waitKey() return nil end

    local st = waitForPrepared(prep.job)
    if not st then return nil end

    local man = getManifest(prep.job)
    if not man then print("No manifest") waitKey() return nil end

    local totalSeconds = tonumber(man.total_seconds or st.total_seconds or TOTAL_SECONDS or 0) or 0
    local expectedTotalFrames = 0
    if totalSeconds > 0 then expectedTotalFrames = math.floor(totalSeconds * DEFAULT_FPS + 0.5) end
    local shortFullPreload = SHORT_PRELOAD_ALL_FRAMES and totalSeconds > 0 and totalSeconds <= SHORT_FULL_PRELOAD_SECONDS

    local audioUrl = man.audio_url
    if audioUrl:sub(1, 1) == "/" then audioUrl = BASE .. audioUrl end

    clearTerm()
    print("Audio mode:")
    print("Tape speed: " .. tostring(man.tape_speed or 1.0))
    print("Slow factor: " .. tostring(man.audio_slow_factor or "?"))
    print("Mode: " .. tostring(man.audio_mode or "?"))
    print("Bytes: " .. tostring(man.audio_bytes or 0))
    if man.audio_expected_bytes then print("Expected: " .. tostring(man.audio_expected_bytes)) end
    print("Clock: tape bytes if available; audio-byte wall fallback")
    monitorClear(mon)
    monitorWrite(mon, 2, 2, "Writing audio to tape...", colors.yellow)
    monitorWrite(mon, 2, 4, "Tape speed: " .. tostring(man.tape_speed or 1.0), colors.white)
    sleep(1)

    local tape = writeAudioToTape(audioUrl, man.tape_speed or 1.0, man.audio_bytes)
    if not tape then waitKey() return nil end

    if not waitForVideoCacheRunwayBeforeTape(prep.job, expectedTotalFrames, totalSeconds) then
        waitKey()
        return nil
    end

    -- V32: refresh the frame count after runway waiting. The earlier v31 loop UI
    -- could still use duration*fps even after the server knew the real ffmpeg
    -- frame count, which makes audio-byte/frame sync drift over long videos.
    local st2 = getJson(BASE .. "/status?job=" .. urlEncode(prep.job)) or st
    local man2 = getManifest(prep.job) or man
    expectedTotalFrames = resolveFrameCount(man2, st2, expectedTotalFrames)
    man = man2 or man
    st = st2 or st

    return {
        prep = prep,
        man = man,
        st = st,
        tape = tape,
        totalSeconds = totalSeconds,
        expectedTotalFrames = expectedTotalFrames,
        shortFullPreload = shortFullPreload,
        picked = picked,
    }
end

local function playPreparedOnce(mon, ctx)
    local prep, man, tape = ctx.prep, ctx.man, ctx.tape
    local expectedTotalFrames = ctx.expectedTotalFrames or 0
    local shortFullPreload = ctx.shortFullPreload

    -- V32: refresh again right before playback/rewind starts, because the
    -- background cache may have finished while audio was written or while the
    -- user was reading the screen. This keeps ms/frame and bytes/frame exact.
    local stStart = getJson(BASE .. "/status?job=" .. urlEncode(prep.job))
    local manStart = getManifest(prep.job)
    expectedTotalFrames = resolveFrameCount(manStart or man, stStart, expectedTotalFrames)
    if manStart then man = manStart; ctx.man = manStart end
    ctx.expectedTotalFrames = expectedTotalFrames

    local wsUrl = BASE:gsub("^http", "ws") .. "/ws_video?job=" .. urlEncode(prep.job)
        .. "&fps=" .. tostring(DEFAULT_FPS)
        .. "&total_seconds=" .. tostring(TOTAL_SECONDS)

    clearTerm()
    print("Checking websocket server route...")
    local probe, probeErr = getJson(BASE .. "/ws_probe")
    if not probe or not probe.ok then
        print("/ws_probe failed.")
        print(tostring(probeErr))
        waitKey()
        return "error"
    end

    local wsPingUrl = BASE:gsub("^http", "ws") .. "/ws_ping"
    print("Testing websocket ping...")
    local pingWs, pingErr = http.websocket(wsPingUrl, WS_HEADERS)
    if pingWs then
        local pong = pingWs.receive()
        pcall(function() pingWs.close() end)
        if pong ~= "WS_OK" then
            print("WS ping odd response: " .. tostring(pong))
            sleep(0.5)
        end
    else
        print("WS ping failed: " .. tostring(pingErr))
        print("Continuing to real video socket anyway...")
        sleep(0.5)
    end

    clearTerm()
    print("Opening WebSocket video...")
    print(trim(wsUrl, 60))
    drawPlaybackHelp(mon, ctx.picked and ctx.picked.title or "Video", prep.job)
    local ws, wsErr = http.websocket(wsUrl, WS_HEADERS)
    if not ws then
        print("WebSocket failed:")
        print(tostring(wsErr))
        waitKey()
        return "error"
    end

    local hello = ws.receive()
    if hello ~= "WS_VIDEO_OK" then
        print("Unexpected WS hello:")
        print(tostring(hello))
        pcall(function() ws.close() end)
        waitKey()
        return "error"
    end

    clearTerm()
    print("Prebuffering WebSocket video...")
    print("Target frames: " .. tostring(VIDEO_PREBUFFER_FRAMES))

    local frameBuffer = {}
    local streamEndedEarly = false
    local streamEndReason = nil

    if shortFullPreload then
        print("Short full preload mode disabled/unused in v31 unless configured.")
    end

    while #frameBuffer < VIDEO_PREBUFFER_FRAMES do
        local packet, reason = readWsPacket(ws)
        if not packet then
            streamEndedEarly = true
            streamEndReason = reason
            break
        end
        frameBuffer[#frameBuffer + 1] = packet
        if #frameBuffer % 5 == 0 then
            clearTerm()
            print("Prebuffering WebSocket video...")
            print("Frames: " .. tostring(#frameBuffer) .. "/" .. tostring(VIDEO_PREBUFFER_FRAMES))
        end
        sleep(0)
    end

    if #frameBuffer == 0 then
        print("No frames buffered: " .. tostring(streamEndReason))
        pcall(function() ws.close() end)
        waitKey()
        return "error"
    end

    clearTerm()
    print("Buffered " .. tostring(#frameBuffer) .. " frame(s).")
    print("Starting queued WebSocket player...")
    print("Controls: R = rewind, Q = cancel, monitor touch = cancel")
    sleep(0.05)

    local playback = nil
    local queue = {}
    local queueFirst = 1
    local queueLast = 0
    local readerDone = false
    local readerErr = nil
    local lastRenderedFrame = 0
    local cancelRequested = false
    local rewindRequested = false
    local finishedNormal = false

    local function queueLen()
        return queueLast - queueFirst + 1
    end

    local function pushFrame(frame)
        queueLast = queueLast + 1
        queue[queueLast] = frame
    end

    local function popFrame()
        if queueFirst > queueLast then return nil end
        local frame = queue[queueFirst]
        queue[queueFirst] = nil
        queueFirst = queueFirst + 1
        if queueFirst > 1000 then
            local n = 0
            for i = queueFirst, queueLast do
                n = n + 1
                queue[n] = queue[i]
                queue[i] = nil
            end
            queueFirst = 1
            queueLast = n
        end
        return frame
    end

    for i = 1, #frameBuffer do pushFrame(frameBuffer[i]) end
    frameBuffer = nil

    local function readerLoop()
        local ok, errOuter = pcall(function()
            while not streamEndedEarly and not cancelRequested and not rewindRequested do
                while queueLen() >= FRAME_QUEUE_MAX and not cancelRequested and not rewindRequested do
                    sleep(0.05)
                end
                if cancelRequested or rewindRequested then break end
                local packet, err = readWsPacket(ws)
                if not packet then
                    readerDone = true
                    readerErr = err
                    return
                end
                pushFrame(packet)
                sleep(0)
            end
            readerDone = true
            readerErr = streamEndReason
        end)
        if not ok then
            readerDone = true
            readerErr = "reader_crash: " .. tostring(errOuter)
        end
    end

    local function waitForQueueStart()
        clearTerm()
        print("Filling video queue...")
        print("Controls active after playback starts.")
        local lastPrint = os.clock()
        local target = QUEUE_START_FRAMES
        while queueLen() < target and not readerDone and not cancelRequested and not rewindRequested do
            if os.clock() - lastPrint > 0.25 then
                clearTerm()
                print("Filling video queue...")
                print("Frames queued: " .. tostring(queueLen()) .. "/" .. tostring(target))
                print("Mode: full redraw every frame; RLE rows")
                lastPrint = os.clock()
            end
            sleep(0.05)
        end
    end

    local function adaptiveFrameDelayLocal(playbackState, frame, renderCost)
        local nextFrameNumber = (tonumber(frame.number or 1) or 1) + 1
        local delay = nil
        local targetByte = frameTargetByte(playbackState, nextFrameNumber)
        local deltaBytes = playbackTapeDeltaBytes(playbackState)
        if VIDEO_CLOCK_MODE == "tape_bytes" and targetByte and deltaBytes then
            local byteEarly = targetByte - deltaBytes
            playbackState.lastTargetByte = targetByte
            playbackState.lastByteEarly = byteEarly
            local byteRate = tonumber(playbackState.bytesPerSecond or 0) or 0
            if byteRate <= 0 then byteRate = 6000 * (tonumber(playbackState.speed or 1.0) or 1.0) end
            delay = byteEarly / byteRate
        else
            local targetNextMs = frameTargetMs(playbackState, nextFrameNumber)
            local nowMs = playbackAudioMs(playbackState)
            delay = (targetNextMs - nowMs) / 1000
        end
        local slept = GOOD_FRAME_SLEEP
        if not delay then
            slept = GOOD_FRAME_SLEEP
        elseif delay <= MIN_FRAME_SLEEP then
            slept = MIN_FRAME_SLEEP
        elseif delay <= (GOOD_FRAME_SLEEP + 0.025) then
            slept = GOOD_FRAME_SLEEP
        else
            slept = math.min(MAX_FRAME_SLEEP, delay)
        end
        playbackState.lastDelay = slept
        playbackState.lastBehindMs = (delay and delay < 0) and (-delay * 1000) or 0
        playbackState.lastAheadMs = (delay and delay > 0) and (delay * 1000) or 0
        sleep(slept)
    end

    local function rendererLoop()
        waitForQueueStart()
        if cancelRequested or rewindRequested then return end

        clearTerm()
        print("Starting tape + queued video...")
        print("Initial queue: " .. tostring(queueLen()) .. " frames")
        print("Controls: R rewind, Q cancel, monitor touch cancel")
        sleep(0.05)

        startTape(tape, man.tape_speed or 1.0)
        playback = makePlaybackClock(tape, man.tape_speed or 1.0, DEFAULT_FPS, man.audio_bytes or 0, expectedTotalFrames)

        while not cancelRequested and not rewindRequested do
            local packet = popFrame()
            if packet then
                local n = packetFrameNumber(packet)
                if lastRenderedFrame > 0 and n > lastRenderedFrame + 1 then
                    playback.gaps = (playback.gaps or 0) + (n - lastRenderedFrame - 1)
                end
                if n <= lastRenderedFrame then
                    playback.duplicates = (playback.duplicates or 0) + 1
                else
                    local t0 = os.clock()
                    local drawnN, rows = drawRawPacket(mon, packet)
                    local renderCost = os.clock() - t0
                    if not drawnN or drawnN <= 0 then drawnN = lastRenderedFrame + 1 end
                    playback.frames = drawnN
                    playback.rendered = playback.rendered + 1
                    playback.lastRenderCost = renderCost
                    playback.lastRows = rows or 0
                    if rows and rows < MON_H_EXPECTED then
                        playback.partialPackets = (playback.partialPackets or 0) + 1
                    end
                    lastRenderedFrame = drawnN
                    adaptiveFrameDelayLocal(playback, { number = drawnN }, renderCost)
                end
            else
                if readerDone then
                    finishedNormal = true
                    return
                else
                    sleep(0.05)
                end
            end
        end
    end

    local function controlLoop()
        while not finishedNormal and not cancelRequested and not rewindRequested do
            local ev, a = os.pullEvent()
            if ev == "monitor_touch" then
                cancelRequested = true
                pcall(function() tape.stop() end)
                pcall(function() ws.close() end)
                return
            elseif ev == "key" then
                if a == keys.q then
                    cancelRequested = true
                    pcall(function() tape.stop() end)
                    pcall(function() ws.close() end)
                    return
                elseif a == keys.r then
                    rewindRequested = true
                    pcall(function() tape.stop() end)
                    rewindTape(tape)
                    pcall(function() ws.close() end)
                    return
                end
            end
        end
    end

    parallel.waitForAny(function() parallel.waitForAll(readerLoop, rendererLoop) end, controlLoop)

    pcall(function() ws.close() end)

    if rewindRequested then
        clearTerm()
        print("Rewinding tape and restarting video from frame 1...")
        monitorClear(mon)
        monitorWrite(mon, 2, 2, "Rewinding...", colors.yellow)
        rewindTape(tape)
        sleep(0.5)
        return "rewind"
    end

    if cancelRequested then
        callCancel(prep.job)
        clearTerm()
        print("Cancelled playback.")
        monitorClear(mon)
        monitorWrite(mon, 2, 2, "Playback cancelled.", colors.red)
        sleep(1)
        return "cancel"
    end

    clearTerm()
    print("Done.")
    if playback then
        print("Actual frames drawn: " .. tostring(playback.rendered))
        print("Missing packet gaps: " .. tostring(playback.gaps or 0))
        print("Last timeline frame: " .. tostring(playback.frames))
        if expectedTotalFrames > 0 then print("Expected frames: " .. tostring(expectedTotalFrames)) end
        print("Clock mode: " .. tostring(playback.clockMode))
        print("ms/frame audio-byte: " .. tostring(playback.msPer))
        print("Last render cost: " .. tostring(playback.lastRenderCost or 0))
        print("Last delay: " .. tostring(playback.lastDelay or 0))
    end
    print("Offset ms: " .. tostring(AUDIO_VIDEO_OFFSET_MS))
    monitorClear(mon)
    monitorWrite(mon, 2, 2, "Video ended.", colors.yellow)
    monitorWrite(mon, 2, 4, "Returning to search loop...", colors.white)
    sleep(2)
    callReset()
    return "done"
end

local function playPickedVideo(mon, picked)
    local ctx = preparePickedVideo(mon, picked)
    if not ctx then return "menu" end
    while true do
        local result = playPreparedOnce(mon, ctx)
        if result == "rewind" then
            -- same cached job/audio/tape, fresh WebSocket from frame 1
        else
            return result
        end
    end
end

