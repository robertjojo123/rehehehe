-- Tape wipe settings:
-- V12 only wipes bytes from the PREVIOUS audio write record.
-- If the tape was empty / no previous record exists, it skips wipe.
-- Set TAPE_WIPE_BYTES_OVERRIDE once if you want a manual emergency wipe.
local WIPE_TAPE_BEFORE_WRITE = true
local TAPE_WIPE_ONLY_PREVIOUS_WRITE = true
local TAPE_LAST_WRITE_RECORD = "yt_ws_last_tape_write_bytes.txt"
local TAPE_WIPE_BYTES_OVERRIDE = 0
local TAPE_WIPE_EXTRA_BYTES = 131072

local AUDIO_CHUNK_SIZE = 262144
local AUDIO_MIN_RATIO_OK = 0.98

local COLOR_SLOTS = {
    colors.white, colors.orange, colors.magenta, colors.lightBlue,
    colors.yellow, colors.lime, colors.pink, colors.gray,
    colors.lightGray, colors.cyan, colors.purple, colors.blue,
    colors.brown, colors.green, colors.red, colors.black,
}

local HEX_BYTE = {}
for i = 0, 255 do
    HEX_BYTE[string.format("%02x", i)] = string.char(i)
    HEX_BYTE[string.format("%02X", i)] = string.char(i)
end

local function clearTerm()
    term.setBackgroundColor(colors.black)
    term.setTextColor(colors.white)
    term.clear()
    term.setCursorPos(1, 1)
end

local function urlEncode(s)
    return tostring(s):gsub("([^%w%-_%.~])", function(c)
        return string.format("%%%02X", string.byte(c))
    end)
end

local function trim(s, n)
    s = tostring(s or "")
    if #s <= n then return s end
    return s:sub(1, n - 3) .. "..."
end

local function get(url)
    local h, err = http.get(url, HTTP_HEADERS)
    if not h then return nil, err end
    local b = h.readAll()
    h.close()
    return b, nil
end

local function getJson(url)
    local b, err = get(url)
    if not b then return nil, err end
    local j = textutils.unserializeJSON(b)
    if not j then return nil, "bad json: " .. tostring(b) end
    return j, nil
end

local function waitKey()
    print("")
    print("Press any key...")
    os.pullEvent("key")
end

local function wall_ms()
    if os.epoch then return os.epoch("utc") end
    return math.floor(os.clock() * 1000 + 0.5)
end

local function hexStringToCharsFast(h)
    local out = {}
    local n = 1
    for i = 1, #h, 2 do
        out[n] = HEX_BYTE[h:sub(i, i + 1)] or " "
        n = n + 1
    end
    return table.concat(out)
end

local function getDisplay()
    local mon = peripheral.find("monitor") or term.current()
    if mon.setTextScale then mon.setTextScale(0.5) end
    mon.setBackgroundColor(colors.black)
    mon.clear()
    return mon
end

local function findTapeDrive()
    for _, name in ipairs(peripheral.getNames()) do
        local typ = tostring(peripheral.getType(name) or "")
        local ok, methods = pcall(peripheral.getMethods, name)
        methods = ok and methods or {}
        local joined = table.concat(methods, " "):lower()
        if typ:lower():find("tape") or (joined:find("write") and joined:find("play") and joined:find("seek")) then
            return peripheral.wrap(name), name
        end
    end
    return nil, nil
end

local function rewindTape(tape)
    pcall(function() tape.stop() end)
    sleep(0.05)
    pcall(function() tape.seek(-999999999) end)
    sleep(0.05)
end

local function getTapeCapacity(tape)
    if not tape then return nil end
    local names = {
        "getSize", "getLength", "getCapacity", "getLimit",
        "size", "length", "capacity"
    }

    for _, name in ipairs(names) do
        if tape[name] then
            local ok, value = pcall(function() return tape[name]() end)
            if ok and type(value) == "number" and value > 0 then
                return math.floor(value)
            end
        end
    end

    return nil
end

local function readLastTapeWriteBytes()
    if not fs or not fs.exists or not fs.open then return 0 end
    if not fs.exists(TAPE_LAST_WRITE_RECORD) then return 0 end

    local h = fs.open(TAPE_LAST_WRITE_RECORD, "r")
    if not h then return 0 end
    local s = h.readAll()
    h.close()

    local n = tonumber(s or "0") or 0
    if n < 0 then n = 0 end
    return math.floor(n)
end

local function saveLastTapeWriteBytes(n)
    if not fs or not fs.open then return end
    n = math.max(0, math.floor(tonumber(n or 0) or 0))

    local h = fs.open(TAPE_LAST_WRITE_RECORD, "w")
    if not h then return end
    h.write(tostring(n))
    h.close()
end

local function wipeTape(tape, expectedBytes)
    if not WIPE_TAPE_BEFORE_WRITE then return true end

    rewindTape(tape)
    pcall(function() tape.setSpeed(1.0) end)

    local wipeBytes = tonumber(TAPE_WIPE_BYTES_OVERRIDE or 0) or 0

    if wipeBytes <= 0 then
        if TAPE_WIPE_ONLY_PREVIOUS_WRITE then
            local previous = readLastTapeWriteBytes()
            if previous > 0 then
                wipeBytes = previous + TAPE_WIPE_EXTRA_BYTES
            else
                wipeBytes = 0
            end
        else
            local cap = getTapeCapacity(tape)
            if cap and cap > 0 then
                wipeBytes = cap
            else
                wipeBytes = (tonumber(expectedBytes or 0) or 0) + TAPE_WIPE_EXTRA_BYTES
            end
        end
    end

    clearTerm()
    print("Tape wipe check...")
    print("Previous bytes: " .. tostring(readLastTapeWriteBytes()))
    print("Wipe bytes: " .. tostring(wipeBytes))

    if wipeBytes <= 0 then
        print("Tape considered empty. Skipping wipe.")
        sleep(0.35)
        rewindTape(tape)
        return true
    end

    print("Wiping previous audio area...")
    local zeroChunk = string.rep(string.char(0), AUDIO_CHUNK_SIZE)
    local written = 0
    local lastPrint = os.clock()

    while written < wipeBytes do
        local n = math.min(AUDIO_CHUNK_SIZE, wipeBytes - written)
        local chunk = zeroChunk
        if n < #zeroChunk then chunk = zeroChunk:sub(1, n) end

        local ok, err = pcall(function() tape.write(chunk) end)
        if not ok then
            print("Tape wipe failed:")
            print(tostring(err))
            return false
        end

        written = written + n

        if os.clock() - lastPrint > 0.5 then
            clearTerm()
            print("Wiping previous audio area...")
            print("Bytes: " .. tostring(written) .. "/" .. tostring(wipeBytes))
            lastPrint = os.clock()
        end

        sleep(0)
    end

    rewindTape(tape)
    print("Previous audio area wiped.")
    sleep(0.25)
    return true
end

local function writeAudioToTape(audioUrl, speed, expectedBytes)
    clearTerm()
    print("Finding tape drive...")
    local tape, tapeName = findTapeDrive()
    if not tape then print("No tape drive found.") return nil end

    print("Tape: " .. tostring(tapeName))
    print("Rewinding...")
    rewindTape(tape)

    if not wipeTape(tape, expectedBytes) then
        return nil
    end

    pcall(function() tape.setSpeed(speed or 1.0) end)

    print("Opening audio...")
    local res = http.get(audioUrl, HTTP_HEADERS, true) or http.get(audioUrl, HTTP_HEADERS)
    if not res then print("Failed to open audio URL") return nil end

    local written = 0
    local lastPrint = os.clock()

    while true do
        local chunk = res.read(AUDIO_CHUNK_SIZE)
        if not chunk or #chunk == 0 then break end

        local ok, err = pcall(function() tape.write(chunk) end)
        if not ok then
            print("Tape write failed: " .. tostring(err))
            res.close()
            return nil
        end

        written = written + #chunk
        if os.clock() - lastPrint > 0.5 then
            clearTerm()
            print("Writing audio to tape...")
            print("Bytes: " .. tostring(written))
            if expectedBytes then print("Expected: " .. tostring(expectedBytes)) end
            lastPrint = os.clock()
        end
        sleep(0)
    end
    res.close()

    if expectedBytes and tonumber(expectedBytes) and tonumber(expectedBytes) > 0 then
        local ratio = written / tonumber(expectedBytes)
        clearTerm()
        print("Audio write finished.")
        print("Expected bytes: " .. tostring(expectedBytes))
        print("Written bytes:  " .. tostring(written))
        print("Ratio: " .. tostring(math.floor(ratio * 1000) / 10) .. "%")
        if ratio < AUDIO_MIN_RATIO_OK then
            print("")
            print("WARNING: audio write ended early.")
            waitKey()
            return nil
        end
        sleep(0.3)
    end

    local silence = string.rep(string.char(0), AUDIO_CHUNK_SIZE)
    local silenceBytes = 0
    for _ = 1, 2 do
        local ok = pcall(function() tape.write(silence) end)
        if ok then silenceBytes = silenceBytes + #silence end
    end

    -- Record exactly how much of the tape we intentionally used.
    -- Next run only wipes this region plus a small safety tail.
    saveLastTapeWriteBytes(written + silenceBytes)

    rewindTape(tape)
    pcall(function() tape.setSpeed(speed or 1.0) end)
    return tape
end

local function startTape(tape, speed)
    rewindTape(tape)
    pcall(function() tape.setSpeed(speed or 1.0) end)
    sleep(0.05)
    pcall(function() tape.play() end)
end

local LAST_PALETTE = {}

local function applyPalette(mon, pal)
    for i = 1, 16 do
        local p = pal[i]
        if p then
            local old = LAST_PALETTE[i]
            if not old or old[1] ~= p[1] or old[2] ~= p[2] or old[3] ~= p[3] then
                mon.setPaletteColor(COLOR_SLOTS[i], p[1], p[2], p[3])
                LAST_PALETTE[i] = {p[1], p[2], p[3]}
            end
        end
    end
end

local function parsePal(line)
    local pal = {}
    local idx = 1
    for rgb in string.gmatch(line:sub(5), "([0-9a-fA-F]+)") do
        if #rgb >= 6 and idx <= 16 then
            pal[idx] = {
                tonumber(rgb:sub(1, 2), 16) / 255,
                tonumber(rgb:sub(3, 4), 16) / 255,
                tonumber(rgb:sub(5, 6), 16) / 255,
            }
            idx = idx + 1
        end
    end
    return pal
end

local function parsePalettePatch(line)
    -- Compact server protocol: PC <slot_1_to_16> <rrggbb>
    local idx, rgb = line:match("^PC%s+(%d+)%s+([0-9a-fA-F]+)$")
    idx = tonumber(idx or "0") or 0
    if idx < 1 or idx > 16 or not rgb or #rgb < 6 then return nil, nil end
    return idx, {
        tonumber(rgb:sub(1, 2), 16) / 255,
        tonumber(rgb:sub(3, 4), 16) / 255,
        tonumber(rgb:sub(5, 6), 16) / 255,
    }
end


local HEX_NIBBLE = {}
for i = 0, 9 do HEX_NIBBLE[string.byte("0") + i] = i end
for i = 0, 5 do
    HEX_NIBBLE[string.byte("a") + i] = 10 + i
    HEX_NIBBLE[string.byte("A") + i] = 10 + i
end

local function hexByteAt(s, pos)
    local a = HEX_NIBBLE[string.byte(s, pos) or 0] or 0
    local b = HEX_NIBBLE[string.byte(s, pos + 1) or 0] or 0
    return a * 16 + b
end

local function parseCompactPalette(line)
    -- V18 server-side-light protocol: C<slothex><rrggbb>
    if #line < 8 then return nil, nil end
    local slot = HEX_NIBBLE[string.byte(line, 2) or 0]
    if slot == nil then return nil, nil end
    return slot + 1, {
        hexByteAt(line, 3) / 255,
        hexByteAt(line, 5) / 255,
        hexByteAt(line, 7) / 255,
    }
end

local function splitLines(s)
    local t = {}
    if not s then return t end
    s = tostring(s):gsub("\r\n", "\n"):gsub("\r", "\n")
    for line in (s .. "\n"):gmatch("(.-)\n") do
        if line ~= "" then t[#t + 1] = line end
    end
    return t
end

local function parseFrameLines(lines)
    local frame = nil

    for _, msg in ipairs(lines) do
        local tag = msg:sub(1, 1)

        if msg:sub(1, 5) == "ERROR" then
            return nil, msg
        elseif msg == "STREAM_END" then
            return nil, "end"
        elseif tag == "M" or msg == "WS_VIDEO_OK" then
            -- META / hello ignored
        elseif tag == "F" then
            -- Supports old "F 123" and compact V18 "F123".
            local n = tonumber(msg:match("^F%s*(%d+)")) or 1
            frame = { number = n, palette = {}, rows = {} }
        elseif tag == "C" and frame then
            -- Compact palette patch: C<slothex><rrggbb>
            local idx, color = parseCompactPalette(msg)
            if idx and color then frame.palette[idx] = color end
        elseif msg:sub(1, 4) == "PAL " and frame then
            -- Legacy fallback
            frame.palette = parsePal(msg)
        elseif msg:sub(1, 3) == "PC " and frame then
            -- Legacy fallback
            local idx, color = parsePalettePatch(msg)
            if idx and color then frame.palette[idx] = color end
        elseif tag == "B" and frame then
            -- Full binary row:
            -- B<yy><164 raw chars><164 fg><164 bg>
            local y = tonumber(msg:sub(2, 3))
            if y then
                local c0 = 4
                local c1 = c0 + 164 - 1
                local f0 = c1 + 1
                local f1 = f0 + 164 - 1
                local b0 = f1 + 1
                local b1 = b0 + 164 - 1
                frame.rows[#frame.rows + 1] = {
                    y = y,
                    x = 1,
                    chars = msg:sub(c0, c1),
                    fg = msg:sub(f0, f1),
                    bg = msg:sub(b0, b1),
                }
            end
        elseif tag == "S" and frame then
            -- Span row, lighter than full-row blit:
            -- S<yy><xxx><lll><raw chars><fg><bg>
            local y = tonumber(msg:sub(2, 3))
            local x = tonumber(msg:sub(4, 6))
            local ln = tonumber(msg:sub(7, 9))
            if y and x and ln and ln > 0 then
                local c0 = 10
                local c1 = c0 + ln - 1
                local f0 = c1 + 1
                local f1 = f0 + ln - 1
                local b0 = f1 + 1
                local b1 = b0 + ln - 1
                frame.rows[#frame.rows + 1] = {
                    y = y,
                    x = x,
                    chars = msg:sub(c0, c1),
                    fg = msg:sub(f0, f1),
                    bg = msg:sub(b0, b1),
                }
            end
        elseif msg:sub(1, 2) == "R " and frame then
            -- Legacy row fallback: R <y> <charhex> <fg> <bg>
            local y, chHex, fg, bg = msg:match("^R%s+(%d+)%s+([0-9a-fA-F]+)%s+([0-9a-fA-F]+)%s+([0-9a-fA-F]+)$")
            if y then
                frame.rows[#frame.rows + 1] = {
                    y = tonumber(y),
                    chars = hexStringToCharsFast(chHex),
                    fg = fg,
                    bg = bg,
                }
            end
        elseif tag == "E" and frame then
            return frame, nil
        end
    end

    return frame, nil
end


local function parseFramePacket(packet)
    -- Same protocol as parseFrameLines(), but without building a split-lines table.
    -- This matters because at 10 FPS, thousands of tiny Lua allocations add up.
    packet = tostring(packet or "")
    local frame = nil
    local pos = 1
    local len = #packet

    while pos <= len do
        local nl = packet:find("\n", pos, true)
        local msg
        if nl then
            msg = packet:sub(pos, nl - 1)
            pos = nl + 1
        else
            msg = packet:sub(pos)
            pos = len + 1
        end

        if msg ~= "" then
            local tag = msg:sub(1, 1)

            if msg:sub(1, 5) == "ERROR" then
                return nil, msg
            elseif msg == "STREAM_END" then
                return nil, "end"
            elseif tag == "M" or msg == "WS_VIDEO_OK" then
                -- META / hello ignored
            elseif tag == "F" then
                local n = tonumber(msg:match("^F%s*(%d+)")) or 1
                frame = { number = n, palette = {}, rows = {} }
            elseif tag == "C" and frame then
                local idx, color = parseCompactPalette(msg)
                if idx and color then frame.palette[idx] = color end
            elseif msg:sub(1, 4) == "PAL " and frame then
                frame.palette = parsePal(msg)
            elseif msg:sub(1, 3) == "PC " and frame then
                local idx, color = parsePalettePatch(msg)
                if idx and color then frame.palette[idx] = color end
            elseif tag == "B" and frame then
                local y = tonumber(msg:sub(2, 3))
                if y then
                    local c0 = 4
                    local c1 = c0 + 164 - 1
                    local f0 = c1 + 1
                    local f1 = f0 + 164 - 1
                    local b0 = f1 + 1
                    local b1 = b0 + 164 - 1
                    frame.rows[#frame.rows + 1] = {
                        y = y,
                        x = 1,
                        chars = msg:sub(c0, c1),
                        fg = msg:sub(f0, f1),
                        bg = msg:sub(b0, b1),
                    }
                end
            elseif tag == "S" and frame then
                local y = tonumber(msg:sub(2, 3))
                local x = tonumber(msg:sub(4, 6))
                local ln = tonumber(msg:sub(7, 9))
                if y and x and ln and ln > 0 then
                    local c0 = 10
                    local c1 = c0 + ln - 1
                    local f0 = c1 + 1
                    local f1 = f0 + ln - 1
                    local b0 = f1 + 1
                    local b1 = b0 + ln - 1
                    frame.rows[#frame.rows + 1] = {
                        y = y,
                        x = x,
                        chars = msg:sub(c0, c1),
                        fg = msg:sub(f0, f1),
                        bg = msg:sub(b0, b1),
                    }
                end
            elseif msg:sub(1, 2) == "R " and frame then
                local y, chHex, fg, bg = msg:match("^R%s+(%d+)%s+([0-9a-fA-F]+)%s+([0-9a-fA-F]+)%s+([0-9a-fA-F]+)$")
                if y then
                    frame.rows[#frame.rows + 1] = {
                        y = tonumber(y),
                        x = 1,
                        chars = hexStringToCharsFast(chHex),
                        fg = fg,
                        bg = bg,
                    }
                end
            elseif tag == "E" and frame then
                return frame, nil
            end
        end
    end

    return frame, nil
end

local function safeWsReceive(ws)
    local ok, packet = pcall(function() return ws.receive() end)
    if not ok then
        return nil, "ws_receive_error: " .. tostring(packet)
    end
    if not packet then
        return nil, "ws_closed_or_eof"
    end
    return packet, nil
end

local function readWsFrame(ws)
    while true do
        local packet, recvErr = safeWsReceive(ws)
        if not packet then return nil, recvErr or "eof" end

        if packet:sub(1, 5) == "ERROR" then
            return nil, packet
        elseif packet == "STREAM_END" then
            return nil, "end"
        elseif packet:sub(1, 4) == "META" then
            -- ignore metadata packet and continue
        elseif packet == "WS_VIDEO_OK" then
            -- ignore hello packet and continue
        elseif packet:sub(1, 10) == "WAIT_FRAME" then
            sleep(0.02)
        else
            local ok, frameOrErr, parseErr = pcall(function()
                local frame, err = parseFramePacket(packet)
                return frame, err
            end)

            if not ok then
                return nil, "frame_parse_error: " .. tostring(frameOrErr)
            end

            if frameOrErr or parseErr then
                return frameOrErr, parseErr
            end
        end
    end
end



-- V27: keep the WebSocket packet raw in the reader queue.  The old path parsed
-- each frame into 81 Lua row tables in the reader coroutine, which burns CPU and
-- memory and can slowly starve the renderer on long videos.  This path queues
-- one raw packet string; the renderer interprets it directly and immediately
-- blits the rows.
local MON_W_EXPECTED = 164
local MON_H_EXPECTED = 81

local function readWsPacket(ws)
    while true do
        local packet, recvErr = safeWsReceive(ws)
        if not packet then return nil, recvErr or "eof" end

        if packet:sub(1, 5) == "ERROR" then
            return nil, packet
        elseif packet == "STREAM_END" then
            return nil, "end"
        elseif packet:sub(1, 4) == "META" then
            -- ignore metadata packet and continue
        elseif packet == "WS_VIDEO_OK" then
            -- ignore hello packet and continue
        elseif packet:sub(1, 10) == "WAIT_FRAME" then
            sleep(0.02)
        else
            return packet, nil
        end
    end
end

local function packetFrameNumber(packet)
    if not packet then return 0 end
    return tonumber(tostring(packet):match("^F(%d+)")) or 0
end

local function applyPalettePatchLine(mon, line)
    -- C<slothex><rrggbb>
    if not line or #line < 8 then return end
    local slotHex = line:sub(2, 2)
    local idx = tonumber(slotHex, 16)
    if not idx then return end
    idx = idx + 1
    local slot = COLOR_SLOTS[idx]
    if not slot then return end

    local r = tonumber(line:sub(3, 4), 16)
    local g = tonumber(line:sub(5, 6), 16)
    local b = tonumber(line:sub(7, 8), 16)
    if not r or not g or not b then return end

    r, g, b = r / 255, g / 255, b / 255
    local old = LAST_PALETTE[idx]
    if not old or old[1] ~= r or old[2] ~= g or old[3] ~= b then
        mon.setPaletteColor(slot, r, g, b)
        LAST_PALETTE[idx] = {r, g, b}
    end
end


local function decodeTinyRLE(s)
    -- Decodes <count>:<char><count>:<char>...
    -- Intentionally simple. Preserves exact chars/fg/bg content.
    if not s or s == "" then return "" end
    local out = {}
    local n = 1
    local pos = 1
    local len = #s
    while pos <= len do
        local colon = s:find(":", pos, true)
        if not colon then
            -- Bad/old data fallback: append the rest raw instead of crashing.
            out[n] = s:sub(pos)
            break
        end
        local count = tonumber(s:sub(pos, colon - 1)) or 0
        local chPos = colon + 1
        local ch = s:sub(chPos, chPos)
        if count > 0 and ch ~= "" then
            out[n] = string.rep(ch, count)
            n = n + 1
        end
        pos = chPos + 1
    end
    return table.concat(out)
end

local function decodeMaybeRLE(mode, payload)
    if mode == "1" then return decodeTinyRLE(payload) end
    return payload or ""
end

local function split3Payloads(s, startPos)
    local p1 = s:find("|", startPos, true)
    if not p1 then return nil end
    local p2 = s:find("|", p1 + 1, true)
    if not p2 then return nil end
    return s:sub(startPos, p1 - 1), s:sub(p1 + 1, p2 - 1), s:sub(p2 + 1)
end

local function drawRawPacket(mon, packet)
    local frameNumber = packetFrameNumber(packet)
    local rows = 0
    local pos = 1
    local len = #packet

    while pos <= len do
        local nl = packet:find("\n", pos, true)
        local line
        if nl then
            line = packet:sub(pos, nl - 1)
            pos = nl + 1
        else
            line = packet:sub(pos)
            pos = len + 1
        end

        local tag = line:sub(1, 1)
        if tag == "C" then
            applyPalettePatchLine(mon, line)
        elseif tag == "B" then
            -- B<yy><164 raw chars><164 fg><164 bg>
            local y = tonumber(line:sub(2, 3))
            if y then
                local w = MON_W_EXPECTED
                local c0 = 4
                local c1 = c0 + w - 1
                local f0 = c1 + 1
                local f1 = f0 + w - 1
                local b0 = f1 + 1
                local b1 = b0 + w - 1
                local chars = line:sub(c0, c1)
                local fg = line:sub(f0, f1)
                local bg = line:sub(b0, b1)
                if #chars == w and #fg == w and #bg == w then
                    mon.setCursorPos(1, y)
                    mon.blit(chars, fg, bg)
                    rows = rows + 1
                end
            end
        elseif tag == "Q" then
            -- V28 RLE full row:
            -- Q<yy><cm><fm><bm><chars>|<fg>|<bg>
            local y = tonumber(line:sub(2, 3))
            if y then
                local cm = line:sub(4, 4)
                local fm = line:sub(5, 5)
                local bm = line:sub(6, 6)
                local cp, fp, bp = split3Payloads(line, 7)
                if cp and fp and bp then
                    local chars = decodeMaybeRLE(cm, cp)
                    local fg = decodeMaybeRLE(fm, fp)
                    local bg = decodeMaybeRLE(bm, bp)
                    if #chars == MON_W_EXPECTED and #fg == MON_W_EXPECTED and #bg == MON_W_EXPECTED then
                        mon.setCursorPos(1, y)
                        mon.blit(chars, fg, bg)
                        rows = rows + 1
                    end
                end
            end
        elseif tag == "S" then
            -- Accept old span packets too, but v28 server/player should use full Q/B rows.
            local y = tonumber(line:sub(2, 3))
            local x = tonumber(line:sub(4, 6))
            local ln = tonumber(line:sub(7, 9))
            if y and x and ln and ln > 0 then
                local c0 = 10
                local c1 = c0 + ln - 1
                local f0 = c1 + 1
                local f1 = f0 + ln - 1
                local b0 = f1 + 1
                local b1 = b0 + ln - 1
                mon.setCursorPos(x, y)
                mon.blit(line:sub(c0, c1), line:sub(f0, f1), line:sub(b0, b1))
                rows = rows + 1
            end
        end
    end

    if rows < MON_H_EXPECTED then
        -- This should not happen with v27 full-frame packets. Make it visible in
        -- diagnostics instead of silently leaking old pixels.
        -- Do not clear here after partial rows because that would erase the rows
        -- already drawn; the final stats will show partial packet count.
    end
    return frameNumber, rows
end

local function drawFrame(mon, frame)
    -- V21 expects every packet to be a complete 81-row redraw.
    -- If a bad/old server sends fewer rows, clear first so old-frame streaks cannot leak.
    local rows = frame.rows or {}
    if #rows < 81 then
        mon.setBackgroundColor(colors.black)
        mon.clear()
    end
    applyPalette(mon, frame.palette)
    for _, row in ipairs(rows) do
        mon.setCursorPos(row.x or 1, row.y)
        mon.blit(row.chars, row.fg, row.bg)
    end
end


local function getTapePosition(tape)
    if not tape then return nil end

    -- Computronics/TapeDrive builds have used different method names.
    -- Try every likely position/tell method, without crashing on missing APIs.
    local names = {
        "getPosition", "getPos", "getBytePosition", "getByte", "tell",
        "position", "pos"
    }

    for _, name in ipairs(names) do
        if tape[name] then
            local ok, value = pcall(function() return tape[name]() end)
            if ok and type(value) == "number" then
                return math.floor(value)
            end
        end
    end

    return nil
end

local function makePlaybackClock(tape, speed, fps, audioBytes, totalFrames)
    speed = tonumber(speed or 1.0) or 1.0
    fps = tonumber(fps or DEFAULT_FPS) or DEFAULT_FPS

    local bps1x = tonumber(TAPE_BPS_1X_OVERRIDE or 0) or 0
    if bps1x <= 0 then bps1x = tonumber(TAPE_BYTES_PER_SECOND_1X or 6000) or 6000 end

    audioBytes = tonumber(audioBytes or 0) or 0
    totalFrames = tonumber(totalFrames or 0) or 0

    local nominalMsPer = 1000 / fps
    local audioHeardSeconds = 0
    if audioBytes > 0 and bps1x > 0 and speed > 0 then
        audioHeardSeconds = (audioBytes / (bps1x * speed)) * (tonumber(AUDIO_LENGTH_TUNE or 1.0) or 1.0)
    end

    local msPer = nominalMsPer
    if FORCE_AUDIO_LOCKED_FRAME_TIME and audioHeardSeconds > 0 and totalFrames > 0 then
        -- V31 hard sync: total heard audio seconds = audioBytes / (6000 * tapeSpeed).
        -- Spread every real video frame evenly across that actual DFPWM payload.
        -- Example: 4,320,000 bytes at 2x = 360s heard audio. 3600 frames = 100ms/frame.
        msPer = (audioHeardSeconds * 1000) / totalFrames
    end

    local startByte = nil
    local usingTapeClock = false
    if VIDEO_CLOCK_MODE == "tape_bytes" and USE_TAPE_BYTE_CLOCK then
        startByte = getTapePosition(tape)
        if type(startByte) == "number" then usingTapeClock = true end
    end

    return {
        tape = tape,
        speed = speed,
        fps = fps,
        msPer = msPer,
        nominalMsPer = nominalMsPer,
        audioBytes = audioBytes,
        audioHeardSeconds = audioHeardSeconds,
        totalFrames = totalFrames,
        startByte = startByte,
        clockStartMs = wall_ms(),
        bytesPerSecond = bps1x * speed,
        tapePositionScale = tonumber(TAPE_POSITION_SCALE or 1.0) or 1.0,
        bps1x = bps1x,
        useTapeClock = usingTapeClock,
        clockMode = VIDEO_CLOCK_MODE,
        frames = 0,
        rendered = 0,
    }
end

local function playbackTapeDeltaBytes(playback)
    if not playback or not playback.useTapeClock then return nil end
    local pos = getTapePosition(playback.tape)
    if not pos or not playback.startByte then
        playback.useTapeClock = false
        return nil
    end

    local deltaBytes = pos - playback.startByte
    if deltaBytes < 0 then deltaBytes = 0 end

    local scale = tonumber(playback.tapePositionScale or 1.0) or 1.0
    if scale <= 0 then scale = 1.0 end
    deltaBytes = deltaBytes * scale

    playback.lastTapePos = pos
    playback.lastDeltaBytes = deltaBytes
    return deltaBytes
end

local function playbackAudioMs(playback)
    if not playback then return 0 end

    local deltaBytes = playbackTapeDeltaBytes(playback)
    if deltaBytes then
        local byteRate = tonumber(playback.bytesPerSecond or 0) or 0
        if byteRate <= 0 then byteRate = 6000 * (tonumber(playback.speed or 1.0) or 1.0) end
        return (deltaBytes / byteRate) * 1000
    end

    local elapsed = wall_ms() - (playback.clockStartMs or wall_ms())
    if elapsed < 0 then elapsed = 0 end
    return elapsed
end

local function frameTargetByte(playback, frameNumber)
    local totalFrames = tonumber(playback and playback.totalFrames or 0) or 0
    local audioBytes = tonumber(playback and playback.audioBytes or 0) or 0
    frameNumber = tonumber(frameNumber or 1) or 1

    if totalFrames <= 1 or audioBytes <= 0 then return nil end

    local byteRate = tonumber(playback.bytesPerSecond or 0) or 0
    if byteRate <= 0 then byteRate = 6000 * (tonumber(playback.speed or 1.0) or 1.0) end
    local offsetBytes = (tonumber(AUDIO_VIDEO_OFFSET_MS or 0) or 0) / 1000 * byteRate

    -- Frame 1 is byte 0. Final frame is near the final written audio byte.
    -- This is the v25 timing fix, but the renderer below still draws every packet like v24.
    local frac = (frameNumber - 1) / math.max(1, totalFrames - 1)
    if frac < 0 then frac = 0 end
    if frac > 1 then frac = 1 end
    return (audioBytes * frac) + offsetBytes
end

local function frameTargetMs(playback, frameNumber)
    return ((frameNumber - 1) * playback.msPer) + AUDIO_VIDEO_OFFSET_MS
end

local function currentTargetFrame(playback)
    local ms = playbackAudioMs(playback) - AUDIO_VIDEO_OFFSET_MS
    if ms < 0 then return 1 end
    return math.max(1, math.floor(ms / playback.msPer) + 1)
end

local function waitForFrame(playback, frameNumber)
    -- V32 intentionally does not pre-wait before drawing.
    -- It draws every packet immediately when popped, then adjusts the next delay.
    -- This avoids the v25 behavior where timing waits made playback look like it was skipping through frames.
    return
end

