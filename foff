    end

    local function handleAccountMessage(sender, msg, replyPublicKey)
        if type(msg) ~= "table" then
            secureReply(sender, replyPublicKey, { ok = false, error = "bad message" })
            return
        end

        if msg.action == "get_Players" then
            secureReply(sender, replyPublicKey, {
                action = "players_list",
                players = listAccountResponse()
            })

        elseif msg.action == "get_balance" then
            secureReply(sender, replyPublicKey, {
                player = msg.player,
                balance = getBalance(msg.player)
            })

        elseif msg.action == "transfer" then
            local player = cleanPlayerName(msg.player)
            local delta = tonumber(msg.delta) or 0

            if player == "" then
                secureReply(sender, replyPublicKey, { ok = false, error = "bad player" })
                return
            end

            -- Safety sanity limit. Change if needed, but this prevents insane spoof/loss bugs.
            if math.abs(delta) > 5000000 then
                print("Rejected huge transfer:", sender, player, delta, tostring(msg.note))
                secureReply(sender, replyPublicKey, { ok = false, error = "transfer too large", player = player, balance = getBalance(player) })
                return
            end

            local old = getBalance(player)
            local new = math.max(0, old + delta)
            local actualDelta = new - old

            setBalance(player, new)
            logTransaction(player, msg.note or "Transfer", actualDelta)
            handleCasinoTransferForStats(player, msg.note)

            secureReply(sender, replyPublicKey, {
                player = player,
                balance = new
            })

        elseif msg.action == "gamble_win_stat" then
            handleDirectGambleWinStat(msg)
            secureReply(sender, replyPublicKey, { ok = true, action = "gamble_win_stat_ack" })

        elseif msg.action == "list_accounts" then
