    local function decryptPayloadToTable(packet)
        if type(packet) ~= "table" then
            return nil, nil, "packet not table"
        end

        if packet.secure ~= true then
            if ACCEPT_PLAINTEXT_CASINO then
                return packet, nil, nil
            end
            return nil, nil, "plaintext casino packet rejected"
        end

        if packet.version ~= SECURE_VERSION then
            return nil, nil, "bad secure version"
        end

        local plain = ""

        if packet.chunked and type(packet.payloadChunks) == "table" then
            for i, encryptedPiece in ipairs(packet.payloadChunks) do
                if type(encryptedPiece) ~= "string" then
                    return nil, nil, "bad encrypted chunk " .. tostring(i)
                end

                local ok, pieceOrErr = pcall(function()
                    return cipher.decrypt(encryptedPiece, accountPrivateKey)
                end)

                if not ok then
                    return nil, nil, "chunk decrypt failed " .. tostring(i) .. ": " .. tostring(pieceOrErr)
                end

                plain = plain .. tostring(pieceOrErr)
                sleep(0)
            end

        elseif type(packet.payload) == "string" then
            local ok, plainOrErr = pcall(function()
                return cipher.decrypt(packet.payload, accountPrivateKey)
            end)

            if not ok then
                return nil, nil, "decrypt failed: " .. tostring(plainOrErr)
            end

            plain = plainOrErr
        else
            return nil, nil, "bad encrypted payload"
        end

        local data = textutils.unserialize(plain)
        if type(data) ~= "table" then
            return nil, nil, "unserialize failed"
        end

        return data, packet.replyPublicKey, nil
    end

    local function encryptTableForReply(tbl, replyPublicKey)
        if type(replyPublicKey) ~= "table" then
            return tbl
        end

        local plain = textutils.serialize(tbl)
        local chunks = {}

        for i = 1, #plain, SECURE_CHUNK_SIZE do
            local piece = plain:sub(i, i + SECURE_CHUNK_SIZE - 1)

            local ok, encryptedOrErr = pcall(function()
                return cipher.encrypt(piece, replyPublicKey)
            end)

            if not ok then
                error("Reply encrypt failed on chunk " .. tostring(#chunks + 1) .. ": " .. tostring(encryptedOrErr))
            end

            table.insert(chunks, encryptedOrErr)
            sleep(0)
        end

        return {
            secure = true,
            version = SECURE_VERSION,
            chunked = true,
            payloadChunks = chunks
        }
    end

