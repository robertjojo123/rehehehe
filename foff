    local activePlayer, balance, distance, message = nil, 0, nil, ""
    local smalrad, largerad = 1.75, 4

    local function scanAccountRadars()
        local seen = {}
        local valP, cP = {}, nil

        for _, radarInfo in ipairs(radars) do
            local ok, players = pcall(function()
                return radarInfo.peripheral.getPlayers()
            end)

            players = (ok and type(players) == "table") and players or {}

            for _, p in ipairs(players) do
                if p.name and p.distance then
                    local key = tostring(p.name)

                    if not seen[key] or p.distance < seen[key].distance then
                        seen[key] = {
                            name = key,
                            distance = p.distance,
                            radar = radarInfo.name
                        }
                    end
                end
            end
        end

        for _, p in pairs(seen) do
            if p.distance <= largerad then
                table.insert(valP, p)

                if p.distance <= smalrad then
                    if not cP or p.distance < cP.distance then
                        cP = p
                    end
                end
            end
        end

        table.sort(valP, function(a, b)
            return (a.distance or 999) < (b.distance or 999)
        end)

        return valP, cP
    end

    local function radarLoop()
        while true do
            local valP, cP = scanAccountRadars()

            if not rip then
                print("no rip")

            elseif #valP == 1 and cP then
                if activePlayer ~= cP.name then
                    logPlayerEncounter(cP.name, "entered payout/deposit radar via " .. tostring(cP.radar or "?"))
                end

                activePlayer = cP.name
                distance = cP.distance
                balance = getBalance(activePlayer)
                rip.setOutput("bottom", true)
                message = ""

            elseif #valP == 1 and not cP then
                if activePlayer then
