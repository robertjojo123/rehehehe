local LOCK_PASSWORD_HASH = "161274240"
local LOCK_SALT = "casino_lock_v1"
local LOCK_REQUEST_ERROR = "__CASINO_LOCK_REQUEST__"

local nativePullEvent = os.pullEvent
local nativePullEventRaw = os.pullEventRaw
local lockUnpack = table.unpack or unpack

local function lockHashPassword(s)
    s = tostring(LOCK_SALT) .. tostring(s or "")

    local h = 5381
    for i = 1, #s do
        h = ((h * 33) + s:byte(i)) % 2147483647
    end

    return tostring(h)
end

local function lockSafeColor(color)
    if term.isColor and not term.isColor() then return end
    if term.setTextColor and color then
        term.setTextColor(color)
    end
end

local function lockClearScreen()
    if term.setBackgroundColor then
        term.setBackgroundColor(colors.black)
    end
    lockSafeColor(colors.white)
    term.clear()
    term.setCursorPos(1, 1)
end

local function lockCenterWrite(y, text, color)
    local w, h = term.getSize()
    lockSafeColor(color or colors.white)
    term.setCursorPos(math.max(1, math.floor((w - #tostring(text)) / 2) + 1), y)
    term.write(tostring(text))
    lockSafeColor(colors.white)
end

local function lockSleep(seconds)
    seconds = tonumber(seconds) or 0
    local timer = os.startTimer(seconds)
    while true do
        local event = {nativePullEventRaw()}
        if event[1] == "timer" and event[2] == timer then
            return
        end
        -- Eat terminate and every other event while sleeping inside lock screens.
    end
end

local function installProtectedPullEvent()
    -- This custom os.pullEvent keeps the normal filter behavior, but catches
    -- terminate events even while code is waiting for filtered events like monitor_touch.
    os.pullEvent = function(filter)
        while true do
            local event = {nativePullEventRaw()}

            if event[1] == "terminate" then
                error(LOCK_REQUEST_ERROR, 0)
            end

            if filter == nil or event[1] == filter then
                return lockUnpack(event)
            end
        end
    end
end

local function restoreNormalPullEvent()
    os.pullEvent = nativePullEvent
end

local function drawLockPasswordScreen(message, messageColor)
    lockClearScreen()

    lockCenterWrite(3, "CASINO ACCOUNT COMPUTER", colors.red)
    lockCenterWrite(5, "Maintenance password required.", colors.yellow)

    if message and message ~= "" then
        lockCenterWrite(7, tostring(message), messageColor or colors.white)
    end

    lockSafeColor(colors.white)
    term.setCursorPos(1, 10)
    term.write("Password: ")
end

local function readLockPasswordMasked()
    local password = ""

    while true do
        local event = {nativePullEventRaw()}
        local eventName = event[1]
        local a = event[2]

        if eventName == "char" then
            password = password .. tostring(a)
            term.write("*")

        elseif eventName == "paste" then
            -- Paste blocked intentionally.

        elseif eventName == "key" then
            if a == keys.enter then
                print("")
                return password

            elseif a == keys.backspace then
                if #password > 0 then
                    password = password:sub(1, -2)
                    local x, y = term.getCursorPos()
                    if x > 1 then
                        term.setCursorPos(x - 1, y)
                        term.write(" ")
                        term.setCursorPos(x - 1, y)
                    end
                end
            end

        elseif eventName == "terminate" then
            drawLockPasswordScreen("Terminate blocked.", colors.red)
        end
    end
end

local function maintenancePasswordGate(reason)
    restoreNormalPullEvent()

    local attempts = 0
    while true do
        if reason and reason ~= "" then
            drawLockPasswordScreen(reason, colors.yellow)
        else
            drawLockPasswordScreen()
        end

        local input = readLockPasswordMasked()

        if lockHashPassword(input) == LOCK_PASSWORD_HASH then
            lockClearScreen()
            lockCenterWrite(6, "Access granted. Shell unlocked.", colors.lime)
            lockSleep(0.5)
            lockClearScreen()
            restoreNormalPullEvent()
            return true
        end

        attempts = attempts + 1
        drawLockPasswordScreen("Access denied. Attempts: " .. tostring(attempts), colors.red)
        lockSleep(1.5)
    end
end

